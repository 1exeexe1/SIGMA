    arrowBtn.FontFace = FONT_MAIN; arrowBtn.TextSize = 10; arrowBtn.ZIndex = 9; arrowBtn.Parent = row
    onTheme(function(th) arrowBtn.TextColor3 = th.ACCENT end)

    local tick = Instance.new("TextButton")
    tick.Name = "ToggleTick"
    tick.Size = UDim2.new(0,16,0,16); tick.Position = UDim2.new(0,20,0.5,-8)
    tick.BackgroundColor3 = state and T.ACCENT or Color3.new(0,0,0)
    tick.BorderColor3 = T.BORDER; tick.Text = ""; tick.ZIndex = 9; tick.Parent = row
    onTheme(function(th)
        tick.BackgroundColor3 = state and th.ACCENT or Color3.new(0,0,0)
        tick.BorderColor3 = th.BORDER
    end)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1,-40,1,0); lbl.Position = UDim2.new(0,38,0,0)
    lbl.BackgroundTransparency = 1; lbl.Text = label; lbl.TextColor3 = T.WHITE
    lbl.FontFace = FONT_MAIN; lbl.TextSize = 13; lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 9; lbl.Parent = row
    onTheme(function(th) lbl.TextColor3 = th.WHITE end)

    local inner = Instance.new("Frame")
    inner.Name = "TSInner"
    inner.BackgroundColor3 = Color3.fromRGB(8,8,12); inner.BorderColor3 = T.BORDER
    inner.AutomaticSize = Enum.AutomaticSize.Y; inner.Size = UDim2.new(1,0,0,0)
    inner.Visible = false; inner.ZIndex = 8; inner.LayoutOrder = 1; inner.Parent = container
    onTheme(function(th) inner.BorderColor3 = th.BORDER end)
    -- Reddit-style vertical thread line: absolute overlay, NOT inside any UIListLayout
    local accentLine = Instance.new("Frame")
    accentLine.Size = UDim2.new(0,2,1,0); accentLine.Position = UDim2.new(0,8,0,0)
    accentLine.BackgroundColor3 = Color3.fromRGB(60,60,70); accentLine.BorderSizePixel = 0
    accentLine.ZIndex = 7; accentLine.Parent = inner
    -- Small horizontal connector at the top of the thread line
    local hLine = Instance.new("Frame")
    hLine.Size = UDim2.new(0,10,0,2); hLine.Position = UDim2.new(0,8,0,0)
    hLine.BackgroundColor3 = Color3.fromRGB(60,60,70); hLine.BorderSizePixel = 0
    hLine.ZIndex = 7; hLine.Parent = inner
    -- Separate content frame owns the UIListLayout so the line overlays are never list items
    local innerContent = Instance.new("Frame")
    innerContent.Name = "TSContent"
    innerContent.BackgroundTransparency = 1
    innerContent.AutomaticSize = Enum.AutomaticSize.Y; innerContent.Size = UDim2.new(1,0,0,0)
    innerContent.ZIndex = 8; innerContent.Parent = inner
    local innerLayout = Instance.new("UIListLayout")
    innerLayout.Padding = UDim.new(0,2); innerLayout.SortOrder = Enum.SortOrder.LayoutOrder
    innerLayout.Parent = innerContent
    local innerPad = Instance.new("UIPadding", innerContent)
    innerPad.PaddingLeft = UDim.new(0,20); innerPad.PaddingTop = UDim.new(0,2)
    innerPad.PaddingBottom = UDim.new(0,2)

    local expanded = false
    arrowBtn.MouseButton1Click:Connect(function()
        expanded = not expanded
        inner.Visible = expanded
        arrowBtn.Text = expanded and "\226\150\188" or "\226\150\182"  -- ▼ / ▶
    end)

    local function setTickColor(col)
        if S and S.uiAnim then
            TweenService:Create(tick,TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{BackgroundColor3=col}):Play()
        else tick.BackgroundColor3 = col end
    end
    local setState = function(v) state=v; setTickColor(v and T.ACCENT or Color3.new(0,0,0)) end
    local function fire()
        state = not state; setTickColor(state and T.ACCENT or Color3.new(0,0,0)); cb(state)
    end
    _tickFireFns[tick] = fire
    tick.MouseButton1Click:Connect(fire)
    return innerContent, tick, setState
end

