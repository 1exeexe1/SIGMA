        local ticks={}
        for _,d in ipairs(inner:GetDescendants()) do
            if d.Name=="ToggleTick" and d:IsA("TextButton") then
                table.insert(ticks,d)
            end
        end
        local anyOff=false
        for _,t in ipairs(ticks) do
            local c=t.BackgroundColor3
            if c.R<0.05 and c.G<0.05 and c.B<0.05 then anyOff=true; break end
        end
        for _,t in ipairs(ticks) do
            local c=t.BackgroundColor3
            local isOn=not(c.R<0.05 and c.G<0.05 and c.B<0.05)
            if isOn~=anyOff then
                local fn=_tickFireFns[t]
                if fn then fn() end
            end
        end
        allTogBtn.BackgroundColor3=anyOff and T.ACCENT or Color3.new(0,0,0)
    end)
    task.defer(function()
        local hasTicks=false
        for _,d in ipairs(inner:GetDescendants()) do
            if d.Name=="ToggleTick" and d:IsA("TextButton") then hasTicks=true; break end
        end
        allTogBtn.Visible=hasTicks
    end)
    return inner
end

