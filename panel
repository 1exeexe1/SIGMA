-- One-time check on load + live watch for deletion/modification.
local _rsCheckDone = false
local function checkRepStorageBrick()
    if _rsCheckDone then return end
    _rsCheckDone = true
    task.wait(2)
    local brick = ReplicatedStorage:FindFirstChild("Brick")
    if not brick then
        notify("\226\154\160 Warning","RepStorage.Brick was erased server-side!")
        return
    end
    if not brick:IsA("BasePart") then
        notify("\226\154\160 Warning","RepStorage.Brick is not a BasePart \226\128\148 likely replaced!")
        return
    end
    local c = brick.Color
    local isDefaultColor = (math.abs(c.R-0.639)<0.1 and math.abs(c.G-0.635)<0.1 and math.abs(c.B-0.647)<0.1)
    local isDefaultMat   = (brick.Material == Enum.Material.SmoothPlastic or brick.Material == Enum.Material.Plastic)
    if not isDefaultColor or not isDefaultMat then
        notify("\226\154\160 Warning","RepStorage.Brick has been Modified/Nuked \226\128\148 use Revert RepStorage in OP tab.")
    end
end

-- Live watcher: fires whenever Brick is removed or its properties change
local function startRepStorageWatcher()
    ReplicatedStorage.ChildRemoved:Connect(function(child)
        if child.Name == "Brick" then
            notify("\226\154\160 RepStorage","Brick was REMOVED from ReplicatedStorage!")
        end
    end)
    ReplicatedStorage.ChildAdded:Connect(function(child)
        if child.Name == "Brick" and not child:IsA("BasePart") then
            notify("\226\154\160 RepStorage","RepStorage.Brick replaced with a non-BasePart!")
        end
    end)
    local b = ReplicatedStorage:FindFirstChild("Brick")
    if b and b:IsA("BasePart") then
        b.Changed:Connect(function(prop)
            if prop == "Color" or prop == "Material" then
                local c = b.Color
                local ok = (math.abs(c.R-0.639)<0.1 and math.abs(c.G-0.635)<0.1 and math.abs(c.B-0.647)<0.1)
                    and (b.Material == Enum.Material.SmoothPlastic or b.Material == Enum.Material.Plastic)
                if not ok then
                    notify("\226\154\160 RepStorage","Brick properties modified! Use Revert in OP.")
                end
            end
        end)
    end
end



