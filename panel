-- ── Send function (replaces _aiCallGroq) ──────────────────────
local function _aiSend(inputBox)
    local text = inputBox.Text
    if text == "" or _aiIsTyping then return end
    text = text:sub(1, 2500)
    inputBox.Text = ""

    table.insert(_aiConversation, {role="user", content=text})
    _aiAddBubble(text, "user")

    _aiIsTyping = true
    _aiStatusLbl.Text = "⬡ Jarvis — Thinking..."

    local typeLbl, typeBub = _jAddBubble("...", "assistant")

    task.spawn(function()
        _jSendWithProbe(text, _aiStatusLbl, function(response)
            table.insert(_aiConversation, {role="assistant", content=response})

            -- Dispatch any panel actions embedded in the response FIRST
            _jDispatchActions(response)

            local displayText = response
                :gsub('{[^\n]*"sigma_action"[^\n]*}\n?', "")
                :gsub("```[^\n]*\n?.-\n?```\n?", "[code block below]\n")

            typeLbl.Text = ""
            for i = 1, #displayText do
                typeLbl.Text = displayText:sub(1,i)
                _aiScrollBottom()
                local ch = displayText:sub(i,i)
                if ch == "." or ch == "!" or ch == "?" then task.wait(0.03)
                elseif ch == "," then task.wait(0.015)
                elseif ch == "\n" then task.wait(0.02)
                else task.wait(0.006) end
            end

            _aiRenderCodeBlocks(response, typeBub, 10)

            _aiIsTyping = false
            _aiStatusLbl.Text = "⬡ Jarvis — Ready"

            while #_aiConversation > 50 do table.remove(_aiConversation, 1) end
        end)
    end)
end

