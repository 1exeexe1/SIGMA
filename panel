-- ── Mode switch logic ──────────────────────────────────────────
local function ctoolSwitchMode(newMode)
    if newMode == _ctoolActiveMode then
        -- Already on this mode; just close dropdown
        _ctoolBarOpen = false; ctoolDropdown.Visible = false; return
    end

    -- Copy zone state from old mode → new mode so position/size is preserved
    local oO,oX,oY,oZ,oP = _ctoolGetZone(_ctoolActiveMode)
    _ctoolSetZone(newMode, oO, oX, oY, oZ, oP)

    -- Unequip old mode
    local unFn = _ctoolVirtualUnequip[_ctoolActiveMode]
    if unFn then pcall(unFn) end

    _ctoolActiveMode = newMode

    -- Update bar visuals
    ctoolBarLabel.Text       = CTOOL_LABEL[newMode]
    ctoolBarLabel.TextColor3 = CTOOL_ACCENT[newMode]
    _ctoolBarStroke.Color    = CTOOL_ACCENT[newMode]

    -- Equip new mode
    local eqFn = _ctoolVirtualEquip[newMode]
    if eqFn then pcall(eqFn) end

    -- Close dropdown
    _ctoolBarOpen = false; ctoolDropdown.Visible = false
end

