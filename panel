        distance = distance * studs
        if typeof(blockscale)=="number" then blockscale=Vector3.new(blockscale,blockscale,blockscale)
        elseif blockscale==nil then blockscale=Vector3.new(studs,studs,studs) end
        if typeof(cframe)=="Vector3" then cframe=CFrame.new(cframe) end
        cframe = cframe - Vector3.new(0,studs,0)
        round = round ~= false  -- Default to true for grid alignment
        roundrot = roundrot ~= false
        if roundrot then
            local x,y,z = cframe:ToOrientation()
            cframe = CFrame.new(cframe.Position) * CFrame.fromOrientation(
                math.rad(math.round(convrot(x)/90)*90),
                math.rad(math.round(convrot(y)/90)*90),
                math.rad(math.round(convrot(z)/90)*90)
            )
        end
        local length = #tab * studs
        local parts = {}; local cfrs = {}
        for i,col in pairs(tab) do
            local wx = i * studs
            for _,row in pairs(col) do
                local wy = row * studs
                local p = Instance.new("Part")
                p.Size = blockscale; p.Anchored = true; p.CanCollide = false
                p.Transparency = 0; p.CastShadow = false
                if displaymat then p.Material = displaymat end
                p.Color = Color3.fromRGB(0,255,0)
                local rawCfr = cframe * CFrame.new((-length/2)+wx, wy, -distance)
                -- FIX #4: Use snapToGrid for consistent alignment with build system
                local snappedPos = snapToGrid(rawCfr.Position)
                local snappedCfr = CFrame.new(snappedPos)
                table.insert(cfrs, snappedCfr)
                p.CFrame = snappedCfr; p.Parent = Workspace
                table.insert(parts, p)
            end
        end
        _displayed[_displayId] = parts
        return _displayId, parts, cfrs
    end

    function lib.deletedisplay(id)
        if _displayed[id] then
            for _,p in pairs(_displayed[id]) do pcall(function() p:Destroy() end) end
            _displayed[id] = nil
        end
    end

    return lib
