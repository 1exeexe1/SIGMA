-- ── SECTION: RINGS ────────────────────────────────────────────
-- A ring (or other pattern) of bricks that orbit around the
-- player at a configurable speed, radius, and orientation.
-- Ownership strategy mirrors De-Grid: bump SimulationRadius to
-- 9e9 so the server grants network ownership, then write CFrame
-- each Heartbeat. Ownership re-asserted whenever a brick drifts.
do -- ╔═ RINGS SCOPE ══╗
-- ─────────────────────────────────────────────────────────────
-- Multi-ring preset storage (survives respawn via getgenv).
-- Schema: _sigmaRings[name] = {
--   speed, radius, length, count, pattern,
--   angleX, angleY, angleZ, aimOn, aimFace,
--   followAngle, hostName, brickSource }
-- _activeRings[name] = { conn, parts, partsWereAnchored,
--                         angle, ownTimer, healTimer }
-- ─────────────────────────────────────────────────────────────
if not getgenv()._sigmaRings then getgenv()._sigmaRings = {} end
local _activeRings = {}

-- ── Single editor-ring state ──────────────────────────────────
local _ringActive            = false
local _ringConn              = nil
local _ringParts             = {}
local _ringPartsWereAnchored = {}
local _ringAngle             = 0
local _ringLastTick          = tick()

-- ── Editor params (also used as defaults for new presets) ─────
local _ringSpeed       = 2
local _ringRadius      = 8
local _ringLength      = 10
local _ringCount       = 6
local _ringPattern     = "Circle"
local _ringAngleX      = 0
local _ringAngleY      = 0
local _ringAngleZ      = 0
local _ringAimOn       = false
local _ringAimFace     = "None"
local _ringFollowAngle = false        -- NEW: orbit rotates with host's Y-yaw
local _ringBrickSource = "My Folder"
local _ringHostName    = "Myself"
local _ringOwnTimer    = 0

-- ── Network-ownership helpers ─────────────────────────────────
local _prevSimRadius = nil
local function _ringBumpOwnership()
    pcall(function()
        if typeof(sethiddenproperty) == "function" then
            if not _prevSimRadius then
                local ok, v = pcall(function()
                    return game:GetService("Players").LocalPlayer.SimulationRadius
                end)
                _prevSimRadius = ok and v or 1000
            end
            sethiddenproperty(lp, "SimulationRadius", 2^24)
        end
    end)
end
local function _ringRestoreOwnership()
    pcall(function()
        if typeof(sethiddenproperty) == "function" and _prevSimRadius then
            sethiddenproperty(lp, "SimulationRadius", _prevSimRadius)
            _prevSimRadius = nil
        end
    end)
end

-- ── Resolve host HRP ─────────────────────────────────────────
local function _ringGetHostHRP(hostName)
    if hostName == "Myself" or hostName == lp.Name then
        return lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    end
    local target = Players:FindFirstChild(hostName)
    if target and target.Character then
        return target.Character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

-- ── Brick source resolver ─────────────────────────────────────
-- "Workspace Unanchored" is limited to parts named "Brick" or "brick"
-- to avoid grabbing characters, humanoid parts, etc.
local function _ringGetSourceBricks(sourceName, excludeSet)
    local results = {}
    pcall(function()
        local function ok(b)
            if not b:IsA("BasePart") then return false end
            if b.Anchored then return false end
            if excludeSet and excludeSet[b] then return false end
            return true
        end
        if sourceName == "My Folder" then
            local f = getMyBrickFolder()
            if f then
                for _, b in ipairs(f:GetChildren()) do
                    if ok(b) then results[#results+1] = b end
                end
            end
        elseif sourceName == "Workspace Unanchored" then
            -- Safety filter: only parts literally named "Brick" or "brick"
            for _, b in ipairs(Workspace:GetDescendants()) do
                if ok(b) and b.Name:lower() == "brick" then
                    results[#results+1] = b
                end
            end
        else
            -- Named player's brick folder
            local bf = getBricksFolder()
            if bf then
                local pf = bf:FindFirstChild(sourceName)
                if pf then
                    for _, b in ipairs(pf:GetChildren()) do
                        if ok(b) then results[#results+1] = b end
                    end
                end
            end
        end
    end)
    return results
end

-- ── Spawn brick set (with cross-ring exclusion) ───────────────
local function _ringSpawnParts(count, sourceName, partsArr, wereAnchoredTbl)
    sourceName      = sourceName      or _ringBrickSource
    partsArr        = partsArr        or _ringParts
    wereAnchoredTbl = wereAnchoredTbl or _ringPartsWereAnchored

    -- Release current bricks
    for _, p in ipairs(partsArr) do
        pcall(function()
            if p and p.Parent then p.Anchored = wereAnchoredTbl[p] or false end
        end)
    end
    for k = #partsArr, 1, -1 do partsArr[k] = nil end
    for k in pairs(wereAnchoredTbl) do wereAnchoredTbl[k] = nil end

    -- Build exclusion set: bricks already held by any running ring
    local excludeSet = {}
    for _, inst in pairs(_activeRings) do
        for _, p in ipairs(inst.parts or {}) do excludeSet[p] = true end
    end
    if partsArr ~= _ringParts then
        for _, p in ipairs(_ringParts) do excludeSet[p] = true end
    end

    local grabbed = _ringGetSourceBricks(sourceName, excludeSet)

    if #grabbed == 0 then
        notify("Rings", "No free bricks in \"" .. sourceName .. "\" -- all claimed or none unanchored!")
        return false
    end
    if #grabbed < count then
        notify("Rings", "Only " .. #grabbed .. " free brick(s) (wanted " .. count .. ") -- using all available.")
    end

    _ringBumpOwnership()
    task.wait(0.06)

    for idx = 1, math.min(count, #grabbed) do
        local b = grabbed[idx]
        wereAnchoredTbl[b] = b.Anchored
        partsArr[#partsArr+1] = b
    end
    return true
end

-- ── Pattern library ───────────────────────────────────────────
local RING_PATTERNS = {
    Circle = function(i, n, angle, radius, _length)
        local a = angle + (i-1) * (2*math.pi / n)
        return Vector3.new(math.cos(a)*radius, 0, math.sin(a)*radius)
    end,
    Helix = function(i, n, angle, radius, length)
        local a = angle + (i-1) * (2*math.pi / n)
        local t = (i-1) / math.max(n-1, 1)
        return Vector3.new(math.cos(a)*radius, (t-0.5)*length, math.sin(a)*radius)
    end,
    ["Infinity-8"] = function(i, n, angle, radius, _length)
        local t = angle + (i-1) * (2*math.pi / n)
        local d = 1 + 0.5*math.sin(t)^2
        return Vector3.new(radius*math.cos(t)/d, 0, radius*math.sin(t)*math.cos(t)/d)
    end,
    Lissajous = function(i, n, angle, radius, length)
        local t = angle + (i-1) * (2*math.pi / n)
        return Vector3.new(radius*math.sin(3*t), length*0.3*math.sin(2*t+math.pi/4), radius*math.cos(2*t))
    end,
    DNA = function(i, n, angle, radius, length)
        local half = math.ceil(n/2)
        local strand = (i <= half) and 0 or math.pi
        local idx2   = (i <= half) and i or (i - half)
        local t = angle + (idx2-1) * (2*math.pi / math.max(half,1))
        local y = ((idx2-1)/math.max(half-1,1) - 0.5) * length
        return Vector3.new(math.cos(t+strand)*radius, y, math.sin(t+strand)*radius)
    end,
    Polygon = function(i, n, angle, radius, _length)
        local sides = math.max(3, math.floor(n/2))
        local a = angle + (i-1) * (2*math.pi / n)
        local corner = math.floor(a / (2*math.pi/sides)) * (2*math.pi/sides)
        local next_c = corner + 2*math.pi/sides
        local frac   = (a - corner) / (2*math.pi/sides)
        local x1,z1  = math.cos(corner)*radius, math.sin(corner)*radius
        local x2,z2  = math.cos(next_c)*radius, math.sin(next_c)*radius
        return Vector3.new(x1+(x2-x1)*frac, 0, z1+(z2-z1)*frac)
    end,
    Spiral = function(i, n, angle, radius, _length)
        local t   = angle + (i-1) * (2*math.pi / n)
        local r   = radius * (0.3 + 0.7 * (i/n))
        return Vector3.new(math.cos(t)*r, 0, math.sin(t)*r)
    end,
    Cardioid = function(i, n, angle, radius, _length)
        local t = angle + (i-1) * (2*math.pi / n)
        local r = radius * (1 - math.cos(t))
        return Vector3.new(math.cos(t)*r, 0, math.sin(t)*r)
    end,
}
local PATTERN_NAMES = {"Circle","Helix","Infinity-8","Lissajous","DNA","Polygon","Spiral","Cardioid"}

local FACE_AXES = {
    None   = nil,
    Front  = Vector3.new( 0, 0,-1),
    Back   = Vector3.new( 0, 0, 1),
    Left   = Vector3.new(-1, 0, 0),
    Right  = Vector3.new( 1, 0, 0),
    Top    = Vector3.new( 0, 1, 0),
    Bottom = Vector3.new( 0,-1, 0),
}
local FACE_CORRECTIONS = {
    [Vector3.new( 0, 0,-1)] = CFrame.new(),
    [Vector3.new( 0, 0, 1)] = CFrame.Angles(0, math.pi, 0),
    [Vector3.new(-1, 0, 0)] = CFrame.Angles(0,  math.pi/2, 0),
    [Vector3.new( 1, 0, 0)] = CFrame.Angles(0, -math.pi/2, 0),
    [Vector3.new( 0, 1, 0)] = CFrame.Angles( math.pi/2, 0, 0),
    [Vector3.new( 0,-1, 0)] = CFrame.Angles(-math.pi/2, 0, 0),
}

-- ── Core tick: move one ring's bricks one frame ───────────────
local HEAL_INTERVAL = 0.5

local function _ringTickInstance(dt, params, state)
    local radius = math.max(params.radius, 0.5)
    state.angle    = state.angle    + (params.speed / radius) * dt
    state.ownTimer = state.ownTimer + dt
    state.healTimer = (state.healTimer or 0) + dt

    if state.ownTimer >= 0.5 then
        state.ownTimer = 0
        _ringBumpOwnership()
    end

    local hrp = _ringGetHostHRP(params.hostName)
    if not hrp then return end

    -- Self-heal: replace missing bricks
    if state.healTimer >= HEAL_INTERVAL then
        state.healTimer = 0
        local alive = {}
        for _, p in ipairs(state.parts) do
            if p and p.Parent then alive[#alive+1] = p end
        end
        if #alive < #state.parts then
            local lost = #state.parts - #alive
            local excl = {}
            for _, inst in pairs(_activeRings) do
                for _, p in ipairs(inst.parts or {}) do excl[p] = true end
            end
            for _, p in ipairs(_ringParts) do excl[p] = true end
            for _, p in ipairs(alive) do excl[p] = true end

            local spares = _ringGetSourceBricks(params.sourceName, excl)
            for i = 1, math.min(lost, #spares) do
                local b = spares[i]
                state.partsWereAnchored[b] = b.Anchored
                alive[#alive+1] = b
            end
            for k = #state.parts, 1, -1 do state.parts[k] = nil end
            for _, p in ipairs(alive) do state.parts[#state.parts+1] = p end
        end
    end

    local n = #state.parts
    if n == 0 then return end

    local patFn   = RING_PATTERNS[params.pattern] or RING_PATTERNS.Circle
    local aimAxis = params.aimOn and FACE_AXES[params.aimFace] or nil

    -- Follow-player-angle: build a yaw CFrame from host's LookVector
    local yawCF = CFrame.new()
    if params.followAngle then
        local look  = hrp.CFrame.LookVector
        local yaw   = math.atan2(-look.X, -look.Z)
        yawCF = CFrame.Angles(0, yaw, 0)
    end

    local tiltCF = CFrame.Angles(
        math.rad(params.angleX),
        math.rad(params.angleY),
        math.rad(params.angleZ)
    )

    local basePos = hrp.Position

    for i, part in ipairs(state.parts) do
        if not part or not part.Parent then continue end

        local offset   = patFn(i, n, state.angle, radius, params.length)
        local rotated  = yawCF * tiltCF * offset
        local worldPos = basePos + rotated

        -- Zero out velocity to prevent fling / repulsion
        pcall(function()
            part.AssemblyLinearVelocity  = Vector3.zero
            part.AssemblyAngularVelocity = Vector3.zero
        end)

        local cf
        if aimAxis then
            local toHost = basePos - worldPos
            local dist   = toHost.Magnitude
            if dist > 0.1 then
                toHost = toHost / dist
                local safeUp = math.abs(toHost:Dot(Vector3.yAxis)) > 0.99
                             and Vector3.xAxis or Vector3.yAxis
                local right  = toHost:Cross(safeUp).Unit
                local newUp  = right:Cross(toHost).Unit
                local lookCF = CFrame.fromMatrix(worldPos, right, newUp, -toHost)
                cf = lookCF * (FACE_CORRECTIONS[aimAxis] or CFrame.new())
            else
                cf = CFrame.new(worldPos)
            end
        else
            cf = CFrame.new(worldPos)
        end

        pcall(function() part.CFrame = cf end)
    end
end

-- ── Editor single-ring heartbeat ─────────────────────────────
local function _ringStartLoop()
    _ringAngle    = 0
    _ringOwnTimer = 0

    local editorState = {
        angle             = 0,
        ownTimer          = 0,
        healTimer         = 0,
        parts             = _ringParts,
        partsWereAnchored = _ringPartsWereAnchored,
    }

    _ringConn = RunService.Heartbeat:Connect(function(dt)
        if not _ringActive then return end
        _ringTickInstance(dt, {
            speed       = _ringSpeed,
            radius      = _ringRadius,
            length      = _ringLength,
            pattern     = _ringPattern,
            angleX      = _ringAngleX,
            angleY      = _ringAngleY,
            angleZ      = _ringAngleZ,
            aimOn       = _ringAimOn,
            aimFace     = _ringAimFace,
            followAngle = _ringFollowAngle,
            hostName    = _ringHostName,
            sourceName  = _ringBrickSource,
        }, editorState)
        _ringAngle = editorState.angle
    end)
end

-- ── Multi-ring: start / stop a named preset ──────────────────
local function _multiRingStart(name)
    local preset = getgenv()._sigmaRings[name]
    if not preset or _activeRings[name] then return end

    local inst = {
        angle             = 0,
        ownTimer          = 0,
        healTimer         = 0,
        parts             = {},
        partsWereAnchored = {},
        conn              = nil,
    }

    local ok = _ringSpawnParts(preset.count or 6, preset.brickSource, inst.parts, inst.partsWereAnchored)
    if not ok then return end

    _ringBumpOwnership()
    _activeRings[name] = inst

    inst.conn = RunService.Heartbeat:Connect(function(dt)
        if not _activeRings[name] then return end
        local p = getgenv()._sigmaRings[name]
        if not p then return end
        _ringTickInstance(dt, {
            speed       = p.speed       or 2,
            radius      = p.radius      or 8,
            length      = p.length      or 10,
            pattern     = p.pattern     or "Circle",
            angleX      = p.angleX      or 0,
            angleY      = p.angleY      or 0,
            angleZ      = p.angleZ      or 0,
            aimOn       = p.aimOn       or false,
            aimFace     = p.aimFace     or "None",
            followAngle = p.followAngle or false,
            hostName    = p.hostName    or "Myself",
            sourceName  = p.brickSource or "My Folder",
        }, inst)
    end)
    notify("Rings", "Ring \"" .. name .. "\" started.")
end

local function _multiRingStop(name)
    local inst = _activeRings[name]
    if not inst then return end
    if inst.conn then inst.conn:Disconnect(); inst.conn = nil end
    for _, p in ipairs(inst.parts) do
        pcall(function()
            if p and p.Parent then p.Anchored = inst.partsWereAnchored[p] or false end
        end)
    end
    _activeRings[name] = nil
    notify("Rings", "Ring \"" .. name .. "\" stopped.")
end

