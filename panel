            pcall(function() sendChat(S.punishOnSelfCmd) end)
            notify("Punish","✓ Fired: "..S.punishOnSelfCmd)
        end)
    end

    -- ── Whitelist group ───────────────────────────────────────────────────
    do
        local g=makeGroup(punishPage,"Whitelist (only fire on these)","Partial match, case-insensitive. Leave empty to apply to everyone.")
        local wlBox; local _,wlBoxRef=makeInput(g,"Add name","e.g. griefer",function() end)
