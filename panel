    -- ── Restore Building ──────────────────────────────────────────────────────
    local _bkitRestoringFast = false
    local function doRestoreBuilding(delay)
        local brickname = "Brick"
        if not game.ReplicatedStorage:FindFirstChild(brickname) then
            local brick = Instance.new("Part")
            brick.Name = brickname; brick.Parent = game.ReplicatedStorage
        end
        for _, v in pairs(lp.Character and lp.Character:GetChildren() or {}) do
            if v:HasTag("The Chosen One by TomazDev") then
                pcall(function() v.Script.Enabled=false; v.Script.Enabled=true end)
            end
        end
        for _, v in pairs(lp.Backpack:GetChildren()) do
            if v:HasTag("The Chosen One by TomazDev") then
                pcall(function() v.Script.Enabled=false; v.Script.Enabled=true end)
            end
        end
        local buildTool = lp.Character and lp.Character:FindFirstChild("Build")
                       or lp.Backpack:FindFirstChild("Build")
        if not buildTool then notify("Restore Bkit","Build tool not found!",3); return false end
        if buildTool.Parent ~= lp.Character then
            pcall(function()
                local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:EquipTool(buildTool) end
            end)
            task.wait(0.2)
            buildTool = lp.Character and lp.Character:FindFirstChild("Build")
        end
        if not buildTool then notify("Restore Bkit","Build tool lost after equip!",3); return false end
        local bc = getgenv().brickcollection
        if not bc or #bc == 0 then notify("Restore Bkit","brickcollection is empty!",3); return false end
        local currbc = {}
        for i, v in pairs(bc) do
            if v ~= nil then
                if v:GetFullName() ~= brickname and v.Name ~= "Debris" then
                    table.insert(currbc, 1, v)
                else
                    if i % 2 == 1 then table.insert(currbc, v)
                    else table.insert(currbc, #currbc+1, v) end
                end
            end
        end
        local getPos = function()
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            return hrp and hrp.Position or Vector3.new(0,0,0)
        end
        local cfolder = Workspace:FindFirstChild(lp.Name)
        if not cfolder then notify("Restore Bkit","cfolder not found!",3); return false end
        local beforeAmt = #cfolder:GetChildren()
        for _, v in pairs(currbc) do
            if v ~= nil and typeof(v) == "Instance" then
                buildTool = lp.Character and lp.Character:FindFirstChild("Build")
                if not buildTool then notify("Restore Bkit","Build tool lost \226\128\148 retry.",5); break end
                pcall(function()
                    buildTool.Script.Event:FireServer(v, Enum.NormalId.Top, getPos(), "detailed")
                end)
                task.wait(delay or 0)
                if #cfolder:GetChildren() > beforeAmt then break end
            end
        end
        task.wait(1)
        local block = cfolder:FindFirstChildWhichIsA("BasePart")
        if not block then return false end
        notify("Restore Bkit","Building restored successfully!",3)
        return true
    end

    makeButton(g, "Restore Building", function(btn)
        if _bkitRestoringFast then return end
        _bkitRestoringFast = true
        local orig = btn and btn.Text or "Restore Building"
        if btn then btn.Text = "Restoring (fast)..." end
        notify("Restore Bkit","Restoring (fast)...",3)
        task.spawn(function()
            local ok = pcall(doRestoreBuilding, 0)
            if not ok then
                if btn and btn.Parent then btn.Text = "Trying slow..." end
                notify("Restore Bkit","Fast failed — trying slow...",4)
                local ok2 = pcall(doRestoreBuilding, 0.15)
                if not ok2 then
                    notify("Restore Bkit","Failed. Run script before delcube finishes.",5)
                end
            end
            if btn and btn.Parent then btn.Text = orig end
            _bkitRestoringFast = false
        end)
    end, "Fast rebuild first, falls back to slow 0.15s delay if needed.")

    -- ── Fix Bkit ──────────────────────────────────────────────────────────────
    local function fixBkit()
        local rs = game:GetService("ReplicatedStorage")
        if not rs:FindFirstChild("Brick") then
            local brick = Instance.new("Part"); brick.Name = "Brick"; brick.Parent = rs
        end
        local character = lp.Character; if not character then return end
        local function resetToolScript(tool)
            local s = tool:FindFirstChild("Script")
            if s then s.Disabled=true; task.wait(); s.Disabled=false end
        end
        for _, v in pairs(character:GetChildren()) do
            if v:IsA("Tool") then resetToolScript(v) end
        end
        for _, v in pairs(lp.Backpack:GetChildren()) do
            if v:IsA("Tool") then resetToolScript(v) end
        end
    end
    lp.CharacterAdded:Connect(function() task.wait(1); pcall(fixBkit) end)
    if lp.Character then task.spawn(function() task.wait(1); pcall(fixBkit) end) end

    makeButton(g, "Fix Bkit", function(btn)
        if not btn then return end
        local orig = btn.Text
        btn.Text = "FIXING..."
        task.spawn(function()
            local ok = pcall(fixBkit)
            if btn and btn.Parent then
                btn.Text = ok and "FIXED!" or "FAILED"
                task.wait(3)
                if btn and btn.Parent then btn.Text = orig end
            end
        end)
    end, "Resets all tool scripts in char + backpack. RS Brick placeholder ensured. Auto-runs on respawn.")

    -- ── Disable Delete Sound ──────────────────────────────────────────────────
    local _permDeleteSoundConn = nil
    makeButton(g, "Disable Delete Sound", function(btn)
        local cfolder = Workspace:FindFirstChild(lp.Name)
        if not cfolder then notify("Bkit","cfolder not found!",3); return end
        for _, desc in ipairs(cfolder:GetDescendants()) do
            if desc:IsA("Sound") then pcall(function() desc.Volume = 0 end) end
        end
        if _permDeleteSoundConn then _permDeleteSoundConn:Disconnect() end
        _permDeleteSoundConn = cfolder.DescendantAdded:Connect(function(desc)
            if desc:IsA("Sound") then pcall(function() desc.Volume = 0 end) end
        end)
        notify("Bkit","Delete sounds permanently disabled",3)
        if btn and btn.Parent then btn.Text = "Sound OFF ✓" end
