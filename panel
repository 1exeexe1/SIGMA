    local _, tpCountBox  = makeInput(attacksPage, "Parts per player", "3",  function(v) _tpBricksPerPlayer = tonumber(v:match("%d+")) or 3 end)
    local _, tpRadBox    = makeInput(attacksPage, "Parts radius (studs)", "60", function(v) _tpRadius = tonumber(v:match("%d+")) or 60 end)
    local _, tpDistBox   = makeInput(attacksPage, "Fling distance (studs)", "30", function(v) _tpFlingDist = tonumber(v:match("%d+")) or 30 end)
    tpFlingBox.Text="120"; tpCountBox.Text="3"; tpRadBox.Text="60"; tpDistBox.Text="30"
    makeToggle(attacksPage, "Return to player when target HP reaches 0", function(on) _tpReturnOnDeath=on end, false,
        "Sends bricks back to you when the target dies.")

    makeButton(attacksPage, "Teleport Parts to Target", function()
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then notify("Attacks","No character."); return end

        -- Collect targets
