                        specBtn.BackgroundColor3=Color3.fromRGB(190,50,50)
                        notify("\226\152\133 Finder","Spectating "..p.Name)
                    end
                end
            end)
        end)

        S._enlCards[p.UserId]={frame=card,specBtn=specBtn,tpBtn=tpBtn}
        _enlUpdateStatus()
    end

    local function _enlRemoveCard(uid)
        local c=S._enlCards[uid]; if not c then return end
        if S._enlSpectating and S._enlSpectating.UserId==uid then
            S._enlSpectating=nil
            pcall(function()
                local myHum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                if myHum then Workspace.CurrentCamera.CameraSubject=myHum end
            end)
        end
        c.frame:Destroy(); S._enlCards[uid]=nil; _enlUpdateStatus()
    end

    local function _enlRecheck(p)
        task.wait(0.15)
        if _enlHasArken(p) then _enlMakeCard(p)
        else _enlRemoveCard(p.UserId) end
    end

    local function _enlWatchPlayer(p)
        if p==lp then return end
        local conns={}
        local function watchContainer(container)
            if not container then return end
            table.insert(conns, container.ChildAdded:Connect(function(item)
                if item.Name=="The Arkenstone" then _enlMakeCard(p) end
            end))
            table.insert(conns, container.ChildRemoved:Connect(function(item)
                if item.Name=="The Arkenstone" then task.spawn(_enlRecheck,p) end
            end))
        end
        local ok,bp=pcall(function() return p.Backpack end)
        if ok and bp then watchContainer(bp) end
        table.insert(conns, p.ChildAdded:Connect(function(child)
            if child.Name=="Backpack" then watchContainer(child) end
        end))
        if p.Character then watchContainer(p.Character) end
        table.insert(conns, p.CharacterAdded:Connect(function(char)
            task.wait(0.3); _enlRecheck(p); watchContainer(char)
        end))
        S._enlWatchers[p.UserId]=conns
        task.spawn(_enlRecheck,p)
    end

    -- Boot: watch everyone already in server
    for _,p in ipairs(Players:GetPlayers()) do task.spawn(_enlWatchPlayer,p) end
    Players.PlayerAdded:Connect(function(p)
        task.wait(1); _enlWatchPlayer(p)
    end)
    Players.PlayerRemoving:Connect(function(p)
        local conns=S._enlWatchers[p.UserId]
        if conns then
            for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
            S._enlWatchers[p.UserId]=nil
        end
        _enlRemoveCard(p.UserId)
    end)
    -- 12-second rescan heartbeat (catches attribute-only enlightens)
    task.spawn(function()
        while true do task.wait(12)
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=lp then
                    if _enlHasArken(p) then _enlMakeCard(p)
                    else _enlRemoveCard(p.UserId) end
                end
            end
        end
    end)
end

