local _NORM_IDS = {
    [Enum.NormalId.Right]  = {Vector3.new(1,0,0),  "X"},
    [Enum.NormalId.Top]    = {Vector3.new(0,1,0),  "Y"},
    [Enum.NormalId.Back]   = {Vector3.new(0,0,1),  "Z"},
    [Enum.NormalId.Left]   = {Vector3.new(-1,0,0), "X"},
    [Enum.NormalId.Bottom] = {Vector3.new(0,-1,0), "Y"},
    [Enum.NormalId.Front]  = {Vector3.new(0,0,-1), "Z"},
}

local function closestFace(brick, hitPos)
    local best, bestDist = Enum.NormalId.Top, math.huge
    for normalId, data in pairs(_NORM_IDS) do
        local faceCentre = brick.Position + data[1] * (brick.Size[data[2]] / 2)
        local d = (hitPos - faceCentre).Magnitude
        if d < bestDist then bestDist = d; best = normalId end
    end
    return best
end

local NANO_OFFSETS={
    Vector3.new(4,0,0),Vector3.new(-4,0,0),
    Vector3.new(0,4,0),Vector3.new(0,-4,0),
    Vector3.new(0,0,4),Vector3.new(0,0,-4),
}

local function nanoNeighbours(part)
    local found={}
    local bricksFolder=getBricksFolder(); if not bricksFolder then return found end
    local params=nil; pcall(function() params=OverlapParams.new() end)
    if not params then return end
    params.FilterType=Enum.RaycastFilterType.Include
    params.FilterDescendantsInstances={bricksFolder}
    for _,offset in ipairs(NANO_OFFSETS) do
        local hits=Workspace:GetPartBoundsInBox(CFrame.new(part.Position+offset),Vector3.new(3,3,3),params)
        for _,hit in ipairs(hits) do
            if hit:IsA("BasePart") and hit~=part and not S.nanoVisited[hit] then
                S.nanoVisited[hit]=true; table.insert(found,hit)
            end
        end
    end
    return found
end

local function nanoAct(brick)
    local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    if S.nanoMode=="Delete" then
        local ev=equipAndGetEvent("Delete"); if ev then ev:FireServer(brick,hrp.Position) end
    elseif S.nanoMode=="Unanchor" then
        -- Use "material" mode so only the anchor state changes — colour is preserved.
        local ev=equipAndGetEvent("Paint"); if ev then ev:FireServer(brick,Enum.NormalId.Top,hrp.Position,"material",Color3.new(1,1,1),"anchor","") end
    elseif S.nanoMode=="Paint-ify" then
        -- Use "color" mode so material is never forced to a default.
        local ev=equipAndGetEvent("Paint"); if ev then
            local col=S.nanoColor
            if S.nanoRainbow then S.nanoRainbowH=(S.nanoRainbowH+0.03)%1; col=Color3.fromHSV(S.nanoRainbowH,1,1) end
            ev:FireServer(brick,Enum.NormalId.Top,hrp.Position,"color",col,"plastic","")
        end
    elseif S.nanoMode=="Materialize" then
        -- Apply both color and material at once with HANDSHAKE ("both 🤝").
        local ev=equipAndGetEvent("Paint"); if ev then
            local col=S.nanoMatColor
            if S.nanoMatRainbow then S.nanoMatRainbowH=(S.nanoMatRainbowH+0.03)%1; col=Color3.fromHSV(S.nanoMatRainbowH,1,1) end
            ev:FireServer(brick,Enum.NormalId.Top,hrp.Position,HANDSHAKE,col,S.nanoMatMat,"")
        end
    end
end

local function startFlood(seed)
    if S.nanoRunning then return end
    S.nanoRunning=true; S.nanoVisited={}; S.nanoVisited[seed]=true
    task.spawn(function()
        local ordered = {}
        local bfsQueue = {seed}
        local batchN = 0
        while #bfsQueue > 0 do
            local cur = table.remove(bfsQueue, 1)
            if cur and cur.Parent then
                table.insert(ordered, cur)
                for _,nb in ipairs(nanoNeighbours(cur)) do
                    table.insert(bfsQueue, nb)
                end
            end
            batchN = batchN + 1
            -- Yield every 50 nodes so the UI stays responsive without
            -- the old per-node task.wait() that made mapping painfully slow.
            if batchN >= 50 then batchN=0; task.wait() end
        end

        for _,brick in ipairs(ordered) do
            if not S.nanoOn then break end
            if brick and brick.Parent then
                nanoAct(brick)
                task.wait(S.nanoSpeed)
            end
        end

        S.nanoRunning=false; S.nanoVisited={}
        S.nanoOn=false
        if S._nanoFloodSetState then S._nanoFloodSetState(false) end
        _nanoSelBox.Adornee=nil
        notify("Sigma","Nanobots: flood complete. ("..#ordered.." blocks)")
    end)
end

