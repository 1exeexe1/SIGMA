            local names = {}
            for _, s in ipairs(_aiSessions) do names[#names+1] = s.name end
            _smListLbl.Text = "Saved: " .. table.concat(names, ", ")
        end
    end
    _smRefreshList()

    makeButton(_smG, "↺ Refresh List", function() _smRefreshList() end)
end  -- Session Manager

