    headerLbl.ZIndex=62; headerLbl.Parent=headerFrame
    onTheme(function(th) headerLbl.TextColor3=th.WHITE end)

    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,18,0,18); closeBtn.Position=UDim2.new(1,-22,0.5,-9)
    closeBtn.BackgroundColor3=Color3.fromRGB(180,40,40); closeBtn.BorderColor3=T.BORDER
    closeBtn.Text="\195\151"; closeBtn.TextColor3=Color3.fromRGB(255,255,255)
    closeBtn.FontFace=FONT_MAIN; closeBtn.TextSize=10; closeBtn.ZIndex=62; closeBtn.Parent=headerFrame

    -- Scrollable content area
    local dropScroll=Instance.new("ScrollingFrame")
    dropScroll.Size=UDim2.new(1,0,1,-24); dropScroll.Position=UDim2.new(0,0,0,24)
    dropScroll.BackgroundTransparency=1; dropScroll.BorderSizePixel=0
    dropScroll.ScrollBarThickness=8; dropScroll.ScrollBarImageColor3=T.ACCENT
    dropScroll.Active=true; dropScroll.ClipsDescendants=true
