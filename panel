local _bbMouse = lp:GetMouse()
local _bbSelLbl = nil   -- forward ref; set after UI is built

local function _bbGetSelectedSound()
    local char = S._boomboxSelected
    if not char then return nil, nil end
    local snd = _bbGetSound(char)
    local id  = snd and (_bbGetId(snd) or "?") or nil
    return snd, id
end

local function _bbRefreshSelBox(char, isSelected)
    local sb = S._boomboxSelBoxes[char]
    if not sb then return end
    local isBoombox = S._boomboxIsBoombox and S._boomboxIsBoombox[char]
    if isSelected then
        sb.Color3        = Color3.fromRGB(0, 220, 255)
        sb.SurfaceColor3 = Color3.fromRGB(0, 220, 255)
    elseif isBoombox then
        sb.Color3        = Color3.fromRGB(255, 180, 0)
        sb.SurfaceColor3 = Color3.fromRGB(255, 200, 0)
    else
        sb.Color3        = Color3.fromRGB(160, 160, 160)
        sb.SurfaceColor3 = Color3.fromRGB(140, 140, 140)
    end
end

local function _bbSetSelected(newChar)
    local old = S._boomboxSelected
    if old and old ~= newChar then _bbRefreshSelBox(old, false) end
    S._boomboxSelected = newChar
    if newChar then _bbRefreshSelBox(newChar, true) end
    -- Update the status label in the UI
    if _bbSelLbl then
        if newChar then
            local snd, id = _bbGetSelectedSound()
            local name = newChar.Name or "?"
            _bbSelLbl.Text = "Selected: "..name..(id and (" · "..id) or "")
        else
            _bbSelLbl.Text = "Selected: none"
        end
    end
end

local function _bbAttachClick()
    if S._boomboxClickConn then S._boomboxClickConn:Disconnect(); S._boomboxClickConn=nil end
    if not S.boomboxClickCopy then return end
    S._boomboxClickConn = _bbMouse.Button1Down:Connect(function()
        if not S.boomboxClickCopy then return end
        local target = _bbMouse.Target
        if not target then return end

        -- Only accept clicks on models we are actively tracking.
        local matched = nil
        -- Check player characters
        for _, plr in ipairs(Players:GetPlayers()) do
            local char = plr.Character
            if char and target:IsDescendantOf(char) then
                local snd = S.boomboxOnly and _bbGetSoundBoomboxOnly(char) or _bbGetSound(char)
                if snd then matched = char end
                break
            end
        end
        -- Check workspace.Clones[username]/* models
        if not matched then
            local clonesFolder = Workspace:FindFirstChild("Clones")
            if clonesFolder then
                for _, userFolder in ipairs(clonesFolder:GetChildren()) do
                    for _, child in ipairs(userFolder:GetChildren()) do
                        if child:IsA("Model") and target:IsDescendantOf(child) then
                            local snd = S.boomboxOnly and _bbGetSoundBoomboxOnly(child) or _bbGetSound(child)
                            if snd then matched = child end
                            break
                        end
                    end
                    if matched then break end
                end
            end
        end

        if not matched then return end
        _bbSetSelected(matched)
        local snd = S.boomboxOnly and _bbGetSoundBoomboxOnly(matched) or _bbGetSound(matched)
        local id = snd and (_bbGetId(snd) or "?") or "?"
        notify("Boombox", "Selected: "..matched.Name.." · "..id)
    end)
end

