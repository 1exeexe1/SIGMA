-- ═══ SCA SHARED UTILITY ════════════════════════════════════════
-- ═══════════════════════════════════════════════════════════════
-- getMouseWorldHit: returns a world-space hit position for drag operations
-- even when the mouse is over the void (no Target).
-- Strategy: use Mouse.Hit when there is a Target; otherwise project
-- Mouse.UnitRay onto the plane that passes through 'planePoint' and
-- faces the camera's look direction.  This keeps dragging smooth in air.
-- Multi-touch guard: SCA drag jitter is caused by secondary touch points both
-- firing InputChanged in the same frame, snapping the drag position back and
-- forth.  We latch the first active touch ID when a drag starts (set by each
-- tool's click handler) and reject any InputChanged that comes from a different
-- touch point.  For mouse, there is no second pointer so the guard is a no-op.
local _scaActiveTouchId = nil  -- nil = mouse mode; number = locked touch ID

local function getMouseWorldHit(mouse, planePoint)
    if mouse.Target then
        local hp = mouse.Hit.Position
        if hp.Magnitude < 20000 then return hp end
    end
    -- Void fallback: ray-plane intersection
    local ray    = mouse.UnitRay
    local camLook= Workspace.CurrentCamera.CFrame.LookVector
    local denom  = camLook:Dot(ray.Direction)
    if math.abs(denom) < 0.001 then return planePoint end  -- ray parallel to plane
    local t = camLook:Dot(planePoint - ray.Origin) / denom
    if t < 0 then return planePoint end
    return ray.Origin + ray.Direction * t
end

