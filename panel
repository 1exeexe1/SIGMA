    local _cloneHasMoved=false

    local function _cGetBlocksInRect(x0,y0,x1,y1)
        local minX,maxX=math.min(x0,x1),math.max(x0,x1)
        local minY,maxY=math.min(y0,y1),math.max(y0,y1)
        if maxX-minX<4 or maxY-minY<4 then return {} end
        local cam=Workspace.CurrentCamera; local found={}
        local folder = getBricksFolder()
        if folder then
            for _,obj in ipairs(folder:GetDescendants()) do
                if obj:IsA("BasePart") then
                    local sp,vis=cam:WorldToScreenPoint(obj.Position)
                    if vis and sp.X>=minX and sp.X<=maxX and sp.Y>=minY and sp.Y<=maxY then
                        table.insert(found,obj)
                    end
                end
            end
        else
            for _,obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") and obj~=Workspace.Terrain then
                    local sp,vis=cam:WorldToScreenPoint(obj.Position)
                    if vis and sp.X>=minX and sp.X<=maxX and sp.Y>=minY and sp.Y<=maxY then
                        table.insert(found,obj)
                    end
                end
            end
        end
        return found
    end

    -- ── Mouse / drag logic for the SCA zone (same pattern as sv) ─────────
    local _clMouse=lp:GetMouse()
    local _clClickConn,_clUpConn,_clDragConn

    local function _clHandleZoneClick()
        if not cloneZone.equipped then return end
        local target=_clMouse.Target; if not target then return end
        local hitPos=_clMouse.Hit.Position
        -- Check if clicking a resize handle
        for key,h in pairs(cloneZoneHandles) do
            if target==h then
                cloneZone.dragging=true; cloneZone.dragKey=key
                cloneZone.dragStartMouse=hitPos
                cloneZone.dragStartOrigin=cloneZone.origin
                cloneZone.dragStartSX=cloneZone.sX; cloneZone.dragStartSY=cloneZone.sY; cloneZone.dragStartSZ=cloneZone.sZ
                return
            end
        end
        if _scaRefreshOnClick or not cloneZone.placed then
            local nv=CT_NORM_VEC[_clMouse.TargetSurface] or Vector3.new(0,1,0)
            cloneZone.origin=snapToGrid(hitPos+nv*CT_GRID*0.5)
            cloneZone.sX=1; cloneZone.sY=1; cloneZone.sZ=1; cloneZone.placed=true
            cloneSyncZone(); _cZoneLblUpdate()
        end
    end

    local function _clHandleZoneDrag()
        if not cloneZone.dragging or not cloneZone.dragKey then return end
        if _scaActiveTouchId and #UserInputService:GetTouchState() > 1 then return end
        local hitPos=getMouseWorldHit(_clMouse,cloneZone.dragStartMouse)
        if hitPos.Magnitude>20000 then return end
        local info=CT_FACES[cloneZone.dragKey]; if not info then return end
        local ax,dir=info.ax,info.dir
        local axV=ax=="X" and Vector3.new(1,0,0) or (ax=="Y" and Vector3.new(0,1,0) or Vector3.new(0,0,1))
        local rawD=(hitPos-cloneZone.dragStartMouse):Dot(axV)
        local blkD=math.clamp(math.floor(rawD/CT_GRID+0.5),-200,200)
        if dir>0 then
            local sS=ax=="X" and cloneZone.dragStartSX or (ax=="Y" and cloneZone.dragStartSY or cloneZone.dragStartSZ)
            local nS=math.max(1,sS+blkD)
            if ax=="X" then cloneZone.sX=nS elseif ax=="Y" then cloneZone.sY=nS else cloneZone.sZ=nS end
        else
            local sS=ax=="X" and cloneZone.dragStartSX or (ax=="Y" and cloneZone.dragStartSY or cloneZone.dragStartSZ)
            local nS=math.max(1,sS-blkD); local sh=(sS-nS)*CT_GRID
            if ax=="X" then cloneZone.sX=nS; cloneZone.origin=Vector3.new(cloneZone.dragStartOrigin.X+sh,cloneZone.origin.Y,cloneZone.origin.Z)
            elseif ax=="Y" then cloneZone.sY=nS; cloneZone.origin=Vector3.new(cloneZone.origin.X,cloneZone.dragStartOrigin.Y+sh,cloneZone.origin.Z)
            else cloneZone.sZ=nS; cloneZone.origin=Vector3.new(cloneZone.origin.X,cloneZone.origin.Y,cloneZone.dragStartOrigin.Z+sh) end
        end
        cloneSyncZone(); _cZoneLblUpdate()
    end

