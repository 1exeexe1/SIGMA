    -- Format is IDENTICAL to Save/Load tab: flat array of
    -- {p={x,y,z}, s={sx,sy,sz}, c={r,g,b 0-255}, m=str, a=bool, cc=bool, sp=sprays}
    -- Corner-offset position: corner = centre - size/2 + 0.5
    -- so Load Build's rawCenter formula (corner + size/2 - 0.5) round-trips exactly.
    local sX2,sY2,sZ2=sv.sX*CT_GRID,sv.sY*CT_GRID,sv.sZ*CT_GRID
    local center=sv.origin+Vector3.new((sv.sX-1)*CT_GRID*0.5,(sv.sY-1)*CT_GRID*0.5,(sv.sZ-1)*CT_GRID*0.5)
    local zoneMin=center-Vector3.new(sX2,sY2,sZ2)*0.5
    local zoneMax=center+Vector3.new(sX2,sY2,sZ2)*0.5
    local collected={}
    for _,playerFolder in ipairs(bricksFolder:GetChildren()) do
        for _,b in ipairs(playerFolder:GetChildren()) do
            if b:IsA("BasePart") then
                local bp=b.Position
                if bp.X>=zoneMin.X-0.1 and bp.X<=zoneMax.X+0.1
                and bp.Y>=zoneMin.Y-0.1 and bp.Y<=zoneMax.Y+0.1
                and bp.Z>=zoneMin.Z-0.1 and bp.Z<=zoneMax.Z+0.1 then
                    local bsz=b.Size
                    local entry={
                        p={(bp.X-bsz.X/2)+0.5,(bp.Y-bsz.Y/2)+0.5,(bp.Z-bsz.Z/2)+0.5},
                        s={bsz.X,bsz.Y,bsz.Z},
                        c={math.round(b.Color.R*255),math.round(b.Color.G*255),math.round(b.Color.B*255)},
                        m=MAT_TO_STR[b.Material] or "plastic",
                        a=b.Anchored,
                        cc=b.CanCollide,
                    }
                    -- Face sprays (SurfaceGui text labels)
                    local sprays={}
                    for _,child in ipairs(b:GetDescendants()) do
                        if child:IsA("SurfaceGui") then
                            local tl=child:FindFirstChildWhichIsA("TextLabel",true)
                            if tl and tl.Text~="" then
                                local hex=tl.Text:match('color="#(%x+)"')
                                local text=tl.Text:match(">(.+)</font>") or tl.Text
                                table.insert(sprays,{child.Face.Name,hex or "FFFFFF",text})
                            end
                        end
                    end
                    if #sprays>0 then entry.sp=sprays end
                    table.insert(collected,entry)
                end
            end
        end
    end
    if #collected==0 then btn.Text="No bricks in zone!"; task.wait(2); btn.Text="\240\159\146\190 Save Build"; return end
    LOG("Save", string.format("--- Save Tool: '%s' | %d bricks in zone ---", buildName, #collected))
    for i, entry in ipairs(collected) do
        local s = entry.s or {4,4,4}
        LOG("Save", string.format("  [%d] pos=(%.2f,%.2f,%.2f) sz=(%.0fx%.0fx%.0f) mat=%s sprays=%d",
            i, entry.p[1], entry.p[2], entry.p[3],
            s[1], s[2], s[3],
            tostring(entry.m),
            entry.sp and #entry.sp or 0))
    end
    local path="SigmaPanel_Builds/"..buildName..".json"
    pcall(function()
        if typeof(writefile)=="function" then
            if typeof(isfolder)=="function" and not isfolder("SigmaPanel_Builds")
            and typeof(makefolder)=="function" then makefolder("SigmaPanel_Builds") end
