-- ── Persistence helpers (module-scope so Rejoin/Hop/JoinXL can all use them) ──
local _sigmaQueueTP = (typeof(queue_on_teleport)  == "function" and queue_on_teleport)
                   or (syn    and typeof(syn.queue_on_teleport)    == "function" and syn.queue_on_teleport)
                   or (fluxus and typeof(fluxus.queue_on_teleport) == "function" and fluxus.queue_on_teleport)
                   or nil

-- Call this BEFORE any TeleportService call when Keep Sigma or Follow Through Servers is on.
-- Arming queueteleport before the teleport fires is more reliable than relying solely on
-- OnTeleport, which some executors fire too late (after the DataModel has started unloading).
-- S.sigmaUrl is set in the S table default and overridable via the Script URL input in Settings.
-- ?t=timestamp is appended every call to bust GitHub CDN cache — never get a stale version again.
local function prepareKeep()
    if not _sigmaQueueTP then return end
    if not (S.keepSigmaOn or S.followServers) then return end
    local url = S.sigmaUrl .. "?t=" .. tostring(os.time())
    _sigmaQueueTP("loadstring(game:HttpGet('"..url.."'))() ")
end

