                local delta  = DC.corner2 - liveC1
                if E.brick == DC.brick1 and E.bodyPos then
                    E.bodyPos.Position = E.bodyPos.Position + delta
                else
                    if not DC.brick1.Anchored then
                        E.brick = DC.brick1
                        installPhysics(DC.brick1)
                        task.wait(0.05)
                        E.bodyPos.Position = DC.brick1.Position + delta
                    end
                end
                notify("De-Grid","\226\156\147 Snapped! Apply Offset, then Apply Anchor.")

            else
                -- ── DIRECTION mode: rotate Brick1 so its C1-axis
                --    aligns with the C2-direction of Brick2 ──────────
                -- targetDir: the world-space direction we want Brick1's
                -- C1 local axis to point toward.
                local b2centre  = DC.brick2.CFrame.Position
                local targetDir = (DC.corner2 - b2centre)
                if targetDir.Magnitude < 0.01 then
                    notify("De-Grid","Corners too close to centre — pick a different corner."); return
                end
                targetDir = targetDir.Unit

                -- sourceDir: the local-space offset of C1 from Brick1's centre
                -- (already stored as DC._c1localOff, which is local object-space)
                local srcLocal = DC._c1localOff
                if srcLocal.Magnitude < 0.01 then
                    notify("De-Grid","Corner1 is at the brick centre — pick a corner, not centre."); return
                end
                local srcDir = srcLocal.Unit   -- object-space unit axis to align

                -- Build a rotation CFrame that maps srcDir → targetDir.
                -- We use the axis-angle formula: cross product gives the rotation
                -- axis, dot gives the cosine of the angle.
                local crossV = Vector3.new(srcDir.Y*targetDir.Z - srcDir.Z*targetDir.Y,
                                           srcDir.Z*targetDir.X - srcDir.X*targetDir.Z,
                                           srcDir.X*targetDir.Y - srcDir.Y*targetDir.X)
                local dotV   = srcDir:Dot(targetDir)

                local newCF
                if crossV.Magnitude < 0.001 then
                    -- Vectors are parallel (or anti-parallel)
                    if dotV > 0 then
                        -- Already aligned — nothing to rotate
                        newCF = DC.brick1.CFrame
                    else
                        -- 180° flip: pick any perpendicular axis
                        local perp = srcDir:Cross(Vector3.new(0,1,0))
                        if perp.Magnitude < 0.01 then perp = srcDir:Cross(Vector3.new(1,0,0)) end
                        perp = perp.Unit
                        -- CFrame.fromAxisAngle rotates the brick's object frame
                        local rotPart = CFrame.fromAxisAngle(perp, math.pi)
                        newCF = CFrame.new(DC.brick1.CFrame.Position) * rotPart
                    end
                else
                    local axis  = crossV.Unit
                    local angle = math.atan2(crossV.Magnitude, dotV)
                    -- Post-multiply in object space so the brick rotates around
                    -- its own C1 axis by exactly the angle needed.
                    newCF = CFrame.new(DC.brick1.CFrame.Position) *
                            (DC.brick1.CFrame - DC.brick1.CFrame.Position) *
                            CFrame.fromAxisAngle(axis, angle)
                end

                -- Apply the new CFrame via BodyGyro
                if E.brick ~= DC.brick1 then
                    if not DC.brick1.Anchored then
                        E.brick = DC.brick1
                        installPhysics(DC.brick1)
                        task.wait(0.05)
                    end
                end
                if E.bodyGyro then
                    E.bodyGyro.CFrame = newCF - newCF.Position
                    -- Keep desiredCF in sync with the new rotation
                    E.desiredCF = newCF
                end
                -- Sync the XYZ display boxes
                task.wait(0.05); readCFrame()
                notify("De-Grid","\226\156\147 Brick1 rotated toward corner 2. Adjust, then Apply Offset.")
            end

            dcClearDots(DC.dots1); dcClearDots(DC.dots2)
            dcClearSelBox2()
            DC.phase=0
            dcSetPhaseText("\226\151\136 Corner Align",Color3.fromRGB(100,180,255))
            btn.Text="\226\151\136 Start: Select Brick 1"
        end
    end)
    DC.btn=_dcMainBtn
end

