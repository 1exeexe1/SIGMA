-- Spawn 8 neon sphere corner markers for 'brick' into 'dots' table.
-- colour: Color3 for the spheres.
-- Returns the table of Parts.
local function dcSpawnDots(brick, dots, colour)
    dcClearDots(dots)
    local cf = brick.CFrame
    local s  = brick.Size * 0.5
    local offsets = {
        Vector3.new( s.X, s.Y, s.Z), Vector3.new(-s.X, s.Y, s.Z),
        Vector3.new( s.X,-s.Y, s.Z), Vector3.new(-s.X,-s.Y, s.Z),
        Vector3.new( s.X, s.Y,-s.Z), Vector3.new(-s.X, s.Y,-s.Z),
        Vector3.new( s.X,-s.Y,-s.Z), Vector3.new(-s.X,-s.Y,-s.Z),
    }
    for _,off in ipairs(offsets) do
        local worldPos = cf:PointToWorldSpace(off)
        local p = Instance.new("Part")
        p.Shape       = Enum.PartType.Ball
        p.Size        = Vector3.new(0.4,0.4,0.4)
        p.Material    = Enum.Material.Neon
        p.Color       = colour
        p.Anchored    = true
        p.CanCollide  = false
        p.CastShadow  = false
        p.CFrame      = CFrame.new(worldPos)
        p.Parent      = Workspace
        -- Store world position as attribute for hit detection
        p:SetAttribute("dcCornerWorld", worldPos)
        table.insert(dots, p)
    end
end

-- Update dot positions to follow brick1 while it moves
local function dcSyncDots1()
    if not DC.brick1 or not DC.brick1.Parent then return end
    if #DC.dots1 == 0 then return end
    local cf = DC.brick1.CFrame
    local s  = DC.brick1.Size * 0.5
    local offsets = {
        Vector3.new( s.X, s.Y, s.Z), Vector3.new(-s.X, s.Y, s.Z),
        Vector3.new( s.X,-s.Y, s.Z), Vector3.new(-s.X,-s.Y, s.Z),
        Vector3.new( s.X, s.Y,-s.Z), Vector3.new(-s.X, s.Y,-s.Z),
        Vector3.new( s.X,-s.Y,-s.Z), Vector3.new(-s.X,-s.Y,-s.Z),
    }
    for i, p in ipairs(DC.dots1) do
        local wp = cf:PointToWorldSpace(offsets[i])
        p.CFrame = CFrame.new(wp)
        p:SetAttribute("dcCornerWorld", wp)
    end
end

-- Find which dot in 'dots' is closest to the mouse hit (within threshold)
local function dcFindClickedCorner(dots, mouse)
    local best, bestDist = nil, 1.5   -- 1.5 stud click radius
    local hitPos = mouse.Hit.Position
    for _, p in ipairs(dots) do
        local wp = p:GetAttribute("dcCornerWorld") or p.Position
        local d  = (hitPos - wp).Magnitude
        if d < bestDist then bestDist = d; best = p end
    end
    return best
end

-- Draw / update the blue beam between corner1 and corner2
local function dcDrawBeam()
    if not DC.corner1 or not DC.corner2 then return end
    dcClearBeam()

    local function makeDot(pos, col)
        local p = Instance.new("Part")
        p.Size=Vector3.new(0.3,0.3,0.3); p.Shape=Enum.PartType.Ball
        p.Material=Enum.Material.Neon; p.Color=col
        p.Anchored=true; p.CanCollide=false; p.CastShadow=false
        p.CFrame=CFrame.new(pos); p.Parent=Workspace
        return p
    end
    DC.beamPart1 = makeDot(DC.corner1, Color3.fromRGB(255,120,0))
    DC.beamPart2 = makeDot(DC.corner2, Color3.fromRGB(0,180,255))

    local att1 = Instance.new("Attachment"); att1.Parent = DC.beamPart1
    local att2 = Instance.new("Attachment"); att2.Parent = DC.beamPart2

    do
        local beam = Instance.new("Beam")
        beam.Attachment0    = att1
        beam.Attachment1    = att2
        beam.Color          = ColorSequence.new(Color3.fromRGB(0,180,255))
        beam.Width0         = 0.08
        beam.Width1         = 0.08
        beam.FaceCamera     = true
        beam.Transparency   = NumberSequence.new(0)
        beam.LightEmission  = 1
        beam.Parent         = Workspace
        DC.beam = beam
    end
end

-- Heartbeat: sync brick1 dots + beam if in phase 2+
do
    local _dcHBConn
    _dcHBConn = RunService.Heartbeat:Connect(function()
        if DC.phase >= 2 and DC.brick1 and DC.brick1.Parent then
            dcSyncDots1()
            -- If corner1 is set, update the beam origin to follow brick1's corner
            if DC.corner1 and DC.beamPart1 then
                -- Recompute corner1 from brick1's stored local offset
                if DC._c1localOff then
                    DC.corner1 = DC.brick1.CFrame:PointToWorldSpace(DC._c1localOff)
                    DC.beamPart1.CFrame = CFrame.new(DC.corner1)
                end
            end
        end
    end)
end

-- Mouse click handler for DC phases
E._mouse.Button1Down:Connect(function()
