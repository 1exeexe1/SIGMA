-- ── LOUD BOOMBOX ─────────────────────────────────────────────
-- Multi-equips every boombox copy in the backpack and fires PlaySong
-- on each simultaneously with the same audio ID, effectively stacking
-- volume proportional to the number of boomboxes equipped.
-- Ring of Boomboxes: un-parents N boomboxes to workspace around the
-- player's feet (absolute-ownership grab to lock position) and fires
-- PlaySong on each. Heartbeat loop re-asserts CFrame to keep them
-- pinned at their spawn position.
do
    local g = makeGroup(boomboxPage, "\240\159\224\138 Loud Boombox",
        "Stack all boomboxes in your backpack to amplify volume. Each extra boombox = +1 layer of audio.")

    local _,volumeBox = makeInput(g, "Volume (# boomboxes)", "max", function() end)
    local _,audioBox  = makeInput(g, "Audio ID", "142376088", function() end)
    volumeBox.Text = "max"
    audioBox.Text  = "142376088"

    -- Internal state
    local _lbPlaying   = false
    local _lbRingParts = {}   -- {tool, part} for ring mode
    local _lbRingConn  = nil  -- Heartbeat for ring lock

    -- Find all boombox tools in backpack + character
    local function _lbGetBoomboxes()
        local found = {}
        local function scan(container)
            for _, t in ipairs(container:GetChildren()) do
                if t:IsA("Tool") and t.Name:lower():find("boombox") then
                    found[#found+1] = t
                end
            end
        end
        pcall(function() scan(lp.Backpack) end)
        pcall(function() if lp.Character then scan(lp.Character) end end)
        return found
    end

    -- Get the Remote inside a boombox tool
    local function _lbGetRemote(tool)
        return tool:FindFirstChild("Remote") or tool:FindFirstChildWhichIsA("RemoteEvent")
    end

    local statusLbl = makeLabel(g, "Status: idle")
    statusLbl.TextColor3 = Color3.fromRGB(140,140,140)
    onTheme(function(th) statusLbl.TextColor3 = Color3.fromRGB(140,140,140) end)

    makeButton(g, "\240\159\224\138 Start Loud Boombox", function()
        if _lbPlaying then notify("Boombox","Already playing — Stop first."); return end
        local rawId   = audioBox.Text:match("%d+")
        local audioId = tonumber(rawId)
        if not audioId then notify("Boombox","Enter a valid numeric Audio ID."); return end

        local boxes = _lbGetBoomboxes()
        if #boxes == 0 then notify("Boombox","No boomboxes found in backpack!"); return end

        -- Determine how many to use
        local maxN = #boxes
        local wantN = maxN
        local vRaw = volumeBox.Text:match("^%s*(.-)%s*$")
        if vRaw ~= "max" and vRaw ~= "" then
            wantN = math.clamp(tonumber(vRaw) or maxN, 1, maxN)
        end
        local toUse = {}
        for i = 1, wantN do toUse[#toUse+1] = boxes[i] end

        _lbPlaying = true
        statusLbl.Text = "Status: equipping " .. #toUse .. " boombox(es)…"

        task.spawn(function()
            local char = lp.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if not (char and hum) then
                notify("Boombox","No character!"); _lbPlaying=false; return
            end
            -- Force-equip each boombox directly to character (multi-equip pattern)
            -- Pre-equip ALL tools first (no delay between moves), then fire all remotes
            -- simultaneously so audio starts on the same server tick → tightest possible sync.
            local equipped = {}
            for _, tool in ipairs(toUse) do
                pcall(function()
                    if tool.Parent == lp.Backpack then
                        tool.Parent = char
                    end
                end)
            end
            -- Single shared settle: wait just enough for server to ACK the parent changes
            task.wait(0.05)
            for _, tool in ipairs(toUse) do
                pcall(function()
                    local remote = _lbGetRemote(tool)
                    if remote then
