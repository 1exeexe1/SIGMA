-- Mode metadata ────────────────────────────────────────────────
-- Per-mode state accessors for zone sync ───────────────────────
-- Returns {origin, sX, sY, sZ, placed} for the given mode
local function _ctoolGetZone(mode)
    if mode=="Construct" then return ct.origin,ct.nbX,ct.nbY,ct.nbZ,ct.placed
    elseif mode=="Brush"     then return br.origin,br.sX,br.sY,br.sZ,br.placed
    elseif mode=="Demolish"  then return dm.origin,dm.sX,dm.sY,dm.sZ,dm.placed
    elseif mode=="Save"      then return sv.origin,sv.sX,sv.sY,sv.sZ,sv.placed
    elseif mode=="Clone"     then
        -- _cloneZoneState is exposed from the Clone do-block (~line 9440)
        if _cloneZoneState then
            return _cloneZoneState.origin,_cloneZoneState.sX,_cloneZoneState.sY,_cloneZoneState.sZ,_cloneZoneState.placed
        end
    end
    -- Zone-less modes or unrecognised: return safe dummy values
    return Vector3.zero,1,1,1,false
end
-- Writes origin/sX/sY/sZ/placed back into the given mode's state
local function _ctoolSetZone(mode, origin, sX, sY, sZ, placed)
    if typeof(origin) ~= "Vector3" then return end
    if mode=="Construct" then
        ct.origin=origin; ct.nbX=sX; ct.nbY=sY; ct.nbZ=sZ; ct.placed=placed
    elseif mode=="Brush" then
        br.origin=origin; br.sX=sX; br.sY=sY; br.sZ=sZ; br.placed=placed
    elseif mode=="Demolish" then
        dm.origin=origin; dm.sX=sX; dm.sY=sY; dm.sZ=sZ; dm.placed=placed
    elseif mode=="Save" then
        sv.origin=origin; sv.sX=sX; sv.sY=sY; sv.sZ=sZ; sv.placed=placed
    elseif mode=="Clone" then
        if _cloneZoneState then
            _cloneZoneState.origin=origin; _cloneZoneState.sX=sX
            _cloneZoneState.sY=sY; _cloneZoneState.sZ=sZ; _cloneZoneState.placed=placed
        end
    end
end

