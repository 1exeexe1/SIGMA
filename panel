local function doClickTP(screenPos)
    local char=lp.Character; local hrp=char and char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    _clickTPRay.FilterDescendantsInstances={char}
    local ray=Workspace.CurrentCamera:ScreenPointToRay(screenPos.X,screenPos.Y)
    local res=Workspace:Raycast(ray.Origin,ray.Direction*2000,_clickTPRay)
    if res then
        -- Use character extents for vertical offset so we land on-surface regardless of avatar size.
        local halfH = char:GetExtentsSize().Y * 0.5 + 0.1
        -- Preserve the HRP's current yaw so the player doesn't snap to face angle 0.
        hrp.CFrame = CFrame.new(res.Position + Vector3.new(0, halfH, 0)) * CFrame.fromMatrix(
            Vector3.new(), hrp.CFrame.RightVector, hrp.CFrame.UpVector)
    end
end

