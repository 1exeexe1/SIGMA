            if missed > 0 then
                notify("Sigma", string.format("Construct: %d brick(s) missed.", missed))
            end
        else
            -- ── Legacy: no brick selected — standard CT_GRID cluster build ──────
            buildChunked(ct.origin, ct.sX, ct.sY, ct.sZ, "normal", btn, nil)
