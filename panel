-- ── helpers ──────────────────────────────────────────────────
-- Extracts a bare numeric Roblox asset ID string from a URL or
-- rbxassetid:// string. Returns nil if nothing found.
local function _dcGetId(str)
    if not str or str=="" then return nil end
    return tostring(str):match("%d%d%d%d%d+")
end

-- Returns the display name of an asset ID via MarketplaceService.
-- Fires asynchronously and stores in S._decalNameCache.
S._decalNameCache = S._decalNameCache or {}
local function _dcFetchName(id, cb)
    local key = tostring(id)
    if S._decalNameCache[key] then cb(S._decalNameCache[key]); return end
    task.spawn(function()
        local ok, info = pcall(function()
            return game:GetService("MarketplaceService"):GetProductInfo(tonumber(id) or 0)
        end)
        local name = (ok and info and info.Name) or ("ID "..key)
        S._decalNameCache[key] = name
        cb(name)
    end)
end

-- Scan all known decal locations and return a list of
-- {label, id, owner, kind} tables.
-- kind = "spray" | "meme" | "protest"
local function _dcScan()
    local results = {}
    local seen = {}

    local function tryLabel(label, owner, kind)
        if not label or not label.Parent then return end
        if seen[label] then return end
        seen[label] = true
        -- Image property (ImageLabel) or Text property (TextLabel with URL)
        local rawId = nil
        if label:IsA("ImageLabel") or label:IsA("ImageButton") then
            rawId = _dcGetId(label.Image)
        elseif label:IsA("TextLabel") or label:IsA("TextButton") then
            rawId = _dcGetId(label.Text)
        end
        if not rawId then
            -- Fallback: check both properties
            pcall(function() rawId = rawId or _dcGetId(label.Image) end)
            pcall(function() rawId = rawId or _dcGetId(label.Text) end)
        end
        if rawId then
            results[#results+1] = {label=label, id=rawId, owner=owner, kind=kind}
        end
    end

    -- 1. workspace.Bricks[username].Brick.Spray.Label (per-player bricks)
    local bricksFolder = Workspace:FindFirstChild("Bricks")
    if bricksFolder then
        for _, userFolder in ipairs(bricksFolder:GetChildren()) do
            local ownerName = userFolder.Name
            -- Named user folder: Bricks[username].Brick.Spray.Label
            local brick = userFolder:FindFirstChild("Brick")
            if brick then
                local spray = brick:FindFirstChild("Spray")
                if spray then
                    local lbl = spray:FindFirstChild("Label")
                    if lbl then tryLabel(lbl, ownerName, "spray") end
                end
            end
            -- Also scan all children generically for Label descendants
            for _, child in ipairs(userFolder:GetChildren()) do
                for _, desc in ipairs(child:GetDescendants()) do
                    if desc.Name == "Label" and (desc:IsA("ImageLabel") or desc:IsA("TextLabel")) then
                        tryLabel(desc, ownerName, "spray")
                    end
                end
            end
        end
        -- Private server: workspace.Bricks.Brick children (no username folder)
        local anonBrick = bricksFolder:FindFirstChild("Brick")
        if anonBrick then
            for _, child in ipairs(anonBrick:GetChildren()) do
                local lbl = child:FindFirstChildOfClass("ImageLabel")
                    or child:FindFirstChildOfClass("TextLabel")
                    or child:FindFirstChild("Label")
                if lbl then tryLabel(lbl, "[anonymous]", "spray") end
            end
        end
    end

    -- 2. workspace.Clones[username].Clone.Meme.Back.Label  (meme decal on clone)
    local clonesFolder = Workspace:FindFirstChild("Clones")
    if clonesFolder then
        for _, userFolder in ipairs(clonesFolder:GetChildren()) do
            local ownerName = userFolder.Name
            for _, child in ipairs(userFolder:GetChildren()) do
                if child:IsA("Model") then
                    local meme = child:FindFirstChild("Meme")
                    if meme then
                        local back = meme:FindFirstChild("Back")
                        if back then
                            local lbl = back:FindFirstChild("Label")
                            if lbl then tryLabel(lbl, ownerName, "meme") end
                        end
                        -- Also scan all label descendants
                        for _, desc in ipairs(meme:GetDescendants()) do
                            if desc.Name=="Label" and (desc:IsA("ImageLabel") or desc:IsA("TextLabel")) then
                                tryLabel(desc, ownerName, "meme")
                            end
                        end
                    end
                end
            end
        end
    end

    -- 3. workspace[username]["The Protest Sign"].Handle.Frame.Spray.Label
    --    Also check Players[username].Backpack["The Protest Sign"]...
    for _, plr in ipairs(Players:GetPlayers()) do
        local uname = plr.Name
        -- In-world protest sign
        local worldUser = Workspace:FindFirstChild(uname)
        if worldUser then
            for _, child in ipairs(worldUser:GetChildren()) do
                if child.Name:lower():find("protest") or child.Name:lower():find("sign") then
                    for _, desc in ipairs(child:GetDescendants()) do
                        if desc.Name=="Label" and (desc:IsA("ImageLabel") or desc:IsA("TextLabel")) then
                            tryLabel(desc, uname, "protest")
                        end
                    end
                end
            end
        end
        -- Backpack protest sign
        local ok, bp = pcall(function() return plr.Backpack end)
        if ok and bp then
            for _, tool in ipairs(bp:GetChildren()) do
                if tool.Name:lower():find("protest") or tool.Name:lower():find("sign") then
                    for _, desc in ipairs(tool:GetDescendants()) do
                        if desc.Name=="Label" and (desc:IsA("ImageLabel") or desc:IsA("TextLabel")) then
                            tryLabel(desc, uname, "protest")
                        end
                    end
                end
            end
        end
        -- Character's equipped protest sign
        local char = plr.Character
        if char then
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") and (tool.Name:lower():find("protest") or tool.Name:lower():find("sign")) then
                    for _, desc in ipairs(tool:GetDescendants()) do
                        if desc.Name=="Label" and (desc:IsA("ImageLabel") or desc:IsA("TextLabel")) then
                            tryLabel(desc, uname, "protest")
                        end
                    end
                end
            end
        end
    end

    return results
end

-- ── Censor / restore helpers ─────────────────────────────────
local _DC_BLANK_IMG = "rbxassetid://0"

local function _dcCensorLabel(label)
    if S._decalCensored[label] then return end   -- already censored
    local orig = {}
    pcall(function() orig.image = label.Image end)
    pcall(function() orig.text  = label.Text  end)
    S._decalCensored[label] = orig
    pcall(function() label.Image = _DC_BLANK_IMG end)
    pcall(function() label.Text  = "" end)
    pcall(function() label.BackgroundColor3 = Color3.fromRGB(0,0,0) end)
    pcall(function() label.BackgroundTransparency = 0 end)
end

local function _dcRestoreLabel(label)
    local orig = S._decalCensored[label]
    if not orig then return end
    S._decalCensored[label] = nil
    pcall(function() if orig.image then label.Image = orig.image end end)
    pcall(function() if orig.text  then label.Text  = orig.text  end end)
    pcall(function() label.BackgroundTransparency = 1 end)
end

-- ── Auto-censor heartbeat ─────────────────────────────────────
local _dcLastScan = 0
local function _dcTick()
    if not S.decalAutoCensor then return end
    local now = tick()
    if (now - _dcLastScan) < 1 then return end
    _dcLastScan = now
    local found = _dcScan()
    local activeLbls = {}
    for _, e in ipairs(found) do
        activeLbls[e.label] = true
        if S._decalBlacklist[e.id] then
            _dcCensorLabel(e.label)
        end
    end
    -- Restore labels that are no longer in the world (auto-cleanup)
    for lbl, _ in pairs(S._decalCensored) do
        if not activeLbls[lbl] then
            pcall(function() _dcRestoreLabel(lbl) end)
        end
    end
end

if S._decalHBConn then S._decalHBConn:Disconnect() end
S._decalHBConn = RunService.Heartbeat:Connect(_dcTick)

-- ── Click-to-select ──────────────────────────────────────────
local _dcMouse    = lp:GetMouse()
local _dcSelLbl   = nil  -- forward ref: UI status label

local function _dcAttachClick()
    if S._decalClickConn then S._decalClickConn:Disconnect(); S._decalClickConn=nil end
    if not S.decalSelectMode then return end
    S._decalClickConn = _dcMouse.Button1Down:Connect(function()
        if not S.decalSelectMode then return end
        local target = _dcMouse.Target
        if not target then return end
        -- Search all scanned decals for one whose label's ancestor is the clicked part
        local found = _dcScan()
        for _, e in ipairs(found) do
            if e.label:IsDescendantOf(target) or e.label == target then
                S._decalSelected      = e.label
                S._decalSelectedOwner = e.owner
                S._decalSelectedId    = e.id
                if _dcSelLbl then
                    _dcSelLbl.Text = "Selected: "..e.owner.." ("..e.kind..") · "..e.id
                end
                _dcFetchName(e.id, function(nm)
                    notify("Decal", "Selected: "..nm.." · ID "..e.id.." ("..e.owner..")")
                end)
                return
            end
        end
        -- Fallback: target itself may be a Label
        local rawId = nil
        pcall(function() rawId = _dcGetId(target.Image) end)
        if not rawId then pcall(function() rawId = _dcGetId(target.Text) end) end
        if rawId then
            S._decalSelected      = target
            S._decalSelectedOwner = target:GetFullName()
            S._decalSelectedId    = rawId
            if _dcSelLbl then _dcSelLbl.Text = "Selected: "..rawId end
            notify("Decal", "Selected decal ID: "..rawId)
        end
    end)
end

