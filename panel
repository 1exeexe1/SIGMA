    end

    -- Phase 3: pick brick2
    if DC.phase == 3 then
        local t = E._mouse.Target
        if not t or not t:IsA("BasePart") or t == Workspace.Terrain then return end
        if t == DC.brick1 then
            notify("De-Grid","Brick2 must be different from Brick1!"); return
        end
        DC.brick2 = t
        DC.phase  = 4
        -- Orange selectionbox on brick2
