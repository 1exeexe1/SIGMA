-- ── SIGMA TOAST NOTIFY ───────────────────────────────────────────
-- Replaces StarterGui:SetCore notifications with a custom themed
-- toast stack. Returns a handle table with :update(title,text) and
-- :dismiss() so callers can mutate live toasts (e.g. Enlighten Log).
-- The global notify(title,text,duration?) fires a one-shot toast.
do
    local _toastStack   = {}          -- ordered list of active toast frames
    local _TOAST_W      = 240         -- toast width  (px)
    local _TOAST_H      = 52          -- toast height (px)
    local _TOAST_PAD    = 6           -- gap between toasts (px)
    local _TOAST_RIGHT  = 10          -- margin from right edge
    local _TOAST_BOTTOM = 68          -- margin from bottom edge (above hotbar)
    local _TOAST_DUR    = 4           -- default display seconds
    local _TOAST_FADE   = 0.35        -- fade-out duration

    local function _reflow()
        local y = _TOAST_BOTTOM
        for i = #_toastStack, 1, -1 do
            local f = _toastStack[i]
            if f and f.Parent then
                local tgt = UDim2.new(1, -(_TOAST_W + _TOAST_RIGHT), 1, -(y + _TOAST_H))
                pcall(function()
                    TweenService:Create(f,
                        TweenInfo.new(0.12, Enum.EasingStyle.Quad),
                        {Position = tgt}):Play()
                end)
                y = y + _TOAST_H + _TOAST_PAD
            else
                table.remove(_toastStack, i)
            end
        end
    end

    local function _makeToast(title, text, duration)
        if S.notifyOn == false then return {update=function()end,dismiss=function()end} end
        duration = duration or _TOAST_DUR

        local f = Instance.new("Frame")
        f.Name            = "SigmaToast"
        f.Size            = UDim2.new(0, _TOAST_W, 0, _TOAST_H)
        f.Position        = UDim2.new(1, 10, 1, -(_TOAST_BOTTOM + _TOAST_H))
        f.BackgroundColor3= T.BG
        f.BorderSizePixel = 0
        f.ZIndex          = 200
        f.ClipsDescendants= true
        f.Parent          = ScreenGui
        local bar = Instance.new("Frame")
        bar.Size              = UDim2.new(0, 3, 1, 0)
        bar.BackgroundColor3  = T.ACCENT
        bar.BorderSizePixel   = 0
        bar.ZIndex            = 201
        bar.Parent            = f
        onTheme(function(th)
            if f.Parent then f.BackgroundColor3 = th.BG end
            if bar.Parent then bar.BackgroundColor3 = th.ACCENT end
        end)
        local stroke = Instance.new("UIStroke", f)
        stroke.Color     = T.ACCENT
        stroke.Thickness = 1
        onTheme(function(th) if stroke.Parent then stroke.Color = th.ACCENT end end)
        local tLbl = Instance.new("TextLabel")
        tLbl.Size                = UDim2.new(1, -20, 0, 18)
        tLbl.Position            = UDim2.new(0, 10, 0, 4)
        tLbl.BackgroundTransparency = 1
        tLbl.Text                = tostring(title or "Sigma")
        tLbl.TextColor3          = T.ACCENT
        tLbl.FontFace            = FONT_MAIN
        tLbl.TextSize            = 12
        tLbl.TextXAlignment      = Enum.TextXAlignment.Left
        tLbl.TextTruncate        = Enum.TextTruncate.AtEnd
        tLbl.ZIndex              = 202
        tLbl.Parent              = f
        onTheme(function(th) if tLbl.Parent then tLbl.TextColor3 = th.ACCENT end end)
        local bLbl = Instance.new("TextLabel")
        bLbl.Size                = UDim2.new(1, -20, 0, 26)
        bLbl.Position            = UDim2.new(0, 10, 0, 22)
        bLbl.BackgroundTransparency = 1
        bLbl.Text                = tostring(text or "")
        bLbl.TextColor3          = T.TXT
        bLbl.FontFace            = FONT_SS
        bLbl.TextSize            = 11
        bLbl.TextXAlignment      = Enum.TextXAlignment.Left
        bLbl.TextWrapped         = true
        bLbl.TextTruncate        = Enum.TextTruncate.AtEnd
        bLbl.ZIndex              = 202
        bLbl.Parent              = f
        onTheme(function(th) if bLbl.Parent then bLbl.TextColor3 = th.TXT end end)

        table.insert(_toastStack, f)
        _reflow()

        pcall(function()
            TweenService:Create(f,
                TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Position = UDim2.new(1, -(_TOAST_W + _TOAST_RIGHT),
                                      1, -(_TOAST_BOTTOM + _TOAST_H))}):Play()
        end)

        local dismissed = false
        local function dismiss()
            if dismissed then return end
            dismissed = true
            -- Slide out to the right, then destroy
            pcall(function()
                local tw = TweenService:Create(f,
                    TweenInfo.new(_TOAST_FADE, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    {Position = UDim2.new(1, 10, f.Position.Y.Scale, f.Position.Y.Offset),
                     BackgroundTransparency = 1})
                tw:Play()
                tw.Completed:Connect(function()
                    for i, v in ipairs(_toastStack) do
                        if v == f then table.remove(_toastStack, i); break end
                    end
                    pcall(function() f:Destroy() end)
                    _reflow()
                end)
            end)
        end

        local handle = {
            update = function(_, newTitle, newText)
                if f.Parent then
                    if newTitle then tLbl.Text = tostring(newTitle) end
                    if newText  then bLbl.Text = tostring(newText)  end
                end
            end,
            dismiss = dismiss,
        }

        task.delay(duration, dismiss)
        return handle
    end

    -- Fill the forward-declared upvalue
    notify = function(title, text, duration)
        _makeToast(title, text, duration)
    end
    -- Expose richer handle version for live-update callers
    shared.sigmaToast = _makeToast
end

