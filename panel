local g4 = makeGroup(radPage, "4 — Core → Warhead", "Uncollides core, stacks 25 bricks in same space. Takes ~13s.")

makeButton(g4, "Core \226\134\146 Warhead", function(btn)
    if RAD.busy then radStatus("Busy!"); return end
    local core = RAD.coreBrick
    if not core or not core.Parent then
        radStatus("No core \226\128\148 run Brick->Core first!"); return
    end
    RAD.busy = true

    task.spawn(function()
        -- Save safe position BEFORE camera shift or any teleport.
        local _safePosWarhead = nil
        do
            local _spw = lp.Character
            local _swh = _spw and _spw:FindFirstChild("HumanoidRootPart")
            if _swh then _safePosWarhead = _swh.CFrame end
        end

        setCamToSpawn(true)
        local ov = makeRadOverlay("Core \226\134\146 Warhead", 25, nil)

        radStatus("Uncolliding core...")
        setCollide(core)   -- toggle: core is currently colliding \226\134\146 now off
        task.wait(0.2)

        -- Pin the core so it stays in place while buildOffFace teleports the player.
        -- Network ownership is claimed inside pinBrick(); no separate bump needed.
        pinBrick(core)

        for i = 1, 25 do
            if btn and btn.Parent then
                btn.Text = string.format("Stack %d/25...", i)
            end
            radStatus(string.format("Stacking %d / 25...", i))
            ov:setProgress(i - 1, 25)
            buildOffFace(core, Enum.NormalId.Front)
            task.wait(0.3)
        end

        -- Unpin before deleting so the BodyPosition/BodyGyro are cleaned up.
        unpinBrick()

        -- Delete the side-built core brick — it fulfilled its purpose
        -- (radiation is now on all 25 stacked bricks)
        deleteBrick(core)
        task.wait(0.4)

        -- Auto-select one of the stacked warhead bricks as the warhead position
        -- anchor. The core brick was deleted; find the nearest surviving brick
        -- in our folder close to core.Position to use as the position reference.
        local corePos = core.Position
        local myF = getMyBrickFolder()
        local bestBrick = nil
        local bestDist  = math.huge
        if myF then
            for _, child in ipairs(myF:GetChildren()) do
                if child:IsA("BasePart") and child ~= core and child.Parent then
                    local d = (child.Position - corePos).Magnitude
                    if d < bestDist then
                        bestDist  = d
                        bestBrick = child
                    end
                end
            end
        end

        if bestBrick and bestDist < 20 then
            RAD.warheadPos  = bestBrick.Position
            S.radWarheadPos = RAD.warheadPos
            -- Highlight the auto-selected warhead brick with the selection box.
            if _radSelectSB then _radSelectSB:Destroy() end
            _radSelectSB = Instance.new("SelectionBox")
            _radSelectSB.Adornee            = bestBrick
            _radSelectSB.Color3             = Color3.fromRGB(255, 80, 0)
            _radSelectSB.LineThickness      = 0.06
            _radSelectSB.SurfaceColor3      = Color3.fromRGB(255, 80, 0)
            _radSelectSB.SurfaceTransparency= 0.7
            _radSelectSB.Parent             = Workspace
        else
            -- Fallback: use the recorded core position (brick may have replicated late)
            RAD.warheadPos  = corePos
            S.radWarheadPos = RAD.warheadPos
        end

        ov:setProgress(25, 25)
        ov:destroy()
        radStatus("Warhead ready at "
            .. math.round(RAD.warheadPos.X)
            .. ", " .. math.round(RAD.warheadPos.Y)
            .. ", " .. math.round(RAD.warheadPos.Z))
        setCamToSpawn(false)
        -- Restore player to safe position (far from warhead).
        if _safePosWarhead then
            local _rw = lp.Character
            local _rwh = _rw and _rw:FindFirstChild("HumanoidRootPart")
            if _rwh then _rwh.CFrame = _safePosWarhead end
        end
        RAD.busy = false
    end)
end)


