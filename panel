-- ═══ DE-GRID TOOL  (floating menu, Move+Rotate extension) ══════
-- ═══════════════════════════════════════════════════════════════
local dgTool = Instance.new("Tool")
dgTool.Name="DeGrid"; dgTool.RequiresHandle=false; dgTool.CanBeDropped=false
dgTool.ToolTip="Sigma De-Grid"

do -- ╔═ DE-GRID TOOL INTERNALS ══╗

-- ── Capability checks ─────────────────────────────────────────
local _hasSetHidden = false
pcall(function() _hasSetHidden = (typeof(sethiddenproperty) == "function") end)

-- ── Physics power ─────────────────────────────────────────────
local _DG_P = 999999

-- ── State ─────────────────────────────────────────────────────
local E = {
    brick       = nil,
    selectArmed = false,
    moveMode    = false,
    rotateMode  = false,
    bodyPos     = nil,
    bodyGyro    = nil,
    bodyVel     = nil,
    dragStartRX = 0, dragStartRY = 0, dragStartRZ = 0,
    rotX = 0, rotY = 0, rotZ = 0,
    gridSnap   = 1,
    roundAngle = 15,
    _mouse     = lp:GetMouse(),
    statusLbl  = nil,
    xBox = nil, yBox = nil, zBox = nil,
    _setMoveTog    = nil,
    _setRotateTog  = nil,
    _selBrickSet   = nil,
    selBox         = nil,
    equipped       = false,
    -- Collision toggle: when true the Heartbeat loop sets E.brick.CanCollide=false
    -- locally every frame. No remote is ever fired — the server never sees this,
    -- so anchor/collide remotes are completely unaffected. applyAnchor() restores
    -- CanCollide=true locally before firing the anchor remote so the brick ends
    -- up solid after anchoring.
    collideOff     = false,
    _setCollideTog = nil,
    -- Desired CFrame for drift detection: set by installPhysics and updated by
    -- move/rotate handlers. The ownership guard uses this to decide if the brick
    -- has been knocked off position by physics or another player.
    desiredCF      = nil,
    -- Ownership guard clock: last time we re-claimed ownership due to drift.
    _ownerLastT    = 0,
}

if _hasSetHidden then
    pcall(function() sethiddenproperty(lp,"SimulationRadius",500) end)
end

-- ── SelectionBox ──────────────────────────────────────────────
E.selBox = Instance.new("SelectionBox")
E.selBox.Color3              = Color3.fromRGB(255,140,0)
E.selBox.SurfaceColor3       = Color3.fromRGB(255,140,0)
E.selBox.SurfaceTransparency = 0.88
E.selBox.LineThickness       = 0.06
E.selBox.Adornee             = nil
E.selBox.Parent              = ScreenGui

-- ── Move Handles ──────────────────────────────────────────────
local eMoveHandles     = Instance.new("Handles")
eMoveHandles.Style     = Enum.HandlesStyle.Movement
eMoveHandles.Faces     = Faces.new(
    Enum.NormalId.Top,   Enum.NormalId.Bottom,
    Enum.NormalId.Front, Enum.NormalId.Back,
    Enum.NormalId.Left,  Enum.NormalId.Right)
eMoveHandles.Adornee   = nil
-- Parent to ScreenGui: renders handles as screen-space overlays that are
-- ALWAYS visible and ALWAYS interactable regardless of geometry in front.
-- This is the correct fix for "can't interact through bricks" — no depth
-- occlusion occurs for GUI-parented adorns.
eMoveHandles.Parent    = ScreenGui

-- ── ArcHandles ────────────────────────────────────────────────
local eArcHandles   = Instance.new("ArcHandles")
eArcHandles.Axes    = Axes.new(Enum.Axis.X, Enum.Axis.Y, Enum.Axis.Z)
eArcHandles.Adornee = nil
eArcHandles.Parent  = ScreenGui

-- ── Selection highlight — shows WHICH brick is selected through walls ──
-- A single Highlight with AlwaysOnTop gives the adornee brick an X-ray
-- outline so the user always knows what they're moving/rotating.
local eHandleHL = Instance.new("Highlight")
eHandleHL.Name                = "SigmaHandleHL"
eHandleHL.FillTransparency    = 1          -- no fill, just outline
eHandleHL.OutlineColor        = Color3.fromRGB(255, 165, 0)
eHandleHL.OutlineTransparency = 0
eHandleHL.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
eHandleHL.Enabled             = false
eHandleHL.Adornee             = nil
eHandleHL.Parent              = ScreenGui

-- ── Helpers ───────────────────────────────────────────────────
local function readCFrame()
    if not E.brick or not E.brick.Parent then return end
    local rx,ry,rz = E.brick.CFrame:ToEulerAnglesYXZ()
    E.rotX = math.round(math.deg(rx))
    E.rotY = math.round(math.deg(ry))
    E.rotZ = math.round(math.deg(rz))
    if E.xBox then E.xBox.Text = tostring(E.rotX) end
    if E.yBox then E.yBox.Text = tostring(E.rotY) end
    if E.zBox then E.zBox.Text = tostring(E.rotZ) end
end

local function roundAng(deg, by)
    return math.round(deg / by) * by
end

local function setRotation(rx, ry, rz)
    E.rotX = rx; E.rotY = ry; E.rotZ = rz
    if E.xBox then E.xBox.Text = tostring(rx) end
    if E.yBox then E.yBox.Text = tostring(ry) end
    if E.zBox then E.zBox.Text = tostring(rz) end
    if E.bodyGyro then
        local newRot = CFrame.fromEulerAnglesYXZ(
            math.rad(rx), math.rad(ry), math.rad(rz))
        E.bodyGyro.CFrame = newRot
        -- Update desiredCF so drift detection uses the new intended rotation
        if E.brick and E.bodyPos then
            E.desiredCF = newRot + E.bodyPos.Position
        end
    end
end

local function syncHandles()
    if not E.brick or not E.brick.Parent then return end
    E.selBox.Adornee     = E.brick
    eMoveHandles.Adornee = E.moveMode   and E.brick or nil
    eArcHandles.Adornee  = E.rotateMode and E.brick or nil
    -- Drive the AlwaysOnTop selection highlight
    local showHL = (E.moveMode or E.rotateMode) and E.brick ~= nil
    eHandleHL.Adornee = showHL and E.brick or nil
    eHandleHL.Enabled = showHL
end

local function setMoveMode(on)
    E.moveMode = on
    eMoveHandles.Adornee = on and E.brick or nil
    syncHandles()
end

local function setRotateMode(on)
    E.rotateMode = on
    eArcHandles.Adornee = on and E.brick or nil
    syncHandles()
end

local function installPhysics(brick)
    if E.bodyPos  then pcall(function() E.bodyPos:Destroy()  end) end
    if E.bodyGyro then pcall(function() E.bodyGyro:Destroy() end) end
    if E.bodyVel  then pcall(function() E.bodyVel:Destroy()  end) end

    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(_DG_P,_DG_P,_DG_P)
    bp.P = _DG_P; bp.D = 2500
    bp.Position = brick.Position
    bp.Parent = brick
    E.bodyPos = bp

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(_DG_P,_DG_P,_DG_P)
    bg.P = _DG_P; bg.D = 6200
    bg.CFrame = brick.CFrame
    bg.Parent = brick
    E.bodyGyro = bg

    -- Record desired CFrame baseline for drift detection
    E.desiredCF = brick.CFrame

    -- No BodyVelocity: BodyPosition at P=999999 overcomes gravity on its own.
    -- A BodyVelocity(MaxForce Y=huge, Velocity=0) would zero out all upward
    -- velocity every physics step, completely cancelling upward handle movement.

    readCFrame(); syncHandles()
end

local function removePhysics()
    if E.bodyPos  then pcall(function() E.bodyPos:Destroy()  end); E.bodyPos  = nil end
    if E.bodyGyro then pcall(function() E.bodyGyro:Destroy() end); E.bodyGyro = nil end
    if E.bodyVel  then pcall(function() E.bodyVel:Destroy()  end); E.bodyVel  = nil end
end

local function fullCleanup()
    removePhysics()
    E.brick = nil
    E.selBox.Adornee     = nil
    eArcHandles.Adornee  = nil
    eMoveHandles.Adornee = nil
    eHandleHL.Adornee    = nil
    eHandleHL.Enabled    = false
    if E._selBrickSet  then E._selBrickSet(false,  "Select Brick") end
    if E._setMoveTog   then E._setMoveTog(false,   "Move Brick")   end
    if E._setRotateTog then E._setRotateTog(false, "Rotate Brick") end
    -- Reset collide flag. No remote needed — suppression was local-only.
    E.collideOff = false
    if E._setCollideTog then E._setCollideTog(false, "No Collision") end
    E.selectArmed = false; E.moveMode = false; E.rotateMode = false
    if E.statusLbl then
        E.statusLbl.Text       = "No brick selected"
        E.statusLbl.TextColor3 = Color3.fromRGB(160,160,160)
    end
end

-- ── applyOffsetOnly ───────────────────────────────────────────
-- Phase 1 of the new two-step flow.
-- Flow: delete original → build replacement → claim network ownership
--       → CFrame-teleport to exact off-grid position → auto-select new brick.
-- Does NOT anchor. The player then moves/rotates further before calling
-- applyAnchor() when satisfied.
local function applyOffsetOnly()
    if not E.brick or not E.brick.Parent then return false end
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local bEv = getToolRemote("Build")
    local dEv = getToolRemote("Delete")
    if not bEv or not dEv then return false end

    -- Snapshot the exact target CFrame while BodyPosition still holds it
    local finalCF = E.brick.CFrame
    if E.bodyPos then E.bodyPos.Position = finalCF.Position end
    task.wait(0.05)
    -- Re-read after settle to capture any last BodyPosition corrections
    finalCF = E.brick.CFrame

    -- Pick face whose world normal points most downward (best build surface)
    local bestFace = Enum.NormalId.Bottom
    local bestDot  = -math.huge
    local faceNorms = {
        [Enum.NormalId.Top]    = Vector3.new( 0, 1, 0),
        [Enum.NormalId.Bottom] = Vector3.new( 0,-1, 0),
        [Enum.NormalId.Front]  = Vector3.new( 0, 0,-1),
        [Enum.NormalId.Back]   = Vector3.new( 0, 0, 1),
        [Enum.NormalId.Left]   = Vector3.new(-1, 0, 0),
        [Enum.NormalId.Right]  = Vector3.new( 1, 0, 0),
    }
    for face, localNorm in pairs(faceNorms) do
        local worldNorm = (finalCF - finalCF.Position):VectorToWorldSpace(localNorm)
        local dot = worldNorm:Dot(Vector3.new(0,-1,0))
        if dot > bestDot then bestDot = dot; bestFace = face end
    end

    local snapPos = finalCF.Position
    removePhysics()   -- destroy BodyPosition/Gyro before delete
    task.wait(0.05)

    -- Watch for the new (off-grid) brick in our folder
    local bf = getBricksFolder()
    local myF = bf and bf:FindFirstChild(lp.Name)
    local newBrick = nil; local conn
    if myF then
        conn = myF.ChildAdded:Connect(function(c)
            if c:IsA("BasePart") then newBrick = c end
        end)
    end

    local targetBrick = E.brick
    dEv:FireServer(targetBrick, hrp.Position)
    task.wait(0.08)
    bEv:FireServer(targetBrick, bestFace, snapPos, "normal")
    local deadline = tick() + 2.5
    repeat task.wait(0.04) until newBrick or tick() > deadline
    if conn then conn:Disconnect() end
    if not newBrick then return false end

    -- ── Ownership claim + CFrame precision placement ───────────────
    -- Bump SimulationRadius so the server grants us network ownership,
    -- then CFrame-teleport the new brick to the exact saved off-grid position.
    pcall(function()
        if typeof(sethiddenproperty) == "function" then
            sethiddenproperty(lp, "SimulationRadius", 9e9)
        end
    end)
    -- Short wait: server replicates the new brick; ownership races to us
    task.wait(0.12)

    -- Force-set CFrame to the off-grid position (ownership required)
    pcall(function() newBrick.CFrame = finalCF end)
    task.wait(0.06)

    -- Restore SimulationRadius to normal
    pcall(function()
        if typeof(sethiddenproperty) == "function" then
            sethiddenproperty(lp, "SimulationRadius", 500)
        end
    end)

    -- ── Auto-select the new off-grid brick ────────────────────────
    -- Clear previous state then immediately lock onto the new brick so
    -- the player can move/rotate/anchor without an extra click.
    fullCleanup()
    E.brick = newBrick
    installPhysics(newBrick)
    E.selBox.Adornee = newBrick
    if E.statusLbl then
        E.statusLbl.Text       = "Off-grid \226\156\147 Move/Rotate, then Apply Anchor"
        E.statusLbl.TextColor3 = Color3.fromRGB(0,220,120)
    end
    notify("De-Grid","\226\172\161 Off-grid brick ready \226\128\148 adjust, then Apply Anchor.")
    return true
end

-- ── applyAnchor ───────────────────────────────────────────────
-- Phase 2 of the new two-step flow.
-- Anchors E.brick in its current CFrame via the Paint remote.
-- Call this once the player is happy with the position & rotation.
local function applyAnchor()
    if not E.brick or not E.brick.Parent then return false end
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local ev = getToolRemote("Paint")
    if not ev then return false end

    -- Claim ownership FIRST and hold it for the ENTIRE anchor sequence.
    -- Restoring SimulationRadius before FireServer creates a race window where
    -- gravity or other players can displace the brick between the CFrame write
    -- and the server seeing the anchor remote. We keep 9e9 until after FireServer.
    if _hasSetHidden then
        pcall(function() sethiddenproperty(lp, "SimulationRadius", 9e9) end)
    end

    -- Freeze both constraints at exact current location
    local finalCF = E.brick.CFrame
    if E.bodyPos  then E.bodyPos.Position  = finalCF.Position end
    if E.bodyGyro then E.bodyGyro.CFrame   = finalCF - finalCF.Position end
    task.wait(0.05)
    -- Re-read after settle (ownership already held, result is stable)
    finalCF = E.brick.CFrame
    -- Lock desiredCF so the Heartbeat guard does not fight this write
    E.desiredCF = finalCF

    -- Precision CFrame write with ownership held -- no race window
    pcall(function() E.brick.CFrame = finalCF end)
    task.wait(0.04)

    -- Fire anchor remote -- SimulationRadius is STILL 9e9 here
    ev:FireServer(E.brick, Enum.NormalId.Front, hrp.Position,
        HANDSHAKE, Color3.new(1,1,1), "anchor", "")
    task.wait(0.08)

    -- NOW restore -- remote has been sent, race window closed
    if _hasSetHidden then
        pcall(function() sethiddenproperty(lp, "SimulationRadius", 500) end)
    end

    -- Restore local CanCollide so the anchored brick is solid.
    if E.collideOff then
        pcall(function() E.brick.CanCollide = true end)
    end

    notify("De-Grid","\226\156\147 Off-grid brick anchored at "
        ..math.round(E.brick.Position.X)..","  
        ..math.round(E.brick.Position.Y)..","  
        ..math.round(E.brick.Position.Z))
    fullCleanup()
    return true
end

-- ── Move Handle events ────────────────────────────────────────
-- FIX: Handles.MouseDrag gives 'distance' as a signed scalar already
-- measured along the handle's own direction in world space.
-- We get the face's world-space normal from the brick's live CFrame,
-- then multiply that unit vector by distance. This fixes:
--   • Up/Down (Top/Bottom) not moving — their local Y is world Y only
--     when the brick is unrotated; for a rotated brick we must transform.
--   • Left/Right/Front/Back being reversed — CT_NORM_VEC pointed the
--     wrong way for negative faces; now we derive direction from CFrame.
-- FIX 2: snap is relative to drag start, not current position, so
-- sub-stud snapping (0.1 stud) doesn't accumulate floating-point drift.
local _mvStartPos   = nil
local _mvFaceNorm   = nil   -- world-space unit vector for the dragged face

-- Face local offsets: the direction each NormalId points in object space
local _faceLocalDir = {
    [Enum.NormalId.Top]    = Vector3.new( 0, 1, 0),
    [Enum.NormalId.Bottom] = Vector3.new( 0,-1, 0),
    [Enum.NormalId.Right]  = Vector3.new( 1, 0, 0),
    [Enum.NormalId.Left]   = Vector3.new(-1, 0, 0),
    [Enum.NormalId.Back]   = Vector3.new( 0, 0, 1),
    [Enum.NormalId.Front]  = Vector3.new( 0, 0,-1),
}

eMoveHandles.MouseButton1Down:Connect(function(face)
    if not E.moveMode or not E.brick or not E.brick.Parent then return end
    _mvStartPos = E.brick.Position
    -- Derive the actual world-space direction from the brick's live CFrame
    local localDir = _faceLocalDir[face] or Vector3.new(0,1,0)
    _mvFaceNorm = E.brick.CFrame:VectorToWorldSpace(localDir).Unit
end)

eMoveHandles.MouseDrag:Connect(function(face, distance)
    if not E.moveMode or not E.brick or not E.brick.Parent then return end
    if not _mvStartPos or not _mvFaceNorm then return end
    -- Snap relative to drag start to avoid float drift at small grid sizes
    local snapped = math.round(distance / E.gridSnap) * E.gridSnap
    local newPos  = _mvStartPos + _mvFaceNorm * snapped
    if E.bodyPos then
        E.bodyPos.Position = newPos
        -- Keep desiredCF in sync so drift guard won't fight the user's drag
        if E.desiredCF then
            E.desiredCF = (E.desiredCF - E.desiredCF.Position) + newPos
        end
    end
end)

eMoveHandles.MouseButton1Up:Connect(function()
    -- Final snap relative to world grid at current gridSnap
    if E.brick and E.brick.Parent and E.bodyPos then
        local p = E.bodyPos.Position
        local g = math.max(0.01, E.gridSnap)
        local snappedPos = Vector3.new(
            math.round(p.X/g)*g,
            math.round(p.Y/g)*g,
            math.round(p.Z/g)*g)
        E.bodyPos.Position = snappedPos
        -- Lock desired position to snapped grid position
        if E.desiredCF then
            E.desiredCF = (E.desiredCF - E.desiredCF.Position) + snappedPos
        end
    end
    _mvStartPos = nil; _mvFaceNorm = nil
    task.wait(0.05); readCFrame()
end)

-- ── Rotate Handle events ──────────────────────────────────────
eArcHandles.MouseButton1Down:Connect(function(axis)
    if not E.rotateMode or not E.brick or not E.brick.Parent then return end
    E.dragStartRX = E.rotX; E.dragStartRY = E.rotY; E.dragStartRZ = E.rotZ
    pcall(function() eArcHandles.Axes = Axes.new(axis) end)
end)

eArcHandles.MouseDrag:Connect(function(axis, relativeAngle)
    if not E.rotateMode or not E.brick or not E.brick.Parent then return end
    local delta = roundAng(math.deg(relativeAngle), E.roundAngle)
    local nX,nY,nZ = E.dragStartRX, E.dragStartRY, E.dragStartRZ
    if     axis == Enum.Axis.X then nX = roundAng(E.dragStartRX+delta, E.roundAngle)
    elseif axis == Enum.Axis.Y then nY = roundAng(E.dragStartRY+delta, E.roundAngle)
    elseif axis == Enum.Axis.Z then nZ = roundAng(E.dragStartRZ+delta, E.roundAngle)
    end
    setRotation(nX,nY,nZ)
end)

eArcHandles.MouseButton1Up:Connect(function()
    pcall(function() eArcHandles.Axes = Axes.new(Enum.Axis.X,Enum.Axis.Y,Enum.Axis.Z) end)
    task.wait(0.05); readCFrame()
end)

-- ═══════════════════════════════════════════════════════════════
-- ── DETAILED CORNER SNAP ─────────────────────────────────────
-- State machine: B1 select → C1 pick → B2 select → C2 pick → Connect
-- ═══════════════════════════════════════════════════════════════
local DC = {
    phase      = 0,    -- 0=idle 1=pickB1 2=pickC1 3=pickB2 4=pickC2 5=ready
    brick1     = nil,  -- unanchored brick
    brick2     = nil,  -- target brick (anchored optional)
    corner1    = nil,  -- Vector3 world pos
    corner2    = nil,
    dots1      = {},   -- neon sphere parts for brick1 corners
    dots2      = {},   -- neon sphere parts for brick2 corners
    beamPart1  = nil,  -- Attachment holder
    beamPart2  = nil,
    beam       = nil,
    selBox2    = nil,  -- orange box around brick2
    phaseLbl   = nil,  -- status label ref (set below)
    btn        = nil,  -- main button ref (set below)
    alignMode  = "Direction",  -- "Direction" (rotate only) or "Snap" (translate)
}

local function dcSetPhaseText(t, col)
    if DC.phaseLbl then
        DC.phaseLbl.Text       = t
        DC.phaseLbl.TextColor3 = col or Color3.fromRGB(140,140,140)
    end
    if DC.btn then DC.btn.Text = t end
end

-- Remove all corner spheres for a set
local function dcClearDots(dots)
    for _,p in ipairs(dots) do pcall(function() p:Destroy() end) end
    table.clear(dots)
end

-- Remove the blue beam
local function dcClearBeam()
    if DC.beam      then pcall(function() DC.beam:Destroy()      end); DC.beam      = nil end
    if DC.beamPart1 then pcall(function() DC.beamPart1:Destroy() end); DC.beamPart1 = nil end
    if DC.beamPart2 then pcall(function() DC.beamPart2:Destroy() end); DC.beamPart2 = nil end
