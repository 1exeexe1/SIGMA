    local row = Instance.new("Frame")
    row.Name = "TSHeader"; row.Size = UDim2.new(1,0,0,20)
    row.BackgroundTransparency = 1; row.ZIndex = 8
    row.LayoutOrder = 0; row.Parent = container

    -- Reddit-tree layout: expand arrow on far left, tick after it, label fills rest
    local arrowBtn = Instance.new("TextButton")
