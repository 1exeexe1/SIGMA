                        for _,d in ipairs(sideDecals) do
                            local lbl=d:FindFirstChildWhichIsA("TextLabel")
                            if lbl and lbl.Text:match("^#+$") then isTagged=true; break end
                            if d:IsA("Decal") and (d.Texture or ""):match("^#+$") then isTagged=true; break end
                        end
                        -- Fallback: check if a SurfaceAppearance label looks like tags
                        if not isTagged then
                            -- Check via a quick re-spray and trust pass count
                        else
                            -- Re-apply font strategy 3 times on this side
                            local r2=math.floor(data.color.R*255)
                            local g2=math.floor(data.color.G*255)
                            local b2=math.floor(data.color.B*255)
                            local hex2=string.format("%02X%02X%02X",r2,g2,b2)
                            local styled2=string.format('<font color="#%s">%s</font>',hex2,data.text)
                            for _=1,3 do
                                ev:FireServer(brick,data.side,hrp.Position,HANDSHAKE,data.color,"spray",styled2)
                                task.wait(0.1)
                            end
                            anyFixed=true
                        end
                    end
                    if not anyFixed then break end
                end
            end)
        end
        notify("Sigma","Applied text!")
    end)
    makeToggle(g,"Check for Tags",function(on) S.opCheckTags=on end,false,
        "If a face shows as tags (######), re-sprays it up to 3 passes.")
end

