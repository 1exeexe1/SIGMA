-- Pin selected brick in-place: BodyPosition + BodyGyro at P=999999 (de-grid style).
-- Also sets brick.Anchored = true LOCALLY so the server never sees the anchor flag
-- change, but local physics are locked by the BodyPosition. This prevents the brick
-- from drifting without firing the Paint anchor-toggle remote (which would fight the pin).
-- Rule 5: sethiddenproperty guarded by typeof check.
local _RAD_PIN_P = 999999
local function pinBrick(brick)
    if not brick or not brick.Parent then return end
    if RAD.pinBP then pcall(function() RAD.pinBP:Destroy() end); RAD.pinBP = nil end
    if RAD.pinBG then pcall(function() RAD.pinBG:Destroy() end); RAD.pinBG = nil end
    -- Claim network ownership so local physics writes replicate
    pcall(function()
        if typeof(sethiddenproperty) == "function" then
            sethiddenproperty(lp, "SimulationRadius", 9e9)
        end
    end)
    task.wait(0.15)
    -- Anchor locally so the brick is locked in place on our client.
    -- This does NOT fire the server anchor remote — the brick stays
    -- unanchored server-side (required for radiation transfer).
    brick.Anchored = true
    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(_RAD_PIN_P, _RAD_PIN_P, _RAD_PIN_P)
    bp.P        = _RAD_PIN_P; bp.D = 2500
    bp.Position = brick.Position
    bp.Parent   = brick
    RAD.pinBP   = bp
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(_RAD_PIN_P, _RAD_PIN_P, _RAD_PIN_P)
    bg.P         = _RAD_PIN_P; bg.D = 6200
    bg.CFrame    = brick.CFrame
    bg.Parent    = brick
    RAD.pinBG    = bg
    pcall(function()
        if typeof(sethiddenproperty) == "function" then
            sethiddenproperty(lp, "SimulationRadius", 500)
        end
    end)
end

-- Remove BodyPosition/BodyGyro pin and release local anchor from the brick.
local function unpinBrick(brick)
    if RAD.pinBP then
        local b = RAD.pinBP.Parent   -- recover brick ref from the BodyPosition
        pcall(function() RAD.pinBP:Destroy() end); RAD.pinBP = nil
        -- Release the local Anchored flag so setAnchor remote takes effect
        if b and b.Parent then pcall(function() b.Anchored = false end) end
    end
    if RAD.pinBG then pcall(function() RAD.pinBG:Destroy() end); RAD.pinBG = nil end
    -- Also accept an explicit brick arg for safety
    if brick and brick.Parent then pcall(function() brick.Anchored = false end) end
end

