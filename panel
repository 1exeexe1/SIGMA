    task.spawn(function()
        if ct.selectedBrick and ct.selectedBrick.Parent then
            -- ── BFS + faceattach seeded from the selected brick ─────────────────
            -- Generate one position per brick cell in the zone, spaced by
            -- brickStepX/Y/Z so the server copies the selected brick's shape.
            local posList = {}
            for iy = 0, ct.nbY - 1 do
                for ix = 0, ct.nbX - 1 do
                    for iz = 0, ct.nbZ - 1 do
                        posList[#posList+1] = ct.origin + Vector3.new(
