    local _,_,setLaserToggle = makeToggle(attacksPage, "Toggle Laser", function(on)
        if on then
            if _laserActive then return end
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then
                notify("Attacks","No character.")
                task.defer(function() if setLaserToggle then setLaserToggle(false) end end)
                return
            end
            local excl = {}
            for _, inst in pairs(_activeRings) do
                for _, p in ipairs(inst.parts or {}) do excl[p] = true end
            end
            local pool = _ringGetSourceBricks(_laserSource, excl)
            if #pool == 0 then
                notify("Attacks","No free bricks for laser.")
                task.defer(function() if setLaserToggle then setLaserToggle(false) end end)
                return
            end
            _ringBumpOwnership()
            task.wait(0.05)
            for _, b in ipairs(pool) do
                _laserPartsWereAnchored[b] = b.Anchored
                _laserParts[#_laserParts+1] = b
            end
            _laserActive = true
            laserStatusLbl.Text = "Laser: active O " .. #_laserParts .. "x"
            _laserConn = RunService.Heartbeat:Connect(function()
                if not _laserActive then return end
                local h = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not h then return end
                local n = #_laserParts
                if n == 0 then return end
                local spacing = _laserLen / math.max(n,1)
                for i, p in ipairs(_laserParts) do
                    if p and p.Parent then
                        local dist = spacing * i
                        local pos  = h.Position + h.CFrame.LookVector * dist
                        pcall(function()
                            p.AssemblyLinearVelocity  = Vector3.zero
                            p.AssemblyAngularVelocity = Vector3.zero
                            p.CFrame = CFrame.new(pos)
                        end)
                    end
                end
            end)
        else
            _laserActive = false
            if _laserConn then _laserConn:Disconnect(); _laserConn = nil end
            for _, p in ipairs(_laserParts) do
                pcall(function()
                    if p and p.Parent then p.Anchored = _laserPartsWereAnchored[p] or false end
                end)
            end
            _laserParts = {}; _laserPartsWereAnchored = {}
            laserStatusLbl.Text = "Laser: inactive"
        end
    end, false, "Hold bricks in a beam pointing forward from your character.")

    makeSection(attacksPage, "── Teleport Parts to Target ────────────────────")

