    function lib.getblocks(text, height, spacing, efficient)
        height = height or 5; spacing = spacing or 2; efficient = efficient ~= false
        local txttable = texttotable["h"..tostring(height)]
        local out = {}; local oddeven = 0
        for i=1,#text do
            local ch = text:sub(i,i)
            if ch and txttable[ch] then
                table.insert(out, {})
                for _,col in ipairs(txttable[ch]) do
                    oddeven = oddeven + 1
                    local c = {unpack(col)} -- Lua5.1/Luau compat: table.unpack → unpack
                    if oddeven%2==0 then table.sort(c, function(a,b) return a<b end) end
                    table.insert(out, c)
                end
