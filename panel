                        )
                    end
                end
            end
            -- Grid for BFS adjacency = smallest brick dimension
            -- (handles symmetric bricks correctly; asymmetric bricks will work
            -- but BFS may plan a suboptimal order — acceptable for v1).
            local bfsGrid = math.min(ct.brickStepX, ct.brickStepY, ct.brickStepZ)
            local plan = planInfBFS(posList, ct.selectedBrick.Position, bfsGrid)
            -- Temporarily seed buildInfBFS from the selected brick so the
            -- server attaches to (and inherits the shape of) that brick.
            local prevSeeder = S.seeder
            S.seeder = ct.selectedBrick
            local scaffoldTrack = {}
            local missed = buildInfBFS(plan, "normal", btn, nil, scaffoldTrack)
            S.seeder = prevSeeder
