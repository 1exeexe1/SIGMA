local _rayExclude=RaycastParams.new(); _rayExclude.FilterType=Enum.RaycastFilterType.Exclude
local _clickTPRay=RaycastParams.new(); _clickTPRay.FilterType=Enum.RaycastFilterType.Exclude
local _atmosphere=Lighting:FindFirstChildOfClass("Atmosphere")
S._origFogDensity=_atmosphere and _atmosphere.Density or 0.3

RunService.RenderStepped:Connect(function(dt)
    if not MainFrame.Visible then return end
    -- 30-frame rolling average: avoids the 20↔40 flicker of raw 1/dt
    if not S._fpsBuf then S._fpsBuf={}; S._fpsBufIdx=1 end
    local buf=S._fpsBuf
    buf[S._fpsBufIdx]=dt; S._fpsBufIdx=(S._fpsBufIdx%30)+1
    local sum=0; local n=#buf; for i=1,n do sum=sum+buf[i] end
    local fps=math.floor(n/sum+0.5)
    local user=lp.DisplayName.." (@"..lp.Name..")"
    TitleLbl.Text="Sigma  |  "..fps.." fps  |  "..#Players:GetPlayers().." players  |  "..user
end)

RunService.Heartbeat:Connect(function()
    local char=lp.Character
    local hrp=char and char:FindFirstChild("HumanoidRootPart")

    if hrp then
        local pos = hrp.Position
        if S.antiGlitch or true then
            local moving = UserInputService:IsKeyDown(Enum.KeyCode.W)
                        or UserInputService:IsKeyDown(Enum.KeyCode.A)
                        or UserInputService:IsKeyDown(Enum.KeyCode.S)
                        or UserInputService:IsKeyDown(Enum.KeyCode.D)
            if moving
            and (S._glitchState == Enum.HumanoidStateType.Running
              or S._glitchState == Enum.HumanoidStateType.RunningNoPhysics
              or S._glitchState == Enum.HumanoidStateType.Landed)
            and pos.Y > -50 and pos.Y < 10000
            and math.abs(pos.X) < 10000 and math.abs(pos.Z) < 10000 then
                S.lastSafe = pos
            end
        end

        if S.antiGlitch then
            local vel = hrp.AssemblyLinearVelocity
            local destroyH = Workspace.FallenPartsDestroyHeight
            local predictedY = pos.Y + vel.Y / 2.5
            -- Only rescue when truly out-of-bounds: >4000 studs from origin
            -- on XZ plane, or implausibly high/low on Y.
            -- This prevents false triggers on large maps that extend >10k studs.
            local distXZ   = math.sqrt(pos.X*pos.X + pos.Z*pos.Z)
            local tooFarX  = distXZ > 4000
            local tooFarY  = math.abs(pos.Y) > 100000
            local falling  = predictedY < (destroyH + 5)

            if tooFarX or tooFarY or falling then
                for _, p in pairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then
                        p.AssemblyLinearVelocity  = Vector3.zero
                        p.AssemblyAngularVelocity = Vector3.zero
                    end
                end
                local dest = S.lastSafe
                if not dest then
                    local sp = Workspace:FindFirstChildOfClass("SpawnLocation")
                    dest = sp and sp.Position + Vector3.new(0,5,0) or Vector3.new(0,5,0)
                end
                char:PivotTo(CFrame.new(dest))
                if S.antiNotify then notify("Anti-Glitch","Glitch detected \226\128\148 returned to safe position.") end
            end
        end
    end

    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then S._glitchState = hum:GetState() end
    end

    if S.antiBlind then
        local b=lp.PlayerGui:FindFirstChild("Blind")
        if b then b.Enabled=false
            for _,v in ipairs(b:GetDescendants()) do if v:IsA("Frame") or v:IsA("ImageLabel") then v.Visible=false end end
        end
    end

    if S.antiMyopic then
        local blur=Lighting:FindFirstChildOfClass("BlurEffect")
        if blur then blur.Enabled=false; blur.Size=0 end
    end

    if S.autoFixCam then
        local cam=Workspace.CurrentCamera
        if cam.CameraType~=Enum.CameraType.Custom then cam.CameraType=Enum.CameraType.Custom end
    end

    if S.antiFog then
        if _atmosphere then _atmosphere.Density=0 end
        local legacyFog=Lighting:FindFirstChildOfClass("Sky") and nil or Lighting:FindFirstChild("Fog")
        if legacyFog then pcall(function() legacyFog.FogStart=100000; legacyFog.FogEnd=100001 end) end
        pcall(function() Lighting.FogEnd=100001; Lighting.FogStart=100000 end)
    end

    if S.antiBlur then local b=Lighting:FindFirstChild("Blur"); if b and b.Enabled then b.Enabled=false end end
    if S.antiNoColor then local r=Lighting:FindFirstChild("RGB"); if r and r.Enabled then r.Enabled=false end end

    if S.antiStun and char then
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hum and hum.PlatformStand then
            -- Immediately unstun, then notify
            hum.PlatformStand = false
            if not S._stunPromptPending then
                S._stunPromptPending = true
                task.spawn(function()
                    if S.antiNotify then
                        notify("Anti-Stun", "You were stunned \226\128\148 auto-unstunned!")
                    end
                    task.wait(3)
                    S._stunPromptPending = false
                end)
            end
        end
    end

    if S.antiDrag and char and hrp then
        if hrp.CollisionGroup=="NoClip" then
            for _,p in pairs(char:GetChildren()) do
                if p:IsA("BasePart") then
                    pcall(function() p.CollisionGroup="Default"; p.CanCollide=true end)
                end
            end
        end
        local vel=hrp.AssemblyLinearVelocity
        local hum=char:FindFirstChildOfClass("Humanoid")
        local isJumping=hum and (hum:GetState()==Enum.HumanoidStateType.Jumping
                               or hum:GetState()==Enum.HumanoidStateType.Freefall)
        if not isJumping and vel.Y>30 then
            hrp.AssemblyLinearVelocity=Vector3.new(vel.X,0,vel.Z)
        end
    end

    if S.animSpeed and char then
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hum then for _,t in pairs(hum:GetPlayingAnimationTracks()) do t:AdjustSpeed(S.animSpeedVal) end end
    end

    local anyTool = S.toolOn_Build or S.toolOn_Delete or S.toolOn_Shape
                 or S.toolOn_Paint or S.toolOn_Shovel or S.toolOn_Sign
    if hrp and anyTool then
        local now = tick()
        if (now - S._toolT) >= S.toolSpeed then
            S._toolT = now

            local mouse = lp:GetMouse()
            local ray   = Workspace.CurrentCamera:ScreenPointToRay(mouse.X, mouse.Y)
            local rp    = RaycastParams.new()
            rp.FilterType = Enum.RaycastFilterType.Exclude
            rp.FilterDescendantsInstances = {char}
            local res     = Workspace:Raycast(ray.Origin, ray.Direction * S.toolRange, rp)
            local hovPart = res and res.Instance
            local hovPos  = res and res.Position or (ray.Origin + ray.Direction * S.toolRange)
            local hitNorm = res and res.Normal or Vector3.new(0,1,0)

            local function normalToFace(n)
                local ax,ay,az=math.abs(n.X),math.abs(n.Y),math.abs(n.Z)
                if ay>=ax and ay>=az then return n.Y>0 and Enum.NormalId.Top or Enum.NormalId.Bottom
                elseif ax>=ay and ax>=az then return n.X>0 and Enum.NormalId.Right or Enum.NormalId.Left
                else return n.Z>0 and Enum.NormalId.Back or Enum.NormalId.Front end
            end
            local hitFace = normalToFace(hitNorm)

            if S.toolOn_Build then
                if not S._toolEvBuild or not S._toolEvBuild.Parent then
                    local t=forceEquip("Build"); S._toolEvBuild=t and t:FindFirstChild("Event",true)
                end
            end
            if S.toolOn_Delete then
                if not S._toolEvDelete or not S._toolEvDelete.Parent then
                    local t=forceEquip("Delete"); S._toolEvDelete=t and t:FindFirstChild("Event",true)
                end
            end
            if S.toolOn_Shape then
                if not S._toolEvShape or not S._toolEvShape.Parent then
                    local t=forceEquip("Shape")
                    if t then
                        local sc=t:FindFirstChild("Script")
                        S._toolEvShape=sc and sc:FindFirstChild("Event")
                    end
                end
            end
            if S.toolOn_Paint then
                if not S._toolEvPaint or not S._toolEvPaint.Parent then
                    local t=forceEquip("Paint"); S._toolEvPaint=t and t:FindFirstChild("Event",true)
                end
            end
            if S.toolOn_Shovel then
                if not S._toolEvShovel or not S._toolEvShovel.Parent then
                    local t=forceEquip("Shovel"); S._toolEvShovel=t and t:FindFirstChild("Event",true)
                end
            end
            if S.toolOn_Sign then
                if not S._toolEvSign or not S._toolEvSign.Parent then
                    local t=forceEquip("Sign"); S._toolEvSign=t and t:FindFirstChild("Event",true)
                end
            end

            if S.toolOn_Build and S._toolEvBuild then
                local target = hovPart or Workspace.Terrain
                local face   = hovPart and hitFace or Enum.NormalId.Top
                S._toolEvBuild:FireServer(target, face, hovPos, S.toolMode_Build)
            end

            if S.toolOn_Delete and S._toolEvDelete and hovPart and hovPart:IsA("BasePart") then
                S._toolEvDelete:FireServer(hovPart, hrp.Position)
            end

            if S.toolOn_Shape and S._toolEvShape and hovPart and hovPart:IsA("BasePart") then
                S._toolEvShape:FireServer(hovPart, hitFace, hovPos, S.toolMode_Shape)
            end

            if S.toolOn_Paint and S._toolEvPaint then
                local target = hovPart and hovPart:IsA("BasePart")
                    and (S.toolPaintTerrain or hovPart ~= Workspace.Terrain)
                    and hovPart or (S.toolPaintTerrain and Workspace.Terrain or nil)
                if target then
                    if S.toolSpray and S.toolSprayText~="" then
                        -- Spray mode: write text onto the aimed face
                        local spCol = S.toolSprayColor
                        local r=math.floor(spCol.R*255); local gg=math.floor(spCol.G*255); local b=math.floor(spCol.B*255)
                        local hex=string.format("%02X%02X%02X",r,gg,b)
                        local styled=string.format('<font color="#%s">%s</font>',hex,S.toolSprayText)
                        S._toolEvPaint:FireServer(target, hitFace, hrp.Position,
                            HANDSHAKE, spCol, "spray", styled)
                    else
                        -- Normal paint mode
                        local col = S.toolColor_Paint
                        if S.toolRainbow_Paint then
                            S.toolRainbowH_Paint=(S.toolRainbowH_Paint+0.03)%1
                            col=Color3.fromHSV(S.toolRainbowH_Paint,1,1)
                        end
                        S._toolEvPaint:FireServer(target, hitFace, hrp.Position,
                            HANDSHAKE, col, S.toolMaterial_Paint, "")
                    end
                end
            end

            if S.toolOn_Shovel and S._toolEvShovel then
                local target = hovPart or Workspace.Terrain
                S._toolEvShovel:FireServer(target, hitFace, hovPos, S.toolMode_Shovel)
            end

            if S.toolOn_Sign and S._toolEvSign then
                local target = hovPart or Workspace.Terrain
                local face   = hovPart and hitFace or Enum.NormalId.Top
                S._toolEvSign:FireServer(target, face, hovPos, S.toolMode_Build)
            end
        end
    end

    if hrp and (S.rainbow or S.killAura or S.detailedPath) then
        _rayExclude.FilterDescendantsInstances={char}
        local mouse=lp:GetMouse()
        local unitRay=Workspace.CurrentCamera:ScreenPointToRay(mouse.X,mouse.Y)
        local rayRes=Workspace:Raycast(unitRay.Origin,unitRay.Direction*2000,_rayExclude)
        local hovPart=rayRes and rayRes.Instance
        local hovPos=rayRes and rayRes.Position or mouse.Hit.Position

        S.rainbowH=(S.rainbowH+S.rainbowSpeed)%1
        local col=Color3.fromHSV(S.rainbowH,1,1)

        if S.rainbow then
            local ev=equipAndGetEvent("Paint")
            if ev then
                local target=(hovPart and hovPart:IsA("BasePart") and hovPart.Name~="Terrain") and hovPart or Workspace.Terrain
                ev:FireServer(target,Enum.NormalId.Top,hovPos,HANDSHAKE,col,S.currentMaterial,"")
            end
        end

        if S.killAura then
            -- Same pattern as Rainbow Brick Trail:
            --   Frame N:   FireServer Build at target → start ChildAdded listener
            --   Frame N+1: paint _killCurBrick (now server-side), fire new Build
            -- This ensures the brick exists before we try to paint it.
            local buildEv=equipAndGetEvent("Build"); local paintEv=equipAndGetEvent("Paint")
            local tPart,dist=nil,20
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local d=(p.Character.HumanoidRootPart.Position-hrp.Position).Magnitude
                    if d<dist then tPart=p.Character.HumanoidRootPart; dist=d end
                end
            end
            if tPart then
                -- Step 1: paint the PREVIOUS brick (exists server-side by now)
                if S._killCurBrick and paintEv and S._killCurBrick.Parent then
                    paintEv:FireServer(S._killCurBrick,Enum.NormalId.Top,S._killCurBrick.Position,HANDSHAKE,Color3.new(0,0,0),"toxic","")
                    S._killCurBrick=nil
                end
                -- Step 2: place NEW brick at target, track it via ChildAdded
                if buildEv then
                    buildEv:FireServer(Workspace.Terrain,Enum.NormalId.Top,tPart.Position,"detailed")
                    if not S._killListening then
                        do
                            local _kbf=getBricksFolder()
                            local _kmf=_kbf and _kbf:FindFirstChild(lp.Name)
                            if _kmf then
                                S._killListening=true
                                local _kconn; _kconn=_kmf.ChildAdded:Connect(function(child)
                                    if child:IsA("BasePart") then
                                        S._killCurBrick=child
                                        _kconn:Disconnect(); S._killListening=false
                                    end
                                end)
                                task.delay(0.5,function()
                                    if S._killListening then
                                        pcall(function() _kconn:Disconnect() end)
                                        S._killListening=false
                                    end
                                end)
                            end
                        end
                    end
                end
            else
                -- No target in range — clear stale state
                S._killCurBrick=nil; S._killListening=false
            end
        end

        if S.detailedPath then
            local pType = S.trailType:gsub("^rainbow ","")
            local buildEv = equipAndGetEvent("Build")
            if buildEv then
                buildEv:FireServer(Workspace.Terrain, Enum.NormalId.Top, hrp.Position, pType)
                -- Flag this position as the next rainbow paint target
                if S.trailType:find("rainbow") then
                    -- Track the ACTUAL placed brick via ChildAdded on our folder
                    local _myBF2 = getBricksFolder()
                    local _myF2  = _myBF2 and _myBF2:FindFirstChild(lp.Name)
                    if _myF2 and not S._trailListening then
                        S._trailListening = true
                        local _conn; _conn = _myF2.ChildAdded:Connect(function(child)
                            if child:IsA("BasePart") then
                                S._trailCurBrick = child
                                _conn:Disconnect(); S._trailListening = false
                            end
                        end)
                        -- Timeout: clear listener after 0.5s to avoid leaks
                        task.delay(0.5, function()
                            if S._trailListening then
                                pcall(function() _conn:Disconnect() end)
                                S._trailListening = false
                            end
                        end)
                    end
                end
            end
            -- Paint the PREVIOUS brick (it now exists on server) — find actual placed brick
            if S.trailType:find("rainbow") and S._trailCurBrick then
                local paintEv = equipAndGetEvent("Paint")
                -- Only paint if we have an actual placed brick — NEVER fall back to Terrain
                if paintEv and S._trailCurBrick.Parent then
                    paintEv:FireServer(
                        S._trailCurBrick, Enum.NormalId.Top,
                        S._trailCurBrick.Position, HANDSHAKE, col, S.currentMaterial, ""
                    )
                end
                S._trailCurBrick = nil
            end
            -- Rotate: what we built this frame becomes paint target next frame
            S._trailCurPaint  = S._trailNextPaint
        else
            S._trailCurBrick   = nil
            S._trailListening  = false
        end
    end

    if hrp and (S.buildAura or S.signAura or S.paintAura or S.deleteAuraAdv or S.propAura) then
        S.auraH=(S.auraH+S.auraRainbowSpeed)%1
        local col=Color3.fromHSV(S.auraH,1,1)
        local now=tick()

        if S.buildAura and not S._auraEvBuild then
            local t=forceEquip("Build"); S._auraEvBuild=t and t:FindFirstChild("Event",true)
        end
        if S.signAura and not S._auraEvSign then
            local t=forceEquip("Sign"); S._auraEvSign=t and t:FindFirstChild("Event",true)
        end
        if S.paintAura and not S._auraEvPaint then
            S._auraEvPaint = getToolRemoteCached("Paint")
        end
        if S.deleteAuraAdv and not S._auraEvDelete then
            S._auraEvDelete = getToolRemoteCached("Delete")
        end

        if S._auraEvBuild and not S._auraEvBuild.Parent then S._auraEvBuild=nil end
        if S._auraEvSign  and not S._auraEvSign.Parent  then S._auraEvSign=nil  end
        if S._auraEvPaint and not S._auraEvPaint.Parent then S._auraEvPaint=nil end
        if S._auraEvDelete and not S._auraEvDelete.Parent then S._auraEvDelete=nil end

        if S.buildAura and (now-S._buildT)>=S.buildSpeed then
            S._buildT=now
            if S._auraEvBuild then S._auraEvBuild:FireServer(Workspace.Terrain,Enum.NormalId.Top,posAround(hrp,3,15),"normal") end
        end
        if S.signAura and (now-S._signT)>=S.signSpeed then
            S._signT=now
            if S._auraEvSign then S._auraEvSign:FireServer(Workspace.Terrain,Enum.NormalId.Top,posAround(hrp,3,15),"normal") end
        end
        if S.paintAura and (now-S._paintT)>=S.paintSpeed then
            S._paintT=now
            if S._auraEvPaint then
                local paCol = S.paintAuraColor
                if S.paintAuraRainbow then
                    S.paintAuraRainbowH=(S.paintAuraRainbowH+S.auraRainbowSpeed*60)%1
                    paCol=Color3.fromHSV(S.paintAuraRainbowH,1,1)
                end
                local paMode = HANDSHAKE
                if S.paintAuraOnlyColor then paMode = "color"
                elseif S.paintAuraOnlyMat  then paMode = "material" end
                -- Batch: collect up to 5 nearby bricks and paint all of them per tick
                local painted = 0
                local folder = getBricksFolder() or Workspace
                local hrpPos = hrp.Position
                local range2 = S.paintRange * S.paintRange
                for _, blk in ipairs(folder:GetDescendants()) do
                    if painted >= 5 then break end
                    if blk:IsA("BasePart") and (hrpPos - blk.Position).Magnitude <= S.paintRange then
                        local skip = false
                        if not S.paintAuraRainbow then
                            local blkMatStr = MAT_TO_STR[blk.Material] or ""
                            local _dc=Vector3.new(blk.Color.R-paCol.R,blk.Color.G-paCol.G,blk.Color.B-paCol.B)
                            local colorMatch = _dc.Magnitude < 0.015
                            local matMatch   = (blkMatStr == S.paintAuraMat)
                            if paMode == "color"    then skip = colorMatch
                            elseif paMode == "material" then skip = matMatch
                            else skip = colorMatch and matMatch end
                        end
                        if not skip then
                            queuePaintBrick(blk, paCol, S.paintAuraMat, paMode, hrpPos)
                            painted = painted + 1
                        end
                    end
                end
            end
        end
        if S.deleteAuraAdv and (now-S._deleteT)>=S.deleteSpeed then
            S._deleteT=now
            local blk=nearestPart(S.deleteRange)
            if S._auraEvDelete and blk then S._auraEvDelete:FireServer(blk,hrp.Position) end
        end
        -- ── Property Aura ─────────────────────────────────────────────────
        -- Finds nearest brick whose property doesn't match the target mode,
        -- then fires Paint remote with "anchor" or "collide" paint mode.
        if S.propAura then
            if not S._auraEvProp then
                S._auraEvProp = getToolRemoteCached("Paint")
            end
            if S._auraEvProp and not S._auraEvProp.Parent then S._auraEvProp = nil end
            if S._auraEvProp and (now - S._propT) >= S.propAuraSpeed then
                S._propT = now
                -- Scan bricks in range for ones that need the property applied
                local folder = getBricksFolder() or Workspace:FindFirstChild("PlacedBlocks")
                if folder then
                    local mode = S.propAuraMode  -- "anchor","unanchor","collide","nocollide"
                    local fired = 0
                    for _, p in ipairs(folder:GetDescendants()) do
                        if fired >= 8 then break end  -- batch up to 8 bricks per tick
                        if p:IsA("BasePart")
                        and (hrp.Position - p.Position).Magnitude <= S.propAuraRange then
                            local needsPaint = false
                            if     mode == "anchor"    and not p.Anchored    then needsPaint = true
                            elseif mode == "unanchor"  and p.Anchored        then needsPaint = true
                            elseif mode == "collide"   and not p.CanCollide  then needsPaint = true
                            elseif mode == "nocollide" and p.CanCollide      then needsPaint = true
                            end
                            if needsPaint then
                                -- Map mode to the Paint remote's expected string
                                local remoteMode = (mode == "anchor" or mode == "unanchor")
                                    and "anchor" or "collide"
                                pcall(function()
                                    S._auraEvProp:FireServer(
                                        p, Enum.NormalId.Front, hrp.Position,
                                        HANDSHAKE, Color3.new(1,1,1), remoteMode, "")
                                end)
                                fired = fired + 1
                            end
                        end
                    end
                end
            end
        else
            S._auraEvProp = nil
        end
    else
        S._auraEvBuild=nil; S._auraEvSign=nil; S._auraEvPaint=nil; S._auraEvDelete=nil
        S._auraEvProp=nil
    end
end)

