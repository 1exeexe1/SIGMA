-- Toggle in Main → CMDs or here:
S.jarvisPublic     = false   -- allow other players to use !jarvis
S.jarvisAICmds     = false   -- allow AI to act on !jarvis commands from non-whitelisted chat users
S.jarvisRateLimit  = {}      -- [playerName] = last request tick()

local _jarvisConn = nil
local function _jStartChatAgent()
    if _jarvisConn then return end
    local function onChat(msg, speaker)
        if not msg:lower():match("^!jarvis") then return end
        local isOp = (speaker == game:GetService("Players").LocalPlayer.Name)
        if not isOp then
            if not S.jarvisPublic then return end
            -- Rate limit non-operators: 1 req / 6 s
            local now = tick()
            if S.jarvisRateLimit[speaker] and (now - S.jarvisRateLimit[speaker]) < 6 then return end
            S.jarvisRateLimit[speaker] = now
        end

        local query = msg:gsub("^!jarvis%s*", ""):gsub("^!Jarvis%s*", "")
        if query == "" then return end

        -- Inject player memory into query context if available
        local memCtx = ""
        pcall(function()
            local mem = _jGetPlayerMemory(speaker)
            if mem then
                memCtx = "\n[PLAYER MEMORY for " .. speaker .. "]: " .. mem
            end
        end)

        task.spawn(function()
            -- Append camera look context for "player I'm looking at" queries
            local camCtx = ""
            pcall(function()
                local cam = workspace.CurrentCamera
                local look = cam.CFrame.LookVector
                local origin = cam.CFrame.Position
                local closest, closestDist = nil, math.huge
                for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
                    if p.Name == game:GetService("Players").LocalPlayer.Name then continue end
                    local char = p.Character
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local toP = (hrp.Position - origin)
                        local dist = (toP - look * toP:Dot(look)).Magnitude
                        if dist < closestDist then closestDist = dist; closest = p end
                    end
                end
                if closest then
                    local hrp2 = closest.Character and closest.Character:FindFirstChild("HumanoidRootPart")
                    local hum2 = closest.Character and closest.Character:FindFirstChildOfClass("Humanoid")
                    camCtx = "\n[CAMERA LOOK TARGET]: " .. closest.Name
                        .. "  HP=" .. (hum2 and math.floor(hum2.Health) or "?")
                        .. "/" .. (hum2 and math.floor(hum2.MaxHealth) or "?")
                        .. (hrp2 and ("  Pos=" .. ("%.0f,%.0f,%.0f"):format(
                            hrp2.Position.X, hrp2.Position.Y, hrp2.Position.Z)) or "")
                end
            end)

            local fullQuery = "[ROBLOX CHAT — from " .. speaker .. "]\n" .. query .. camCtx .. memCtx
            -- Record this interaction in player memory (fact = last topic)
            pcall(function()
                local shortQ = query:sub(1,60):gsub("\n"," ")
                _jAddPlayerMemoryFact(speaker, "asked: " .. shortQ)
            end)
            _jThink("💬 Chat from " .. speaker .. ": " .. query:sub(1,60))
            _jSendWithProbe(fullQuery, _aiStatusLbl, function(response)
                -- Dispatch panel actions first (toggles fly, noclip, etc.)
                _jDispatchActions(response)

                -- Strip action JSON + code blocks for the in-game chat reply
                local cleanReply = response
                    :gsub('{[^\n]*"sigma_action"[^\n]*}\n?', "")
                    :gsub("```[^\n]*\n?.-\n?```\n?", "")
                    :gsub("\n+", " ")
                    :match("^%s*(.-)%s*$")  -- trim

                -- ── CHUNKED SENDING ──────────────────────────────────────────
                -- Split reply into chunks of ≤25 words or at sentence boundaries
                -- (period, exclamation, question mark), then send each chunk with
                -- a 1.5-second delay so Roblox's chat length limit is never hit.
                -- No code should ever be sent via chat (action JSON already stripped).
                if cleanReply ~= "" then
                    -- Split at sentence-ending punctuation first
                    local chunks = {}
                    -- Replace sentence enders with a sentinel split marker
                    local working = cleanReply:gsub("([%.%!%?])%s+", "%1\0")
                    for segment in (working .. "\0"):gmatch("([^\0]+)\0?") do
                        segment = segment:match("^%s*(.-)%s*$")
                        if segment ~= "" then
                            -- If segment is still too long (>25 words), split by word count
                            local words = {}
                            for w in segment:gmatch("%S+") do words[#words+1] = w end
                            if #words > 25 then
                                local i = 1
                                while i <= #words do
                                    local slice = {}
                                    for j = i, math.min(i+24, #words) do
                                        slice[#slice+1] = words[j]
                                    end
                                    chunks[#chunks+1] = table.concat(slice, " ")
                                    i = i + 25
                                end
                            else
                                chunks[#chunks+1] = segment
                            end
                        end
                    end

                    -- Send each chunk with a 1.5-second delay
                    task.spawn(function()
                        for idx, chunk in ipairs(chunks) do
                            if chunk ~= "" then
                                sendChat("[J] " .. chunk)
                                if idx < #chunks then
                                    task.wait(1.5)
                                end
                            end
                        end
                    end)
                end
                -- Add to panel chat log
                table.insert(_aiConversation, {role="user", content=fullQuery})
                table.insert(_aiConversation, {role="assistant", content=response})
                local lbl, bub = _jAddBubble(response, "assistant")
                _aiRenderCodeBlocks(response, bub, 10)
                -- Record actions taken for this player in memory
                pcall(function()
                    for line in (response .. "\n"):gmatch("([^\n]+)\n") do
                        local trimmed = line:match("^%s*({.+})%s*$")
                        if trimmed and trimmed:find('"sigma_action"') then
                            local ok, act = pcall(function()
                                return game:GetService("HttpService"):JSONDecode(trimmed)
                            end)
                            if ok and act and act.sigma_action == "set_toggle" then
                                local val = act.value and "ON" or "OFF"
                                _jAddPlayerMemoryFact(speaker, "Jarvis toggled " .. tostring(act.key) .. " " .. val)
                            end
                        end
                    end
                end)
            end)
        end)
    end

    -- Hook ChatSpy (existing system)
    local chatSpy = game:GetService("Players").LocalPlayer
        and game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
    -- Use TextChatService if available, fallback to legacy
    pcall(function()
        local TCS = game:GetService("TextChatService")
        if TCS and TCS.MessageReceived then
            _jarvisConn = TCS.MessageReceived:Connect(function(msg)
                onChat(msg.Text or "", msg.TextSource and msg.TextSource.Name or "?")
            end)
        end
    end)
    if not _jarvisConn then
        -- Legacy chat fallback
        pcall(function()
            _jarvisConn = game:GetService("Players").PlayerAdded:Connect(function() end) -- stub
            for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
                p.Chatted:Connect(function(msg) onChat(msg, p.Name) end)
            end
            game:GetService("Players").PlayerAdded:Connect(function(p)
                p.Chatted:Connect(function(msg) onChat(msg, p.Name) end)
            end)
        end)
    end
end

