-- ── Mouse / Input handlers ──────────────────────────────────────
local _ctMouse = lp:GetMouse()
local _ctClickConn, _ctUpConn, _ctDragConn

-- Guard: set to true for one frame when a ctMenu button is clicked,
-- so ctHandleClick ignores the tap that toggled a menu button.
local _ctMenuClickGuard = false

local function ctHandleClick()
    if not ct.equipped or ct.building then return end
    if _ctMenuClickGuard then _ctMenuClickGuard=false; return end
    local target = _ctMouse.Target

    -- ── Move Area Cube mode: reposition zone, keep size ────────
    -- Only fires if moveArea is currently ON at the moment of click,
    -- preventing the toggle-off tap from also repositioning the zone.
    if ct.moveArea then
        if target and target~=nil then
            local nv = CT_NORM_VEC[_ctMouse.TargetSurface] or Vector3.new(0,1,0)
            local hitPos = _ctMouse.Hit.Position
            -- Ignore hits on void (returns a point very far away)
            if hitPos.Magnitude < 5000 then
                ct.origin = snapToGrid(hitPos + nv * (CT_GRID * 0.5))
                ct.placed = true
                ctSyncZone(); ctSizeLblUpdate()
            end
        end
        return
    end

    -- ── Select-Brick mode ──────────────────────────────────────
    if ct.selectArmed then
        if target and target:IsA("BasePart") then
            local bf = getBricksFolder()
            if (bf and target:IsDescendantOf(bf)) or target==Workspace.Terrain then
                ct.selectedBrick = target
                ct.selectArmed   = false
                _ctSelBrickSet(false, "\226\156\147 "..target.Name)
                notify("Sigma","Construct: locked \226\134\146 "..target.Name)

                -- Size the SCA to exactly one copy of the selected brick.
                -- brickStepX/Y/Z record the per-axis step for handle dragging.
                -- nbX/Y/Z start at 1 (single brick); dragging expands by that step.
                local bs = target.Size
                ct.brickStepX = math.max(1, math.round(bs.X))
                ct.brickStepY = math.max(1, math.round(bs.Y))
                ct.brickStepZ = math.max(1, math.round(bs.Z))
                ct.nbX = 1; ct.nbY = 1; ct.nbZ = 1

                local nv = CT_NORM_VEC[_ctMouse.TargetSurface] or Vector3.new(0,1,0)
                ct.origin = snapToGrid(_ctMouse.Hit.Position + nv * (CT_GRID * 0.5))
                ct.placed = true
                ctSyncZone(); ctSizeLblUpdate()
            end
        end
        return
    end

    -- ── Handle hit detection ────────────────────────────────────
    -- Pass 1: exact Target match (fast, works when handle is unoccluded).
    local hitKey = nil
    for key, h in pairs(ctHandles) do
        if target == h then hitKey = key; break end
    end
    -- Pass 2: screen-space proximity (handles occluded by bricks or inside SCA).
    -- mouse.Target returns the geometry in front, not the handle behind it.
    -- We project every visible handle to viewport and accept the closest one
    -- within THRESHOLD pixels, giving you click-through interaction.
    if not hitKey and ct.placed then
        local cam       = Workspace.CurrentCamera
        local mx, my    = _ctMouse.X, _ctMouse.Y
        local bestDist  = 28  -- pixel threshold
        for key, h in pairs(ctHandles) do
            if h.Transparency < 1 then
                local sp, inView = cam:WorldToViewportPoint(h.Position)
                if inView then
                    local dx = sp.X - mx; local dy = sp.Y - my
                    local d  = math.sqrt(dx*dx + dy*dy)
                    if d < bestDist then bestDist = d; hitKey = key end
                end
            end
        end
    end
    if hitKey then
        ct.dragging        = true
        ct.dragKey         = hitKey
        ct.dragStartMouse  = _ctMouse.Hit.Position
        ct.dragStartOrigin = ct.origin
        ct.dragStartNbX    = ct.nbX
        ct.dragStartNbY    = ct.nbY
        ct.dragStartNbZ    = ct.nbZ
        return
    end

    if target then
        local nv = CT_NORM_VEC[_ctMouse.TargetSurface] or Vector3.new(0,1,0)
        local newOrigin = snapToGrid(_ctMouse.Hit.Position + nv * (CT_GRID * 0.5))
        if _scaRefreshOnClick or not ct.placed then
            -- Classic: reset to 1×1×1 at click position; restore default step.
            ct.origin = newOrigin
            ct.sX=1; ct.sY=1; ct.sZ=1
            ct.nbX=1; ct.nbY=1; ct.nbZ=1
            ct.brickStepX=CT_GRID; ct.brickStepY=CT_GRID; ct.brickStepZ=CT_GRID
            ct.placed = true
        else
            -- Locked: SCA stays at current size/position, ignore click
        end
        ctSyncZone(); ctSizeLblUpdate()
    end
end

local function ctHandleDrag()
    if not ct.dragging or not ct.dragKey then return end
    if _scaActiveTouchId and #UserInputService:GetTouchState() > 1 then return end
    local hitPos = getMouseWorldHit(_ctMouse, ct.dragStartMouse)
    if hitPos.Magnitude > 20000 then return end  -- void safety
    local info    = CT_FACES[ct.dragKey]
    local ax, dir = info.ax, info.dir
    local axV     = ax=="X" and Vector3.new(1,0,0)
                 or (ax=="Y" and Vector3.new(0,1,0) or Vector3.new(0,0,1))
    -- Per-axis step: brickStepX/Y/Z when a brick is selected; CT_GRID otherwise.
    local step    = ax=="X" and ct.brickStepX or (ax=="Y" and ct.brickStepY or ct.brickStepZ)
    local rawDelta = (hitPos - ct.dragStartMouse):Dot(axV)
    -- Delta in brick-count units; clamp to ±200 to guard against void glitches.
    local blkDelta = math.clamp(math.floor(rawDelta / step + 0.5), -200, 200)
    if dir > 0 then
        local startNb = ax=="X" and ct.dragStartNbX or (ax=="Y" and ct.dragStartNbY or ct.dragStartNbZ)
        local newNb   = math.max(1, startNb + blkDelta)
        if ax=="X" then ct.nbX=newNb elseif ax=="Y" then ct.nbY=newNb else ct.nbZ=newNb end
    else
        local startNb = ax=="X" and ct.dragStartNbX or (ax=="Y" and ct.dragStartNbY or ct.dragStartNbZ)
        local newNb   = math.max(1, startNb - blkDelta)
        local shift   = (startNb - newNb) * step
        if ax=="X" then
            ct.nbX = newNb
            ct.origin = Vector3.new(ct.dragStartOrigin.X + shift, ct.origin.Y, ct.origin.Z)
        elseif ax=="Y" then
            ct.nbY = newNb
            ct.origin = Vector3.new(ct.origin.X, ct.dragStartOrigin.Y + shift, ct.origin.Z)
        else
            ct.nbZ = newNb
            ct.origin = Vector3.new(ct.origin.X, ct.origin.Y, ct.dragStartOrigin.Z + shift)
        end
    end
    ctSyncZone(); ctSizeLblUpdate()
end

