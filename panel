-- A toggle that also acts as a collapsible settings section.
-- The ⚙ square button expands/collapses the child settings below.
-- Returns: inner (parent for child widgets), tick, setState
local function makeToggleSection(parent, label, cb, defaultOn)
    local state = defaultOn or false

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.AutomaticSize = Enum.AutomaticSize.Y
