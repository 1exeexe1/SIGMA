        end
        DC.selBox2.Adornee = t
        dcSpawnDots(t, DC.dots2, Color3.fromRGB(0,180,255))
        dcSetPhaseText("\226\151\136 Select Corner 2", Color3.fromRGB(0,180,255))
        notify("De-Grid","Click a blue corner on Brick2.")
        return
    end

    -- Phase 4: pick corner2 → draw beam
    if DC.phase == 4 then
        local hit = dcFindClickedCorner(DC.dots2, E._mouse)
        if not hit then return end
        DC.corner2 = hit:GetAttribute("dcCornerWorld")
        hit.Color  = Color3.fromRGB(255,255,255)
