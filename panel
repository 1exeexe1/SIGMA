-- Feed decal logger from a periodic scan (auto-refresh every 3 s, no toggle needed)
local _dcLogLastRefresh = 0
local _dcLogAutoConn
_dcLogAutoConn = RunService.Heartbeat:Connect(function()
    local now = tick()
    if (now - _dcLogLastRefresh) < 3 then return end
    _dcLogLastRefresh = now
    local found = _dcScan()
    local changed = false
    for _, e in ipairs(found) do
        local key = e.owner..":"..e.id
        if not _dcLogSeen[key] then
            _dcLogSeen[key] = true
            local nm = S._decalNameCache[tostring(e.id)] or ("ID "..e.id)
            table.insert(_dcLogEntries,1,{id=e.id,name=nm,kind=e.kind,owner=e.owner})
            -- Async name fetch → rebuild once resolved
            _dcFetchName(e.id, function(rn)
                for _, ent in ipairs(_dcLogEntries) do
                    if ent.id == e.id and ent.name ~= rn then
                        ent.name = rn
                        if _dcLogVisible then _dcLogRebuildRows() end
                    end
                end
            end)
            if #_dcLogEntries > 50 then table.remove(_dcLogEntries) end
            changed = true
        end
    end
    if changed and _dcLogVisible then _dcLogRebuildRows() end
end)

