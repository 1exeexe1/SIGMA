-- ── CONSTRUCT TOOL ────────────────────────────────────────────
-- ══════════════════════════════════════════════════════════════
-- A no-LocalScript fake Tool driven entirely from this script.
-- Player clicks a surface → zone appears adjacent (grid-snapped,
-- outside the surface). Six neon handles (one per face) let the
-- player drag-resize the zone in any direction.
-- Bottom-right compact menu: cam locks, select-brick, construct.
-- Build uses buildChunked (cluster-teleport, same as Build Cube).

-- ── State ──────────────────────────────────────────────────────
do -- ╔═ CONSTRUCT TOOL INTERNALS ══╗
ct = {
    equipped  = false,
    placed    = false,
    origin    = Vector3.new(0,0,0),
    sX=1, sY=1, sZ=1,          -- grid units (CT_GRID studs each) — kept for buildChunked compat
    building  = false,
    dragging     = false,
    dragKey      = nil,
    dragStartMouse  = Vector3.zero,
    dragStartOrigin = Vector3.zero,
    dragStartSX=1, dragStartSY=1, dragStartSZ=1,
    -- Brick-step sizing (set when a brick is selected via Select Brick)
    -- Default = CT_GRID so no-selection behaviour is identical to before.
    brickStepX = CT_GRID, brickStepY = CT_GRID, brickStepZ = CT_GRID,
    -- Brick-count per axis (replaces raw sX/sY/sZ for visual/resize logic)
    nbX = 1, nbY = 1, nbZ = 1,
    dragStartNbX = 1, dragStartNbY = 1, dragStartNbZ = 1,
    lockAngle = false,
    lockPos   = false,
    savedCamRot = nil,
    savedCamPos = nil,
    selectArmed   = false,
    selectedBrick = nil,
    moveArea      = false,  -- when true: clicks reposition zone without resizing (mobile-friendly)
}

-- ── Fake Tool ──────────────────────────────────────────────────
local ctTool = Instance.new("Tool")
ctTool.Name           = "Construct"
ctTool.RequiresHandle = false
ctTool.CanBeDropped   = false
ctTool.ToolTip        = "Sigma Construct"
-- Tool is NOT parented here — it only enters the backpack when
-- the player clicks "⚒ Equip Construction Tool" in the Build tab.

-- ── Zone visuals ───────────────────────────────────────────────
local ctZonePart = Instance.new("Part")
ctZonePart.Name        = "SigmaConstructZone"
ctZonePart.Anchored    = true
ctZonePart.CanCollide  = false
ctZonePart.Transparency= 1
ctZonePart.CastShadow  = false
ctZonePart.Size        = Vector3.new(CT_GRID, CT_GRID, CT_GRID)
ctZonePart.Parent      = Workspace

local ctSelBox = Instance.new("SelectionBox")
ctSelBox.Color3              = Color3.fromRGB(160, 32, 240)
ctSelBox.SurfaceColor3       = Color3.fromRGB(160, 32, 240)
ctSelBox.SurfaceTransparency = 0.88
ctSelBox.LineThickness       = 0.09
ctSelBox.Adornee             = nil
ctSelBox.Parent              = ScreenGui

-- Six face-centre resize handles
-- Each handle gets a Highlight so it renders through bricks (AlwaysOnTop)
ctHandles = {}
for key in pairs(CT_FACES) do
    local h = Instance.new("Part")
    h.Name        = "CTH_"..key
    h.Size        = Vector3.new(1.5, 1.5, 1.5)
    h.Material    = Enum.Material.Neon
    h.Color       = Color3.fromRGB(180, 0, 255)
    h.Anchored    = true
    h.CanCollide  = false
    h.CastShadow  = false
    h.Transparency= 1
    h.Parent      = Workspace
    -- Highlight makes the handle visible through geometry (AlwaysOnTop equivalent)
    local hl = Instance.new("Highlight")
    hl.Name               = "CTH_HL"
    hl.FillColor          = Color3.fromRGB(180, 0, 255)
    hl.FillTransparency   = 0.3
    hl.OutlineColor       = Color3.fromRGB(255, 255, 255)
    hl.OutlineTransparency= 0
    hl.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled            = false  -- only enabled when handle is visible
    hl.Parent             = h
    ctHandles[key] = h
end

-- ── Zone sync ──────────────────────────────────────────────────
ctSyncZone = function()
    if not ct.placed then
        ctSelBox.Adornee = nil
        for _,h in pairs(ctHandles) do h.Transparency = 1 end
        return
    end
    -- Physical stud dimensions driven by brick-count × brick-step.
    -- When no brick is selected brickStep = CT_GRID, so this is
    -- identical to the old sX * CT_GRID formula.
    local sX = ct.nbX * ct.brickStepX
    local sY = ct.nbY * ct.brickStepY
    local sZ = ct.nbZ * ct.brickStepZ
    -- Keep sX/sY/sZ in grid-unit sync so buildChunked stays compatible.
    ct.sX = math.max(1, math.round(sX / CT_GRID))
    ct.sY = math.max(1, math.round(sY / CT_GRID))
    ct.sZ = math.max(1, math.round(sZ / CT_GRID))
    -- Center: origin is the first-brick corner; offset by (n-1)*step/2.
    local center = ct.origin + Vector3.new(
        (ct.nbX - 1) * ct.brickStepX * 0.5,
        (ct.nbY - 1) * ct.brickStepY * 0.5,
        (ct.nbZ - 1) * ct.brickStepZ * 0.5
    )
    ctZonePart.Size   = Vector3.new(sX, sY, sZ)
    ctZonePart.CFrame = CFrame.new(center)
    ctSelBox.Adornee  = ctZonePart
    local hx = sX * 0.5 + 0.8
    local hy = sY * 0.5 + 0.8
    local hz = sZ * 0.5 + 0.8
    ctHandles.px.CFrame = CFrame.new(center + Vector3.new( hx, 0,  0))
    ctHandles.nx.CFrame = CFrame.new(center + Vector3.new(-hx, 0,  0))
    ctHandles.py.CFrame = CFrame.new(center + Vector3.new( 0,  hy, 0))
    ctHandles.ny.CFrame = CFrame.new(center + Vector3.new( 0, -hy, 0))
    ctHandles.pz.CFrame = CFrame.new(center + Vector3.new( 0,  0,  hz))
    ctHandles.nz.CFrame = CFrame.new(center + Vector3.new( 0,  0, -hz))
    local ctHandleVis = not ct.moveArea
    for _,h in pairs(ctHandles) do
        h.Transparency = ctHandleVis and 0.35 or 1
        local hl = h:FindFirstChild("CTH_HL")
        if hl then hl.Enabled = ctHandleVis end
    end
