-- BFS-style build off a face of anchorPart.
-- Matches buildInfBFS signature exactly: anchorPart, face, faceCenter, "normal"
-- Returns the newly placed BasePart or nil on timeout.
local function buildOffFace(anchorPart, face)
    if not anchorPart or not anchorPart.Parent then return nil end
    local char = lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local buildEv = getToolRemote("Build")
    if not buildEv then radStatus("Build tool missing!"); return nil end

    local myF = getMyBrickFolder()
    if not myF then radStatus("Brick folder missing!"); return nil end

    -- Compute face center using the same CT_NORM_VEC already defined in the panel
    local norm = CT_NORM_VEC[face] or Vector3.new(0, 1, 0)
    local ax   = (face == Enum.NormalId.Top or face == Enum.NormalId.Bottom) and "Y"
              or (face == Enum.NormalId.Left or face == Enum.NormalId.Right)  and "X"
              or "Z"
    local faceCenter = anchorPart.Position + norm * (anchorPart.Size[ax] / 2)

    -- Position player near face (server requires ~6 stud proximity)
    hrp.CFrame   = CFrame.new(faceCenter + norm * 6)
    task.wait(BUILD_SETTLE)
    hrp.Anchored = true

    local lastBuilt = nil
    local conn = myF.ChildAdded:Connect(function(child)
        if child:IsA("BasePart") then lastBuilt = child end
    end)

    buildEv:FireServer(anchorPart, face, faceCenter, "normal")

    -- Wait for server confirmation (same window as buildInfBFS)
    local dl = tick() + 1.5
    while not lastBuilt and tick() < dl do task.wait(0.02) end
    hrp.Anchored = false
    conn:Disconnect()

    return lastBuilt
end

