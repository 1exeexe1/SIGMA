do
    local _smG = makeGroup(aiAgentPage, "💾 Jarvis Sessions",
        "Save/load full conversation history. Stored in getgenv() — persists across re-executes this session.")

    local _smCurrentLbl = makeLabel(_smG, "Active: (unsaved)")
