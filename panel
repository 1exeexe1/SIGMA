    swatchLbl.FontFace = FONT_MAIN
    swatchLbl.TextSize = 12
    swatchLbl.TextXAlignment = Enum.TextXAlignment.Left
    swatchLbl.ZIndex = 9
    swatchLbl.Parent = swatchRow
    onTheme(function(th) swatchLbl.TextColor3 = th.WHITE end)

    local swatch = Instance.new("Frame")
    swatch.Size = UDim2.new(0,22,0,20)
    swatch.Position = UDim2.new(0,82,0.5,-10)
    swatch.BackgroundColor3 = _cpColor
    swatch.BorderColor3 = T.BORDER
    swatch.ZIndex = 9
    swatch.Parent = swatchRow
    onTheme(function(th) swatch.BorderColor3 = th.BORDER end)

    local pickBtn = Instance.new("TextButton")
    pickBtn.Size = UDim2.new(0,52,0,20)
    pickBtn.Position = UDim2.new(0,108,0.5,-10)
    pickBtn.BackgroundColor3 = T.BTN
    pickBtn.BorderColor3 = T.BORDER
    pickBtn.Text = "Pick \226\153\170"
    pickBtn.TextColor3 = T.WHITE
    pickBtn.FontFace = FONT_MAIN
    pickBtn.TextSize = 11
    pickBtn.ZIndex = 9
    pickBtn.Parent = swatchRow
    onTheme(function(th)
        pickBtn.BackgroundColor3 = th.BTN
        pickBtn.BorderColor3     = th.BORDER
        pickBtn.TextColor3       = th.WHITE
    end)
    pickBtn.MouseButton1Click:Connect(function()
        openColorPicker(function(c)
            _cpColor  = c
            swatch.BackgroundColor3 = c
            -- Opening the picker implies you want a solid color, not rainbow/random
            _cpRainbow = false
            _cpRandom  = false
        end)
    end)

    -- Rainbow + Random as simple toggles beneath the swatch
    makeToggle(g, "Rainbow  (shifts hue per-part)", function(on)
        _cpRainbow = on
        if on then _cpRandom = false end
    end)
    makeToggle(g, "Random   (new color per-part)", function(on)
        _cpRandom = on
        if on then _cpRainbow = false end
    end)

    -- Target scope dropdown (My Bricks only vs All Workspace)
    local _cpScope = "My Bricks"
    makeDropdown(g, "Target Scope", {"My Bricks","All Workspace"}, "My Bricks",
        function(v) _cpScope = v end, "My Bricks = your cfolder only. All Workspace = everything (heavy, use with care).")

    -- ── Helpers ────────────────────────────────────────────────────────

    local function _cpGetBucket()
        local char = lp.Character
        if not char then return nil end
        local pb = char:FindFirstChild("PaintBucket")
                or lp.Backpack:FindFirstChild("PaintBucket")
        if not pb then return nil end
        if pb.Parent ~= char then
            pb.Parent = char
            task.wait(0.15)
        end
        return pb
    end

    -- Returns the color to use for the current part.
    -- Rainbow and Random override _cpColor; otherwise _cpColor is used directly.
    local function _cpResolveColor()
        if _cpRainbow then return Color3.fromHSV(tick() % 1, 1, 1) end
        if _cpRandom  then return Color3.new(math.random(), math.random(), math.random()) end
        return _cpColor
    end

    local function _cpPaint(remFn, obj, col)
        coroutine.wrap(function()
            pcall(function()
                remFn:InvokeServer("PaintPart", {Part = obj, Color = col})
            end)
        end)()
    end

    local function _cpCollectParts()
        local parts = {}
        if _cpScope == "My Bricks" then
            local folder = getMyBrickFolder()
            if folder then
                for _, obj in ipairs(folder:GetDescendants()) do
                    if obj:IsA("BasePart") then parts[#parts+1] = obj end
                end
            end
        else
            local roots = {workspace, ReplicatedStorage}
            for _, root in ipairs(roots) do
                for _, obj in ipairs(root:GetDescendants()) do
                    if obj:IsA("BasePart") then
                        local ok, _ = pcall(function() return obj.Color end)
                        if ok then parts[#parts+1] = obj end
                    end
                end
            end
        end
        return parts
    end

    -- ── Buttons ────────────────────────────────────────────────────────

    makeButton(g, "\226\154\153  Paint All", function()
        if _cpPainting then notify("Sigma", "Already painting! Stop first."); return end
        local pb = _cpGetBucket()
        if not pb then
            notify("Sigma", "PaintBucket not found! Add gear id 18474459 first.")
            return
        end
        local remFn = pb:FindFirstChild("Remotes") and pb.Remotes:FindFirstChild("ServerControls")
        if not remFn then notify("Sigma", "PaintBucket remote missing."); return end

        local parts = _cpCollectParts()
        if #parts == 0 then notify("Sigma", "No parts found in scope."); return end

        -- Also paint RepStorage.Brick (syncs the build-preview colour)
        local rsBrick = ReplicatedStorage:FindFirstChild("Brick")
        if rsBrick then _cpPaint(remFn, rsBrick, _cpResolveColor()) end

        _cpBeforeColors = {}
        _cpPainting = true
        notify("Sigma", "Painting " .. #parts .. " parts\226\128\166")

        task.spawn(function()
            for _, part in ipairs(parts) do
                if not _cpPainting then break end
                if part and part.Parent then
                    local ok, origCol = pcall(function() return part.Color end)
                    if ok and typeof(origCol) == "Color3" then
                        if not _cpBeforeColors[part] then
                            _cpBeforeColors[part] = origCol
                        end
                        _cpPaint(remFn, part, _cpResolveColor())
                    end
                end
            end
            _cpPainting = false
            notify("Sigma", "\226\156\147 Paint All done! (" .. #parts .. " parts)")
        end)
    end)

    makeButton(g, "\226\143\185  Stop Painting", function()
        if not _cpPainting then return end
        _cpPainting = false
        notify("Sigma", "Paint stopped.")
    end)

    -- ── Instant fun buttons (no delay, fire-and-forget coroutines) ────────
    makeButton(g, "🌈  Instant Rainbow (scope)", function()
        if _cpPainting then notify("Sigma","Stop current paint first."); return end
        local pb = _cpGetBucket()
        if not pb then notify("Sigma","PaintBucket not found!"); return end
        local remFn = pb:FindFirstChild("Remotes") and pb.Remotes:FindFirstChild("ServerControls")
        if not remFn then notify("Sigma","PaintBucket remote missing."); return end
        local parts = _cpCollectParts()
        if #parts == 0 then notify("Sigma","No parts found in scope."); return end
        notify("Sigma", "Rainbow blast: "..#parts.." parts \240\159\140\136")
        -- Fire every part simultaneously in its own coroutine — no task.wait, pure chaos
        local h = 0
        local step = 1 / math.max(#parts, 1)
        for _, part in ipairs(parts) do
            local col = Color3.fromHSV(h % 1, 1, 1)
            h = h + step
            _cpPaint(remFn, part, col)
        end
        notify("Sigma", "\226\156\147 Rainbow blast done!")
    end)

    makeButton(g, "\226\172\155  Instant Monochrome (scope)", function()
        if _cpPainting then notify("Sigma","Stop current paint first."); return end
        local pb = _cpGetBucket()
        if not pb then notify("Sigma","PaintBucket not found!"); return end
        local remFn = pb:FindFirstChild("Remotes") and pb.Remotes:FindFirstChild("ServerControls")
        if not remFn then notify("Sigma","PaintBucket remote missing."); return end
        local parts = _cpCollectParts()
        if #parts == 0 then notify("Sigma","No parts found in scope."); return end
        notify("Sigma", "Monochrome blast: "..#parts.." parts \226\172\155")
        -- Each part gets a grey value evenly distributed across all parts
        local n = #parts
        for i, part in ipairs(parts) do
            local v = (i - 1) / math.max(n - 1, 1)  -- 0 = black, 1 = white
            local col = Color3.new(v, v, v)
            _cpPaint(remFn, part, col)
        end
        notify("Sigma", "\226\156\147 Monochrome blast done!")
    end)

    makeButton(g, "\226\134\169  Revert Colors", function()
        if next(_cpBeforeColors) == nil then
            notify("Sigma", "Nothing to revert.")
            return
        end
        local pb = _cpGetBucket()
        if not pb then notify("Sigma", "PaintBucket not found!"); return end
        local remFn = pb:FindFirstChild("Remotes") and pb.Remotes:FindFirstChild("ServerControls")
        if not remFn then notify("Sigma", "PaintBucket remote missing."); return end

        local count = 0
        for part, origCol in pairs(_cpBeforeColors) do
            if part and part.Parent then
                _cpPaint(remFn, part, origCol)
                count = count + 1
            end
        end
        _cpBeforeColors = {}
        notify("Sigma", "\226\134\169 Reverted " .. count .. " parts.")
    end)
end
