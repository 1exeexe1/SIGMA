-- ═══ BLITZ BUILD — pure aura-fire kernel (v4.7.4) ═══════════════════════════
-- No sort, no per-N yield. Fires every position in the cluster at full Luau
-- throughput and returns. Caller is responsible for post-fire verification.
-- This is the hot path called by blitzBuildChaos on Wave 1 and every re-pass.
-- ═══════════════════════════════════════════════════════════════════════════════
local function blitzBuild(ev, positions, bsize, probe)
    local arg      = bsize or "normal"
    -- Use the caller-supplied probe box (detailed=0.8³, normal=3³) for the
    -- pre-fire existence check so we don't fire at bricks that are already there.
    local probeBox = probe or ((bsize == "detailed") and Vector3.new(0.8,0.8,0.8) or Vector3.new(3,3,3))

    -- Deduplicate
    local seen   = {}
    local unique = {}
    for _, pos in ipairs(positions) do
        local key = string.format("%.0f,%.0f,%.0f", pos.X, pos.Y, pos.Z)
        if not seen[key] then seen[key] = true; unique[#unique+1] = pos end
    end
    if #unique == 0 then return end

    -- Aura fire: blast every position in the cluster with zero delay.
    -- Pre-filter with hasBlockAt so we never re-fire at an already-placed brick
    -- (server silently drops duplicates but they still consume remote budget and
    -- can trigger server-side rate-limit backpressure, slowing the whole build).
    for _, pos in ipairs(unique) do
        if S.buildStopped then return end
        if not hasBlockAt(pos, probeBox) then
            ev:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, arg)
        end
    end
end

-- ═══ CHAOS BLITZ ═════════════════════════════════════════════════════════════
-- CHAOS BLITZ — stubborn convergence kernel. No pass limit.
-- Used by buildChunked (cube), buildTextPositions, passFixBuild,
-- and clusterBlitz (Load Build). Sole exit condition: zero holes.
--
-- Wave strategy (hybrid):
--   Wave 1 (primary): snake order via blitzBuild — spatial locality
--     at full speed. Best-case: zero holes, done in one wave.
--   Wave 2+ (re-pass): chaos shuffle — holes are now sparse and
--     scattered, locality is gone. Shuffle avoids sequential pattern
--     bias the server might apply to retry queues.
--
-- HRP anchored by caller. No cap, no failure path.
-- ═══════════════════════════════════════════════════════════════

-- ── SERVER-SIDE POSITION SYNC CHECK ─────────────────────────────────────────
-- After a teleport the server may still think the player is at the old
-- position for up to several frames. If the server-side position is too far
-- from the cluster seed, any build remote fired against that seed will be
-- outside the 666-stud server build radius → silently dropped.
--
-- waitForServerPosSync(hrp, targetPos, tolerance, timeout)
--   Polls hrp.Position (which reflects what the server has ack'd back to us
--   via replication) against targetPos. Returns true once the server-replicated
--   position is within `tolerance` studs, or false if `timeout` seconds elapse.
--
-- Callers should pass the cluster seed (or chunkCenter) as targetPos.
-- A tolerance of 8 studs covers normal replication jitter without being so
-- wide that a stale position sneaks through.
-- ─────────────────────────────────────────────────────────────────────────────
local function waitForServerPosSync(hrp, targetPos, tolerance, timeout)
    tolerance = tolerance or 8
    timeout   = timeout   or 1.5
    local deadline = tick() + timeout
    while tick() < deadline do
        -- hrp.Position reflects the last server-confirmed position once the
        -- server has ack'd the CFrame write back through replication.
        if (hrp.Position - targetPos).Magnitude <= tolerance then
            return true
        end
        task.wait(0.05)
    end
    return false
end

local function blitzBuildChaos(ev, positions, bsize, probe)
    local probeBox = probe or ((bsize == "detailed") and Vector3.new(0.8,0.8,0.8) or Vector3.new(3,3,3))
    local arg      = bsize or "normal"

    -- Deduplicate once upfront
    local seen    = {}
    local targets = {}
    for _, pos in ipairs(positions) do
        local key = string.format("%.0f,%.0f,%.0f", pos.X, pos.Y, pos.Z)
        if not seen[key] then seen[key] = true; targets[#targets+1] = pos end
    end
    if #targets == 0 then return end

    local isRepass = false

    -- Stubborn loop: keep firing until every brick is confirmed present
    while true do
        if S.buildStopped then return end

        if not isRepass then
            -- Wave 1: snake order via blitzBuild (spatial locality)
            blitzBuild(ev, targets, arg, probeBox)
            isRepass = true
        else
            -- Wave 2+: chaos shuffle then full-speed aura fire (holes are sparse)
            for i = #targets, 2, -1 do
                local j = math.random(1, i)
                targets[i], targets[j] = targets[j], targets[i]
            end
            for _, pos in ipairs(targets) do
                if S.buildStopped then return end
                ev:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, arg)
            end
        end

        -- Give the server time to ack all fires before scanning
        task.wait(BUILD_VERIFY_WAIT)

        -- Collect holes
        local holes = {}
        for _, pos in ipairs(targets) do
            if S.buildStopped then return end
            if not hasBlockAt(pos, probeBox) then holes[#holes+1] = pos end
        end

        -- Zero holes: cluster is done
        if #holes == 0 then return end

        -- Next wave targets only the remaining holes
        targets = holes
    end
end

-- ═══════════════════════════════════════════════════════════════
-- PASS FIX — re-run full position list up to 5 times, skipping
-- already-built bricks per-check. No separate "find missing" scan.
-- Replaces the old 3-cycle repair pass for Build/Text builders.
-- Returns the (possibly refreshed) ev remote.
-- ═══════════════════════════════════════════════════════════════
local function passFixBuild(allPositions, bsize, ev, btn, maxPasses)
    -- ── Clustering strategy: seed-anchored radius (mirrors clusterBlitz) ─────
    -- Old approach: rectangular grid decomposition + centroid TP.
    --   Problem: centroid may sit far from edge bricks in tall/thin clusters;
    --   pairs() iteration is non-deterministic; isolated bricks at non-ground Y
    --   levels (e.g. Y=14 roof) would appear in their own cell with correct TP
    --   but blitzBuild's short verify windows (0.18 s) can race the server ack
    --   on isolated terrain placements → duplicate fires → server rejects both.
    --
    -- New approach: take the first remaining brick as the cluster SEED. Pull in
    -- every other remaining brick within REACH of that seed. Teleport HRP to
    -- seed+6↑, settle, anchor, fire. Isolated bricks naturally form 1-brick
    -- clusters — HRP is precisely 6 studs above them, maximally stable.
    -- Deterministic ordering (ipairs) and a 0.05 s inter-cluster gap prevent
    -- server flooding when many isolated bricks exist.
    maxPasses = maxPasses or 5
    local probeBox = (bsize=="detailed") and Vector3.new(0.8,0.8,0.8) or Vector3.new(3,3,3)
    -- Match clusterBlitz REACH values exactly (empirically validated):
    --   normal:   BUILD_NORMAL_CHUNK × GRID_MULT × 0.92 ≈ 22 studs
    --   detailed: BUILD_DETAIL_CHUNK × 0.9              ≈ 18 studs
    local REACH = (bsize=="detailed")
        and (BUILD_DETAIL_CHUNK * 0.9)
        or  (BUILD_NORMAL_CHUNK * GRID_MULT * 0.92)

    for pass = 1, maxPasses do
        if S.buildStopped then break end

        -- Collect still-unbuilt positions (mutable copy for this pass)
        local remaining = {}
        for _, pos in ipairs(allPositions) do
            if not hasBlockAt(pos, probeBox) then remaining[#remaining+1] = pos end
        end
        if #remaining == 0 then break end

        if btn and btn.Parent then
            btn.Text = string.format("PassFix %d/%d: %d left", pass, maxPasses, #remaining)
        end

        -- ── Seed-anchored radius clustering ─────────────────────────────────
        local clIdx = 0
        while #remaining > 0 do
            if S.buildStopped then break end
            clIdx = clIdx + 1

            -- Seed = first remaining brick (deterministic; ipairs order preserved)
            local seed    = table.remove(remaining, 1)
            local cluster = { seed }

            -- Pull in every brick within REACH of the seed
            local i = 1
            while i <= #remaining do
                if (remaining[i] - seed).Magnitude <= REACH then
                    cluster[#cluster+1] = table.remove(remaining, i)
                else
                    i = i + 1
                end
            end

            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then break end

            -- 1. Teleport to seed+6↑ (guaranteed within range of whole cluster)
            local tpTarget = seed + Vector3.new(0, 6, 0)
            hrp.CFrame   = CFrame.new(tpTarget)
            task.wait(BUILD_SETTLE)   -- server replicates new HRP position
            -- 1b. Confirm server-side position caught up before anchoring.
            --     If the server still thinks we're at the old position, build
            --     remotes fired at `seed` could be outside the 666-stud radius.
            waitForServerPosSync(hrp, tpTarget)
            -- 2. Anchor AFTER settle (server sees stable position before remote)
            hrp.Anchored = true

            if not ev or not ev.Parent then ev = getToolRemote("Build") end
            if ev then blitzBuildChaos(ev, cluster, bsize, probeBox) end

            hrp.Anchored = false
            -- 3. Brief inter-cluster gap — prevents server flooding when many
            --    isolated bricks each form their own 1-brick cluster
            task.wait(0.05)
        end

        task.wait(BUILD_VERIFY_WAIT)
    end

    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Anchored = false end
    return ev
end

