do  -- ── Font Encoder ───────────────────────────────────────────
    local g=makeGroup(tcoPage,"Font Encoder",'Encodes text with <font size="0"> padding. Copy result to clipboard.\nLv1: first char solo, rest in 2-char clusters. Lv2: every char split.')

    -- Level description
    -- Level 1: D → "D<font>dd</font>is<font>dd</font>co<font>dd</font>rd"
    --           clusters of 2 chars at middle/end, 1 char at start
    -- Level 2: every letter separated → "D<font>dd</font>i<font>dd</font>s<font>dd</font>..."

    local FONT_PAD = '<font size="0">ddxdsxc</font>'

    local function encodeLevel1(text)
        -- Split into clusters: first char solo, then pairs
        local result = ""
        local i = 1
        local len = #text
        local first = true
        while i <= len do
            local chunk
            if first then
                chunk = text:sub(i, i)
                i = i + 1
                first = false
            else
                chunk = text:sub(i, i+1)  -- cluster of 2
                i = i + 2
            end
            if result == "" then
                result = chunk
            else
                result = result .. FONT_PAD .. chunk
            end
        end
        return result
    end

    local function encodeLevel2(text)
        local result = ""
        for j = 1, #text do
            local ch = text:sub(j, j)
            if result == "" then
                result = ch
            else
                result = result .. FONT_PAD .. ch
            end
        end
        return result
    end

    -- Text input row
    local inputRow=Instance.new("Frame"); inputRow.Size=UDim2.new(1,0,0,22)
    inputRow.BackgroundTransparency=1; inputRow.ZIndex=8; inputRow.Parent=g
    local inputLbl=Instance.new("TextLabel"); inputLbl.Size=UDim2.new(0,36,1,0)
    inputLbl.BackgroundTransparency=1; inputLbl.Text="Text"; inputLbl.TextColor3=T.WHITE
    inputLbl.FontFace=FONT_MAIN; inputLbl.TextSize=12
    inputLbl.TextXAlignment=Enum.TextXAlignment.Left; inputLbl.ZIndex=9; inputLbl.Parent=inputRow
    onTheme(function(th) inputLbl.TextColor3=th.WHITE end)
    local fontInput=Instance.new("TextBox"); fontInput.Size=UDim2.new(1,-40,0,18)
    fontInput.Position=UDim2.new(0,38,0.5,-9); fontInput.BackgroundColor3=Color3.new(0,0,0)
    fontInput.BorderColor3=T.BORDER; fontInput.Text=""; fontInput.PlaceholderText="Enter text..."
    fontInput.TextColor3=T.WHITE; fontInput.FontFace=FONT_MAIN; fontInput.TextSize=12
    fontInput.ZIndex=9; fontInput.Parent=inputRow
    onTheme(function(th) fontInput.BorderColor3=th.BORDER; fontInput.TextColor3=th.WHITE end)

    -- Level dropdown
    local fontLevel = "Level 1"
    makeDropdown(g,"Level",{"Level 1","Level 2"},"Level 1",function(v) fontLevel=v end)

    -- Encode + Copy button
    makeButton(g,"Font → Copy",function(btn)
        local raw = fontInput.Text
        if raw=="" then notify("Font","Enter text first!"); return end
        local encoded
        if fontLevel=="Level 2" then
            encoded = encodeLevel2(raw)
        else
            encoded = encodeLevel1(raw)
        end
        local clip = setclipboard or (Synapse and function(s) Synapse:Copy(s) end) or nil
        if clip then
            pcall(function() clip(encoded) end)
            btn.Text="Copied!"; task.delay(1.5, function() if btn and btn.Parent then btn.Text="Font → Copy" end end)
            notify("Font","Encoded & copied! ("..#encoded.." chars)")
        else
            notify("Font","No clipboard API found on this executor.")
        end
    end)
end

