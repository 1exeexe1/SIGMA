        _ringBumpOwnership()
        task.wait(0.05)
        local dir = hrp.CFrame.LookVector
        for _, ch in ipairs(clones) do
            task.spawn(function()
                local traveled = 0
                local throwConn
                throwConn = RunService.Heartbeat:Connect(function(dt)
