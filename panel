do -- Save Repstorage
    local g=makeGroup(opPage,"Save Repstorage","Serialize / restore brick settings as a copy-pasteable string.")

    -- Encode brick state to a compact string
    local function encodeBrickState(brick)
        local r=math.floor(brick.Color.R*255+0.5)
        local gv=math.floor(brick.Color.G*255+0.5)
        local b=math.floor(brick.Color.B*255+0.5)
        local mat=tostring(brick.Material):gsub("Enum%.Material%.",""):lower()
        local anch=brick.Anchored and "1" or "0"
        local parts={"SRS1",r,gv,b,mat,anch}
        -- spray text for each face
        for _,side in ipairs(ALL_SIDES_S) do
            local face=Enum.NormalId[side]
            local dec=brick:FindFirstChild("Decal_"..side) or brick:FindFirstChild(side)
            local txt=""
            if dec and dec:IsA("Decal") then txt=tostring(dec.Texture or "") end
            -- Try SurfaceGui approach too
            for _,child in ipairs(brick:GetDescendants()) do
                if child:IsA("SurfaceGui") and child.Face==face then
                    local lbl=child:FindFirstChildOfClass("TextLabel")
                    if lbl then txt=lbl.Text or "" end
                end
            end
            table.insert(parts,side..":"..txt:gsub("|","&pipe;"))
        end
        return table.concat(parts,"|")
    end

    local function decodeBrickState(str,brick,hrp,ev)
        local parts={}
        for p in str:gmatch("([^|]+)") do table.insert(parts,p) end
        if parts[1]~="SRS1" or #parts<6 then return false,"Invalid string" end
        local r=tonumber(parts[2]); local gv=tonumber(parts[3]); local b=tonumber(parts[4])
        local mat=parts[5]; local anch=parts[6]
        if not (r and gv and b) then return false,"Bad RGB" end
        local col=Color3.fromRGB(r,gv,b)
        -- Apply color+material to all sides
        for _,side in ipairs(ALL_SIDES_E) do
            ev:FireServer(brick,side,hrp.Position,HANDSHAKE,col,mat,""); task.wait(0.07)
        end
        -- Apply anchor state
        if anch=="0" and brick.Anchored then
            ev:FireServer(brick,Enum.NormalId.Front,hrp.Position,HANDSHAKE,Color3.new(1,1,1),"anchor","")
            task.wait(0.1)
        end
        -- Apply spray text per face
        for i=7,#parts do
            local chunk=parts[i]
            local side,txt=chunk:match("^(%a+):(.*)$")
            if side and txt then
                txt=txt:gsub("&pipe;","|")
                local faceEnum=Enum.NormalId[side]
                if faceEnum and txt~="" then
                    ev:FireServer(brick,faceEnum,hrp.Position,HANDSHAKE,col,"spray",txt)
                    task.wait(0.08)
                end
            end
        end
        return true,"OK"
    end

    makeButton(g,"Save Brick Settings",function(btn)
        local brick=ReplicatedStorage:FindFirstChild("Brick")
        if not brick then btn.Text="No Brick!"; return end
        local str=encodeBrickState(brick)
        pcall(function() setclipboard(str) end)
        notify("Sigma","Brick settings copied to clipboard!")
        btn.Text="Copied!"
    end)

    local _,loadBox=makeInput(g,"Paste string here","SRS1|...",function(v) end)

    makeButton(g,"Load Brick Settings",function(btn)
        local brick=ReplicatedStorage:FindFirstChild("Brick"); local ev=getToolRemote("Paint")
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not brick or not ev or not hrp then btn.Text="Missing tools!"; return end
        local str=loadBox.Text:match("^%s*(.-)%s*$")
        if str=="" then btn.Text="Paste a string first!"; return end
        btn.Text="Applying..."
        task.spawn(function()
            local ok,msg=decodeBrickState(str,brick,hrp,ev)
            btn.Text=ok and "Applied!" or ("Err: "..tostring(msg))
            task.wait(3); btn.Text="Load Brick Settings"
        end)
    end)

    makeButton(g,"Copy Current Repstorage Brick",function(btn)
        local brick=ReplicatedStorage:FindFirstChild("Brick")
        if not brick then btn.Text="No Brick!"; return end
        local str=encodeBrickState(brick)
        pcall(function() setclipboard(str) end)
        notify("Sigma","Current brick state copied (from others)!")
        btn.Text="Copied!"
    end)
end

