-- ── PAINT AURA BATCH QUEUE ───────────────────────────────────
-- Instead of FireServer once per frame per brick, queue ops and flush
-- every 0.05s. Reduces paint-aura remote calls by ~60-80%.
-- NOTE: Aura features are EXPECTED to cause lag when active.
--       When all auras are off, this queue is never touched.
local _paintBatch      = {}
local _paintBatchTimer = nil
local function queuePaintBrick(brick, color, material, mode, hrpPos)
    local key = tostring(brick)
    _paintBatch[key] = {brick=brick, color=color, material=material, mode=mode, hrp=hrpPos}
    if not _paintBatchTimer then
        _paintBatchTimer = task.delay(0.05, function()
            local ev = getToolRemoteCached("Paint")
            if ev then
                for _, d in pairs(_paintBatch) do
                    if d.brick and d.brick.Parent then
                        ev:FireServer(d.brick, Enum.NormalId.Top, d.hrp,
                            d.mode, d.color, d.material, "")
                    end
                end
            end
            _paintBatch      = {}
            _paintBatchTimer = nil
        end)
    end
end

