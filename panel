local function _jAddPlayerMemoryFact(playerName, fact)
    if not _jChatMemory[playerName] then
        _jChatMemory[playerName] = { facts = {}, lastSeen = tick() }
    end
    local mem = _jChatMemory[playerName]
    mem.lastSeen = tick()
    -- Deduplicate & cap at 8 facts
    for _, f in ipairs(mem.facts) do
        if f == fact then return end
    end
    mem.facts[#mem.facts+1] = fact
    while #mem.facts > 8 do table.remove(mem.facts, 1) end
    _jSaveChatMemory()
end

