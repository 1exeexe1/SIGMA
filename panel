do
    local gAtk = makeGroup(attacksPage, "Brick Attacks",
        "Send bricks and clones as projectiles or teleport them onto targets.")

    makeSection(attacksPage, "── Throw ───────────────────────────────────────")

    local _throwSource   = "My Folder"
    local _throwCount    = 5
    local _throwSpeed    = 80
    local _throwDist     = 200
    local _throwGravless = false
    local _throwReturn   = false

    local _, throwSrcSetValues = makeDropdown(attacksPage,
        "Throw Source", {"My Folder","Workspace Unanchored"}, "My Folder",
        function(v) _throwSource = v end)
    local _, throwCntBox = makeInput(attacksPage, "Bricks to throw",  "5",  function(v) _throwCount = tonumber(v:match("%d+")) or 5 end)
    local _, throwSpdBox = makeInput(attacksPage, "Speed (studs/s)", "80", function(v) _throwSpeed = tonumber(v:match("%d+")) or 80 end)
    local _, throwDstBox = makeInput(attacksPage, "Max travel distance", "200", function(v) _throwDist = tonumber(v:match("%d+")) or 200 end)
    throwCntBox.Text="5"; throwSpdBox.Text="80"; throwDstBox.Text="200"
    makeToggle(attacksPage, "Gravity-less projectile (keep ownership)", function(on) _throwGravless=on end, false,
        "Bricks travel in a straight line and keep ownership throughout flight.")
    makeToggle(attacksPage, "Return to player when finished", function(on) _throwReturn=on end, false,
        "Bricks fly back to you after reaching max distance.")

    makeButton(attacksPage, "Throw Bricks", function()
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then notify("Attacks","No character."); return end

        local excl = {}
        for _, inst in pairs(_activeRings) do
            for _, p in ipairs(inst.parts or {}) do excl[p] = true end
        end
        local pool = _ringGetSourceBricks(_throwSource, excl)
        if #pool == 0 then notify("Attacks","No free bricks to throw."); return end

        local count = math.min(_throwCount, #pool)
        _ringBumpOwnership()
        task.wait(0.05)

        local dir = hrp.CFrame.LookVector
        local spread = 1.5

        for i = 1, count do
            local b = pool[i]
            if not b or not b.Parent then continue end
            local offset = Vector3.new((i - count/2 - 0.5)*spread, 0, 0)
            local startPos = hrp.Position + dir*4 + offset

            task.spawn(function()
                local traveled = 0
                local prevPos  = startPos
                b.CFrame = CFrame.new(startPos)
                if _throwGravless then b.AssemblyLinearVelocity = Vector3.zero end

                local throwConn
                throwConn = RunService.Heartbeat:Connect(function(dt)
                    if not b or not b.Parent then throwConn:Disconnect(); return end
                    local vel = dir * _throwSpeed
                    if _throwGravless then
                        pcall(function()
                            b.AssemblyLinearVelocity  = vel
                            b.AssemblyAngularVelocity = Vector3.zero
                        end)
                    end
                    traveled = traveled + _throwSpeed * dt
                    if traveled >= _throwDist then
                        throwConn:Disconnect()
                        if _throwReturn then
                            -- Fly back
                            local returnConn
                            returnConn = RunService.Heartbeat:Connect(function(dt2)
                                if not b or not b.Parent then returnConn:Disconnect(); return end
                                local myHRP = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                                if not myHRP then returnConn:Disconnect(); return end
                                local toMe = (myHRP.Position - b.Position)
                                if toMe.Magnitude < 3 then
                                    returnConn:Disconnect()
                                    pcall(function() b.AssemblyLinearVelocity = Vector3.zero end)
                                    return
                                end
                                pcall(function()
                                    b.AssemblyLinearVelocity  = toMe.Unit * _throwSpeed
                                    b.AssemblyAngularVelocity = Vector3.zero
                                end)
                            end)
                        else
                            pcall(function()
                                if b and b.Parent then
                                    b.AssemblyLinearVelocity  = Vector3.zero
                                    b.AssemblyAngularVelocity = Vector3.zero
                                end
                            end)
                        end
                    end
                end)
            end)
        end
        notify("Attacks","Thrown " .. count .. " brick(s).")
    end)

    makeSection(attacksPage, "── Laser (Brick Beam) ──────────────────────────")
    makeSection(attacksPage, "Lines bricks up in a forward beam. Best with 5-20 bricks.")

    local _laserSource = "My Folder"
