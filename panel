    local _, cloneRadBox = makeInput(cloneCtrlPage, "Orbit radius", "8",   function(v) _cloneRadius = tonumber(v:match("[%d%.]+")) or 8   end)
    cloneSpdBox.Text="1.5"; cloneRadBox.Text="8"
    makeToggle(cloneCtrlPage, "Follow host angle", function(on) _cloneFollow=on end, false,
        "Clone ring rotates with the host's yaw.")

