-- ── Command parser & dispatcher ───────────────────────────────
local function dispatchCmd(rawText)
    if not S.chatCmds then return end
    local prefix = S.cmdPrefix or ";"
    if rawText:sub(1, #prefix) ~= prefix then return end
    local body = rawText:sub(#prefix + 1):match("^%s*(.-)%s*$")
    if body == "" then return end

    -- Split into tokens
    local tokens = {}
    for tok in body:gmatch("%S+") do tokens[#tokens+1] = tok end
    if #tokens == 0 then return end

    local cmdName = tokens[1]:lower()
    table.remove(tokens, 1)

    for _, cmd in ipairs(SIGMA_CMDS) do
        if cmd.name == cmdName or table.find(cmd.aliases, cmdName) then
            task.spawn(function()
                local ok, err = pcall(cmd.fn, tokens)
                if not ok then notify("CMD Error", tostring(err)) end
            end)
            return
        end
    end
    -- Unknown command: silent (don't spam notify for every normal chat message)
end

