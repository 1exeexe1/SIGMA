    onTheme(function(th) _smCurrentLbl.TextColor3 = th.ACCENT end)

    local _,_smNameBox = makeInput(_smG, "Session name", "my-session", function() end)

    local function _smUpdateLbl()
        _smCurrentLbl.Text = "Active: " .. (_aiCurrentSession or "(unsaved)")
    end

    makeButton(_smG, "💾 Save Session", function()
        local name = _smNameBox.Text
        if name == "" then notify("Jarvis","Enter a session name first."); return end
        -- Find or create
        local found = false
        for i, sess in ipairs(_aiSessions) do
            if sess.name == name then
                _aiSessions[i].history = _aiConversation
                found = true; break
            end
        end
        if not found then
            _aiSessions[#_aiSessions+1] = {name=name, history=_aiConversation, saved=os.time()}
        end
        _aiCurrentSession = name
        _jSaveSessions()
        _smUpdateLbl()
        notify("Jarvis", "Session saved: " .. name)
    end)

    makeButton(_smG, "📂 Load Session", function()
        local name = _smNameBox.Text
        for _, sess in ipairs(_aiSessions) do
            if sess.name == name then
                _aiConversation = sess.history or {}
                _aiCurrentSession = name
                _aiClearChat()
                -- Replay chat bubbles from history
                for _, msg in ipairs(_aiConversation) do
                    _aiAddBubble(msg.content:sub(1,500) .. (#msg.content > 500 and "…" or ""), msg.role)
                end
                _smUpdateLbl()
                notify("Jarvis","Session loaded: " .. name)
                return
            end
        end
        notify("Jarvis","Session not found: " .. name)
    end)

    makeButton(_smG, "🗑 Delete Session", function()
        local name = _smNameBox.Text
        for i, sess in ipairs(_aiSessions) do
            if sess.name == name then
                table.remove(_aiSessions, i)
                _jSaveSessions()
                if _aiCurrentSession == name then _aiCurrentSession = nil end
                _smUpdateLbl()
                notify("Jarvis","Deleted: " .. name); return
            end
        end
        notify("Jarvis","Not found: " .. name)
    end)

    -- List existing sessions
    local _smListLbl = makeLabel(_smG, "Saved sessions: (none)")
    local function _smRefreshList()
        if #_aiSessions == 0 then
            _smListLbl.Text = "Saved sessions: (none)"
