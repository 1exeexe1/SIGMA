local _ctCamAngleConn, _ctCamPosConn  -- declared here so mainPage + ctMenu both see them
-- Camera lock state lives in S (available at load time) so the toggles below
-- don't need ct (which is declared later, inside the Construct Tool block).
S.camLockAngle    = false
S.camLockPos      = false
S.camSavedRot     = nil   -- CFrame.Rotation snapshot
S.camSavedPos     = nil   -- Vector3 snapshot

do -- Camera lock group in main tab
    local g=makeGroup(mainPage,"Camera","Lock camera while using build tools — prevents accidental view rotation during construction.")

    makeToggle(g,"Lock Cam Angle",function(on)
        S.camLockAngle = on
        local cam = Workspace.CurrentCamera
        if on then
            S.camSavedRot = cam.CFrame.Rotation
            -- On mobile, the default touch-drag camera script overrides RenderStepped
            -- even when we force CFrame every frame.  Setting the type to Scriptable
            -- suspends Roblox's camera module entirely, so touch-drag is ignored.
            if UserInputService.TouchEnabled then
                S._camPrevType = cam.CameraType
                cam.CameraType = Enum.CameraType.Scriptable
            end
            if _ctCamAngleConn then _ctCamAngleConn:Disconnect() end
            _ctCamAngleConn = RunService.RenderStepped:Connect(function()
                if not S.camLockAngle then _ctCamAngleConn:Disconnect(); _ctCamAngleConn=nil; return end
                local c = Workspace.CurrentCamera
                c.CFrame = CFrame.new(c.CFrame.Position) * S.camSavedRot
            end)
        else
            if _ctCamAngleConn then _ctCamAngleConn:Disconnect(); _ctCamAngleConn=nil end
            -- Restore camera type when unlocking
            if UserInputService.TouchEnabled then
                cam.CameraType = S._camPrevType or Enum.CameraType.Custom
                S._camPrevType = nil
            end
        end
    end)
    makeToggle(g,"Lock Cam Pos",function(on)
        S.camLockPos = on
        if on then
            S.camSavedPos = Workspace.CurrentCamera.CFrame.Position
            if _ctCamPosConn then _ctCamPosConn:Disconnect() end
            _ctCamPosConn = RunService.RenderStepped:Connect(function()
                if not S.camLockPos then _ctCamPosConn:Disconnect(); _ctCamPosConn=nil; return end
                local c = Workspace.CurrentCamera
                c.CFrame = CFrame.new(S.camSavedPos) * c.CFrame.Rotation
            end)
        else
            if _ctCamPosConn then _ctCamPosConn:Disconnect(); _ctCamPosConn=nil end
        end
    end)

    -- ── Free Cam (moved from Misc) ────────────────────────────────
    makeToggle(g,"Free Cam",function(on)
        S.freeCam=on
        local cam=Workspace.CurrentCamera
        if on then
            -- Save old WalkSpeed before zeroing
            local hum0=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
            if hum0 then S._freeCamOldWS=hum0.WalkSpeed; hum0.WalkSpeed=0 end

            cam.CameraType=Enum.CameraType.Scriptable
            S._freeCamCF = cam.CFrame

            -- Try ControlModule disable (executor may not support require())
            local _cm=nil
            pcall(function()
                _cm=require(lp.PlayerScripts:WaitForChild("PlayerModule",3)
                    :WaitForChild("ControlModule",3))
                _cm:Disable()
            end)
            S._freeCamCM=_cm

            local freeCamConn, freeCamZoom, freeCamStep, freeCamWSLoop
            local draggingCam  = false   -- PC: RMB held
            local touchDragging= false   -- Mobile: finger on screen
            local camYaw,camPitch=0,0; local camDist=30
            local camFocus = cam.CFrame.Position + cam.CFrame.LookVector*camDist
            local _,ry,_ = cam.CFrame:ToEulerAnglesYXZ()
            camYaw = ry

            -- ── WalkSpeed enforcement loop ──────────────────────────────────
            -- Belt-and-suspenders: runs every frame to ensure the character
            -- cannot move even if ControlModule:Disable() failed or the
            -- Humanoid was replaced (e.g. by game systems).
            freeCamWSLoop = RunService.Heartbeat:Connect(function()
                if not S.freeCam then freeCamWSLoop:Disconnect(); return end
                local h=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                if h and h.WalkSpeed ~= 0 then h.WalkSpeed=0 end
            end)

            freeCamStep = RunService.RenderStepped:Connect(function(dt)
                if not S.freeCam then freeCamStep:Disconnect(); return end
                local speed = 20 * dt
                local rot = CFrame.fromEulerAnglesYXZ(camPitch, camYaw, 0)
                local fwd  = rot.LookVector
                local right= rot.RightVector
                local up   = Vector3.new(0,1,0)
                local move = Vector3.zero
                local UIS  = UserInputService
                if UIS:IsKeyDown(Enum.KeyCode.W) then move = move + fwd  * speed end
                if UIS:IsKeyDown(Enum.KeyCode.S) then move = move - fwd  * speed end
                if UIS:IsKeyDown(Enum.KeyCode.A) then move = move - right * speed end
                if UIS:IsKeyDown(Enum.KeyCode.D) then move = move + right * speed end
                if UIS:IsKeyDown(Enum.KeyCode.E) then move = move + up    * speed end
                if UIS:IsKeyDown(Enum.KeyCode.Q) then move = move - up    * speed end
                if move.Magnitude > 0 then
                    camFocus = camFocus + move
                    cam.CFrame = CFrame.new(camFocus) * rot * CFrame.new(0,0,camDist)
                end
            end)

            -- ── Mouse movement (PC RMB-drag) ────────────────────────────────
            freeCamConn = UserInputService.InputChanged:Connect(function(inp)
                if not S.freeCam then freeCamConn:Disconnect(); return end
                local rot
                if inp.UserInputType==Enum.UserInputType.MouseMovement and draggingCam then
                    local delta = inp.Delta
                    camYaw   = camYaw   - delta.X * 0.005
                    camPitch = math.clamp(camPitch - delta.Y * 0.005, -math.pi/2+0.05, math.pi/2-0.05)
                    rot = CFrame.fromEulerAnglesYXZ(camPitch, camYaw, 0)
                    cam.CFrame = CFrame.new(camFocus) * rot * CFrame.new(0,0,camDist)
                -- ── Touch drag (mobile) — no draggingCam gate needed ────────
                -- On mobile UserInputType.Touch InputChanged always fires for
                -- the active finger; we just need one touch active.
                elseif inp.UserInputType==Enum.UserInputType.Touch
                   and inp.UserInputState==Enum.UserInputState.Change
                   and touchDragging then
                    local delta = inp.Delta
                    camYaw   = camYaw   - delta.X * 0.005
                    camPitch = math.clamp(camPitch - delta.Y * 0.005, -math.pi/2+0.05, math.pi/2-0.05)
                    rot = CFrame.fromEulerAnglesYXZ(camPitch, camYaw, 0)
                    cam.CFrame = CFrame.new(camFocus) * rot * CFrame.new(0,0,camDist)
                end
            end)

            freeCamZoom = UserInputService.InputChanged:Connect(function(inp)
                if not S.freeCam then freeCamZoom:Disconnect(); return end
                if inp.UserInputType==Enum.UserInputType.MouseWheel then
                    camDist = math.clamp(camDist - inp.Position.Z*3, 3, 500)
                    local rot = CFrame.fromEulerAnglesYXZ(camPitch, camYaw, 0)
                    cam.CFrame = CFrame.new(camFocus) * rot * CFrame.new(0,0,camDist)
                end
            end)

            -- PC: RMB sets drag flag
            UserInputService.InputBegan:Connect(function(inp)
                if not S.freeCam then return end
                if inp.UserInputType==Enum.UserInputType.MouseButton2 then
                    draggingCam=true
                elseif inp.UserInputType==Enum.UserInputType.Touch then
                    touchDragging=true
                end
            end)
            UserInputService.InputEnded:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton2 then
                    draggingCam=false
                elseif inp.UserInputType==Enum.UserInputType.Touch then
                    -- Only stop dragging when ALL fingers lift
                    if #UserInputService:GetTouchState()==0 then
                        touchDragging=false
                    end
                end
            end)

            S._freeCamConn    = freeCamConn
            S._freeCamZoom    = freeCamZoom
            S._freeCamStep    = freeCamStep
            S._freeCamWSLoop  = freeCamWSLoop
        else
            if S._freeCamConn   then S._freeCamConn:Disconnect();   S._freeCamConn=nil   end
            if S._freeCamZoom   then S._freeCamZoom:Disconnect();   S._freeCamZoom=nil   end
            if S._freeCamStep   then S._freeCamStep:Disconnect();   S._freeCamStep=nil   end
            if S._freeCamWSLoop then S._freeCamWSLoop:Disconnect(); S._freeCamWSLoop=nil end
            -- Restore WalkSpeed and re-enable ControlModule
            local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed=S._freeCamOldWS or 16 end
            pcall(function() if S._freeCamCM then S._freeCamCM:Enable() end end)
            S._freeCamCM=nil
            cam.CameraType=Enum.CameraType.Custom
            local char=lp.Character
            if char and char:FindFirstChildOfClass("Humanoid") then
                cam.CameraSubject=char:FindFirstChildOfClass("Humanoid")
            end
        end
    end)
end



