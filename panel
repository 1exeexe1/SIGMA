local function _jResolveKey(raw)
    local lower = tostring(raw or ""):lower():gsub("_"," ")
    return _jKeyAliases[lower] or _jKeyAliases[raw] or raw
end

-- ── Tool executor ──────────────────────────────────────────────
local function _aiExecuteAction(actionJson)
    local ok, act = pcall(function()
        return game:GetService("HttpService"):JSONDecode(actionJson)
    end)
    if not ok or type(act) ~= "table" then return nil end

    local atype = act.sigma_action
    if not atype then return nil end

    local resultLines = {"[ACTION: " .. atype .. "]"}

    if atype == "set_toggle" then
        local key = _jResolveKey(act.key)
        local entry = _jActionRegistry[key]
        if entry and entry.set then
            local wantOn = (act.value == true or act.value == 1)
            pcall(entry.set, wantOn)
            resultLines[#resultLines+1] = key .. " → " .. (wantOn and "ON" or "OFF")
            notify("Jarvis", key .. " " .. (wantOn and "ON ✓" or "OFF ✓"))
        else
            -- Fallback: write directly to S table (for toggles not yet in registry)
            if S[key] ~= nil then
                S[key] = (act.value == true or act.value == 1)
                resultLines[#resultLines+1] = "S." .. key .. " = " .. tostring(S[key])
            else
                resultLines[#resultLines+1] = "Unknown toggle key: " .. tostring(act.key)
            end
        end

    elseif atype == "set_param" then
        local key = _jResolveKey(act.key)
        local entry = _jActionRegistry[key]
        if entry and entry.setParam then
            if key == "blockColor" then
                pcall(entry.setParam, act.r, act.g, act.b)
            else
                pcall(entry.setParam, act.value)
            end
            resultLines[#resultLines+1] = key .. " set to " .. tostring(act.value)
            notify("Jarvis", key .. " → " .. tostring(act.value))
        else
            resultLines[#resultLines+1] = "Unknown param key: " .. tostring(act.key)
        end

    elseif atype == "build_cube" then
        -- Set cube size then trigger a build if possible
        local sz = tonumber(act.size) or 3
        pcall(function()
            local entry = _jActionRegistry["cubeSize"]
            if entry then entry.setParam(sz) end
        end)
        resultLines[#resultLines+1] = "Cube size set to " .. sz .. ". Use the Build Cube button to place."
        notify("Jarvis", "Cube size → " .. sz)

    elseif atype == "equip_tool" then
        pcall(function()
            local LP   = game:GetService("Players").LocalPlayer
            local bp   = LP:FindFirstChildOfClass("Backpack")
            local name = tostring(act.tool or "")
            local tool = bp and bp:FindFirstChild(name)
            if not tool then
                for _, t in ipairs(bp and bp:GetChildren() or {}) do
                    if t:IsA("Tool") and t.Name:lower():find(name:lower()) then tool = t; break end
                end
            end
            if tool then
                tool.Parent = LP.Character
                resultLines[#resultLines+1] = "Equipped: " .. tool.Name
            else
                resultLines[#resultLines+1] = "Tool not found: " .. name
            end
        end)

    elseif atype == "set_block_color" then
        pcall(function()
            local parts = {}
            for p in tostring(act.color or ""):gmatch("%d+") do parts[#parts+1] = tonumber(p) end
            if #parts >= 3 then
                S.blockColor = Color3.fromRGB(parts[1], parts[2], parts[3])
                resultLines[#resultLines+1] = "Block color set to " .. act.color
            end
        end)

    elseif atype == "set_block_material" then
        pcall(function()
            S.blockMaterial = tostring(act.material or S.blockMaterial)
            resultLines[#resultLines+1] = "Block material set to " .. S.blockMaterial
        end)

    elseif atype == "execute" then
        -- Run arbitrary Luau and return captured output as an action result.
        -- AI uses this for "do X then tell me what happened" steps.
        -- {"sigma_action":"execute","code":"...","label":"optional description"}
        pcall(function()
            local code  = tostring(act.code or "")
            local label = tostring(act.label or "execute")
            if code == "" then
                resultLines[#resultLines+1] = "execute: no code provided"
                return
            end
            code = code:gsub('\\"','"'):gsub('\\n','\n'):gsub('\\\\','\\')
            local out = _jCaptureOutput(code)
            resultLines[#resultLines+1] = "[" .. label .. "] " .. out
            notify("Jarvis", "exec: " .. label)
        end)

    elseif atype == "execute_until" then
        -- Run `code` repeatedly until `check` returns a truthy print, or max_attempts hit.
        -- {"sigma_action":"execute_until","code":"...","check":"print(char.Humanoid.Health < 1)",
        --  "max_attempts":8,"interval":0.6,"label":"wait for oof"}
        -- `check` should print exactly "true" or "1" when the condition is met.
        pcall(function()
            local code     = tostring(act.code  or "")
            local chk      = tostring(act.check or "")
            local maxTries = math.min(tonumber(act.max_attempts) or 6, 20)
            local interval = math.max(tonumber(act.interval)     or 0.5, 0.1)
            local label    = tostring(act.label or "execute_until")

            if code == "" then resultLines[#resultLines+1] = "execute_until: no code"; return end

            code = code:gsub('\\"','"'):gsub('\\n','\n'):gsub('\\\\','\\')
            chk  = chk :gsub('\\"','"'):gsub('\\n','\n'):gsub('\\\\','\\')

            notify("Jarvis", label .. " — starting (max " .. maxTries .. " tries)")

            task.spawn(function()
                for attempt = 1, maxTries do
                    -- Run the action code
                    _jCaptureOutput(code)
                    task.wait(interval)
