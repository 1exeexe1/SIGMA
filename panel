-- ── DEPOSITS: ENLIGHTEN DEPOSIT ─────────────────────────────
do
    local g=makeGroup(depositsPage,"Enlighten Deposit","Automated enlighten storage & backup system.")

    S.enlightenDepositPos   = nil
    S.enlightenDepositBuilt = false
    S._autoEnlighten        = false
    S._autoRefill           = false
    S._notifyInvader        = false
    S._backupSlotIdx        = nil   -- index into SPREAD of the clone holding the bucket
    S._cloneSlots           = {}    -- per-slot state: "empty" | "clone" | "backup"

    -- ── Shared slot layout (compressed to fit inside the 5×5 platform) ──
    -- Offsets are relative to S.enlightenDepositPos
    local SPREAD = {
        Vector3.new(-9, 9, -9), Vector3.new( 9, 9, -9),
        Vector3.new(-9, 9,  9), Vector3.new( 9, 9,  9),
        Vector3.new(-9, 9,  0), Vector3.new( 9, 9,  0),
    }
    -- Initialise slot state table
    for i=1,#SPREAD do S._cloneSlots[i] = {state="empty"} end

    -- ── Helper: does the player currently hold the bucket?
    -- "Bucket" = any Tool in char/backpack that isn't The Arkenstone.
    local function hasBucket()
        local char=lp.Character
        if char then
            for _,t in ipairs(char:GetChildren()) do
                if t:IsA("Tool") and t.Name~="The Arkenstone" then return true end
            end
        end
        for _,t in ipairs(lp.Backpack:GetChildren()) do
            if t:IsA("Tool") and t.Name~="The Arkenstone" then return true end
        end
        return false
    end

    -- ── Make Deposit Platform ────────────────────────────────
    makeButton(g,"Make Deposit Platform",function(btn)
        btn.Text="Building..."
        task.spawn(function()
            local char=lp.Character; local hrp=char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then btn.Text="No char!"; return end
            local sp=Workspace:FindFirstChildOfClass("SpawnLocation")
            local spPos=sp and sp.Position or Vector3.new(0,0,0)
            local angle=math.random()*math.pi*2
            local dist=2000+math.random(0,200)
            local depPos=Vector3.new(spPos.X+math.cos(angle)*dist,150,spPos.Z+math.sin(angle)*dist)
            hrp.CFrame=CFrame.new(depPos+Vector3.new(0,12,0))
            task.wait(BUILD_SETTLE)
            hrp.Anchored=true
            local bEv=getToolRemote("Build")
            if not bEv then hrp.Anchored=false; btn.Text="No Build tool!"; return end
            for bx=0,4 do for bz=0,4 do
                local bp=depPos+Vector3.new((bx-2)*GRID_MULT,0,(bz-2)*GRID_MULT)
                bEv:FireServer(Workspace.Terrain,Enum.NormalId.Top,bp,"normal"); task.wait(0.06)
            end end
            hrp.Anchored=false
            -- Reset slot states for the new platform
            for i=1,#SPREAD do S._cloneSlots[i]={state="empty"} end
            S._backupSlotIdx=nil
            S.enlightenDepositPos=depPos; S.enlightenDepositBuilt=true
            notify("Deposits",string.format("Platform built @ (%.0f,%.0f,%.0f)",depPos.X,depPos.Y,depPos.Z))
            btn.Text="Platform Built!"; task.wait(3); btn.Text="Make Deposit Platform"
        end)
    end)

    -- ── Fill Deposit ─────────────────────────────────────────
    makeButton(g,"Fill Deposit",function(btn)
        if not S.enlightenDepositBuilt or not S.enlightenDepositPos then
            notify("Deposits","Build a deposit platform first!"); return
        end
        btn.Text="Filling..."
        task.spawn(function()
            local _sayCount=0
            local function safeSay(msg)
                _sayCount=_sayCount+1
                if _sayCount%5==0 then
                    task.wait(5); pcall(function() sendChat("") end); task.wait(5)
                end
                pcall(function() sendChat(msg) end); task.wait(0.8)
            end

            local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then btn.Text="No char!"; return end

            safeSay(";Mute"); safeSay(";Invisible"); safeSay(";God")
            hrp.CFrame=CFrame.new(S.enlightenDepositPos+Vector3.new(0,10,0)); task.wait(0.5)

            -- Kick Build out — Arkenstone only for clone phase
            local char=lp.Character
            if char then
                local bld=char:FindFirstChild("Build")
                if bld then bld.Parent=lp.Backpack end
            end
            pcall(function() forceEquip("The Arkenstone") end)

            local BASE=S.enlightenDepositPos
            local function goSlot(i)
                hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.CFrame=CFrame.new(BASE+SPREAD[i]); task.wait(0.3) end
            end
            local function spin180()
                hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.pi,0) end
            end

            -- Reset slot states
            for i=1,#SPREAD do S._cloneSlots[i]={state="empty"} end
            S._backupSlotIdx=nil

            -- ── Phase 1: make 6 frozen Arkenstone clones, one per slot ──
            -- v4.7.0: reduced clone wait 1.8 → 1.2s (server replication confirmed safe)
            for i=1,#SPREAD do
                goSlot(i)
                safeSay(";Freeze"); task.wait(0.3)
                safeSay(";Clone"); task.wait(1.2)
                safeSay(";Unfreeze"); spin180()
                S._cloneSlots[i].state="clone"
            end

            -- ── Phase 2: gear the bucket, find which clone takes it ──
            safeSay(";Gear 25162389"); task.wait(1.2) -- wait for gear to appear

            -- Kick any non-Arkenstone tool that slipped in before the gear arrived
            char=lp.Character
            if char then
                for _,t in ipairs(char:GetChildren()) do
                    if t:IsA("Tool") and t.Name~="The Arkenstone" and not hasBucket() then
                        -- hasBucket() not true yet means the gear hasn't arrived —
                        -- this branch intentionally left empty; just waiting below
                    end
                end
            end

            -- Walk each slot; the first one that takes the bucket is flagged "backup"
            local bucketFound=false
            for i=1,#SPREAD do
                if not hasBucket() then
                    -- Bucket hasn't arrived in char yet — unusual, keep waiting
                    task.wait(0.5)
                end
                goSlot(i); task.wait(0.4)
                if not hasBucket() then
                    -- Clone i took the bucket
                    S._cloneSlots[i].state="backup"
                    S._backupSlotIdx=i
                    bucketFound=true
                    notify("Deposits","Deposit filled! Backup clone: slot "..i)
                    break
                end
            end
            if not bucketFound then
                notify("Deposits","\226\154\160 No clone took the bucket \226\128\148 try again or clean & refill.")
            end

            btn.Text="Fill Done!"; task.wait(3); btn.Text="Fill Deposit"
        end)
    end)

    -- ── Auto-Enlighten ───────────────────────────────────────
    makeToggle(g,"Auto-Enlighten",function(on)
        S._autoEnlighten=on
        if on then
            task.spawn(function()
                while S._autoEnlighten do
                    repeat
                    task.wait(5)
                    -- Guard: deposit must exist and have a backup clone
                    if not S.enlightenDepositBuilt or not S.enlightenDepositPos then break end
                    if not S._backupSlotIdx then
                        notify("Auto-Enlighten","No backup clone \226\128\148 fill deposit first!"); break
                    end
                    local char=lp.Character; if not char then break end
                    local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then break end

                    -- Check if player already has enlighten — if so, nothing to do
                    local hasArken=char:FindFirstChild("The Arkenstone")
                        or lp.Backpack:FindFirstChild("The Arkenstone")
                    if hasArken then break end

                    -- ── Step 1: TP to backup clone slot to grab the bucket ──
                    local BASE=S.enlightenDepositPos
                    hrp.CFrame=CFrame.new(BASE+SPREAD[S._backupSlotIdx]); task.wait(0.5)
                    char=lp.Character; hrp=char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then break end

                    if not hasBucket() then
                        notify("Auto-Enlighten","\226\154\160 Couldn't grab bucket from backup clone \226\128\148 slot may be empty.")
                        break
                    end

                    -- ── Step 2: TP to a random clone slot to give it the bucket ──
                    local candidates={}
                    for i,slot in ipairs(S._cloneSlots) do
                        repeat
                        if i~=S._backupSlotIdx and slot.state=="clone" then
                            candidates[#candidates+1]=i
                        end
                        until true
                    end
                    if #candidates==0 then
                        notify("Auto-Enlighten","No clone slots left \226\128\148 refill deposit!"); break
                    end

                    local oldBackup=S._backupSlotIdx
                    local targetIdx=candidates[math.random(1,#candidates)]
                    hrp.CFrame=CFrame.new(BASE+SPREAD[targetIdx]); task.wait(0.5)

                    if not hasBucket() then
                        -- Clone took the bucket — rotate the flags
                        S._cloneSlots[oldBackup].state="empty"
                        S._cloneSlots[targetIdx].state="backup"
                        S._backupSlotIdx=targetIdx
                        notify("Auto-Enlighten","\226\156\147 Enlighten refreshed! New backup: slot "..targetIdx)
                    else
                        notify("Auto-Enlighten","Clone didn't take bucket \226\128\148 retrying next cycle.")
                    end
                    until true
                end
            end)
        end
    end)

    makeToggle(g,"Auto-Refill",function(on) S._autoRefill=on end)

    -- ── Notify Invader ───────────────────────────────────────
    makeToggle(g,"Notify Invader",function(on)
        S._notifyInvader=on
        if on then
            local _invaderCooldowns={}
            task.spawn(function()
                while S._notifyInvader do
                    task.wait(3)
                    if S.enlightenDepositPos then
                        local now=tick()
                        for _,p in ipairs(Players:GetPlayers()) do
                            if p~=lp and p.Character then
                                local pHrp=p.Character:FindFirstChild("HumanoidRootPart")
                                if pHrp and (pHrp.Position-S.enlightenDepositPos).Magnitude<60 then
                                    local last=_invaderCooldowns[p.UserId] or 0
                                    if (now-last)>=30 then
                                        _invaderCooldowns[p.UserId]=now
                                        notify("\226\154\160 Deposit","Invader near deposit: "..p.DisplayName)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end
    end)

    -- ── Clean Deposit ────────────────────────────────────────
    makeButton(g,"\240\159\167\185 Clean Deposit",function(btn)
        btn.Text="Cleaning..."
        task.spawn(function()
            pcall(function() sendChat(";Delclones") end)
            task.wait(2)
            -- Reset all slot states after cleaning
            for i=1,#SPREAD do S._cloneSlots[i]={state="empty"} end
            S._backupSlotIdx=nil
            btn.Text="Cleaned!"; task.wait(2); btn.Text="\240\159\167\185 Clean Deposit"
        end)
    end)

    -- ── Rebuild Deposit ──────────────────────────────────────
    makeButton(g,"\240\159\148\129 Rebuild Deposit",function(btn)
        if not S.enlightenDepositPos then
            notify("Deposits","No deposit position saved \226\128\148 use Make Deposit Platform first!"); return
        end
        btn.Text="Rebuilding..."
        task.spawn(function()
            local char=lp.Character; local hrp=char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then btn.Text="No char!"; return end
            local depPos=S.enlightenDepositPos
            hrp.CFrame=CFrame.new(depPos+Vector3.new(0,12,0))
            task.wait(BUILD_SETTLE); hrp.Anchored=true
            local bEv=getToolRemote("Build")
            if not bEv then hrp.Anchored=false; btn.Text="No Build tool!"; return end
            for bx=0,4 do for bz=0,4 do
                local bp=depPos+Vector3.new((bx-2)*GRID_MULT,0,(bz-2)*GRID_MULT)
                bEv:FireServer(Workspace.Terrain,Enum.NormalId.Top,bp,"normal"); task.wait(0.06)
            end end
            hrp.Anchored=false
            S.enlightenDepositBuilt=true
            notify("Deposits","Platform rebuilt @ existing position!")
            btn.Text="Rebuilt!"; task.wait(3); btn.Text="\240\159\148\129 Rebuild Deposit"
        end)
    end)
end -- ╚═ ENLIGHTEN DEPOSIT ══╝

