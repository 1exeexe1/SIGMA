snapToGrid = function(pos)
    local m = GRID_MULT
    local function snapAxis(n) return math.round((n-2)/m)*m+2 end
    return Vector3.new(snapAxis(pos.X), snapAxis(pos.Y), snapAxis(pos.Z))
end

-- Returns the HumanoidRootPart (or PrimaryPart) of a character model.
getRoot = function(char)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

local function posAround(part, minR, maxR)
    local d = math.random()*(maxR-minR)+minR
    local t = math.random()*math.pi*2
    local phi = math.acos(2*math.random()-1)
    return part.Position + Vector3.new(
        d*math.sin(phi)*math.cos(t),
        d*math.cos(phi),
        d*math.sin(phi)*math.sin(t)
    )
end

local function nearestPart(maxR)
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local folder = getBricksFolder()
                or Workspace:FindFirstChild("PlacedBlocks")
    if not folder then return end
    local out = {}
    for _, p in ipairs(folder:GetDescendants()) do
        if p:IsA("BasePart") and (hrp.Position-p.Position).Magnitude <= maxR then
            out[#out+1] = p
        end
    end
    return #out > 0 and out[math.random(1,#out)] or nil
end

local function removeCollision(obj)
    if not obj then return end
    for _, p in ipairs(obj:GetDescendants()) do
        if p:IsA("BasePart") then p.CanCollide = false end
    end
end

