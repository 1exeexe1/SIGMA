    -- Blur
    makeToggle(g,"Anti-Blur",function(on)
        S.antiBlur=on
        if not on then local b=Lighting:FindFirstChild("Blur"); if b then b.Enabled=true end end
    end)
    -- Drag
    makeToggle(g,"Anti-Drag",function(on) S.antiDrag=on end)
    -- Fling
    -- Smart Anti-Fling v2: per-player threat tracking instead of blanket CanCollide=false.
    -- Detects three threat patterns and responds differently to each:
    --   N1 — Exploiter flings: walkfling (close-range velocity spike), jumpkick (vertical spike),
    --         fly+spin (rapid angular + linear combo from airborne player).
    --   N2 — Enlighten "Fling" command: sudden massive horizontal velocity applied to OUR hrp
    --         from a server-side push; countered by nullifying external force on our hrp each frame.
    -- Strategy:
    --   • Track each OTHER player's HRP velocity history (3-frame rolling window).
    --   • If a player's velocity is erratic (spike > FLING_SPIKE_MAG in one frame) AND they are
    --     within FLING_RANGE studs, classify them as a threat and noclip ONLY that player's char
    --     (CanCollide=false on their parts) — not everyone indiscriminately.
    --   • Our own HRP is protected: any horizontal velocity above FLING_OWN_MAX is zeroed each
    --     Stepped frame, and seat-state is cleared (covers Enlighten Fling command).
    --   • CanCollide is restored on threat players once their velocity calms down for 2+ seconds
    --     (FLING_CALM_TIME). This prevents permanent noclip on innocent players.
    makeToggle(g,"Anti-Fling",function(on)
        S.antiFling=on
        if on then
            -- Per-player state: {lastVel, spikeTick, threatTick, isThreat}
            local _afState = {}   -- [player] = state table
            local FLING_RANGE      = 30   -- studs: only watch players this close
            local FLING_SPIKE_MAG  = 55   -- velocity delta (studs/s) in one frame = suspicious
            local FLING_OWN_MAX    = 75   -- our own horiz vel cap (covers Enlighten fling)
            local FLING_CALM_TIME  = 2.0  -- seconds of calm before threat is cleared
            local FLING_SPIN_MAG   = 8    -- rad/s angular magnitude = fly+spin pattern

            S._flingConn2=RunService.Stepped:Connect(function()
                if not S.antiFling then return end
                local char=lp.Character; if not char then return end
                local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
                local hum=char:FindFirstChildOfClass("Humanoid")
                local now=tick()

                -- ── Protect OUR character ──────────────────────────────────
                -- Clear seat state (exploiters seat you to immobilise + fling)
                if hum and hum:GetState()==Enum.HumanoidStateType.Seated then
                    hum:SetStateEnabled(Enum.HumanoidStateType.Seated,false)
                    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                    hrp.AssemblyLinearVelocity=Vector3.zero
                end
                -- Nullify external horizontal force (covers Enlighten Fling command &
                -- exploit walkfling that targets our velocity directly)
                local vel=hrp.AssemblyLinearVelocity
                local horizMag=Vector2.new(vel.X,vel.Z).Magnitude
                if horizMag>FLING_OWN_MAX then
                    hrp.AssemblyLinearVelocity=Vector3.new(0,math.min(vel.Y,60),0)
                end

                -- ── Per-player threat detection ────────────────────────────
                local myPos=hrp.Position
                for _,p in pairs(Players:GetPlayers()) do
                    if p~=lp then
                        local pchar=p.Character
                        local phrp=pchar and pchar:FindFirstChild("HumanoidRootPart")
                        if pchar and phrp then
                            local dist=(phrp.Position-myPos).Magnitude
                            if dist>FLING_RANGE then
                                -- Out of range: restore collision if they were flagged
                                local st=_afState[p]
                                if st and st.isThreat then
                                    for _,part in pairs(pchar:GetDescendants()) do
                                        if part:IsA("BasePart") then pcall(function() part.CanCollide=true end) end
                                    end
                                    st.isThreat=false
                                end
                            else
                                -- In range: track and classify
                                if not _afState[p] then
                                    _afState[p]={lastVel=phrp.AssemblyLinearVelocity,spikeTick=0,threatTick=0,isThreat=false}
                                end
                                local st=_afState[p]
                                local curVel=phrp.AssemblyLinearVelocity
                                local delta=(curVel-st.lastVel).Magnitude
                                local angMag=phrp.AssemblyAngularVelocity.Magnitude
                                local isSpiking=(delta>FLING_SPIKE_MAG) or (angMag>FLING_SPIN_MAG and curVel.Magnitude>40)
                                st.lastVel=curVel

                                if isSpiking then
                                    st.spikeTick=now
                                    if not st.isThreat then
                                        st.isThreat=true; st.threatTick=now
                                        for _,part in pairs(pchar:GetDescendants()) do
                                            if part:IsA("BasePart") then pcall(function() part.CanCollide=false end) end
                                        end
                                        if S.antiNotify then notify("Anti-Fling","Threat: "..p.Name,3) end
                                    end
                                elseif st.isThreat and (now-st.spikeTick)>FLING_CALM_TIME then
                                    st.isThreat=false
                                    for _,part in pairs(pchar:GetDescendants()) do
                                        if part:IsA("BasePart") then pcall(function() part.CanCollide=true end) end
                                    end
                                end
                            end
                        end
                    end
                end

                -- GC: remove state for players who left
                for p in pairs(_afState) do
                    if not p.Parent then _afState[p]=nil end
                end
            end)
        else
            if S._flingConn2 then S._flingConn2:Disconnect(); S._flingConn2=nil end
            -- Restore Seated state and CanCollide on all players
            local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
            if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Seated,true) end
            for _,p in pairs(Players:GetPlayers()) do
                if p~=lp and p.Character then
                    for _,part in pairs(p.Character:GetDescendants()) do
                        if part:IsA("BasePart") then pcall(function() part.CanCollide=true end) end
                    end
                end
            end
        end
    end)
    -- Fog
    makeToggle(g,"Anti-Fog",function(on)
        S.antiFog=on
        if not on then
            local atm=Lighting:FindFirstChildOfClass("Atmosphere")
            if atm then atm.Density=S._origFogDensity or 0.3 end
        end
    end)
    -- Freeze
    makeToggle(g,"Anti-Freeze (Hielo)",function(on)
        S.antiFreeze=on
        if on then
            local char=lp.Character
            if char then
                local hrp=char:FindFirstChild("HumanoidRootPart")
                local torso=char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                local hum=char:FindFirstChildOfClass("Humanoid")
                if hum and ((hrp and hrp.Anchored) or (torso and torso.Transparency>=0.9) or char:FindFirstChild("Hielo")) then
                    hum.Health=0
                end
            end
        end
    end)
    -- Glitch
    makeToggle(g,"Anti-Glitch",function(on) S.antiGlitch=on end)
    -- Jail
    makeToggle(g,"Anti-Jail",function(on)
        S.antiJail=on
        if on and lp.Character and lp.Character:FindFirstChild("Jail") then removeCollision(lp.Character.Jail) end
    end)
    -- Kick
    makeToggle(g,"Anti-Kick",function(on)
        S.antiKick=on
        if on then pcall(function()
            if hookfunction then S._oldKickFn=hookfunction(lp.Kick,function() end) end
            if hookmetamethod then
                S._oldKickHook=hookmetamethod(game,"__namecall",function(self,...)
                    if self==lp and getnamecallmethod():lower()=="kick" then return end
                    return S._oldKickHook(self,...)
                end)
            end
        end) else pcall(function()
            if S._oldKickFn and hookfunction then hookfunction(lp.Kick,S._oldKickFn) end
            if S._oldKickHook and hookmetamethod then hookmetamethod(game,"__namecall",S._oldKickHook) end
        end) end
    end)
    -- NaN (Maptide NaN protection)
    makeToggle(g,"Anti-NaN",function(on)
        S.antiNan=on
    end)
    makeSection(g,"Counters Maptide NaN: on death/void-spawn → TP to map center. TP-to-Death still saves your last real position.")
    makeToggle(g,"Anti-Knockback",function(on)
        S.antiKB=on
        if on then
            S._kbConn=RunService.Heartbeat:Connect(function()
                if not S.antiKB then return end
                local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
                local vel=hrp.AssemblyLinearVelocity
                local horizMag=Vector2.new(vel.X,vel.Z).Magnitude
                if horizMag>40 then hrp.AssemblyLinearVelocity=Vector3.new(0,vel.Y,0) end
                if vel.Y>80 then hrp.AssemblyLinearVelocity=Vector3.new(vel.X,0,vel.Z) end
            end)
        else
            if S._kbConn then S._kbConn:Disconnect(); S._kbConn=nil end
        end
    end)
    -- Myopic
    makeToggle(g,"Anti-Myopic",function(on) S.antiMyopic=on end)
    -- NoColor
    makeToggle(g,"Anti-NoColor",function(on)
        S.antiNoColor=on
        if not on then local r=Lighting:FindFirstChild("RGB"); if r then r.Enabled=true end end
    end)
    -- Ragdoll
    makeToggle(g,"Anti-Ragdoll",function(on)
        S.antiRagdoll=on
        if on then
            S._ragConn=RunService.Stepped:Connect(function()
                local char=lp.Character; if not char then return end
                local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return end
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
                hum:SetStateEnabled(Enum.HumanoidStateType.Seated,false)
                local st=hum:GetState()
                if st==Enum.HumanoidStateType.Ragdoll or st==Enum.HumanoidStateType.FallingDown then
                    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
                for _,v in ipairs(char:GetDescendants()) do
                    if v:IsA("BallSocketConstraint") or v:IsA("HingeConstraint") or v:IsA("NoCollisionConstraint") then v:Destroy() end
                end
            end)
        else
            if S._ragConn then S._ragConn:Disconnect(); S._ragConn=nil end
        end
    end)
    -- Stun
    makeToggle(g,"Anti-Stun",function(on) S.antiStun=on end)
    -- Toxic
    makeToggle(g,"Anti-Toxic",function(on)
        S.antiToxic=on
        for _,c in pairs(S._toxicConns) do pcall(function() c:Disconnect() end) end; S._toxicConns={}
        if on then
            local function disableTouch(part)
                if part:IsA("BasePart") then
                    pcall(function() part.CanTouch=false; part.CanQuery=false end)
                    S._toxicConns[#S._toxicConns+1]=part:GetPropertyChangedSignal("CanTouch"):Connect(function()
                        if S.antiToxic then pcall(function() part.CanTouch=false end) end
                    end)
                end
            end
            local function hookChar(char)
                for _,part in pairs(char:GetDescendants()) do disableTouch(part) end
                S._toxicConns[#S._toxicConns+1]=char.DescendantAdded:Connect(function(part)
                    if S.antiToxic then disableTouch(part) end
                end)
            end
            for _,p in pairs(Players:GetPlayers()) do
                if p~=lp and p.Character then hookChar(p.Character) end
                S._toxicConns[#S._toxicConns+1]=p.CharacterAdded:Connect(function(char)
                    task.wait(0.1); if S.antiToxic then hookChar(char) end
                end)
            end
            local bricks=getBricksFolder()
            if bricks then
                for _,part in pairs(bricks:GetDescendants()) do
                    if part:IsA("BasePart") then pcall(function() part.CanTouch=false end) end
                end
                S._toxicConns[#S._toxicConns+1]=bricks.DescendantAdded:Connect(function(part)
                    if S.antiToxic and part:IsA("BasePart") then pcall(function() part.CanTouch=false end) end
                end)
            end
        end
    end, true)
    -- Void
    makeToggle(g,"Anti-Void",function(on)
        S.antiVoid=on
        if on then
            S._avOrig=Workspace.FallenPartsDestroyHeight
            pcall(function() Workspace.FallenPartsDestroyHeight=-50000 end)
            local function doChar(char)
                local hrp=char:WaitForChild("HumanoidRootPart",5); if not hrp then return end
                S._avConn=RunService.Stepped:Connect(function()
                    if hrp.Position.Y<((S._avOrig or -500)+5) then
                        for _,p in pairs(char:GetDescendants()) do
                            if p:IsA("BasePart") then
                                p.AssemblyLinearVelocity  = Vector3.zero
                                p.AssemblyAngularVelocity = Vector3.zero
                            end
                        end
                        char:PivotTo(CFrame.new(hrp.Position.X,(S._avOrig or -500)+25,hrp.Position.Z))
                    end
                end)
            end
            if lp.Character then doChar(lp.Character) end
            S._avCharConn=lp.CharacterAdded:Connect(doChar)
        else
            if S._avConn then S._avConn:Disconnect(); S._avConn=nil end
            if S._avCharConn then S._avCharConn:Disconnect(); S._avCharConn=nil end
            if S._avOrig then pcall(function() Workspace.FallenPartsDestroyHeight=S._avOrig end) end
        end
    end, true)
    -- WalkSpeed
    makeToggle(g,"Anti-WalkSpeed",function(on) S.antiWS=on end)
    -- Auto-Fix Camera (utility, not strictly an "anti" — kept at bottom)
    makeToggle(g,"Auto-Fix Camera",function(on) S.autoFixCam=on; if on then fixPlayerState() end end)
    makeButton(g,"Manual UI Restore",function() fixPlayerState() end)
end

