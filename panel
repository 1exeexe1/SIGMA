-- Brush input handlers (same as Construct)
local _brMouse=lp:GetMouse()
local _brClickConn,_brUpConn,_brDragConn

local function brHandleClick()
    if not br.equipped or br.painting then return end
    local target=_brMouse.Target
    if br.moveArea then
        if target then
            local nv=CT_NORM_VEC[_brMouse.TargetSurface] or Vector3.new(0,1,0)
            local hp=_brMouse.Hit.Position
            if hp.Magnitude<5000 then br.origin=snapToGrid(hp+nv*(CT_GRID*0.5)); br.placed=true; brSyncZone(); brSizeLblUpdate() end
        end; return
    end
    for key,h in pairs(brHandles) do
        if target==h then
            br.dragging=true; br.dragKey=key; br.dragStartMouse=_brMouse.Hit.Position
            br.dragStartOrigin=br.origin; br.dragStartSX=br.sX; br.dragStartSY=br.sY; br.dragStartSZ=br.sZ; return
        end
    end
    if target then
        local nv=CT_NORM_VEC[_brMouse.TargetSurface] or Vector3.new(0,1,0)
        local hp=_brMouse.Hit.Position
        if hp.Magnitude<5000 then
            if _scaRefreshOnClick or not br.placed then
                br.origin=snapToGrid(hp+nv*(CT_GRID*0.5)); br.sX=1;br.sY=1;br.sZ=1; br.placed=true
            end
            brSyncZone(); brSizeLblUpdate()
        end
    end
end

local function brHandleDrag()
    if not br.dragging or not br.dragKey then return end
    if _scaActiveTouchId and #UserInputService:GetTouchState() > 1 then return end
    local hp = getMouseWorldHit(_brMouse, br.dragStartMouse)
    if hp.Magnitude > 20000 then return end
    local info=CT_FACES[br.dragKey]; local ax,dir=info.ax,info.dir
    local axV=ax=="X" and Vector3.new(1,0,0) or (ax=="Y" and Vector3.new(0,1,0) or Vector3.new(0,0,1))
    local rawD=(hp-br.dragStartMouse):Dot(axV)
    local blkD=math.clamp(math.floor(rawD/CT_GRID+0.5),-200,200)
    if dir>0 then
        local sS=ax=="X" and br.dragStartSX or (ax=="Y" and br.dragStartSY or br.dragStartSZ)
        local nS=math.max(1,sS+blkD)
        if ax=="X" then br.sX=nS elseif ax=="Y" then br.sY=nS else br.sZ=nS end
    else
        local sS=ax=="X" and br.dragStartSX or (ax=="Y" and br.dragStartSY or br.dragStartSZ)
        local nS=math.max(1,sS-blkD); local sh=(sS-nS)*CT_GRID
        if ax=="X" then br.sX=nS; br.origin=Vector3.new(br.dragStartOrigin.X+sh,br.origin.Y,br.origin.Z)
        elseif ax=="Y" then br.sY=nS; br.origin=Vector3.new(br.origin.X,br.dragStartOrigin.Y+sh,br.origin.Z)
        else br.sZ=nS; br.origin=Vector3.new(br.origin.X,br.origin.Y,br.dragStartOrigin.Z+sh) end
    end
    brSyncZone(); brSizeLblUpdate()
end

