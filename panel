-- ── HELPERS: show/hide MainFrame with fancy scale-from-bubble ────────────
-- Animation breakdown (uiAnim=true):
--   Open : panel scales up from the bubble's screen position → full size
--          with a spring-style Bounce easing. Accent UIStroke pulses once.
--   Close: panel shrinks back toward bubble with Quad InOut, then hides.
--   Minimize/Restore: height-only tween with Quad Out (unchanged feel).
-- uiAnim=false: instant show/hide as before — zero extra cost.
local _panelTI      = TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
local _panelOpenTI  = TweenInfo.new(0.22,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
local _panelCloseTI = TweenInfo.new(0.16,Enum.EasingStyle.Quad,Enum.EasingDirection.InOut)
local _panelMinTI   = TweenInfo.new(0.18,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)

-- UIStroke on MainFrame — used for the open-pulse effect only.
local _mainStroke = Instance.new("UIStroke")
_mainStroke.Color     = T.ACCENT
_mainStroke.Thickness = 0
_mainStroke.Parent    = MainFrame
onTheme(function(th) _mainStroke.Color = th.ACCENT end)

local function _pulseStroke()
    -- Quick accent-stroke flash: 0 → 2 → 0 over 0.35 s
    _mainStroke.Thickness = 0
    TweenService:Create(_mainStroke, TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
        {Thickness=2}):Play()
    task.delay(0.13, function()
        TweenService:Create(_mainStroke, TweenInfo.new(0.22,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
            {Thickness=0}):Play()
    end)
end

local function showPanel()
    guiVisible=true; panelMinimized=false
    ContentArea.Visible=true; SideBar.Visible=true
    local tb=tabPages[S.activeTab or "Main"]
    if tb then tb.Visible=true end

    if S.uiAnim then
        -- Compute bubble screen position relative to ScreenGui so we can
        -- start the panel "at" the bubble and expand outward.
        local bubAbs  = bubble.AbsolutePosition
        local bubSz   = bubble.AbsoluteSize
        local bubCX   = bubAbs.X + bubSz.X/2
        local bubCY   = bubAbs.Y + bubSz.Y/2
        -- Tiny starting size centred on the bubble
        local startW, startH = 60, 26
        MainFrame.Size     = UDim2.new(0, startW, 0, startH)
        MainFrame.Position = UDim2.new(0, bubCX - startW/2, 0, bubCY - startH/2)
        MainFrame.BackgroundTransparency = 0.6
        MainFrame.Visible  = true
        -- Animate to full size + original position simultaneously
        TweenService:Create(MainFrame, _panelOpenTI, {
            Size                 = UDim2.new(0,500,0,PANEL_FULL_H),
            Position             = UDim2.new(0.5,-250,0.5,-170),
            BackgroundTransparency = 0,
        }):Play()
        _pulseStroke()
    else
        MainFrame.Size     = UDim2.new(0,500,0,PANEL_FULL_H)
        MainFrame.Position = UDim2.new(0.5,-250,0.5,-170)
        MainFrame.BackgroundTransparency = 0
        MainFrame.Visible  = true
    end
end

local function hidePanel()
    guiVisible=false; panelMinimized=false
    if S.uiAnim then
        -- Shrink toward bubble
        local bubAbs = bubble.AbsolutePosition
        local bubSz  = bubble.AbsoluteSize
        local bubCX  = bubAbs.X + bubSz.X/2
        local bubCY  = bubAbs.Y + bubSz.Y/2
        TweenService:Create(MainFrame, _panelCloseTI, {
            Size                 = UDim2.new(0, 40, 0, 16),
            Position             = UDim2.new(0, bubCX-20, 0, bubCY-8),
            BackgroundTransparency = 1,
        }):Play()
        task.delay(0.17, function()
            MainFrame.Visible  = false
            -- Reset so next open starts clean
            MainFrame.BackgroundTransparency = 0
        end)
    else
        MainFrame.Visible=false
    end
end

-- ── MINIMIZE: collapse to top-bar strip ──────────────────────
local function minimizePanel()
