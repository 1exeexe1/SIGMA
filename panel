    -- ── Multi-Chat ───────────────────────────────────────────────
    -- Extra chat input bars (Chat2–Chat5) positioned below the
    -- Roblox default chat input at bottom-left of screen.
    -- Each bar has a TextBox + a ➤ send button themed to T.ACCENT.
    -- ClearTextOnFocus=false so users can pre-compose messages.
    do
        local mcGui      -- ScreenGui housing all extra bars
        local mcBars = {}  -- array of Frame rows

        -- Tries modern TextChatService first, falls back to deprecated Chat.
        local function _mcSend(msg)
            if msg == "" then return end
            pcall(function()
                local ch = game:GetService("TextChatService")
                    :FindFirstChild("TextChannels")
                    and game:GetService("TextChatService").TextChannels
                    :FindFirstChild("RBXGeneral")
                if ch then ch:SendAsync(msg) return end
            end)
            -- legacy fallback
            pcall(function() game:GetService("Chat"):Chat(lp.Character, msg) end)
        end

        local function _mcBuildBar(index)
            -- index 1 = Chat2, 2 = Chat3, …
            -- Stack bars above the Roblox chat input (roughly 50px from bottom)
            -- Each bar is 28px tall with 4px gap between bars.
            local BAR_H = 28
            local BAR_GAP = 4
            local BASE_OFFSET = 54   -- clears Roblox's chat input
            local yOff = BASE_OFFSET + (index - 1) * (BAR_H + BAR_GAP)

            local bar = Instance.new("Frame")
            bar.Size  = UDim2.new(0, 300, 0, BAR_H)
            bar.Position = UDim2.new(0, 4, 1, -yOff)
            bar.BackgroundColor3 = Color3.fromRGB(10, 10, 14)
            bar.BorderColor3 = T.ACCENT
            bar.ZIndex = 30
            bar.Parent = mcGui
            onTheme(function(th) bar.BorderColor3 = th.ACCENT end)

            local tb = Instance.new("TextBox", bar)
            tb.Size  = UDim2.new(1, -32, 1, -4)
            tb.Position = UDim2.new(0, 2, 0, 2)
            tb.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
            tb.BorderColor3 = T.BORDER
            tb.PlaceholderText = "Chat " .. (index + 1) .. "…"
            tb.Text = ""
            tb.TextColor3 = T.WHITE
            tb.PlaceholderColor3 = Color3.fromRGB(90, 90, 110)
            tb.FontFace = FONT_MAIN
            tb.TextSize = 12
            tb.TextXAlignment = Enum.TextXAlignment.Left
            tb.ClearTextOnFocus = false
            tb.ZIndex = 31
            onTheme(function(th)
                tb.BorderColor3 = th.BORDER
                tb.TextColor3   = th.WHITE
            end)
            -- Send on Enter
            tb.FocusLost:Connect(function(entered)
                if entered then _mcSend(tb.Text) end
            end)

            -- ➤ send button (accent-colored, square — Dev Rule 6)
            local btn = Instance.new("TextButton", bar)
            btn.Size     = UDim2.new(0, 28, 1, -4)
            btn.Position = UDim2.new(1, -30, 0, 2)
            btn.BackgroundColor3 = T.ACCENT
            btn.BorderColor3     = T.BORDER
            btn.Text      = "\226\158\164"   -- ➤
            btn.TextColor3 = T.WHITE
            btn.FontFace  = FONT_MAIN
            btn.TextSize  = 14
            btn.ZIndex    = 31
            onTheme(function(th)
                btn.BackgroundColor3 = th.ACCENT
                btn.BorderColor3     = th.BORDER
            end)
            btn.MouseButton1Click:Connect(function()
                _mcSend(tb.Text)
            end)

            return bar
        end

        local function _mcApply()
            -- Tear down existing bars
            for _, b in ipairs(mcBars) do pcall(function() b:Destroy() end) end
            mcBars = {}
            if not S.multiChat then return end
            if not mcGui or not mcGui.Parent then
                mcGui = Instance.new("ScreenGui")
                mcGui.Name = "SigmaMultiChat"
                mcGui.ResetOnSpawn = false
                mcGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
                pcall(function() mcGui.Parent = game:GetService("CoreGui") end)
                if not mcGui.Parent then mcGui.Parent = lp:FindFirstChild("PlayerGui") or lp.PlayerGui end
            end
            for i = 1, S.multiChatCount do
                mcBars[i] = _mcBuildBar(i)
            end
        end

        -- Toggle
        makeToggle(g, "Enable Multi-Chat", function(on)
            S.multiChat = on
            _mcApply()
            notify("Sigma", "Multi-Chat " .. (on and "ON (" .. S.multiChatCount .. " extra)" or "OFF"))
        end, false,
        "Adds extra chat input bars below the Roblox chat. Pre-compose messages for quick use in fast-paced situations. ClearTextOnFocus is off — click again without losing your text.")

        -- Dropdown: how many extra bars
        local MC_OPTS = {"+1", "+2", "+3", "+4"}
        makeDropdown(g, "Extra Chats", MC_OPTS, nil, function(sel)
            local n = tonumber(sel:match("%d+")) or 1
            S.multiChatCount = n
            if S.multiChat then _mcApply() end
        end)
        makeSection(g, "+1 = Chat2 only,  +4 = Chat2–Chat5")
    end

