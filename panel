brMkBtn("\240\159\142\168 Paint Zone",6,true,function(btn)
    if not br.placed then notify("Sigma","Place zone first!"); return end
    if br.painting then return end
    br.painting=true
    btn.Text="Painting..."
    task.spawn(function()
        local ev=getToolRemote("Paint")
        if not ev then notify("Sigma","Paint tool not found!"); br.painting=false; btn.Text="\240\159\142\168 Paint Zone"; return end
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then br.painting=false; btn.Text="\240\159\142\168 Paint Zone"; return end

        -- Collect all brick positions in zone
        local bf=getBricksFolder()
        if not bf then notify("Sigma","No Bricks folder!"); br.painting=false; btn.Text="\240\159\142\168 Paint Zone"; return end

        local targets={}
        local checkP=nil; pcall(function() checkP=OverlapParams.new(); checkP.FilterType=Enum.RaycastFilterType.Include end)
        if not checkP then notify("Sigma","OverlapParams not supported!"); br.painting=false; btn.Text="Paint Zone"; return end
        checkP.FilterDescendantsInstances={bf}
        for by=0,br.sY-1 do for bx=0,br.sX-1 do for bz=0,br.sZ-1 do
            local pos=br.origin+Vector3.new(bx*CT_GRID,by*CT_GRID,bz*CT_GRID)
            local hits=Workspace:GetPartBoundsInBox(CFrame.new(pos),Vector3.new(3,3,3),checkP)
            for _,h in ipairs(hits) do
                if h:IsA("BasePart") and not table.find(targets,h) then targets[#targets+1]=h end
            end
        end end end

        if #targets==0 then notify("Sigma","No blocks in zone!"); br.painting=false; btn.Text="\240\159\142\168 Paint Zone"; return end

        local wantCol = br.color
        local wantMat = br.material
        local painted = 0

        local function blockNeedsPaint(b)
            if not b or not b.Parent then return false end
            local bMatStr = MAT_TO_STR and MAT_TO_STR[b.Material] or b.Material.Name:lower()
            if bMatStr ~= wantMat then return true end
            local tol = 1/255
            if math.abs(b.Color.R-wantCol.R)>tol
            or math.abs(b.Color.G-wantCol.G)>tol
            or math.abs(b.Color.B-wantCol.B)>tol then return true end
            return false
        end

        -- Pass Fix: 5 passes. Each brick: already matches → skip; different → paint.
        local PASSES = 5
        for pass=1,PASSES do
            if not br.painting then break end
            local anyFired=false
            if not ev or not ev.Parent then ev=getToolRemote("Paint") end
            if not ev then break end
            hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then break end
            for _,b in ipairs(targets) do
                if not br.painting then break end
                if b and b.Parent then
                    if blockNeedsPaint(b) then
                        ev:FireServer(b,Enum.NormalId.Top,hrp.Position,HANDSHAKE,wantCol,wantMat,"")
                        painted=painted+1; anyFired=true; task.wait(0.02)
                    end
                end
            end
            if not anyFired then break end
            task.wait(0.35)
        end
        notify("Sigma","Painted "..painted.." blocks!")
        br.painting=false; btn.Text="Paint Zone"
    end)
end)

