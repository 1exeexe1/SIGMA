-- visualPage: sub-tab inside "Main" big tab (declared at top with makeSubTabBar)

do
    local g=makeGroup(visualPage,"ESP")

    -- ── helpers ────────────────────────────────────────────────────────────
    local function createNameGui(p)
        if S.espGuis[p] and S.espGuis[p].bb then S.espGuis[p].bb:Destroy() end
        local char=p.Character; if not char then return end
        local head=char:FindFirstChild("Head"); if not head then return end
        local bb=Instance.new("BillboardGui"); bb.Size=UDim2.new(0,200,0,30)
        bb.StudsOffset=Vector3.new(0,3,0); bb.Adornee=head; bb.AlwaysOnTop=true
        bb.Enabled=S.espOn; bb.Parent=head
        local lbl=Instance.new("TextLabel"); lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
        lbl.TextColor3=Color3.fromRGB(255,255,255); lbl.TextStrokeTransparency=0; lbl.TextSize=13
        lbl.FontFace=FONT_MAIN; lbl.Text=S.espDisplay and p.DisplayName or p.Name; lbl.Parent=bb
        S.espGuis[p]={bb=bb,lbl=lbl}
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hum then hum.Died:Connect(function()
            if S.espGuis[p] and S.espGuis[p].bb then S.espGuis[p].bb:Destroy() end; S.espGuis[p]=nil
        end) end
    end

    -- Apply or remove a named Highlight on a character.
    -- hlName: unique name e.g. "ESP_Admin", color: Color3, alwaysOnTop: bool
    local function setCharHighlight(char, hlName, on, color, alwaysOnTop)
        if not char then return end
        local old=char:FindFirstChild(hlName); if old then old:Destroy() end
        if on then
            local h=Instance.new("Highlight")
            h.Name=hlName; h.FillTransparency=1
            h.OutlineColor=color; h.OutlineTransparency=0
            h.DepthMode = alwaysOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
            h.Parent=char
        end
    end

    -- Check if a player is the current leaderboard leader (top Time).
    local function isAdmin(p)
        local ls=p:FindFirstChild("leaderstats"); if not ls then return false end
        local myTime=ls:FindFirstChild("Time"); if not myTime then return false end
        local topVal=myTime.Value
        for _,op in pairs(Players:GetPlayers()) do
            if op~=p then
                local ols=op:FindFirstChild("leaderstats")
                local ot=ols and ols:FindFirstChild("Time")
                if ot and ot.Value>topVal then return false end
            end
        end
        return topVal>0
    end

    -- Check if a player has The Arkenstone in their character or backpack.
    local function hasArkenstone(p)
        local char=p.Character
        if char then
            for _,t in ipairs(char:GetChildren()) do
                if t:IsA("Tool") and t.Name=="The Arkenstone" then return true end
            end
        end
        if p.Backpack then
            for _,t in ipairs(p.Backpack:GetChildren()) do
                if t:IsA("Tool") and t.Name=="The Arkenstone" then return true end
            end
        end
        return false
    end

    -- Check if all visible BaseParts in a character are fully transparent (invisible).
    local function isCharInvisible(char)
        if not char then return false end
        local found=false
        for _,p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then
                found=true
                if p.Transparency<0.99 then return false end
            end
        end
        return found -- true only if we found parts AND all were transparent
    end

    -- Re-evaluate all special highlights for a given player.
    local function refreshSpecialESP(p)
        if p==lp then return end
        local char=p.Character

        -- Enlightened outline: cyan if holding Arkenstone, deep-blue if enlightened rank but not holding
        -- Evaluated FIRST so admin (below) is the last Highlight added → renders on top.
        if S.espEnlighten then
            local hasStone=hasArkenstone(p)
            if hasStone then
                setCharHighlight(char,"ESP_Enlighten", true, Color3.fromRGB(0,255,220), true)
            else
                if S._espEnlightenSeen and S._espEnlightenSeen[p] then
                    setCharHighlight(char,"ESP_Enlighten", true, Color3.fromRGB(0,80,160), true)
                else
                    setCharHighlight(char,"ESP_Enlighten", false, nil, true)
                end
            end
        else
            setCharHighlight(char,"ESP_Enlighten", false, nil, true)
        end

        -- Admin outline: yellow — evaluated LAST so its Highlight instance sits
        -- after ESP_Enlighten in the character hierarchy → always renders on top.
        if S.espAdmin then
            setCharHighlight(char,"ESP_Admin", isAdmin(p), Color3.fromRGB(255,215,0), true)
        else
            setCharHighlight(char,"ESP_Admin", false, nil, true)
        end

        -- Invisible outline: white AlwaysOnTop so the outline persists through transparency
        if S.espInvisible then
            local inv=isCharInvisible(char)
            setCharHighlight(char,"ESP_Invisible", inv, Color3.fromRGB(255,255,255), true)
        else
            setCharHighlight(char,"ESP_Invisible", false, nil, true)
        end
    end

    -- Refresh all players at once.
    local function refreshAllSpecialESP()
        for _,p in pairs(Players:GetPlayers()) do refreshSpecialESP(p) end
    end

    -- Start the special-ESP polling loop (runs while any special ESP is active).
    local _espSpecialLoop=nil
    local function startSpecialESPLoop()
        if _espSpecialLoop then return end
        _espSpecialLoop=true
        task.spawn(function()
            while _espSpecialLoop do
                if not (S.espAdmin or S.espEnlighten or S.espInvisible) then
                    _espSpecialLoop=nil; break
                end
                refreshAllSpecialESP()
                task.wait(1.5)
            end
        end)
    end
    local function stopSpecialESPLoop()
        _espSpecialLoop=nil
    end

    -- Track which players we've ever seen hold the Arkenstone (for Enlightened dim-blue).
    S._espEnlightenSeen = S._espEnlightenSeen or {}
    Players.PlayerAdded:Connect(function(p)
        p.CharacterAdded:Connect(function(char)
            char.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and child.Name=="The Arkenstone" then
                    S._espEnlightenSeen[p]=true
                end
            end)
        end)
    end)
    -- Also catch players already in game.
    for _,p in pairs(Players:GetPlayers()) do
        if p~=lp and hasArkenstone(p) then S._espEnlightenSeen[p]=true end
        if p.Character then
            p.Character.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and child.Name=="The Arkenstone" then
                    S._espEnlightenSeen[p]=true
                end
            end)
        end
        p.CharacterAdded:Connect(function(char)
            char.ChildAdded:Connect(function(child)
                if child:IsA("Tool") and child.Name=="The Arkenstone" then
                    S._espEnlightenSeen[p]=true
                end
            end)
        end)
    end

    -- ── Griefer detection ──────────────────────────────────────────────────
    -- Watch every player for: has Delete tool equipped AND is firing delete events
    -- targeting bricks they don't own (approximated by bricks NOT in their folder).
    local _grieferWatches={} -- [Player] = {conn1, conn2, ...}

    local function getOwnerFolder(p)
        -- In most Roblox building games each player has a folder named after them in Workspace.
        local f=Workspace:FindFirstChild(p.Name)
        if not f then f=Workspace:FindFirstChild(p.UserId) end
        return f
    end

    local function watchPlayerForGrief(p)
        if p==lp or _grieferWatches[p] then return end
        local conns={}
        _grieferWatches[p]=conns
        -- Poll every 0.5s: check if they have the Delete tool equipped (in Character).
        local pollConn; pollConn=RunService.Heartbeat:Connect(function()
            if not S.espGriefer then
                pollConn:Disconnect()
                _grieferWatches[p]=nil
                setCharHighlight(p.Character,"ESP_Griefer",false,nil,true)
                return
            end
            local char=p.Character; if not char then return end
            local hasDel=false
            for _,t in ipairs(char:GetChildren()) do
                if t:IsA("Tool") and t.Name=="Delete" then hasDel=true; break end
            end
            if not hasDel then
                setCharHighlight(char,"ESP_Griefer",false,nil,true)
                return
            end
            -- They have the delete tool out. Now detect if they've recently deleted
            -- someone else's brick. We do this by watching ChildRemoved on other folders.
            -- Check if we've flagged them already (flag resets after 8s).
            if char:FindFirstChild("ESP_Griefer") then return end -- already flagged
            -- We can't easily intercept their remote calls, so we watch ChildRemoved
            -- on all workspace folders that don't belong to this player.
            local myFolder=getOwnerFolder(p)
            local recentlyDeleted=false
            for _,obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Folder") or obj:IsA("Model") then
                    if obj~=myFolder then
                        -- check if a child was recently removed (poll-based: snapshot count)
                        -- This approach: just mark them as suspect if Delete is equipped.
                        -- For real detection we hook ChildRemoved below in startGrieferWatch.
                    end
                end
            end
            -- Mark red while Delete is equipped (warning state)
            setCharHighlight(char,"ESP_Griefer",true,Color3.fromRGB(255,40,40),true)
        end)
        table.insert(conns, pollConn)
    end

    -- ChildRemoved hook: fires notify when someone's brick disappears while another
    -- player has Delete equipped.
    local _grieferDeleteWatcher=nil
    local _grieferCooldown={}

    local function startGrieferWatch()
        if _grieferDeleteWatcher then return end
        _grieferDeleteWatcher=Workspace.DescendantRemoving:Connect(function(obj)
            if not S.espGriefer then return end
            if not (obj:IsA("BasePart") or obj:IsA("UnionOperation") or obj:IsA("SpecialMesh")) then return end
            -- Find which player (if any) has Delete tool equipped right now.
            for _,p in pairs(Players:GetPlayers()) do
                if p~=lp and p.Character then
                    local hasDel=false
                    for _,t in ipairs(p.Character:GetChildren()) do
                        if t:IsA("Tool") and t.Name=="Delete" then hasDel=true; break end
                    end
                    if hasDel then
                        -- Check it's not their own folder.
                        local myF=getOwnerFolder(p)
                        local isOwn=myF and (obj:IsDescendantOf(myF))
                        if not isOwn then
                            -- Notify + highlight red
                            setCharHighlight(p.Character,"ESP_Griefer",true,Color3.fromRGB(255,40,40),true)
                            if not _grieferCooldown[p] or (tick()-_grieferCooldown[p])>8 then
                                _grieferCooldown[p]=tick()
                                notify("\240\159\148\180 Griefer Detected","Griefer: "..p.Name,6)
                            end
                            -- Auto-clear flag after 10s of inactivity
                            task.delay(10, function()
                                if p.Character then
                                    setCharHighlight(p.Character,"ESP_Griefer",false,nil,true)
                                end
                            end)
                        end
                    end
                end
            end
        end)
        -- Also set up per-player delete-tool watchers.
        for _,p in pairs(Players:GetPlayers()) do watchPlayerForGrief(p) end
        Players.PlayerAdded:Connect(function(p) watchPlayerForGrief(p) end)
    end

    local function stopGrieferWatch()
        if _grieferDeleteWatcher then _grieferDeleteWatcher:Disconnect(); _grieferDeleteWatcher=nil end
        for p,conns in pairs(_grieferWatches) do
            for _,c in ipairs(conns) do pcall(function() c:Disconnect() end) end
            if p.Character then setCharHighlight(p.Character,"ESP_Griefer",false,nil,true) end
        end
        _grieferWatches={}
    end

    -- ── Standard ESP toggles ───────────────────────────────────────────────
    makeToggle(g,"Enable ESP",function(on) S.espOn=on
        for _,d in pairs(S.espGuis) do if d and d.bb then d.bb.Enabled=on end end
        for _,p in pairs(Players:GetPlayers()) do
            if p~=lp and p.Character then
                local h=p.Character:FindFirstChild("ESPHighlight")
                if h then h.Enabled=on end
            end
        end
    end,true)
    makeToggle(g,"Name ESP",function(on) S.espNames=on
        if on then for _,p in pairs(Players:GetPlayers()) do if p~=lp then createNameGui(p) end end
        else for p in pairs(S.espGuis) do if S.espGuis[p] and S.espGuis[p].bb then S.espGuis[p].bb:Destroy() end; S.espGuis[p]=nil end end
    end)
    makeToggle(g,"Distance Label",function(on) S.espDist=on end)
    makeToggle(g,"Show Display Names",function(on) S.espDisplay=on
        for plr,d in pairs(S.espGuis) do if d and d.lbl then d.lbl.Text=on and plr.DisplayName or plr.Name end end
    end)
    makeToggle(g,"Player Outline",function(on)
        S.espOutline=on
        for _,p in pairs(Players:GetPlayers()) do
            if p~=lp and p.Character then
                local old=p.Character:FindFirstChild("ESPHighlight"); if old then old:Destroy() end
                if on then local h=Instance.new("Highlight"); h.Name="ESPHighlight"; h.FillTransparency=1; h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                    h.OutlineColor=Color3.fromRGB(255,255,255); h.OutlineTransparency=0; h.Parent=p.Character end
            end
        end
    end)
    makeToggleInput(g,"Max Distance","(1000)",function(on,val)
        local n=tonumber(val); S.espMaxDist=n or 1000
    end)

    -- ── Special ESP toggles ────────────────────────────────────────────────
    makeToggle(g,"Admin ESP",function(on)
        S.espAdmin=on
        if on then startSpecialESPLoop()
        else
            for _,p in pairs(Players:GetPlayers()) do
                if p.Character then setCharHighlight(p.Character,"ESP_Admin",false,nil,true) end
            end
            if not (S.espEnlighten or S.espInvisible) then stopSpecialESPLoop() end
        end
    end)

    makeToggle(g,"Enlightened ESP",function(on)
        S.espEnlighten=on
        if on then startSpecialESPLoop()
        else
            for _,p in pairs(Players:GetPlayers()) do
                if p.Character then setCharHighlight(p.Character,"ESP_Enlighten",false,nil,true) end
            end
            if not (S.espAdmin or S.espInvisible) then stopSpecialESPLoop() end
