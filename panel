        task.delay(0.12, function()
            ContentArea.Visible=false; SideBar.Visible=false
        end)
    else
        MainFrame.Size=UDim2.new(0,500,0,26)
        ContentArea.Visible=false; SideBar.Visible=false
    end
end

local function restorePanel()
    panelMinimized=false; guiVisible=true
    MinBtn.Text="-"
    ContentArea.Visible=true; SideBar.Visible=true
    if S.uiAnim then
        TweenService:Create(MainFrame, _panelMinTI,
            {Size=UDim2.new(0,500,0,PANEL_FULL_H)}):Play()
