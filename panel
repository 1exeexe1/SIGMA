        if cloneZone.placed then cloneSyncZone() end; _cZoneLblUpdate()

        -- Screen-drag selection connections
        table.insert(_cloneEquipConns, UserInputService.InputBegan:Connect(function(inp,gpe)
            if gpe then return end
            if inp.UserInputType==Enum.UserInputType.MouseButton1 then
                _cloneDragging=true; _cloneHasMoved=false
                _cloneOrigin=Vector2.new(inp.Position.X,inp.Position.Y)
                _cloneCurrent=_cloneOrigin
                _cloneDragFrame.Position=UDim2.fromOffset(_cloneOrigin.X,_cloneOrigin.Y)
                _cloneDragFrame.Size=UDim2.fromOffset(0,0)
                _cloneDragGui.Enabled=true
            elseif inp.KeyCode==Enum.KeyCode.G then
                _cloneSnap=not _cloneSnap
                _cSnapBtn.Text=_cloneSnap and "Snap: ON  (G)" or "Snap: OFF (G)"
                _cSnapBtn.BackgroundColor3=_cloneSnap and Color3.fromRGB(0,120,0) or T.BTN
            elseif inp.KeyCode==Enum.KeyCode.R then
                _cClearSel()
            end
        end))
        table.insert(_cloneEquipConns, UserInputService.InputChanged:Connect(function(inp)
            if _cloneDragging and inp.UserInputType==Enum.UserInputType.MouseMovement then
                _cloneHasMoved=true
                _cloneCurrent=Vector2.new(inp.Position.X,inp.Position.Y)
                local minX=math.min(_cloneOrigin.X,_cloneCurrent.X)
                local minY=math.min(_cloneOrigin.Y,_cloneCurrent.Y)
                local w=math.abs(_cloneCurrent.X-_cloneOrigin.X)
                local h=math.abs(_cloneCurrent.Y-_cloneOrigin.Y)
                _cloneDragFrame.Position=UDim2.fromOffset(minX,minY)
                _cloneDragFrame.Size=UDim2.fromOffset(w,h)
            end
        end))
        table.insert(_cloneEquipConns, UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType~=Enum.UserInputType.MouseButton1 then return end
            _cloneDragging=false
            _cloneDragFrame.Size=UDim2.fromOffset(0,0)
            if not _cloneHasMoved then return end
            local found=_cGetBlocksInRect(
                _cloneOrigin.X,_cloneOrigin.Y,_cloneCurrent.X,_cloneCurrent.Y)
            if not _cloneAddMode then _cClearSel() end
            for _,part in ipairs(found) do
                _cloneSel[part]=true; _cHighlight(part,true)
            end
            _cUpdateCount()
            if _cUpdateCount()>0 then _cBuildHandles() end
        end))
    end

    _ctoolVirtualUnequip["Clone"]=function()
