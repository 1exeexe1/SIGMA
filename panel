    cloneStatusLbl.TextColor3 = Color3.fromRGB(140,140,140)

    local _,_,setCloneToggle = makeToggle(cloneCtrlPage, "Toggle Clone Ring", function(on)
        if on then
            if _cloneActive then return end
            _cloneHRPs = _getCloneHRPs()
            if #_cloneHRPs == 0 then
                notify("Clone Ctrl","No clone HRPs found in Workspace.")
                task.defer(function() if setCloneToggle then setCloneToggle(false) end end)
                return
            end
            _ringBumpOwnership()
            _cloneActive = true
            cloneStatusLbl.Text = "Clone ring: active O " .. #_cloneHRPs .. " clones"
            _cloneConn = RunService.Heartbeat:Connect(function(dt)
                if not _cloneActive then return end
                _cloneAngle = _cloneAngle + (_cloneSpeed / math.max(_cloneRadius,0.5)) * dt
                local hrp = _cloneGetHostHRP(_cloneHostName)
                if not hrp then return end
                local n = #_cloneHRPs
                if n == 0 then return end
                local yaw = CFrame.new()
                if _cloneFollow then
                    local look = hrp.CFrame.LookVector
                    yaw = CFrame.Angles(0, math.atan2(-look.X,-look.Z), 0)
                end
                for i, ch in ipairs(_cloneHRPs) do
                    if not ch or not ch.Parent then continue end
                    local a   = _cloneAngle + (i-1)*(2*math.pi/n)
                    local off = yaw * Vector3.new(math.cos(a)*_cloneRadius, 0, math.sin(a)*_cloneRadius)
                    pcall(function()
                        ch.AssemblyLinearVelocity  = Vector3.zero
                        ch.AssemblyAngularVelocity = Vector3.zero
                        ch.CFrame = CFrame.new(hrp.Position + off)
                    end)
                end
            end)
        else
            _cloneActive = false
            if _cloneConn then _cloneConn:Disconnect(); _cloneConn = nil end
            _cloneHRPs = {}; _cloneAngle = 0
            cloneStatusLbl.Text = "Clone ring: inactive"
        end
    end, false, "Orbit all workspace clone HRPs around the host in a ring.")

