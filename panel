    dropScroll.CanvasSize=UDim2.new(0,0,0,0); dropScroll.ZIndex=61; dropScroll.Parent=dropFrame
    onTheme(function(th) dropScroll.ScrollBarImageColor3=th.ACCENT end)

    local dl=Instance.new("UIListLayout"); dl.Padding=UDim.new(0,2); dl.Parent=dropScroll
    local dp=Instance.new("UIPadding"); dp.PaddingTop=UDim.new(0,4); dp.PaddingLeft=UDim.new(0,4)
    dp.PaddingRight=UDim.new(0,4); dp.PaddingBottom=UDim.new(0,4); dp.Parent=dropScroll

    local ITEM_H = 26
    local function getMaxH()
        return math.floor(ScreenGui.AbsoluteSize.Y * 0.5)
    end

    -- Build option rows with name label + select square
    local function buildOpts(opts)
        -- Clear existing
        for _,c in ipairs(dropScroll:GetChildren()) do
            if c:IsA("Frame") then c:Destroy() end
        end
        _optionButtons={}

        for _,opt in ipairs(opts) do
            -- Option row container
            local optRow=Instance.new("Frame")
            optRow.Size=UDim2.new(1,0,0,ITEM_H); optRow.BackgroundTransparency=1
            optRow.ZIndex=62; optRow.Parent=dropScroll

            -- Name label (for reading and dragging to scroll)
            local nameLbl=Instance.new("TextLabel")
            nameLbl.Size=UDim2.new(1,-32,1,0); nameLbl.Position=UDim2.new(0,0,0,0)
            nameLbl.BackgroundColor3=Color3.fromRGB(28,28,28); nameLbl.BorderColor3=T.BORDER
            nameLbl.Text=opt; nameLbl.TextColor3=T.WHITE
            nameLbl.FontFace=FONT_MAIN; nameLbl.TextSize=11; nameLbl.TextXAlignment=Enum.TextXAlignment.Left
            nameLbl.ZIndex=63; nameLbl.Parent=optRow
            onTheme(function(th) nameLbl.BorderColor3=th.BORDER; nameLbl.TextColor3=th.WHITE end)
            local namePad=Instance.new("UIPadding",nameLbl); namePad.PaddingLeft=UDim.new(0,6)

            -- Selection square button
            local selectBtn=Instance.new("TextButton")
            selectBtn.Size=UDim2.new(0,22,0,22); selectBtn.Position=UDim2.new(1,-24,0.5,-11)
            selectBtn.BackgroundColor3=(opt==selected) and T.ACCENT or Color3.fromRGB(45,45,45)
            selectBtn.BorderColor3=T.BORDER; selectBtn.Text=""
            selectBtn.ZIndex=63; selectBtn.Parent=optRow
            onTheme(function(th) 
                selectBtn.BorderColor3=th.BORDER
                if opt==selected then selectBtn.BackgroundColor3=th.ACCENT end
            end)

            -- Store reference for theme updates
            _optionButtons[opt]=selectBtn

            -- Name label drag-to-scroll behavior
            local dragConn, dragEndConn
            nameLbl.InputBegan:Connect(function(inp)
                if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
                    _draggingDrop=true
                    _dragStartY=inp.Position.Y
                    _scrollStartY=dropScroll.CanvasPosition.Y
                    dragConn=UserInputService.InputChanged:Connect(function(i2)
                        if _draggingDrop and (i2.UserInputType==Enum.UserInputType.MouseMovement or i2.UserInputType==Enum.UserInputType.Touch) then
                            local delta=i2.Position.Y-_dragStartY
                            dropScroll.CanvasPosition=Vector2.new(0,math.max(0,_scrollStartY-delta))
                        end
                    end)
                    dragEndConn=UserInputService.InputEnded:Connect(function(i2)
                        if i2.UserInputType==Enum.UserInputType.MouseButton1 or i2.UserInputType==Enum.UserInputType.Touch then
                            _draggingDrop=false
                            if dragConn then dragConn:Disconnect() end
                            if dragEndConn then dragEndConn:Disconnect() end
                        end
                    end)
                end
            end)

            -- Selection square click
            selectBtn.MouseButton1Click:Connect(function()
                selected=opt; btn.Text=label..": "..selected.." \226\150\190"
                open=false; dropFrame.Visible=false
                -- Update all squares
                for o,b in pairs(_optionButtons) do
                    b.BackgroundColor3=(o==selected) and T.ACCENT or Color3.fromRGB(45,45,45)
                end
                cb(opt)
            end)
        end
    end
    buildOpts(options)

    -- Theme update for all squares
    onTheme(function(th)
        for o,b in pairs(_optionButtons) do
            b.BackgroundColor3=(o==selected) and th.ACCENT or Color3.fromRGB(45,45,45)
        end
    end)

    local function openDrop()
        RunService.RenderStepped:Wait()
        local abs=btn.AbsolutePosition; local absS=btn.AbsoluteSize
        local idealH = #options * (ITEM_H+2) + 40
        local h = math.min(idealH, getMaxH())
        local scH=ScreenGui.AbsoluteSize.Y
        local scW=ScreenGui.AbsoluteSize.X
        local posY=abs.Y-h-2
        if posY < 10 then posY=abs.Y+absS.Y+2 end
        posY=math.clamp(posY, 2, scH-h-2)
        local posX=math.clamp(abs.X, 2, scW-absS.X-2)
        dropFrame.Position=UDim2.new(0,posX,0,posY)
        dropFrame.Size=UDim2.new(0,absS.X,0,h)
        dropFrame.Visible=true
        dropScroll.CanvasPosition=Vector2.zero
    end

    btn.MouseButton1Click:Connect(function()
        open=not open
        if open then task.spawn(openDrop) else dropFrame.Visible=false end
    end)

    -- X button closes dropdown (only way to close without selecting)
    closeBtn.MouseButton1Click:Connect(function()
        open=false; dropFrame.Visible=false
    end)

    local function setValues(newOpts, newSel)
        options=newOpts; buildOpts(newOpts)
        if newSel then selected=newSel; btn.Text=label..": "..selected.." \226\150\190" end
    end
    return row, setValues
end
