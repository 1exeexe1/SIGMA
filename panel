        makeToggle(g,"Enable",function(on) S.punishOnLeaveOn=on; _rewireJoinLeave() end)
        makeInput(g,"Command",";say [Name] left",function(v) S.punishOnLeaveCmd=v; _rewireJoinLeave() end)
