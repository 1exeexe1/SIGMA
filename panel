        p.Anchored = true; p.CanCollide = false; p.CastShadow = false
        p.Parent = Workspace
        table.insert(parts, p)
    end
    return parts
end

local function makePreviewBox(origin, sX, sY, sZ, grid)
    local parts = {}
    local tX = sX*grid; local tY = sY*grid; local tZ = sZ*grid
    local cx = origin.X + (sX-1)*grid/2
    local cy = origin.Y + (sY-1)*grid/2
    local cz = origin.Z + (sZ-1)*grid/2
    local center = Vector3.new(cx,cy,cz)
    local e = 0.25
    local edges = {
        {Vector3.new(tX,e,e), Vector3.new(0,-tY/2,-tZ/2)},
        {Vector3.new(tX,e,e), Vector3.new(0, tY/2,-tZ/2)},
        {Vector3.new(tX,e,e), Vector3.new(0,-tY/2, tZ/2)},
        {Vector3.new(tX,e,e), Vector3.new(0, tY/2, tZ/2)},
        {Vector3.new(e,tY,e), Vector3.new(-tX/2,0,-tZ/2)},
        {Vector3.new(e,tY,e), Vector3.new( tX/2,0,-tZ/2)},
        {Vector3.new(e,tY,e), Vector3.new(-tX/2,0, tZ/2)},
        {Vector3.new(e,tY,e), Vector3.new( tX/2,0, tZ/2)},
        {Vector3.new(e,e,tZ), Vector3.new(-tX/2,-tY/2,0)},
        {Vector3.new(e,e,tZ), Vector3.new( tX/2,-tY/2,0)},
        {Vector3.new(e,e,tZ), Vector3.new(-tX/2, tY/2,0)},
        {Vector3.new(e,e,tZ), Vector3.new( tX/2, tY/2,0)},
    }
    for _,edge in ipairs(edges) do
        local p = Instance.new("Part")
        p.Size = edge[1]; p.CFrame = CFrame.new(center + edge[2])
        p.Material = Enum.Material.Neon
        p.Color = Color3.fromRGB(0,255,0)
        p.Anchored = true; p.CanCollide = false; p.CastShadow = false
        p.Parent = Workspace
        table.insert(parts, p)
    end
    return parts
end
local S  -- forward declaration: defined fully below; preview closures need the slot
-- ═══ LIVE PREVIEW + MOVE PREVIEW SYSTEM (v4.7.4) ═══════════════════════════
-- S.livePreview        (bool)    — Live Preview toggle state
-- S.movePreview        (bool)    — Move Preview toggle state
-- S._livePreviewParts  (array)   — currently live ForceField/edge Parts
-- S._livePreviewAnchor (Part)    — invisible anchor at preview centre (Handles adornee)
-- S._previewOffset     (Vector3) — cumulative drag offset applied at build time
-- S._previewHandles    (Handles) — movement handles instance (Move Preview)
-- S._previewGenTag     (string)  — "cube"/"text"/"load" — last preview type
--
-- Public API used by Build Cube, Build Text, Load Build:
--   _clearLivePreview()          — destroy all preview parts + handles
--   _spawnLivePreview(parts, anchorPos)
--                                — replace live preview with new parts list
--   _getPreviewOffset()          — return S._previewOffset (Vector3)
-- ═══════════════════════════════════════════════════════════════════════════════

local function _clearLivePreview()
    -- Destroy move handles first
    if S._previewHandles then
        pcall(function() S._previewHandles:Destroy() end)
        S._previewHandles = nil
    end
    -- Destroy all preview geometry
    for _, p in ipairs(S._livePreviewParts) do
        pcall(function() p:Destroy() end)
    end
    S._livePreviewParts = {}
    -- Destroy anchor
    if S._livePreviewAnchor then
        pcall(function() S._livePreviewAnchor:Destroy() end)
        S._livePreviewAnchor = nil
    end
    S._previewAnchor = nil   -- keep alias in sync
    S._previewOffset = Vector3.new(0,0,0)
end

-- Declared here (before _attachMoveHandles) so MouseDrag can index it without a nil error.
-- Previously lived after the function, causing "attempt to index nil with invoke" on drag.
local CT_NORM_VEC = {
    [Enum.NormalId.Top]    = Vector3.new( 0, 1, 0),
    [Enum.NormalId.Bottom] = Vector3.new( 0,-1, 0),
    [Enum.NormalId.Front]  = Vector3.new( 0, 0,-1),
    [Enum.NormalId.Back]   = Vector3.new( 0, 0, 1),
    [Enum.NormalId.Left]   = Vector3.new(-1, 0, 0),
    [Enum.NormalId.Right]  = Vector3.new( 1, 0, 0),
}

local function _attachMoveHandles()
    if not S._previewAnchor then return end
    if S._previewHandles then
        pcall(function() S._previewHandles:Destroy() end)
        S._previewHandles = nil
    end
    local h = Instance.new("Handles")
    h.Style  = Enum.HandlesStyle.Movement
    h.Faces  = Faces.new(
        Enum.NormalId.Top, Enum.NormalId.Bottom,
        Enum.NormalId.Front, Enum.NormalId.Back,
        Enum.NormalId.Left,  Enum.NormalId.Right
    )
    h.Adornee = S._previewAnchor
    h.Parent  = workspace
    S._previewHandles = h

    -- MouseDrag: translate every preview part + the anchor by the drag delta
    h.MouseDrag:Connect(function(face, distance)
        if not S.movePreview or not S.livePreview then return end
        local faceVec = CT_NORM_VEC[face] or Vector3.new(0,0,0)
        local delta   = faceVec * distance

        -- Move anchor
        if S._previewAnchor and S._previewAnchor.Parent then
            S._previewAnchor.CFrame = S._previewAnchor.CFrame + delta
        end
        -- Move all preview parts
        for _, p in ipairs(S._livePreviewParts) do
            if p and p.Parent then
                p.CFrame = p.CFrame + delta
            end
        end
        -- Accumulate offset for build-time application
        S._previewOffset = S._previewOffset + delta
    end)
end

local function _spawnLivePreview(parts, anchorPos)
    -- Tear down previous preview
    _clearLivePreview()

    S._livePreviewParts = parts or {}

    -- Create invisible anchor at the geometric centre of the preview
    local anchor = Instance.new("Part")
    anchor.Size         = Vector3.new(1,1,1)
    anchor.CFrame       = CFrame.new(anchorPos or Vector3.new(0,0,0))
    anchor.Transparency = 1
    anchor.Anchored     = true
    anchor.CanCollide   = false
    anchor.CastShadow   = false
    anchor.Parent       = workspace
    S._previewAnchor    = anchor
    -- Keep legacy alias consistent (older code used _livePreviewAnchor)
    S._livePreviewAnchor = anchor

    if S.movePreview then
        _attachMoveHandles()
    end
end

-- Called by Move Preview toggle to attach/detach handles without rebuilding preview
local function _setMovePreview(on)
    S.movePreview = on
    if on and S.livePreview and S._previewAnchor then
        _attachMoveHandles()
    elseif not on and S._previewHandles then
        pcall(function() S._previewHandles:Destroy() end)
        S._previewHandles = nil
    end
end

-- Returns cumulative offset to be added to every fire position at build time
local function _getPreviewOffset()
    return S._previewOffset
end

