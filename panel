-- Keys stored in getgenv()._jarvisKeys = array of
--   {id, label, url, key, active}
-- Queue stored in getgenv()._jarvisQueue = {id, id, ...} ordered priority
-- exhausted = set of ids dead this session only (not persisted)
local _jKeys     = getgenv()._jarvisKeys  or {}
local _jQueue    = getgenv()._jarvisQueue or {}
local _jExhausted = {}   -- id → true (session-only)

local _JKEYS_FILE = "SigmaPanel_JarvisKeys.json"

local function _jSave()
    getgenv()._jarvisKeys  = _jKeys
    getgenv()._jarvisQueue = _jQueue
    -- File persistence: write label/url/key/model for each entry
    pcall(function()
        if typeof(writefile) ~= "function" then return end
        local out = {}
        for _, k in ipairs(_jKeys) do
            out[#out+1] = {
                id    = k.id,
                label = k.label,
                url   = k.url,
                key   = k.key,
                model = k.model or "",
                active = k.active or false,
            }
        end
        writefile(_JKEYS_FILE, HttpService:JSONEncode({keys=out, queue=_jQueue}))
    end)
end

local function _jLoadFile()
    pcall(function()
        if typeof(readfile) ~= "function" or typeof(isfile) ~= "function" then return end
        if not isfile(_JKEYS_FILE) then return end
        local raw = readfile(_JKEYS_FILE)
        if not raw or raw == "" then return end
        local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
        if not ok or type(data) ~= "table" then return end
        -- Only load from file if getgenv has no keys yet (fresh executor session).
        -- On re-execute, prefer in-memory state to avoid overwriting session-added keys.
        if #_jKeys == 0 and type(data.keys) == "table" then
            for _, k in ipairs(data.keys) do
                if type(k.label)=="string" and type(k.key)=="string" and type(k.url)=="string" then
                    _jKeys[#_jKeys+1] = {
                        id    = tonumber(k.id) or (#_jKeys+1),
                        label = k.label,
                        url   = k.url,
                        key   = k.key,
                        model = k.model or "google/gemini-2.5-pro-preview",
                        active = false,
                    }
                end
            end
        end
        if #_jQueue == 0 and type(data.queue) == "table" then
            for _, id in ipairs(data.queue) do
                _jQueue[#_jQueue+1] = tonumber(id)
            end
        end
    end)
end

