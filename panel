-- ── BLITZBUILD SPEED TEST ─────────────────────────────────────
do
    local dbgPage = dbgPage_ref
    local g5 = makeGroup(dbgPage, "BlitzBuild Speed Test",
        "Builds 10 consecutive 3×3×3 cubes (27 bricks each) at increasing BPS. "..
        "Starts at 20 bps, steps +3 bps per cube up to 47 bps. "..
        "Outputs per-cube time, fix-pass count, and a final BPS vs passes comparison table.")

    -- Schedule: 20 bps → 47 bps in steps of 3
    -- delay_s = 1 / bps (time between consecutive FireServer calls)
    local SPEED_SCHEDULE = {}
    for i = 0, 9 do
        local bps     = 20 + i * 3          -- 20, 23, 26, 29, 32, 35, 38, 41, 44, 47
        local delay_s = 1 / bps
        SPEED_SCHEDULE[i + 1] = {delay_s, bps}
    end

    local _blitzTestRunning = false
    local btn5 = makeButton(g5, "Test BlitzBuild Speed", function()
        if _blitzTestRunning then
            notify("BlitzTest", "Already running — wait for it to finish.")
            return
        end
        task.spawn(function()
            _blitzTestRunning = true
            if btn5 and btn5.Parent then btn5.Text = "Running..." end

            local lp    = game.Players.LocalPlayer
            local hrp   = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then
                notify("BlitzTest", "No character — aborting.")
                _blitzTestRunning = false
                if btn5 and btn5.Parent then btn5.Text = "Test BlitzBuild Speed" end
                return
            end

            -- Build probe for 4×4×4 normal bricks
            local probeBox = Vector3.new(3, 3, 3)

            -- Each cube offset 20 studs along X from the previous
            local basePos = hrp.Position + Vector3.new(10, 0, 0)

            -- Acquire Build remote
            local ev = getToolRemote("Build")
            if not ev then
                notify("BlitzTest", "Build remote not found — equip the Build tool first.")
                _blitzTestRunning = false
                if btn5 and btn5.Parent then btn5.Text = "Test BlitzBuild Speed" end
                return
            end

            print("[BlitzTest] ══════════════════════════════════════════════")
            print("[BlitzTest] BlitzBuild speed test — 10 cubes, 27 bricks each.")
            print("[BlitzTest] Schedule: 20 bps → 47 bps (step +3). Starting.")
            print("[BlitzTest] ══════════════════════════════════════════════")

            -- Results table accumulated for the final comparison printout.
            -- Each entry: {cubeIdx, bps, elapsed_s, repeatCount, firstPassMisses}
            local results = {}

            for cubeIdx, schedule in ipairs(SPEED_SCHEDULE) do
                if S.buildStopped then break end

                local delay_s = schedule[1]
                local bps     = schedule[2]

                local cubeOrigin = Vector3.new(
                    basePos.X + (cubeIdx - 1) * 20,
                    basePos.Y,
                    basePos.Z
                )

                -- Generate 3×3×3 = 27 normal brick positions (4-stud grid)
                local positions = {}
                for dx = 0, 2 do
                    for dy = 0, 2 do
                        for dz = 0, 2 do
                            positions[#positions+1] = snapToGrid(Vector3.new(
                                cubeOrigin.X + dx * GRID_MULT,
                                cubeOrigin.Y + dy * GRID_MULT,
                                cubeOrigin.Z + dz * GRID_MULT
                            ))
                        end
                    end
                end

                -- Teleport HRP to center of this cube and anchor
                local cubeCentre = Vector3.new(
                    cubeOrigin.X + GRID_MULT,
                    cubeOrigin.Y + GRID_MULT,
                    cubeOrigin.Z + GRID_MULT
                )
                hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then break end
                hrp.CFrame   = CFrame.new(cubeCentre + Vector3.new(0, 8, 0))
                task.wait(BUILD_SETTLE)
                hrp.Anchored = true

                if btn5 and btn5.Parent then
                    btn5.Text = string.format("Cube %d/10 @ %d bps", cubeIdx, bps)
                end

                -- ── Primary fire pass ─────────────────────────────────────────
                local cubeStart = tick()

                for _, pos in ipairs(positions) do
                    if S.buildStopped then break end
                    ev:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, "normal")
                    task.wait(delay_s)
                end

                -- ── Verify + fix passes ───────────────────────────────────────
                task.wait(BUILD_VERIFY_WAIT)

                local function collectHoles()
                    local holes = {}
                    for _, pos in ipairs(positions) do
                        if not hasBlockAt(pos, probeBox) then holes[#holes+1] = pos end
                    end
                    return holes
                end

                local holes           = collectHoles()
                local firstPassMisses = #holes   -- how many were missing after the initial fire
                local repeatCount     = 0

                while #holes > 0 do
                    repeatCount = repeatCount + 1
                    if not ev or not ev.Parent then ev = getToolRemote("Build") end
                    if not ev then break end

                    if btn5 and btn5.Parent then
                        btn5.Text = string.format(
                            "Cube %d fix-%d (%d miss)", cubeIdx, repeatCount, #holes)
                    end

                    print(string.format(
                        "[BlitzTest] Cube %d @ %d bps — fix pass %d: %d missing, re-blitzing...",
                        cubeIdx, bps, repeatCount, #holes))

                    -- Shuffle holes for spatial locality variety
                    for i = #holes, 2, -1 do
                        local j = math.random(1, i)
                        holes[i], holes[j] = holes[j], holes[i]
                    end
                    for i, pos in ipairs(holes) do
                        if S.buildStopped then break end
                        ev:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, "normal")
                        if i % 12 == 0 then task.wait(0.07) end
                    end
                    task.wait(BUILD_VERIFY_WAIT)
                    holes = collectHoles()
                end

                local elapsed = tick() - cubeStart
                hrp.Anchored  = false

                -- Store result
                results[#results+1] = {cubeIdx, bps, elapsed, repeatCount, firstPassMisses}

                -- Per-cube log line
                if repeatCount == 0 then
                    print(string.format(
                        "[BlitzTest] Cube %2d | %2d bps | %.2fs | CLEAN (0 fix passes, 0 misses on first pass)",
                        cubeIdx, bps, elapsed))
                    notify("BlitzTest",
                        string.format("Cube %d @ %dbps — clean! %.2fs", cubeIdx, bps, elapsed), 4)
                else
                    print(string.format(
                        "[BlitzTest] Cube %2d | %2d bps | %.2fs | %d fix pass(es) | %d miss(es) on first pass",
                        cubeIdx, bps, elapsed, repeatCount, firstPassMisses))
                    notify("BlitzTest",
                        string.format("Cube %d @ %dbps — %d fix(es), %.2fs", cubeIdx, bps, repeatCount, elapsed), 4)
                end

                -- Gap between cubes
                task.wait(0.5)
            end

            -- ── Final comparison table ────────────────────────────────────────
            print("[BlitzTest] ══════════════════════════════════════════════")
            print("[BlitzTest] FINAL RESULTS — BPS vs Fix Passes per Cube")
            print("[BlitzTest] ──────────────────────────────────────────────")
            print(string.format("[BlitzTest] %-6s %-6s %-10s %-12s %-10s",
                "Cube", "BPS", "Time (s)", "Fix Passes", "1st Misses"))
            print("[BlitzTest] ──────────────────────────────────────────────")
            for _, r in ipairs(results) do
                local cIdx, bps2, elapsed2, passes, misses = r[1], r[2], r[3], r[4], r[5]
                local passLabel = passes == 0 and "clean" or tostring(passes)
                print(string.format("[BlitzTest] %-6d %-6d %-10.2f %-12s %-10d",
                    cIdx, bps2, elapsed2, passLabel, misses))
            end
            print("[BlitzTest] ══════════════════════════════════════════════")

            -- Quick trend note
            local allClean = true
            local firstDirty = nil
            for _, r in ipairs(results) do
                if r[4] > 0 then
                    allClean = false
                    if not firstDirty then firstDirty = r end
                end
            end
            if allClean then
                print("[BlitzTest] All 10 cubes built clean. Server is very healthy at these rates.")
            else
                print(string.format(
                    "[BlitzTest] Fix passes started at cube %d (%d bps). Below that: clean.",
                    firstDirty[1], firstDirty[2]))
            end

            print("[BlitzTest] Speed test complete.")
            notify("BlitzTest", "Speed test done — see output for full table.", 6)
            _blitzTestRunning = false
            if btn5 and btn5.Parent then btn5.Text = "Test BlitzBuild Speed" end
        end)
    end)
end

