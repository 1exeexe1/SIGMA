local function makePreviewIndividual(positions, grid)
    local parts = {}
    for _,pos in ipairs(positions) do
        -- For normal bricks (grid=4) snap to the 4-stud grid.
        -- For detailed bricks (grid=1) use position as-is (already integer-offset).
        local snappedPos = (grid >= 4) and snapToGrid(pos) or pos
