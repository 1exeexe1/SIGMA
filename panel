    local g=makeGroup(mainPage,"Server")

    makeButton(g,"Rejoin",function(btn)
        btn.Text="Rejoining..."; task.wait(0.5)
        prepareKeep()  -- arm queue_on_teleport BEFORE the teleport fires
        if game.PrivateServerId ~= "" then
            local rejoined = false
            pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, lp)
                rejoined = true
            end)
            if not rejoined then
                local opts = Instance.new("TeleportOptions")
                opts.ServerInstanceId = game.JobId
                pcall(function() TeleportService:TeleportAsync(game.PlaceId, {lp}, opts) end)
            end
        else
            pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, lp)
            end)
        end
    end)
    makeButton(g,"Joinxl",function()
        prepareKeep()
        game.ReplicatedStorage.System:FireServer("xl")
    end)
    makeButton(g,"Join Largest XL",function(btn)
        btn.Text="Finding..."
        -- Arm queue_on_teleport NOW, before the async fetch begins.
        -- Some executors' queue_on_teleport has a short validity window;
        -- calling it inside task.spawn (after several seconds of HTTP fetch)
        -- can miss the teleport event. Calling it here guarantees coverage.
        prepareKeep()
        task.spawn(function()
            local PLACE=12943245078; local bestId,bestCount=nil,-1; local cursor=""
            for _=1,5 do
                local url=("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100"):format(PLACE)
                if cursor~="" then url=url.."&cursor="..cursor end
                local ok,res=pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
                if not ok or not res or not res.data then break end
                for _,sv in ipairs(res.data) do
                    if (sv.playing or 0)>bestCount then bestCount=sv.playing; bestId=sv.id end
                end
                if bestCount >= 10 then break end  -- found a populated server, stop early
                local npc2=res.nextPageCursor
                if not npc2 or tostring(npc2)=="null" or tostring(npc2)=="nil" or npc2=="" then break end
                cursor=npc2
            end
            if not bestId then btn.Text="Not found!"; return end
            if game.JobId==bestId then btn.Text="Already here!"; return end
            btn.Text="Joining ("..bestCount..")..."
            -- prepareKeep() already called above; call again here as a
            -- belt-and-suspenders measure in case the fetch took a long time.
            prepareKeep()
            pcall(function() TeleportService:TeleportToPlaceInstance(PLACE,bestId,lp) end)
        end)
    end)

    makeSection(g,"Server Hopper")

    local _,minBox = makeInput(g,"Min Players","0",function(v)
        S.serverHopMinPop = tonumber(v) or 0
    end)
    local _,maxBox = makeInput(g,"Max Players","999",function(v)
        S.serverHopMaxPop = tonumber(v) or 999
    end)

    local function doHop(btn, loop)
        if S._hopRunning then return end
        S._hopRunning = true

        task.spawn(function()
            repeat
                if btn then btn.Text = "Searching..." end

                local placeId  = game.PlaceId
                local found    = false
                local cursor   = ""
                local attempts = 0

                local candidates = {}
                repeat
                    attempts = attempts + 1
                    local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(placeId)
                    if cursor ~= "" then url = url .. "&cursor=" .. cursor end
                    local ok, res = pcall(function()
                        return HttpService:JSONDecode(game:HttpGet(url))
                    end)
                    if not ok or not res or not res.data then break end

                    for _, sv in ipairs(res.data) do
                        local pop = sv.playing or 0
                        local cap = sv.maxPlayers or 999
                        if sv.id ~= game.JobId
                        and pop >= S.serverHopMinPop
                        and pop <= S.serverHopMaxPop
                        and pop < cap then
                            table.insert(candidates, sv.id)
                        end
                    end

                    local npc = res.nextPageCursor
                    if npc and npc ~= "" and tostring(npc) ~= "null" and tostring(npc) ~= "nil" then
                        cursor = npc
                    else
                        cursor = ""
                    end
                until cursor == "" or attempts >= 10

                if #candidates > 0 then
                    local target = candidates[math.random(1, #candidates)]
                    found = true
                    if btn then btn.Text = "Hopping..." end
                    prepareKeep()
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(placeId, target, lp)
                    end)
                    task.wait(5)
                else
                    if btn then btn.Text = "No server found" end
                    task.wait(3)
                end

                if not loop then S._hopRunning = false; break end
                if not S.serverHopEnabled then S._hopRunning = false; break end

                task.wait(1)
            until not S.serverHopEnabled

            S._hopRunning = false
            if btn and btn.Parent then btn.Text = "Hop Server" end
        end)
    end

    makeButton(g,"Hop Server",function(btn) doHop(btn, false) end)

    makeToggle(g,"Auto-Hop Loop",function(on)
        S.serverHopEnabled = on
        if on then
            doHop(nil, true)
        else
            S._hopRunning = false
            notify("Sigma","Auto-Hop stopped.")
        end
    end)

    makeSection(g,"Persistence")

    -- ── Keep Sigma + Follow Through Servers ───────────────────────────────
    -- Both features share _sigmaQueueTP (hoisted to module scope above the
    -- Server block) so prepareKeep() works from ANY teleport button.
    -- OnTeleport is a belt-and-suspenders safety net for server-initiated
    -- teleports (e.g. kicked to hub) where we never called prepareKeep().
    if _sigmaQueueTP then
        -- _queued guard: Roblox fires RequestedFromServer AND Started for the
        -- same teleport; without it queueteleport would run twice.
        local _queued = false
        lp.OnTeleport:Connect(function(state)
            if state == Enum.TeleportState.Failed
            or state == Enum.TeleportState.InProgress then
                _queued = false  -- reset on non-success so next hop can queue fresh
            end
            if not _queued
            and (S.keepSigmaOn or S.followServers)
            and (state == Enum.TeleportState.RequestedFromServer
              or state == Enum.TeleportState.Started) then
                _queued = true
                local url = S.sigmaUrl .. "?t=" .. tostring(os.time())
                _sigmaQueueTP("loadstring(game:HttpGet('"..url.."'))() ")
            end
        end)

        makeToggle(g,"Keep Sigma",function(on)
            S.keepSigmaOn = on
            _queued = false
            if on then notify("Sigma","Keep Sigma ON \226\128\148 panel will re-load on teleport.") end
        end, true)

        makeToggle(g,"Follow Through Servers",function(on)
            S.followServers = on
            _queued = false
            if on then
                notify("Sigma","Follow ON \226\128\148 re-executes after every teleport.")
            else
                notify("Sigma","Follow OFF.")
            end
        end, true)
    else
        makeSection(g,"Keep Sigma / Follow: not supported by this executor")
    end

    -- ── Script URL for re-execute ─────────────────────────────
    -- S.sigmaUrl is the single source of truth used by prepareKeep() and
    -- the OnTeleport handler. The input below lets you point Keep Sigma at
    -- your own fork / personal URL without editing the script.
    -- A URL saved in SigmaPanel_url.txt overrides the built-in default on load.
    -- Cache-busting (?t=timestamp) is appended automatically by prepareKeep().
    pcall(function()
        if typeof(isfile) == "function" and typeof(readfile) == "function" then
            if isfile("SigmaPanel_url.txt") then
                local saved = readfile("SigmaPanel_url.txt"):match("^%s*(.-)%s*$")
                if saved ~= "" then S.sigmaUrl = saved end
            end
        end
    end)

    local _,urlBox = makeInput(g,"Script URL", S.sigmaUrl, function(v)
        v = v:match("^%s*(.-)%s*$")
        if v ~= "" then
            S.sigmaUrl = v
            pcall(function() if typeof(writefile)=="function" then writefile("SigmaPanel_url.txt", v) end end)
            notify("Sigma","Script URL updated — Keep Sigma will use this on next teleport.")
        end
    end)
    urlBox.Text = S.sigmaUrl  -- pre-fill with current value (default or saved)

    makeButton(g,"Test Re-execute",function(btn)
        btn.Text = "Loading..."
        task.spawn(function()
            -- Use live S.sigmaUrl with cache-bust: tests exactly what Keep Sigma loads
            local url = S.sigmaUrl .. "?t=" .. tostring(os.time())
            local ok, err = pcall(function() loadstring(game:HttpGet(url))() end)
            btn.Text = ok and "OK!" or "Failed"
            if not ok then notify("Sigma","Re-execute test failed: "..tostring(err)) end
        end)
    end)
end

do -- Character
    local g=makeGroup(mainPage,"Character")
    makeToggle(g,"Noclip",function(on)
        S.noclip=on
        -- Suppress the falling animation while noclip is active.
        -- SetStateEnabled blocks Freefall/FallingDown transitions so the Humanoid
        -- stays in Running state visually. The Stepped loop is belt-and-suspenders:
        -- if the Humanoid somehow forces its way into Freefall anyway (e.g. on respawn
        -- before CharacterAdded fires), we kick it back to Running immediately.
        local function applyStates(char)
            local hum=char and char:FindFirstChildOfClass("Humanoid"); if not hum then return end
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Freefall,    false)
        end
        local function restoreStates(char)
            local hum=char and char:FindFirstChildOfClass("Humanoid"); if not hum then return end
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Freefall,    true)
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        if on then
            applyStates(lp.Character)
            -- Re-apply state blocks on respawn so noclip persists across deaths
            S._noclipRespConn=lp.CharacterAdded:Connect(function(c)
                task.wait(0.1) -- let Humanoid initialise
                if S.noclip then applyStates(c) end
            end)
            S._noclipConn=RunService.Stepped:Connect(function()
                local char=lp.Character; if not char then return end
                local hum=char:FindFirstChildOfClass("Humanoid")
                for _,p in pairs(char:GetChildren()) do
                    if p:IsA("BasePart") then p.CanCollide=false end
                end
                -- Only call ChangeState when actually in a falling state to avoid
                -- every-frame spam that causes animation jitter
                if hum then
                    local st=hum:GetState()
                    if st==Enum.HumanoidStateType.Freefall
                    or st==Enum.HumanoidStateType.FallingDown then
                        hum:ChangeState(Enum.HumanoidStateType.Running)
                    end
                end
            end)
        else
            if S._noclipConn     then S._noclipConn:Disconnect();     S._noclipConn=nil     end
            if S._noclipRespConn then S._noclipRespConn:Disconnect(); S._noclipRespConn=nil end
            local char=lp.Character
            restoreStates(char)
            -- Restore CanCollide so the player lands normally
            if char then
                for _,p in pairs(char:GetChildren()) do
                    if p:IsA("BasePart") then p.CanCollide=true end
                end
            end
        end
    end)
