-- Returns list for brick-source dropdown (My Folder, Workspace Unanchored, player names)
local function _buildSourceList()
    local list = {"My Folder", "Workspace Unanchored"}
    local bf = getBricksFolder()
    if bf then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp and bf:FindFirstChild(p.Name) then
                list[#list+1] = p.Name
            end
        end
    end
    return list
end

-- Returns list for host dropdown (Myself + all players with a character)
local function _buildHostList()
    local list = {"Myself"}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then list[#list+1] = p.Name end
    end
    return list
end

