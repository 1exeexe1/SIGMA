local g3 = makeGroup(radPage, "3 — Brick → Core", "1 round per staff (up to 20): equip → fire ability → build on face → delete prev brick.")

makeButton(g3, "Brick \226\134\146 Core", function(btn)
    if RAD.busy then radStatus("Busy!"); return end
    local brick = RAD.selectedBrick
    if not brick or not brick.Parent then
        radStatus("No brick selected!"); return
    end
    RAD.busy = true

    task.spawn(function()
        -- Save safe position BEFORE camera shift or any teleport.
        local _safePosCore = nil
        do
            local _spc = lp.Character
            local _sph = _spc and _spc:FindFirstChild("HumanoidRootPart")
            if _sph then _safePosCore = _sph.CFrame end
        end

        setCamToSpawn(true)

        -- Snapshot all staffs once, in backpack-index order, before any equip.
        -- Each staff is used for exactly one round: equip \226\134\146 fire \226\134\146 build \226\134\146 delete prev.
        local staffList = snapshotStaffs()
        if #staffList == 0 then
            radStatus("No Force Staffs! Run Get Staffs first.")
            setCamToSpawn(false); RAD.busy = false; return
        end

        local totalRounds = #staffList   -- up to 20
        local ov = makeRadOverlay("Brick \226\134\146 Core", totalRounds, nil)
        local currentBrick = brick
        -- Record the starting position so we can teleport the final brick back
        -- before anchoring, rather than fighting gravity on every intermediate brick.
        local originalPos = brick.Position

        -- Alternate faces each round: Left on odd rounds, Right on even rounds.
        -- This keeps the new brick growing in opposite directions so the core
        -- stays close to the original position rather than walking in one direction.
        local FACES = { Enum.NormalId.Left, Enum.NormalId.Right }

        -- Pin the starting brick immediately so it does not drift upward while
        -- the player teleports away during the first round.
        pinBrick(currentBrick)

        for i = 1, totalRounds do
            if btn and btn.Parent then
                btn.Text = string.format("Core %d/%d...", i, totalRounds)
            end
            radStatus(string.format("Core %d/%d \226\128\148 equipping staff %d...", i, totalRounds, i))
            ov:setProgress(i - 1, totalRounds)

            -- If the brick has drifted significantly despite the pin, teleport the
            -- player to follow it so the build remote range check still passes.
            local hrpChk = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrpChk and currentBrick and currentBrick.Parent then
                local dist = (hrpChk.Position - currentBrick.Position).Magnitude
                if dist > 20 then
                    hrpChk.CFrame = CFrame.new(currentBrick.Position + Vector3.new(0, 6, 0))
                    task.wait(0.1)
                end
            end

            -- Step A: equip staff[i] and fire its ability \226\134\146 3s radiation aura begins
            local ok = equipAndFireStaff(staffList, i)
            if not ok then
                radStatus(string.format("Staff %d failed to fire \226\128\148 skipping.", i))
                task.wait(0.2)
            else
                -- Brief pause so radiation aura is confirmed on server before we build.
                -- currentBrick is pinned (brick.Anchored=true locally + BodyPosition/BodyGyro)
                -- so it holds position while the player teleports to its face.
                task.wait(0.15)

                -- Step B: build on alternating faces (Left/Right) to keep core on-spot.
                local face = FACES[(i % 2) + 1]   -- i=1→Left, i=2→Right, i=3→Left ...
                radStatus(string.format("Core %d/%d \226\128\148 building (%s)...", i, totalRounds,
                    face == Enum.NormalId.Left and "Left" or "Right"))
                local newBrick = buildOffFace(currentBrick, face)

                if not newBrick then
                    radStatus("Build failed on round " .. i .. "! Aborting.")
                    unpinBrick()
                    ov:destroy()
                    setCamToSpawn(false)
                    if _safePosCore then
                        local _re = lp.Character
                        local _reh = _re and _re:FindFirstChild("HumanoidRootPart")
                        if _reh then _reh.CFrame = _safePosCore end
                    end
                    RAD.busy = false
                    return
                end

                -- Step B2: pin newBrick immediately (bumps ownership, locks locally).
                -- pinBrick() replaces RAD.pinBP/BG, auto-releasing the old pin on currentBrick.
                pinBrick(newBrick)
                task.wait(0.06)

                -- Step C: delete the previous brick (radiation transferred to newBrick).
                deleteBrick(currentBrick)
                task.wait(0.06)

                -- Step D: advance
                currentBrick = newBrick
            end

            task.wait(0.08)
        end

        -- Bring the final brick back to its original position before anchoring.
        -- unpinBrick() first: releases brick.Anchored=true (local) and destroys
        -- BodyPosition/BodyGyro so they don't fight the CFrame write.
        -- Then bump ownership, write CFrame, settle, and fire the anchor remote.
        unpinBrick(currentBrick)
        task.wait(0.05)

        pcall(function()
            if typeof(sethiddenproperty) == "function" then
                sethiddenproperty(lp, "SimulationRadius", 9e9)
            end
        end)
        task.wait(0.15)
        currentBrick.CFrame = CFrame.new(originalPos)
        task.wait(BUILD_SETTLE)

        -- Anchor via remote (brick is now unanchored server-side at originalPos).
        setAnchor(currentBrick)
        task.wait(0.2)
        -- Paint core pitch-black if it is white/default: black maximises radiation transfer & containment.
        local _cCol = currentBrick.Color
        local _isWhite = (math.abs(_cCol.R-0.639)<0.1 and math.abs(_cCol.G-0.635)<0.1 and math.abs(_cCol.B-0.647)<0.1)
        if _isWhite then
            paintBrick(currentBrick, Color3.fromRGB(0, 0, 0), "glass")
            task.wait(0.15)
        end

        pcall(function()
            if typeof(sethiddenproperty) == "function" then
                sethiddenproperty(lp, "SimulationRadius", 500)
            end
        end)

        RAD.coreBrick   = currentBrick
        S.radCoreBrick  = currentBrick

        -- Move selection box to core for visual clarity
        if _radSelectSB then _radSelectSB.Adornee = currentBrick end

        ov:setProgress(totalRounds, totalRounds)
        ov:destroy()
        radStatus(string.format("Core built after %d rounds! Proceed to Core->Warhead.", totalRounds))
        setCamToSpawn(false)
        -- Restore player to safe position (far from core/warhead area).
        if _safePosCore then
            local _rc = lp.Character
            local _rh = _rc and _rc:FindFirstChild("HumanoidRootPart")
            if _rh then _rh.CFrame = _safePosCore end
        end
        RAD.busy = false
    end)
end)
