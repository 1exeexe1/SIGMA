do -- ╔═ buildBlockLegacy SCOPE ══╗
local function buildBlockLegacy(pos, bsize)
    setupBuiltTracker()
    if hasBlockAt(pos) then return end
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local grid = (bsize=="detailed") and 1 or GRID_MULT
    local maxChunk = (bsize=="detailed") and BUILD_DETAIL_CHUNK or BUILD_NORMAL_CHUNK
    local reach = maxChunk * grid * 0.5 * math.sqrt(3)
    if (hrp.Position - pos).Magnitude > reach then
        hrp.CFrame = CFrame.new(pos)   -- 1. teleport
        task.wait(BUILD_SETTLE)        -- 2. wait for server to see new position
        hrp.Anchored = true            -- 3. THEN anchor
    end
    local ev = getToolRemote("Build")
    if ev then
        ev:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, bsize or "normal")
        task.wait(BUILD_VERIFY_WAIT)
        if not hasBlockAt(pos) then
            ev:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, bsize or "normal")
            task.wait(BUILD_VERIFY_WAIT)
        end
    end
    hrp.Anchored = false
    S.built = false
end
end -- ╚═ buildBlockLegacy SCOPE ══╝ (still inside Construct Tool block)
