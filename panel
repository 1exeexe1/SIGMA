    -- Match every JSON object on its own line that has sigma_action
    for line in (response .. "\n"):gmatch("([^\n]+)\n") do
        local trimmed = line:match("^%s*({.+})%s*$")
        if trimmed and trimmed:find('"sigma_action"') and not trimmed:find('"probe"') then
            pcall(_aiExecuteAction, trimmed)
        end
    end
end

