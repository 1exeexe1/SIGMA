-- ── helpers ──────────────────────────────────────────────────
-- Returns the first playing Sound found inside a character/clone,
-- filtering out Roblox built-in locomotion sounds.
local _BB_IGNORE = {
    ["rbxasset://sounds/action_get_up.mp3"]=true,
    ["rbxasset://sounds/uuhhh.mp3"]=true,
    ["rbxasset://sounds/action_falling.mp3"]=true,
    ["rbxasset://sounds/action_jump.mp3"]=true,
    ["rbxasset://sounds/action_jump_land.mp3"]=true,
    ["rbxasset://sounds/impact_water.mp3"]=true,
    ["rbxasset://sounds/action_swim.mp3"]=true,
    ["rbxasset://sounds/action_footsteps_plastic.mp3"]=true,
}

local function _bbGetSound(char)
    -- Returns the first playing non-ignored Sound inside char (used for single-sound checks)
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Sound") and obj.Playing and not _BB_IGNORE[obj.SoundId] then
            return obj
        end
    end
    return nil
end

local function _bbGetAllSounds(char)
    -- Returns ALL playing non-ignored Sounds inside char (for multi-boombox clones)
    local out = {}
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("Sound") and obj.Playing and not _BB_IGNORE[obj.SoundId] then
            out[#out+1] = obj
        end
    end
    return out
end

local function _bbGetId(sound)
    -- Strip rbxassetid:// prefix; return bare numeric ID string
    if not sound then return nil end
    local id = tostring(sound.SoundId)
    return id:match("%d+") or id
end

local function _bbDuration(sound)
    -- Format TimeLength as M:SS; falls back to "?:??" if not loaded yet
    local ok, tl = pcall(function() return sound.TimeLength end)
    if not ok or tl == 0 then return "?:??" end
    local m = math.floor(tl/60)
    local s = math.floor(tl%60)
    return string.format("%d:%02d", m, s)
end

-- Returns a list of {char, sound, label, owner, isBoombox} for every
-- character/clone currently playing audio (boombox or otherwise depending
-- on S.boomboxOnly).
local function _bbGetSoundBoomboxOnly(char)
    -- Strict mode: only accept sounds that live inside a Tool whose name
    -- contains "boombox" (case-insensitive) or whose parent is a Tool.
    for _, tool in ipairs(char:GetDescendants()) do
        if tool:IsA("Tool") and tool.Name:lower():find("boombox") then
            for _, obj in ipairs(tool:GetDescendants()) do
                if obj:IsA("Sound") and obj.Playing and not _BB_IGNORE[obj.SoundId] then
                    return obj
                end
            end
        end
    end
    return nil
end

local function _bbScan()
    local results = {}
    local counted = {}   -- set of Model objects already added

    local function tryAdd(model, labelStr, ownerStr)
        if counted[model] then return end
        local snd, isBoombox
        if S.boomboxOnly then
            snd = _bbGetSoundBoomboxOnly(model)
            isBoombox = true
        else
            -- Permissive: any non-ignored playing sound
            snd = _bbGetSound(model)
            -- Check if it came from a boombox tool for tinting purposes
            isBoombox = snd and (function()
                local p = snd.Parent
                while p and p ~= model do
                    if p:IsA("Tool") and p.Name:lower():find("boombox") then return true end
                    p = p.Parent
                end
                return false
            end)() or false
        end
        if snd then
            results[#results+1] = {char=model, sound=snd, label=labelStr,
                                   owner=ownerStr, isBoombox=isBoombox}
            counted[model] = true
        end
    end

    -- 1. Player characters
    for _, plr in ipairs(Players:GetPlayers()) do
        local char = plr.Character
        if char then tryAdd(char, plr.Name, plr.Name) end
    end

    -- 2. workspace.Clones[username] — iterate ALL Model children, not just
    --    FindFirstChild("Clone"), so multiple clones per user are all caught.
    local clonesFolder = Workspace:FindFirstChild("Clones")
    if clonesFolder then
        for _, userFolder in ipairs(clonesFolder:GetChildren()) do
            local ownerName = userFolder.Name
            for _, child in ipairs(userFolder:GetChildren()) do
                if child:IsA("Model") then
                    tryAdd(child, "[Clone] "..ownerName, ownerName)
                end
            end
        end
    end

    return results
end

