-- ── SUB-TAB BAR ──────────────────────────────────────────────
-- Creates a horizontal sub-tab strip inside a big tab's scroll page.
-- subNames: array of string names (first = default active).
-- Returns a table { [name] = scrollingFrame } of sub-tab content pages.
local function makeSubTabBar(parentScrollPage, subNames)
    local bar = Instance.new("Frame")
    bar.Name = "SubTabBar"
    bar.Size = UDim2.new(1,0,0,24)
    bar.BackgroundColor3 = T.SIDEBAR; bar.BorderColor3 = T.BORDER
    bar.BorderMode = Enum.BorderMode.Middle
    bar.ZIndex = 8; bar.LayoutOrder = -999; bar.Parent = parentScrollPage
    onTheme(function(th) bar.BackgroundColor3=th.SIDEBAR; bar.BorderColor3=th.BORDER end)

    local barLayout = Instance.new("UIListLayout")
    barLayout.FillDirection = Enum.FillDirection.Horizontal
    barLayout.SortOrder = Enum.SortOrder.LayoutOrder
    barLayout.Padding = UDim.new(0,1)
    barLayout.Parent = bar

    local subPages = {}
    local subBtns  = {}
    local activeSubName = subNames[1]

    local function setSubTab(name)
        activeSubName = name
        for n, btn in pairs(subBtns) do
            btn.BackgroundColor3 = (n==name) and T.ACCENT or T.BTN
            btn.TextColor3 = T.WHITE
        end
        for n, pg in pairs(subPages) do
            pg.Visible = (n==name)
        end
    end
    onTheme(function(th)
        bar.BackgroundColor3 = th.SIDEBAR; bar.BorderColor3 = th.BORDER
        for n, btn in pairs(subBtns) do
            btn.BackgroundColor3 = (n==activeSubName) and th.ACCENT or th.BTN
            btn.BorderColor3 = th.BORDER; btn.TextColor3 = th.WHITE
        end
    end)

    for i, name in ipairs(subNames) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1/#subNames, 0, 1, 0)
        btn.BackgroundColor3 = (i==1) and T.ACCENT or T.BTN
        btn.BorderColor3 = T.BORDER; btn.BorderSizePixel = 1
        btn.Text = name; btn.TextColor3 = T.WHITE
        btn.FontFace = FONT_MAIN; btn.TextSize = 11
        btn.LayoutOrder = i; btn.ZIndex = 9; btn.Parent = bar
        subBtns[name] = btn

        local sf = Instance.new("ScrollingFrame")
        sf.Name = "SubPage_"..name
        sf.Size = UDim2.new(1,-6,1,-30)
        sf.Position = UDim2.new(0,3,0,27)
        sf.BackgroundTransparency = 1; sf.BorderSizePixel = 0
        sf.ScrollBarThickness = 3; sf.ScrollBarImageColor3 = T.ACCENT
        sf.AutomaticCanvasSize = Enum.AutomaticSize.Y
        sf.CanvasSize = UDim2.new(0,0,0,0)
        sf.Visible = (i==1); sf.ZIndex = 7; sf.Parent = parentScrollPage
        onTheme(function(th) sf.ScrollBarImageColor3 = th.ACCENT end)

        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0,5); layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Parent = sf
        local pad = Instance.new("UIPadding")
        pad.PaddingTop = UDim.new(0,4); pad.PaddingLeft = UDim.new(0,4)
        pad.PaddingRight = UDim.new(0,4); pad.Parent = sf

        subPages[name] = sf
        btn.MouseButton1Click:Connect(function() setSubTab(name) end)
    end

    return subPages
end

