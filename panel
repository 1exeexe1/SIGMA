do
    local gCos = makeGroup(cosmeticsPage, "Cosmetic Presets",
        "Arrange bricks/parts into shapes: wings, swords, staffs, etc. "..
        "Each preset is a position/CFrame layout applied relative to your character.")

    makeSection(gCos, "── Static Formations ───────────────────────────")
    makeSection(gCos, "Pick a shape, choose brick source, then Apply. Bricks stay in that formation until released.")

    local _cosSource = "My Folder"
    local _cosHostName = "Myself"
    local _cosActive = false
    local _cosConn   = nil
    local _cosParts  = {}
    local _cosPartsWereAnchored = {}

    local function _cosGetHostHRP(hostName)
        if hostName == "Myself" or hostName == lp.Name then
            return lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        end
        local t = Players:FindFirstChild(hostName)
        return t and t.Character and t.Character:FindFirstChild("HumanoidRootPart")
    end

    -- Formation definitions: return list of CFrame offsets relative to host HRP
    local FORMATIONS = {
        ["Wings"] = function(n)
            local offsets = {}
            local half = math.ceil(n/2)
            for i = 1, half do
                local t = i/half
                local x = -3 - t*3; local y = t*2; local z = 0
                offsets[#offsets+1] = CFrame.new(x, y, z) * CFrame.Angles(0,0, math.rad(30*t))
            end
            for i = 1, n - half do
                local t = i/(n-half)
                local x = 3 + t*3; local y = t*2; local z = 0
                offsets[#offsets+1] = CFrame.new(x, y, z) * CFrame.Angles(0,0,-math.rad(30*t))
            end
            return offsets
        end,
        ["Sword"] = function(n)
            local offsets = {}
            for i = 1, n do
                offsets[#offsets+1] = CFrame.new(0, 0, -i * 2) * CFrame.Angles(0, 0, 0)
            end
            return offsets
        end,
        ["Staff"] = function(n)
            local offsets = {}
            for i = 1, n do
                offsets[#offsets+1] = CFrame.new(0, i * 2, 0)
            end
            return offsets
        end,
        ["Halo"] = function(n)
            local offsets = {}
            for i = 1, n do
                local a = (i-1) * (2*math.pi / n)
                offsets[#offsets+1] = CFrame.new(math.cos(a)*4, 4, math.sin(a)*4)
            end
            return offsets
        end,
        ["Shield"] = function(n)
            local offsets = {}
            local cols = math.ceil(math.sqrt(n))
            for i = 1, n do
                local row = math.floor((i-1)/cols)
                local col = (i-1) % cols
                offsets[#offsets+1] = CFrame.new((col - cols/2)*1.2, (row - cols/2)*1.2, -4)
            end
            return offsets
        end,
    }
    local FORMATION_NAMES = {"Wings","Sword","Staff","Halo","Shield"}

    local _cosFormation = "Wings"
    local _cosFollowAngle = false

    local _, cosSourceSetValues = makeDropdown(cosmeticsPage,
        "Brick Source", {"My Folder","Workspace Unanchored"}, "My Folder",
        function(v) _cosSource = v end)
    local _, cosHostSetValues = makeDropdown(cosmeticsPage,
        "Host", {"Myself"}, "Myself",
        function(v) _cosHostName = v end)
    makeDropdown(cosmeticsPage, "Formation", FORMATION_NAMES, "Wings",
        function(v) _cosFormation = v end)
    makeSection(cosmeticsPage, "Wings=wing pair | Sword=forward blade | Staff=vertical pole | Halo=head ring | Shield=front wall")
    makeToggle(cosmeticsPage, "Follow Player's Angle", function(on) _cosFollowAngle=on end, false,
        "Formation rotates with host yaw -- good for wings/sword.")

    local cosStatusLbl = makeLabel(cosmeticsPage, "Status: inactive")
    cosStatusLbl.TextColor3 = Color3.fromRGB(140,140,140)

    local function _cosStop()
        _cosActive = false
        if _cosConn then _cosConn:Disconnect(); _cosConn = nil end
        for _, p in ipairs(_cosParts) do
            pcall(function()
                if p and p.Parent then p.Anchored = _cosPartsWereAnchored[p] or false end
            end)
        end
        _cosParts = {}; _cosPartsWereAnchored = {}
        cosStatusLbl.Text = "Status: inactive"
    end

    local _,_,setCosToggle = makeToggle(cosmeticsPage, "Toggle Formation", function(on)
        if on then
            if _cosActive then return end
            local hrp = _cosGetHostHRP(_cosHostName)
            if not hrp then
                notify("Cosmetics","Host has no character.")
                task.defer(function() if setCosToggle then setCosToggle(false) end end)
                return
            end
            -- Grab bricks (re-use ring source logic)
            local excl = {}
            for _, inst in pairs(_activeRings) do
                for _, p in ipairs(inst.parts or {}) do excl[p] = true end
            end
            local src = _ringGetSourceBricks(_cosSource, excl)
            if #src == 0 then
                notify("Cosmetics","No free bricks found.")
                task.defer(function() if setCosToggle then setCosToggle(false) end end)
                return
            end
            _cosActive = true
            _ringBumpOwnership()
            task.wait(0.06)
            for _, b in ipairs(src) do
                _cosPartsWereAnchored[b] = b.Anchored
                _cosParts[#_cosParts+1] = b
            end
            local n = #_cosParts
            local fmFn = FORMATIONS[_cosFormation]
            cosStatusLbl.Text = "Status: active O " .. n .. "x " .. _cosFormation
            _cosConn = RunService.Heartbeat:Connect(function()
                if not _cosActive then return end
                local h = _cosGetHostHRP(_cosHostName)
                if not h then return end
                local offsets = fmFn(n)
                local yaw = CFrame.new()
                if _cosFollowAngle then
                    local look = h.CFrame.LookVector
                    yaw = CFrame.Angles(0, math.atan2(-look.X,-look.Z), 0)
                end
                local base = CFrame.new(h.Position)
                for i, p in ipairs(_cosParts) do
                    if p and p.Parent then
                        local off = offsets[i] or offsets[#offsets]
                        pcall(function()
                            p.AssemblyLinearVelocity  = Vector3.zero
                            p.AssemblyAngularVelocity = Vector3.zero
                            p.CFrame = base * yaw * off
                        end)
                    end
                end
            end)
        else
            _cosStop()
        end
    end, false, "Hold bricks in the chosen formation around the host.")

    -- Player-list refresh for cosmetics dropdowns
    local function _cosRefreshDropdowns()
        local hostList = {"Myself"}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= lp then hostList[#hostList+1] = p.Name end
        end
        if cosHostSetValues then cosHostSetValues(hostList, _cosHostName) end
    end
    Players.PlayerAdded:Connect(_cosRefreshDropdowns)
    Players.PlayerRemoving:Connect(function() task.wait(0.1); _cosRefreshDropdowns() end)
end


