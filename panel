-- ── Info-button system ─────────────────────────────────────────────────────
-- Each widget with a tip string gets a square [i] button appended to its row.
-- Clicking [i] toggles an inline label below the row showing the description.
-- No hover, no timer, no floating frame — fully deterministic.
-- Works on desktop AND mobile (just a button click).
-- ─────────────────────────────────────────────────────────────────────────────

-- Shared label pool: one TextLabel per row reused across open/close.
-- We reuse the same pattern as the old tooltip but inline instead of floating.

local function attachInfoBtn(row, tipText)
    if not tipText or tipText == "" then return end
    if not row or not row.Parent then return end

    -- Shrink the main content in the row to make room for the [i] button.
    -- The first non-Frame, non-UIPadding child that fills the row width gets shrunk.
    local content = nil
    for _, c in ipairs(row:GetChildren()) do
        if c:IsA("GuiObject") and c ~= nil then
            -- Buttons, TextBoxes, TextLabels that span most of the row
            if c.Size.X.Scale > 0.5 or c.Size.X.Offset > 60 then
                content = c; break
            end
        end
    end
    if content then
        -- Reserve 22px on the right for the [i] button
        content.Size = UDim2.new(
            content.Size.X.Scale,
            content.Size.X.Offset - 22,
            content.Size.Y.Scale,
            content.Size.Y.Offset)
    end

    -- The [i] button itself — fixed 18×18 square, right-aligned in the row
    local iBtn = Instance.new("TextButton")
    iBtn.Name            = "InfoBtn"
    iBtn.Size            = UDim2.new(0, 18, 0, 16)
    iBtn.Position        = UDim2.new(1, -20, 0.5, -8)
    iBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
    iBtn.BorderColor3    = T.BORDER
    iBtn.Text            = "i"
    iBtn.TextColor3      = T.ACCENT
    iBtn.FontFace        = FONT_MAIN
    iBtn.TextSize        = 11
    iBtn.ZIndex          = 10
    iBtn.Parent          = row
    onTheme(function(th)
        iBtn.BorderColor3 = th.BORDER
        iBtn.TextColor3   = th.ACCENT
    end)

    -- The inline description label — lives in the parent group frame, below the row.
    -- Hidden by default; toggled by iBtn clicks.
    local descLbl = Instance.new("TextLabel")
    descLbl.Name             = "InfoDesc"
    descLbl.Size             = UDim2.new(1, -8, 0, 0)
    descLbl.AutomaticSize    = Enum.AutomaticSize.Y
    descLbl.Position         = UDim2.new(0, 4, 0, 0)
    descLbl.BackgroundColor3 = Color3.fromRGB(14, 14, 20)
    descLbl.BorderColor3     = T.ACCENT
    descLbl.Text             = tipText
    descLbl.TextColor3       = Color3.fromRGB(190, 190, 210)
    descLbl.FontFace         = FONT_MAIN
    descLbl.TextSize         = 11
    descLbl.TextWrapped      = true
    descLbl.TextXAlignment   = Enum.TextXAlignment.Left
    descLbl.ZIndex           = 9
    descLbl.Visible          = false
    descLbl.Parent           = row.Parent   -- sibling in the group inner frame
    onTheme(function(th)
        descLbl.BorderColor3 = th.ACCENT
    end)

    -- Padding inside the desc label
    local dp = Instance.new("UIPadding", descLbl)
    dp.PaddingLeft   = UDim.new(0, 4)
    dp.PaddingRight  = UDim.new(0, 4)
    dp.PaddingTop    = UDim.new(0, 3)
    dp.PaddingBottom = UDim.new(0, 3)

    -- Toggle on click
    local open = false
    iBtn.MouseButton1Click:Connect(function()
        open = not open
        descLbl.Visible      = open
        iBtn.Text            = open and "x" or "i"
        iBtn.BackgroundColor3 = open
            and Color3.fromRGB(40, 40, 60)
            or  Color3.fromRGB(30, 30, 42)
    end)
end

-- Keep attachTooltip as an alias so any leftover direct calls still work.
local function attachTooltip(obj, tipText)
    if not tipText or tipText == "" then return end
    -- Find the row (parent Frame) to attach the [i] button to
    local row = obj
    if obj and obj.Parent and obj.Parent:IsA("Frame")
       and obj.Parent.BackgroundTransparency == 1 then
        row = obj.Parent
    end
    attachInfoBtn(row, tipText)
end

-- Patch widget makers to auto-attach [i] info buttons.
local _origMakeButton   = makeButton
local _origMakeToggle   = makeToggle
local _origMakeSection  = makeSection
local _origMakeGroup    = makeGroup

-- makeButton: pass tip as 4th arg
makeButton = function(parent, label, cb, tip)
    local row, btn = _origMakeButton(parent, label, cb)
    if tip then attachInfoBtn(row, tip) end
    return row, btn
end

-- makeToggle: pass tip as 5th arg
makeToggle = function(parent, label, cb, defaultOn, tip)
    local row, tick, setState = _origMakeToggle(parent, label, cb, defaultOn)
    if tip then attachInfoBtn(row, tip) end
    return row, tick, setState
end

-- makeSection: pass tip as 3rd arg
makeSection = function(parent, text, tip)
    local lbl = _origMakeSection(parent, text)
    if tip then
        -- For sections, attach [i] to the label row directly
        attachInfoBtn(lbl, tip)
    end
    return lbl
end

-- makeGroup: pass tip as 3rd arg (attaches [i] to the group header row)
makeGroup = function(parent, title, tip)
    local inner = _origMakeGroup(parent, title)
    if tip then
        local grpFrame = inner.Parent
        if grpFrame then
            local titleLbl = grpFrame:FindFirstChildWhichIsA("TextLabel")
            if titleLbl and titleLbl.Parent then
                attachInfoBtn(titleLbl.Parent, tip)
            end
        end
    end
    return inner
end

-- ── Player resolver ───────────────────────────────────────────
-- Matches by: exact username, exact display name, partial username,
-- partial display name, numeric user-id prefix ("83" → "8363hls").
local function resolvePlayer(raw)
    if not raw or raw == "" then return nil end
    raw = raw:lower():gsub("^%s+", ""):gsub("%s+$", "")
    local best, bestScore = nil, 0
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            local uLow = p.Name:lower()
            local dLow = p.DisplayName:lower()
            local uid  = tostring(p.UserId)
            local score = 0
            -- Exact matches win immediately
            if uLow == raw or dLow == raw then return p end
            -- Numeric prefix of UserId
            if uid:sub(1, #raw) == raw then score = 90 end
            -- Starts-with match
            if uLow:sub(1, #raw) == raw then score = math.max(score, 80) end
            if dLow:sub(1, #raw) == raw then score = math.max(score, 75) end
            -- Substring match
            if uLow:find(raw, 1, true) then score = math.max(score, 60) end
            if dLow:find(raw, 1, true) then score = math.max(score, 55) end
            if score > bestScore then bestScore = score; best = p end
        end
    end
    return best
end

-- ── Color parser (hex or r,g,b) ───────────────────────────────
local function parseColor(s)
    if not s then return nil end
    s = s:gsub("^%s+",""):gsub("%s+$","")
    local hex = s:match("^#?(%x%x%x%x%x%x)$")
    if hex then
        return Color3.fromRGB(
            tonumber(hex:sub(1,2),16),
            tonumber(hex:sub(3,4),16),
            tonumber(hex:sub(5,6),16))
    end
    local r,g,b = s:match("^(%d+)[,%s]+(%d+)[,%s]+(%d+)$")
    if r then return Color3.fromRGB(tonumber(r),tonumber(g),tonumber(b)) end
    return nil
end

-- ── Command definitions ───────────────────────────────────────
-- Each entry: { name, aliases={}, args="<syntax>", desc="...", fn=function(args) }
-- args is a table of whitespace-split tokens after the command name.
local SIGMA_CMDS = {}

local function addCmd(name, aliases, argSyntax, desc, fn, stateKey)
    SIGMA_CMDS[#SIGMA_CMDS+1] = {
        name     = name:lower(),
        aliases  = aliases or {},
        args     = argSyntax or "",
        desc     = desc or "",
        fn       = fn,
        stateKey = stateKey,  -- optional: S field name for boolean toggles
    }
end

-- ── Helper: notify only if cmdNotify on ──────────────────────
