            inner.ClipsDescendants=true
            local targetY=minimized and 0 or inner.UIListLayout and inner.UIListLayout.AbsoluteContentSize.Y or 0
            -- Use AutomaticSize trick: disable it, tween to 0, re-enable on expand
            if minimized then
                local fullH=inner.AbsoluteSize.Y
                inner.AutomaticSize=Enum.AutomaticSize.None
                inner.Size=UDim2.new(1,0,0,fullH)
                TweenService:Create(inner,TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,0)}):Play()
            else
                inner.Size=UDim2.new(1,0,0,0)
                inner.AutomaticSize=Enum.AutomaticSize.None
                inner.Visible=true
                local layout=inner:FindFirstChildOfClass("UIListLayout")
                local fullH=layout and layout.AbsoluteContentSize.Y or 60
                TweenService:Create(inner,TweenInfo.new(0.15,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(1,0,0,fullH)}):Play()
