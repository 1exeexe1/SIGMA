                end
            end
        else
            local p = Players:FindFirstChild(_tpTargetName)
            if p and p.Character then targets[1] = p end
        end

        if #targets == 0 then notify("Attacks","No targets in range."); return end

        local excl = {}
        for _, inst in pairs(_activeRings) do
            for _, p in ipairs(inst.parts or {}) do excl[p] = true end
        end
        local pool = _ringGetSourceBricks(_tpSource, excl)
        if #pool == 0 then notify("Attacks","No free bricks."); return end

        _ringBumpOwnership()
        task.wait(0.05)

        for _, target in ipairs(targets) do
            if not target.Character then continue end
            local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
            if not tHRP then continue end
            local hum  = target.Character:FindFirstChildOfClass("Humanoid")

            for j = 1, _tpBricksPerPlayer do
                if #pool == 0 then break end
                local b = table.remove(pool, 1)
                if not b or not b.Parent then continue end

                task.spawn(function()
                    -- Move brick to target
                    local offset = Vector3.new(
                        math.random(-2,2), math.random(0,3), math.random(-2,2))
                    pcall(function()
                        b.AssemblyLinearVelocity  = Vector3.zero
                        b.AssemblyAngularVelocity = Vector3.zero
                        b.CFrame = CFrame.new(tHRP.Position + offset)
                    end)

                    -- Push with fling velocity
                    task.wait(0.05)
                    local flingDir = (tHRP.Position - hrp.Position).Unit
                    pcall(function()
                        b.AssemblyLinearVelocity = flingDir * _tpFlingStr
                    end)

                    -- Return on death
                    if _tpReturnOnDeath and hum then
                        local deathConn
                        deathConn = hum.Died:Connect(function()
                            deathConn:Disconnect()
                            -- Fly back to local player
                            local retConn
                            retConn = RunService.Heartbeat:Connect(function()
                                if not b or not b.Parent then retConn:Disconnect(); return end
                                local myH = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                                if not myH then retConn:Disconnect(); return end
                                local toMe = myH.Position - b.Position
                                if toMe.Magnitude < 4 then
                                    retConn:Disconnect()
                                    pcall(function() b.AssemblyLinearVelocity = Vector3.zero end)
                                    return
                                end
                                pcall(function()
                                    b.AssemblyLinearVelocity  = toMe.Unit * 60
                                    b.AssemblyAngularVelocity = Vector3.zero
                                end)
                            end)
                        end)
                    end
                end)
            end
        end
        notify("Attacks", "Sent parts to " .. #targets .. " target(s).")
    end)

