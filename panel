-- Try to fetch whitelist externally
local function loadExternalWhitelist()
    local ok, result = pcall(function()
        return game:HttpGet(WHITELIST_URL)
    end)
    if ok and result and result ~= "" then
        local loaded = {}
        for line in (result .. "\n"):gmatch("([^\n\r]+)[\n\r]*") do
            local name = line:match("^%s*(.-)%s*$")
            if name ~= "" then
                loaded[name] = true
            end
        end
        -- Sanity check: at least one name must be present
        local count = 0
        for _ in pairs(loaded) do count = count + 1 end
        if count > 0 then
            WHITELIST = loaded
            whitelistLoaded = true
            LOG("Whitelist", "External whitelist loaded: " .. count .. " entries.")
            return true
        end
    end
    LOG("Whitelist", "External load failed — using fallback whitelist.")
    WHITELIST = WHITELIST_FALLBACK
    return false
end

