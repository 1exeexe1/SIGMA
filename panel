-- ── Teardown helpers ─────────────────────────────────────────
local _bbLastId = {}   -- [char] = last soundId string seen (hoisted for teardown access)

local function _bbClearChar(char)
    local sb = S._boomboxSelBoxes[char]
    if sb then sb:Destroy(); S._boomboxSelBoxes[char]=nil end
    local bbd = S._boomboxBillboards[char]
    if bbd then bbd:Destroy(); S._boomboxBillboards[char]=nil end
    if S._boomboxIsBoombox then S._boomboxIsBoombox[char]=nil end
    _bbLastId[char]=nil
end

local function _bbClearAll()
    for char,_ in pairs(S._boomboxSelBoxes) do
        local sb=S._boomboxSelBoxes[char]; if sb then sb:Destroy() end
        S._boomboxSelBoxes[char]=nil
    end
    for char,_ in pairs(S._boomboxBillboards) do
        local bbd=S._boomboxBillboards[char]; if bbd then bbd:Destroy() end
        S._boomboxBillboards[char]=nil
    end
    S._boomboxSelBoxes={}; S._boomboxBillboards={}; S._boomboxNameCache={}
    S._boomboxIsBoombox={}
    _bbLastId={}
end

-- ── Main scan loop ────────────────────────────────────────────
local _bbLastScan  = 0

local function _bbTick()
    if not S.boomboxESP and not S.boomboxAudioHUD then
        _bbClearAll(); return
    end

    local now = tick()
    if (now - _bbLastScan) < 0.5 then return end
    _bbLastScan = now

    local found = _bbScan()
    local foundChars = {}
    for _, entry in ipairs(found) do foundChars[entry.char]=true end

    -- Remove stale entries; deselect if the selected char vanished
    for char,_ in pairs(S._boomboxSelBoxes) do
        if not foundChars[char] then
            if S._boomboxSelected == char then S._boomboxSelected = nil end
            _bbClearChar(char); _bbLastId[char]=nil
        end
    end
    for char,_ in pairs(S._boomboxBillboards) do
        if not foundChars[char] then
            if S._boomboxSelected == char then S._boomboxSelected = nil end
            _bbClearChar(char); _bbLastId[char]=nil
        end
    end

    for _, entry in ipairs(found) do
        local char, snd, label, isBoombox = entry.char, entry.sound, entry.label, entry.isBoombox
        local id       = _bbGetId(snd) or "?"
        local duration = _bbDuration(snd)

        -- Track boombox classification for color restoration on deselect
        S._boomboxIsBoombox[char] = isBoombox

        -- Auto-mute blacklisted IDs
        if S.boomboxAutoMute and S._boomboxBlacklist[id] then
            pcall(function() snd.Volume = 0 end)
            S._boomboxMuted[char] = true
        elseif S._boomboxMuted[char] then
            -- re-apply mute state (e.g. after billboard rebuild)
            pcall(function() snd.Volume = 0 end)
        end

        -- Name cache: keyed by (char, id) so a new song triggers a fresh lookup.
        local cacheKey = tostring(char)..":"..id
        if not S._boomboxNameCache[cacheKey] then
            task.spawn(function()
                local ok, info = pcall(function()
                    return game:GetService("MarketplaceService"):GetProductInfo(tonumber(id) or 0)
                end)
                if ok and info then S._boomboxNameCache[cacheKey] = info.Name end
            end)
        end
        local displayName = S._boomboxNameCache[cacheKey] or label

        -- SelectionBox: create once, never rebuild (clone-safe: adornee is the Model)
        if S.boomboxESP then
            if not S._boomboxSelBoxes[char] or not S._boomboxSelBoxes[char].Parent then
                local isSelected = (S._boomboxSelected == char)
                S._boomboxSelBoxes[char] = _bbMakeSelBox(char, isBoombox, isSelected)
            end
        else
            local sb=S._boomboxSelBoxes[char]; if sb then sb:Destroy(); S._boomboxSelBoxes[char]=nil end
        end

        -- BillboardGui: only rebuild when the song actually changes.
        if S.boomboxAudioHUD then
            local songChanged = (_bbLastId[char] ~= id)
            if songChanged or not S._boomboxBillboards[char] or not S._boomboxBillboards[char].Parent then
                local old = S._boomboxBillboards[char]
                if old then old:Destroy() end
                S._boomboxBillboards[char] = _bbMakeBillboard(char, id, duration, displayName, snd)
                _bbLastId[char] = id
            else
                -- Same song — just refresh the duration label in-place
                local bb = S._boomboxBillboards[char]
                local bg = bb and bb:FindFirstChildWhichIsA("Frame")
                if bg then
                    local dl = bg:FindFirstChild("DurLbl")
                    if dl then dl.Text = "⏱ "..duration end
                end
            end
        else
            local bbd=S._boomboxBillboards[char]; if bbd then bbd:Destroy(); S._boomboxBillboards[char]=nil end
            _bbLastId[char]=nil
        end
    end
end

