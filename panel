    if dm.running then return end
    dm.running=true; btn.Text="Demolishing..."
    task.spawn(function()
        local bf=getBricksFolder()
        if not bf then notify("Sigma","No Bricks folder!"); dm.running=false; btn.Text="\240\159\146\165 Demolish Zone"; return end
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then dm.running=false; btn.Text="\240\159\146\165 Demolish Zone"; return end

        local checkP=nil; pcall(function() checkP=OverlapParams.new(); checkP.FilterType=Enum.RaycastFilterType.Include end)
        if not checkP then notify("Sigma","OverlapParams not supported!"); dm.running=false; btn.Text="Demolish Zone"; return end
        checkP.FilterDescendantsInstances={bf}
        local targets={}
        for by=0,dm.sY-1 do for bx=0,dm.sX-1 do for bz=0,dm.sZ-1 do
            local pos=dm.origin+Vector3.new(bx*CT_GRID,by*CT_GRID,bz*CT_GRID)
            local hits=Workspace:GetPartBoundsInBox(CFrame.new(pos),Vector3.new(3,3,3),checkP)
            for _,h in ipairs(hits) do
                if h:IsA("BasePart") and not table.find(targets,h) then targets[#targets+1]=h end
            end
        end end end

        if #targets==0 then notify("Sigma","No blocks in zone!"); dm.running=false; btn.Text="\240\159\146\165 Demolish Zone"; return end

        -- Pass Fix: re-run all targets up to 5 times.
        -- Delete: if brick still has .Parent → fire; gone → skip.
        -- Unanchor: if brick still Anchored → fire; already loose → skip.
        local count = 0
        local PASSES = 5

        if dm.mode=="Delete" then
            local ev=getToolRemote("Delete")
            if not ev then notify("Sigma","Delete tool not found!"); dm.running=false; btn.Text="Demolish Zone"; return end
            for pass=1,PASSES do
                if not dm.running then break end
                local anyFired=false
                if not ev or not ev.Parent then ev=getToolRemote("Delete") end
                if not ev then break end
                hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then break end
                for _,b in ipairs(targets) do
                    if not dm.running then break end
                    if b and b.Parent then
                        ev:FireServer(b,hrp.Position); count=count+1; anyFired=true; task.wait(0.02)
                    end
                end
                if not anyFired then break end
                task.wait(0.35)
            end
        else  -- Unanchor
            local ev=getToolRemote("Paint")
            if not ev then notify("Sigma","Paint tool not found!"); dm.running=false; btn.Text="Demolish Zone"; return end
            for pass=1,PASSES do
                if not dm.running then break end
                local anyFired=false
                if not ev or not ev.Parent then ev=getToolRemote("Paint") end
                if not ev then break end
                hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then break end
                for _,b in ipairs(targets) do
                    if not dm.running then break end
                    if b and b.Parent and b.Anchored then
                        ev:FireServer(b,Enum.NormalId.Top,hrp.Position,HANDSHAKE,Color3.new(1,1,1),"anchor","")
                        count=count+1; anyFired=true; task.wait(0.02)
                    end
                end
                if not anyFired then break end
                task.wait(0.35)
            end
        end
        notify("Sigma",dm.mode.."d "..count.." block-ops!")
        dm.running=false; btn.Text="Demolish Zone"
    end)
end)

