local function _jRequest(userMsg)
    if #_jQueue == 0 then
        return "[Jarvis] No API keys in queue. Add keys in the API Manager tab."
    end

    local ctx      = _aiGetGameContext()
    local fullUser = "[LIVE GAME CONTEXT]\n" .. ctx .. "\n\n[USER MESSAGE]\n" .. userMsg

    local messages = {{role="system", content=AI_SYSTEM_PROMPT}}
    local startIdx = math.max(1, #_aiConversation - 18)
    for i = startIdx, #_aiConversation do
        table.insert(messages, _aiConversation[i])
    end
    table.insert(messages, {role="user", content=fullUser})

    if not _aiHttpRequest then
        return "[Jarvis] No HTTP executor found (need Synapse/Fluxus/KRNL)."
    end

    for _, id in ipairs(_jQueue) do
        if _jExhausted[id] then continue end
        local k = _jGetKey(id)
        if not k then continue end

        local ok, result = pcall(function()
            local body = game:GetService("HttpService"):JSONEncode({
                model       = k.model or "openai/gpt-4.1-mini",
                messages    = messages,
                max_tokens  = 2048,
                temperature = 0.7,
            })
            local resp = _aiHttpRequest({
                Url    = k.url,
                Method = "POST",
                Headers = {
                    ["Content-Type"]  = "application/json",
                    ["Authorization"] = "Bearer " .. k.key,
                    ["HTTP-Referer"]  = "https://sigma-panel",
                    ["X-Title"]       = "Jarvis/SigmaPanel",
                },
                Body = body,
            })
            if resp.StatusCode == 200 then
                local data = game:GetService("HttpService"):JSONDecode(resp.Body)
                if data.choices and data.choices[1] then
                    return data.choices[1].message.content
                end
                return "[Jarvis] Unexpected response shape."
            elseif resp.StatusCode == 429 or resp.StatusCode == 402 or resp.StatusCode == 413 then
                _jExhausted[id] = true
                notify("Jarvis", k.label .. " exhausted — switching to next key.")
                return nil  -- signal to try next
            else
                return "[Jarvis] API error " .. resp.StatusCode .. ": " .. tostring(resp.Body):sub(1,120)
            end
        end)

        if ok and result then return result end
        if ok and result == nil then continue end  -- exhausted, try next
        -- pcall failed
        if not ok then
            _jExhausted[id] = true
            notify("Jarvis", k.label .. " request failed — trying next.")
        end
    end

    return "[Jarvis] All queued API keys exhausted or failed."
end

-- ── ReAct probe loop ──────────────────────────────────────────
-- If Jarvis emits {"sigma_action":"probe","code":"..."}, we run
-- the code, capture output, and feed it back for a second pass.
local function _jCaptureOutput(code)
    local captured = {}

    -- Capture function that records any print/warn call
    local function captureFn(...)
        local parts = {}
        for i = 1, select("#", ...) do
            parts[#parts+1] = tostring(select(i, ...))
        end
        captured[#captured+1] = table.concat(parts, "\t")
    end

    -- Build an execution environment that inherits all globals
    -- but overrides print/warn so loadstring'd code is captured.
    -- setmetatable(__index=_G means any global the code uses still works.
    local execEnv = setmetatable({
        print = captureFn,
        warn  = captureFn,
        -- also expose common Roblox globals directly so they're not shadowed
        game        = game,
        workspace   = workspace,
        Workspace   = workspace,
        script      = script,
        task        = task,
        tick        = tick,
        os          = os,
        math        = math,
        string      = string,
        table       = table,
        pairs       = pairs,
        ipairs      = ipairs,
        select      = select,
        tostring    = tostring,
        tonumber    = tonumber,
        type        = type,
        pcall       = pcall,
        xpcall      = xpcall,
        error       = error,
        unpack      = unpack,
        rawget      = rawget,
        rawset      = rawset,
        next        = next,
        setmetatable= setmetatable,
        getmetatable= getmetatable,
        Instance    = Instance,
        Vector3     = Vector3,
        CFrame      = CFrame,
        Color3      = Color3,
        BrickColor  = BrickColor,
        Enum        = Enum,
        UDim2       = UDim2,
        UDim        = UDim,
        Ray         = Ray,
        TweenInfo   = TweenInfo,
        -- executor globals
        getfenv     = getfenv,
        setfenv     = setfenv,
        loadstring  = loadstring,
        getgenv     = getgenv,
        getrenv     = getrenv,
        syn         = syn,
        fluxus      = fluxus,
        http        = http,
        http_request= http_request,
        request     = request,
        writefile   = writefile,
        readfile    = readfile,
        isfile      = isfile,
        listfiles   = listfiles,
        sethiddenproperty = sethiddenproperty,
        gethiddenproperty = gethiddenproperty,
        firetouchinterest = firetouchinterest,
        fireclickdetector = fireclickdetector,
        fireproximityprompt = fireproximityprompt,
        setclipboard= setclipboard,
        -- panel globals
        S           = S,
        lp          = lp,
        Players     = Players,
        RunService  = RunService,
        ReplicatedStorage = ReplicatedStorage,
        HANDSHAKE   = HANDSHAKE,
        sendChat    = sendChat,
        notify      = notify,
        getToolRemote = getToolRemote,
        getBricksFolder = getBricksFolder,
    }, {__index = _G})

    local fn, lerr = loadstring(code)
    if not fn then
        captured[#captured+1] = "[compile error] " .. tostring(lerr)
    else
        -- Apply our capturing environment to the loaded function
        pcall(function()
            if setfenv then setfenv(fn, execEnv) end
        end)
        local ok, err = pcall(fn)
        if not ok then
            captured[#captured+1] = "[runtime error] " .. tostring(err)
        end
    end

    -- Also patch the global print temporarily as a belt-and-suspenders fallback
    -- for executors that don't support setfenv but do share a global env
    return #captured > 0 and table.concat(captured, "\n") or "(no output)"
end

local function _jSendWithProbe(userMsg, statusLbl, onDone)
    local MAX_ROUNDS = 5   -- covers probe + web_search + execute rounds combined
    local probeRound = 0
    local workingMsg = userMsg

    -- ── Web search helper (fires request() to a simple search scraper) ──────
    local function _jWebSearch(query)
        _jThink("🌐 Web search: " .. query:sub(1,80))
        local ok, result = pcall(function()
            -- Use DuckDuckGo instant answer API (no key needed)
            local encoded = query:gsub(" ", "+"):gsub("[^%w%+%-%._%~]", function(c)
                return string.format("%%%02X", string.byte(c))
            end)
            local url = "https://api.duckduckgo.com/?q=" .. encoded .. "&format=json&no_html=1&skip_disambig=1"
            local resp
            if typeof(request) == "function" then
                resp = request({Url=url, Method="GET"})
            elseif typeof(http) == "table" and typeof(http.get) == "function" then
                resp = {Body = http.get(url), StatusCode = 200}
            elseif typeof(syn) == "table" and typeof(syn.request) == "function" then
                resp = syn.request({Url=url, Method="GET"})
            elseif typeof(http_request) == "function" then
                resp = http_request({Url=url, Method="GET"})
            end
            if not resp then return "(web search: no HTTP executor)" end
            if resp.StatusCode ~= 200 then return "(web search: HTTP " .. tostring(resp.StatusCode) .. ")" end
            local body = resp.Body or ""
            -- Parse DDG JSON: AbstractText, Answer, RelatedTopics[0].Text
            local abstract = body:match('"AbstractText":"(.-)"') or ""
            local answer   = body:match('"Answer":"(.-)"') or ""
            local related  = body:match('"Text":"(.-)"') or ""
            abstract = abstract:gsub("\\n"," "):gsub('\\"','"'):sub(1,400)
            answer   = answer  :gsub("\\n"," "):gsub('\\"','"'):sub(1,200)
            related  = related :gsub("\\n"," "):gsub('\\"','"'):sub(1,200)
            local parts = {}
            if answer  ~= "" then parts[#parts+1] = "Answer: "   .. answer  end
            if abstract~= "" then parts[#parts+1] = "Summary: "  .. abstract end
            if related ~= "" then parts[#parts+1] = "Related: "  .. related  end
            if #parts == 0 then return "(web search: no results for \"" .. query .. "\")" end
            return table.concat(parts, "\n")
        end)
        local out = ok and result or ("(web search error: " .. tostring(result) .. ")")
        _jThink("   → " .. out:sub(1,100))
        return out
    end

    local function doRound()
        local raw = _jRequest(workingMsg)
        if not raw then onDone("[Jarvis] Request returned nil."); return end

        -- ── Web search action ─────────────────────────────────────────────────
        local wsQuery = raw:match('{"sigma_action":"web_search","query":"(.-)"[^}]*}')
        if wsQuery and probeRound < MAX_ROUNDS then
            probeRound = probeRound + 1
            wsQuery = wsQuery:gsub('\\"','"'):gsub('\\n','\n')
            statusLbl.Text = "⬡ Jarvis — searching web... (round " .. probeRound .. ")"
            local searchOut = _jWebSearch(wsQuery)
            workingMsg = workingMsg
                .. "\n\n[WEB SEARCH RESULT - round " .. probeRound .. " | query: " .. wsQuery .. "]\n" .. searchOut
            task.spawn(doRound)
            return
        end

        -- ── Probe action ──────────────────────────────────────────────────────
        local probeCode = raw:match('{"sigma_action":"probe","code":"(.-)"[^}]*}')
        if probeCode and probeRound < MAX_ROUNDS then
            probeRound = probeRound + 1
            probeCode = probeCode:gsub('\\"', '"'):gsub('\\n', '\n'):gsub('\\\\', '\\')
            statusLbl.Text = "⬡ Jarvis — probing game... (round " .. probeRound .. ")"
            _jThink("🔍 Probe " .. probeRound .. ": " .. probeCode:sub(1,80))
            local output = _jCaptureOutput(probeCode)
            _jThink("   → " .. output:sub(1,120))
            workingMsg = workingMsg
                .. "\n\n[PROBE OUTPUT - round " .. probeRound .. "]\n" .. output
            task.spawn(doRound)
            return
        end

        -- ── Execute / execute_until actions — run + auto-feed output ──────────
        local execResults = {}
        for line in (raw .. "\n"):gmatch("([^\n]+)\n") do
            local trimmed = line:match("^%s*({.+})%s*$")
            if trimmed and trimmed:find('"sigma_action"')
               and not trimmed:find('"probe"')
               and not trimmed:find('"web_search"') then
                -- For execute actions, capture output directly
                local execCode = trimmed:match('"code":"(.-)"[^}]*}')
                if execCode and (trimmed:find('"execute"') or trimmed:find('"execute_until"')) then
                    execCode = execCode:gsub('\\"','"'):gsub('\\n','\n'):gsub('\\\\','\\')
                    _jThink("⚡ Execute: " .. execCode:sub(1,80))
                    local out = _jCaptureOutput(execCode)
                    _jThink("   → " .. out:sub(1,100))
                    execResults[#execResults+1] = out
                end
                pcall(_jDispatchActions, trimmed)
            end
        end

        -- Auto-feed execute output back so Jarvis can confirm/react
        if #execResults > 0 and probeRound < MAX_ROUNDS then
            probeRound = probeRound + 1
            statusLbl.Text = "⬡ Jarvis — processing results... (round " .. probeRound .. ")"
            _jThink("✅ Execute results (round " .. probeRound .. "): " .. table.concat(execResults," | "):sub(1,100))
            workingMsg = workingMsg
                .. "\n\n[EXECUTE OUTPUT - round " .. probeRound .. "]\n"
                .. table.concat(execResults, "\n")
            task.spawn(doRound)
            return
        end

        onDone(raw)
    end

    task.spawn(doRound)
end

