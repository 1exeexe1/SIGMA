-- CHUNK BUILDER — rectangular decomposition for cubes/rectangles
-- KEY FIX: CFrame → wait(SETTLE) → Anchored=true (in that order)
-- This ensures the server sees the new HRP position BEFORE anchoring.
-- ═══════════════════════════════════════════════════════════════
-- ╔═ INF-BFS ENGINE ══════════════════════════════════════════════════════════╗
-- Infinite-range BFS build planner + executor.
-- Core insight: Build/Delete/Paint/Shape remotes accept a BasePart as arg[1].
-- When a brick ref is passed (not Terrain) the server ignores the caller's
-- position → zero-teleport builds from any distance.
--
-- planInfBFS  → compute ordered build plan + scaffold bridges
-- buildInfBFS → execute the plan by firing remotes, tracks placed parts
-- ─────────────────────────────────────────────────────────────────────────────

-- Face normals & axis lookup
local INF_FACE_NORM = {
    [Enum.NormalId.Right]  = Vector3.new( 1, 0, 0),
    [Enum.NormalId.Left]   = Vector3.new(-1, 0, 0),
    [Enum.NormalId.Top]    = Vector3.new( 0, 1, 0),
    [Enum.NormalId.Bottom] = Vector3.new( 0,-1, 0),
    [Enum.NormalId.Back]   = Vector3.new( 0, 0, 1),
    [Enum.NormalId.Front]  = Vector3.new( 0, 0,-1),
}
local INF_FACE_AX = {
    [Enum.NormalId.Right]="X", [Enum.NormalId.Left]="X",
    [Enum.NormalId.Top]="Y",   [Enum.NormalId.Bottom]="Y",
    [Enum.NormalId.Back]="Z",  [Enum.NormalId.Front]="Z",
}
-- Centre of a face on a part
local function infFaceCenter(part, face)
    local n  = INF_FACE_NORM[face]
    local ax = INF_FACE_AX[face]
    return part.Position + n * (part.Size[ax] / 2)
end
-- String key for a Vector3 (1-stud resolution)
local function infPK(v)
    return math.round(v.X).."_"..math.round(v.Y).."_"..math.round(v.Z)
end
-- Face of anchorPos pointing toward childPos (must be exactly one grid step apart)
local function infGridFace(anchorPos, childPos, grid)
    local dx = math.round((childPos.X - anchorPos.X) / grid)
    local dy = math.round((childPos.Y - anchorPos.Y) / grid)
    local dz = math.round((childPos.Z - anchorPos.Z) / grid)
    if dx== 1 and dy==0 and dz==0 then return Enum.NormalId.Right  end
    if dx==-1 and dy==0 and dz==0 then return Enum.NormalId.Left   end
    if dx== 0 and dy==1 and dz==0 then return Enum.NormalId.Top    end
    if dx== 0 and dy==-1 and dz==0 then return Enum.NormalId.Bottom end
    if dx== 0 and dy==0 and dz==1 then return Enum.NormalId.Back   end
    if dx== 0 and dy==0 and dz==-1 then return Enum.NormalId.Front  end
    return nil
end

-- ─────────────────────────────────────────────────────────────────────────────
-- planInfBFS(positions, seederPos, grid)
--
-- positions  : flat array of Vector3 (the target build positions, world-space)
-- seederPos  : Vector3 | nil
--              • not nil → an existing world brick at this position is the BFS root.
--                           The first ring of bricks build ON the seeder's faces.
--              • nil     → auto-pick the lowest-Y build position as root;
--                           that one brick falls back to a single Terrain build,
--                           then the entire rest of the load chains from it.
-- grid       : stud spacing (4 for normal, 1 for detailed)
--
-- Returns:
--   plan.order       — ordered list of entries:
--     { pos=V3, anchorPos=V3|nil, face=NormalId|nil, isScaffold=bool }
--     anchorPos=nil  → Terrain fallback (teleport needed for this single brick)
--     anchorPos=V3   → fire Build on the brick placed at anchorPos
--   plan.scaffoldKeys — set of infPK strings for scaffold bricks (to delete later)
-- ─────────────────────────────────────────────────────────────────────────────
local function planInfBFS(positions, seederPos, grid)
    local DIRS = {
        Vector3.new( grid, 0,   0), Vector3.new(-grid, 0,    0),
        Vector3.new( 0,    grid, 0), Vector3.new( 0,   -grid, 0),
        Vector3.new( 0,    0,   grid), Vector3.new( 0,    0, -grid),
    }

    -- Build position lookup (includes scaffold added later)
    local posSet      = {}  -- infPK → V3
    local scaffoldSet = {}  -- infPK → true (scaffold-only bricks)
    for _, p in ipairs(positions) do posSet[infPK(p)] = p end

    local visited = {}  -- infPK → true
    local order   = {}  -- final plan (built incrementally)
    local queue   = {}  -- BFS frontier: {pos=V3, anchorPos=V3}
    local qi      = 1

    -- ── Determine root ──────────────────────────────────────────────────────
    local virtualSeeder = false
    local rootPos       = seederPos

    if not rootPos then
        -- No seeder → use the lowest-Y build brick as the virtual root.
        -- That brick will be built with a one-time Terrain teleport.
        local lowestY, lowestP = math.huge, nil
        for k, p in pairs(posSet) do
            if p.Y < lowestY then lowestY = p.Y; lowestP = p end
        end
        if not lowestP then return {order={}, scaffoldKeys={}} end
        -- Place the virtual seeder one step BELOW the lowest brick so that brick
        -- is seeded in the first BFS ring (anchorPos = virtual root = Terrain fallback)
        rootPos       = lowestP - Vector3.new(0, grid, 0)
        virtualSeeder = true
    end

    visited[infPK(rootPos)] = true

    -- Seed ring: positions adjacent to root
    for _, d in ipairs(DIRS) do
        local nb = rootPos + d
        local k  = infPK(nb)
        if posSet[k] and not visited[k] then
            visited[k] = true
            local face      = infGridFace(rootPos, nb, grid)
            -- If virtual seeder: the first ring has anchorPos=nil (Terrain fallback).
            -- If real seeder: anchorPos=rootPos (build on seeder brick).
            local anchorArg = virtualSeeder and nil or rootPos
            order[#order+1] = {pos=nb, anchorPos=anchorArg, face=face, isScaffold=false}
            queue[#queue+1] = {pos=nb, anchorPos=anchorArg or nb}
            -- Note: queue uses the ACTUAL placed position (nb) as anchor for children,
            -- because after the Terrain build 'nb' itself is a real placed brick.
        end
    end

    -- ── BFS expansion ───────────────────────────────────────────────────────
    local function expandQueue()
        while qi <= #queue do
            local cur = queue[qi]; qi = qi + 1
            for _, d in ipairs(DIRS) do
                local nb = cur.pos + d
                local k  = infPK(nb)
                if posSet[k] and not visited[k] then
                    visited[k] = true
                    local face  = infGridFace(cur.pos, nb, grid)
                    local isSc  = scaffoldSet[k] or false
                    order[#order+1] = {pos=nb, anchorPos=cur.pos, face=face, isScaffold=isSc}
                    queue[#queue+1] = {pos=nb, anchorPos=cur.pos}
                end
            end
        end
    end
    expandQueue()

    -- ── Scaffold bridging for disconnected components ────────────────────────
    -- For each component unreachable from the seeder (e.g. gaps between text letters),
    -- walk an axis-aligned (Y→X→Z) path from the nearest visited position to the
    -- nearest unvisited position, placing scaffold bricks at every empty grid step.
    -- Scaffolds are tagged, built as part of the BFS, and deleted at the end.

    local function collectDisconnected()
        local disc = {}
        for k, p in pairs(posSet) do
            if not visited[k] and not scaffoldSet[k] then disc[#disc+1] = p end
        end
        return disc
    end

    local function addBridge(fromPos, toPos)
        -- L-shaped walk: Y axis first (avoid colliding into existing bricks at same height),
        -- then X, then Z.
        local cur = fromPos
        for _, ax in ipairs({"Y","X","Z"}) do
            local delta = toPos[ax] - cur[ax]
            local steps = math.round(delta / grid)
            local sign  = steps > 0 and 1 or -1
            for _ = 1, math.abs(steps) do
                local nxt = cur + Vector3.new(
                    ax=="X" and sign*grid or 0,
                    ax=="Y" and sign*grid or 0,
                    ax=="Z" and sign*grid or 0
                )
                local k = infPK(nxt)
                if not posSet[k] then
                    posSet[k]      = nxt
                    scaffoldSet[k] = true
                end
                cur = nxt
            end
        end
    end

    local disc       = collectDisconnected()
    local bridgePass = 0
    while #disc > 0 and bridgePass < 300 do
        bridgePass = bridgePass + 1
        -- Find closest (visited, disconnected) pair
        local bestDist, bestVP, bestDP = math.huge, nil, nil
        for k, vp in pairs(posSet) do
            if visited[k] then
                for _, dp in ipairs(disc) do
                    local d = (dp - vp).Magnitude
                    if d < bestDist then bestDist=d; bestVP=vp; bestDP=dp end
                end
            end
        end
        if not bestVP then break end
        addBridge(bestVP, bestDP)
        expandQueue()
        disc = collectDisconnected()
    end

    -- Remaining unreachable → Terrain fallback (safety net; ideally never reached)
    for k, p in pairs(posSet) do
        if not visited[k] then
            order[#order+1] = {pos=p, anchorPos=nil, face=nil, isScaffold=scaffoldSet[k] or false}
        end
    end

    return { order=order, scaffoldKeys=scaffoldSet }
end

-- ─────────────────────────────────────────────────────────────────────────────
-- buildInfBFS(plan, bmode, btn, previewParts, scaffoldTrack)
--
-- Executes a build plan from planInfBFS.
-- • Infinite-range bricks: FireServer(anchorPart, face, faceCenter, bmode) — no teleport.
-- • Terrain-fallback bricks (anchorPos=nil): teleport once, then Terrain build.
-- • scaffoldTrack: table — scaffold BaseParts are appended here for later deletion.
-- Returns: number of missed bricks (failed to confirm placement).
-- ─────────────────────────────────────────────────────────────────────────────
local function buildInfBFS(plan, bmode, btn, previewParts, scaffoldTrack)
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end

    -- Wait for brick folder (may not exist yet if this is the very first build)
    local myF = nil
    local fDL = tick() + 4
    repeat
        myF = getMyBrickFolder()
        if not myF then task.wait(0.06) end
    until myF or tick() > fDL

    if not myF then
        notify("Sigma", "Brick folder not found \226\128\148 cannot run BFS build.")
        if previewParts then for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end end
        return 0
    end

    local buildEv = getToolRemote("Build")
    if not buildEv then
        notify("Sigma", "Build tool missing!")
        if previewParts then for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end end
        return 0
    end

    -- posToPartRef: infPK(pos) → BasePart
    -- Pre-seed with the seeder brick (anchor for the very first ring)
    local posToPartRef = {}
    if S.seeder and S.seeder.Parent then
        posToPartRef[infPK(S.seeder.Position)] = S.seeder
    end

    local lastBuilt = nil
    local builtConn = myF.ChildAdded:Connect(function(child)
        if child:IsA("BasePart") then lastBuilt = child end
    end)

    local total  = #plan.order
    local missed = 0
    local WAIT_DL = 0.8   -- seconds to wait for ChildAdded confirmation (was 1.5)

    for idx, entry in ipairs(plan.order) do
        if S.buildStopped then break end
        S.skipBlock = false
        if btn then btn.Text = string.format("BFS %d/%d", idx, total) end

        local anchorPart = entry.anchorPos and posToPartRef[infPK(entry.anchorPos)]
        lastBuilt = nil

        if anchorPart and anchorPart.Parent and entry.face then
            -- ── Infinite-range: no teleport ──────────────────────────────────
            local fc = infFaceCenter(anchorPart, entry.face)
            buildEv:FireServer(anchorPart, entry.face, fc, bmode)
        else
            -- ── Terrain fallback: one-time teleport (first brick / no path) ──
            hrp.CFrame   = CFrame.new(entry.pos + Vector3.new(0, 6, 0))
            task.wait(BUILD_SETTLE)
            hrp.Anchored = true
            buildEv:FireServer(Workspace.Terrain, Enum.NormalId.Top, entry.pos, bmode)
        end

        -- Wait for ChildAdded confirmation
        local dl = tick() + WAIT_DL
        while not lastBuilt and tick() < dl do task.wait(0.02) end
        hrp.Anchored = false   -- safe even if never anchored

        if lastBuilt and lastBuilt.Parent then
            -- Register placed brick so children can anchor on it
            posToPartRef[infPK(lastBuilt.Position)] = lastBuilt
            -- Also register at the planned position (in case of sub-stud snap drift)
            posToPartRef[infPK(entry.pos)]          = lastBuilt
            if entry.isScaffold and scaffoldTrack then
                scaffoldTrack[#scaffoldTrack+1] = lastBuilt
            end
        else
            missed = missed + 1
        end

        task.wait(0.02)   -- minimum inter-brick spacing (was 0.06)
    end

    builtConn:Disconnect()
    hrp.Anchored = false

    if previewParts then
        for _, p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
    end

    return missed
end

-- Delete scaffold bricks via infinite-range Delete remote
local function deleteScaffold(scaffoldParts)
    if #scaffoldParts == 0 then return end
    local delEv = getToolRemoteCached("Delete")
    if not delEv then
        notify("Sigma", "Delete tool missing \226\128\148 scaffold bricks not cleaned up!")
        return
    end
    for _, b in ipairs(scaffoldParts) do
        if b and b.Parent then
            delEv:FireServer(b, b.Position)
            task.wait(0.01)  -- was 0.02
        end
    end
end

-- ╚═ INF-BFS ENGINE ══╝

local function buildChunked(originPos, sizeX, sizeY, sizeZ, bsize, btn, previewParts)
    local grid     = (bsize=="detailed") and 1 or GRID_MULT
    local maxChunk = (bsize=="detailed") and BUILD_DETAIL_CHUNK or BUILD_NORMAL_CHUNK

    -- Save player position before the first chunk TP; restore when done.
    local _preCF = nil
    do
        local _c = lp.Character
        local _h = _c and _c:FindFirstChild("HumanoidRootPart")
        if _h then _preCF = _h.CFrame end
    end

    local ev = getToolRemote("Build")
    if not ev then
        notify("Sigma","Build tool not found!")
        if btn and btn.Parent then btn.Text="No Build tool!" end
        return
    end

    setupBuiltTracker()  -- hook ChildAdded ONCE for the whole session

    local chunksX = math.max(1, math.ceil(sizeX/maxChunk))
    local chunksY = math.max(1, math.ceil(sizeY/maxChunk))
    local chunksZ = math.max(1, math.ceil(sizeZ/maxChunk))
    local totalChunks = chunksX*chunksY*chunksZ
    local chunkIdx = 0
    local allPositions = {}  -- track every position for final repair pass

    local _abort = false
    for cy=0,chunksY-1 do
        if _abort then break end
        for cx=0,chunksX-1 do
            if _abort then break end
            for cz=0,chunksZ-1 do
                if S.buildStopped then _abort = true; break end
                chunkIdx = chunkIdx + 1

                local bx0=cx*maxChunk; local bx1=math.min(bx0+maxChunk,sizeX)-1
                local by0=cy*maxChunk; local by1=math.min(by0+maxChunk,sizeY)-1
                local bz0=cz*maxChunk; local bz1=math.min(bz0+maxChunk,sizeZ)-1

                local wx = originPos.X + (bx0+bx1)*0.5*grid
                local wy = originPos.Y + (by0+by1)*0.5*grid
                local wz = originPos.Z + (bz0+bz1)*0.5*grid
                local chunkCenter = Vector3.new(wx, wy, wz)

                local positions = {}
                for by=by0,by1 do for bx=bx0,bx1 do for bz=bz0,bz1 do
                    local pos = originPos + Vector3.new(bx*grid, by*grid, bz*grid)
                    positions[#positions+1] = pos
                    allPositions[#allPositions+1] = pos
                end end end

                if btn and btn.Parent then
                    btn.Text = string.format("Chunk %d/%d", chunkIdx, totalChunks)
                end

                if not ev or not ev.Parent then
                    ev = getToolRemote("Build")
                    if not ev then _abort = true; break end
                end

                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then _abort = true; break end

                local didAnchor = false
                local chunkOk = pcall(function()
                    hrp.CFrame = CFrame.new(chunkCenter)
                    task.wait(BUILD_SETTLE)
                    -- Confirm server has caught up to our new position before anchoring.
                    -- A fast teleport between chunks can leave the server at the old
                    -- chunk position, making the new chunk's positions exceed 666 studs.
                    waitForServerPosSync(hrp, chunkCenter)
                    hrp.Anchored = true
                    didAnchor = true
                    local probeB=(bsize=="detailed") and Vector3.new(0.8,0.8,0.8) or nil
                    -- Chaos blitz: hammer this cluster until every brick lands.
                    -- No trailing passFixBuild needed — convergence is per-cluster.
                    blitzBuildChaos(ev, positions, bsize, probeB)
                end)

                if didAnchor then
                    hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.Anchored = false end
                end

                if not chunkOk then
                    ev = getToolRemote("Build")
                    if not ev then _abort = true; break end
                end
            end
        end
    end

    -- Safety unanchor
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Anchored = false end

    -- Restore pre-build position
    if _preCF then
        local _rh = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if _rh then _rh.CFrame = _preCF; task.wait(BUILD_SETTLE) end
    end

    if previewParts then
        for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
    end

    -- Final count and notify
    if btn and btn.Parent then
        if S.buildStopped then
            btn.Text = "Stopped."
        else
            notify("Sigma", "Build fully completed! \226\156\147")
            btn.Text = string.format("Done! %d blks \226\156\147", #allPositions)
        end
        task.delay(4, function() if btn and btn.Parent then btn.Text="Build Cube" end end)
    end
end

-- ═══════════════════════════════════════════════════════════════
-- TEXT BUILDER — column-based grouping along spread axis
-- Same CFrame→settle→anchor fix as buildChunked.
-- ═══════════════════════════════════════════════════════════════
local function buildTextPositions(positions, bsize, btn, previewParts)
    if #positions==0 then return end

    local grid     = (bsize=="detailed") and 1 or GRID_MULT
    local maxChunk = (bsize=="detailed") and BUILD_DETAIL_CHUNK or BUILD_NORMAL_CHUNK
    local maxSpan  = maxChunk * grid

    -- Save player position before the first group TP; restore when done.
    local _preCF = nil
    do
        local _c = lp.Character
        local _h = _c and _c:FindFirstChild("HumanoidRootPart")
        if _h then _preCF = _h.CFrame end
    end

    local ev = getToolRemote("Build")
    if not ev then
        notify("Sigma","Build tool not found!")
        if btn and btn.Parent then btn.Text="No Build tool!" end
        return
    end

    setupBuiltTracker()  -- hook once for the whole session

    -- Detect dominant spread axis
    local minX,maxX,minZ,maxZ = math.huge,-math.huge,math.huge,-math.huge
    for _,p in ipairs(positions) do
        minX=math.min(minX,p.X); maxX=math.max(maxX,p.X)
        minZ=math.min(minZ,p.Z); maxZ=math.max(maxZ,p.Z)
    end
    local useZ = (maxZ-minZ) > (maxX-minX)

    table.sort(positions, function(a,b)
        return (useZ and a.Z or a.X) < (useZ and b.Z or b.X)
    end)

    -- Window into column groups
    local groups = {}
    local curGroup = {}
    local groupStart = nil
    for _,pos in ipairs(positions) do
        local coord = useZ and pos.Z or pos.X
        if not groupStart then
            groupStart = coord; curGroup = {pos}
        elseif (coord - groupStart) <= maxSpan then
            curGroup[#curGroup+1] = pos
        else
            groups[#groups+1] = curGroup
            groupStart = coord; curGroup = {pos}
        end
    end
    if #curGroup>0 then groups[#groups+1] = curGroup end

    for gi, group in ipairs(groups) do
        if S.buildStopped then break end

        -- Bounding center of this group
        local sx,sy,sz,ex,ey,ez = math.huge,math.huge,math.huge,-math.huge,-math.huge,-math.huge
        for _,p in ipairs(group) do
            sx=math.min(sx,p.X); ex=math.max(ex,p.X)
            sy=math.min(sy,p.Y); ey=math.max(ey,p.Y)
            sz=math.min(sz,p.Z); ez=math.max(ez,p.Z)
        end
        local cx=(sx+ex)/2; local cy=(sy+ey)/2; local cz=(sz+ez)/2

        if btn and btn.Parent then
            btn.Text = string.format("Text %d/%d (%d blks)", gi, #groups, #group)
        end

        -- Refresh ev before each group
        if not ev or not ev.Parent then
            ev = getToolRemote("Build")
            if not ev then break end
        end

        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then break end

        local didAnchor = false
        local ok = pcall(function()
            local tpTarget = Vector3.new(cx, cy+6, cz)
            hrp.CFrame = CFrame.new(tpTarget)              -- 1. teleport (raised 6 studs)
            task.wait(BUILD_SETTLE)                            -- 2. wait for server
            -- 2b. Confirm server-side position is synced before anchoring.
            --     Rapid letter-group teleports can desync the server position,
            --     placing the group outside the server's 666-stud build radius.
            waitForServerPosSync(hrp, tpTarget)
            hrp.Anchored = true                               -- 3. THEN anchor
            didAnchor = true
            local probeB=(bsize=="detailed") and Vector3.new(0.8,0.8,0.8) or nil
            -- Chaos blitz: hammer this letter group until every brick lands.
            blitzBuildChaos(ev, group, bsize, probeB)
        end)

        if didAnchor then
            hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.Anchored = false end
        end

        if not ok then
            ev = getToolRemote("Build")
            if not ev then break end
        end
    end

    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Anchored = false end

    -- Restore pre-build position
    if _preCF then
        local _rh = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if _rh then _rh.CFrame = _preCF; task.wait(BUILD_SETTLE) end
    end

    if previewParts then
        for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
    end

    -- Final count and notify
    if btn and btn.Parent then
        local probeB=(bsize=="detailed") and Vector3.new(0.8,0.8,0.8) or Vector3.new(3,3,3)
        local finalMissing = 0
        for _,pos in ipairs(positions) do
            if not hasBlockAt(pos,probeB) then finalMissing=finalMissing+1 end
        end
        if S.buildStopped then
            btn.Text = "Stopped."
        elseif finalMissing == 0 then
            notify("Sigma", "Build fully completed! \226\156\147")
            btn.Text = string.format("Done! %d blks \226\156\147", #positions)
        else
            notify("Sigma", string.format("Build done \226\128\148 %d blocks still missing.", finalMissing))
            btn.Text = string.format("Done (%d missing)", finalMissing)
        end
        task.delay(4, function() if btn and btn.Parent then btn.Text="Build Text" end end)
    end
end

