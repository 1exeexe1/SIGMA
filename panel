do
    local banner=Instance.new("TextLabel"); banner.Size=UDim2.new(1,0,0,18); banner.BackgroundTransparency=1
    banner.Text=isTCO() and "\226\156\147 TCO detected" or "\226\154\160 Not in TCO"
    banner.TextColor3=isTCO() and Color3.fromRGB(0,200,100) or Color3.fromRGB(255,180,0)
    banner.FontFace=FONT_MAIN; banner.TextSize=11; banner.ZIndex=8; banner.Parent=tcoPage
end

do
    local g=makeGroup(tcoPage,"Arkenstone Safeguards","Requires The Arkenstone in backpack/character.")

    -- ── Shared helpers ──────────────────────────────────────────────────────

    local function isPrivilegedSender(plr)
        if not plr or plr == lp then return false end
        if plr.Neutral == false then return true end
        if plr:GetAttribute("Arken") == true then return true end
        return false
    end

    local function hasArkenstoneNow()
        local char = lp.Character
        if char and char:FindFirstChild("The Arkenstone") then return true end
        if lp.Backpack:FindFirstChild("The Arkenstone") then return true end
        return false
    end

    local function equipArkenstone()
        local stone = lp.Backpack:FindFirstChild("The Arkenstone")
                   or (lp.Character and lp.Character:FindFirstChild("The Arkenstone"))
        if not stone then return nil end
        if stone.Parent ~= lp.Character then
            pcall(function()
                local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                if hum then hum:EquipTool(stone) end
            end)
            task.wait(0.1)
        end
        return lp.Character and lp.Character:FindFirstChild("The Arkenstone")
    end

    local _disarmCooldown = false
    local function doDisarmArkenstone()
        if _disarmCooldown then return end
        if not hasArkenstoneNow() then return end
        _disarmCooldown = true
        task.spawn(function()
            local stone = equipArkenstone()
            if not stone then _disarmCooldown=false; return end
            task.wait(0.05)
            pcall(function() stone.Parent = Workspace end)
            task.wait(0.08)
            task.delay(1.0, function()
                local dropped = Workspace:FindFirstChild("The Arkenstone")
                if dropped then
                    pcall(function() dropped.Parent = lp.Backpack end)
                end
                _disarmCooldown = false
            end)
        end)
    end

    -- ── Auto-R15 ────────────────────────────────────────────────────────────
    local _r15Conn = nil
    local function setupAutoR15(on)
        if _r15Conn then _r15Conn:Disconnect(); _r15Conn=nil end
        if not on then return end
        local function wireChar(char)
            if not char then return end
            local hum = char:WaitForChild("Humanoid", 3)
            if not hum then return end
            local _hpConn; _hpConn = hum:GetPropertyChangedSignal("Health"):Connect(function()
                if not S.autoR15 then _hpConn:Disconnect(); return end
                if hum.Health < 1 and not S._autoR15Active and hasArkenstoneNow() then
                    S._autoR15Active = true  -- set BEFORE spawn to block re-entry
                    task.spawn(function()
                        local wasAutoDrop = S.autoDrop
                        S.autoDrop = false
                        task.wait(0.05)
                        local stone = equipArkenstone()
                        if stone then
                            task.wait(0.05)
                            sendChat(";R15")
                            task.wait(0.15)
                            sendChat(";R15")
                        end
                        -- Wait for respawn before releasing the guard
                        local deadline = tick() + 6
                        repeat task.wait(0.25) until
                            (lp.Character and lp.Character:FindFirstChild("Humanoid")
                             and lp.Character.Humanoid.Health > 0)
                            or tick() > deadline
                        S.autoDrop = wasAutoDrop
                        S._autoR15Active = false
                    end)
                end
            end)
        end
        wireChar(lp.Character)
        _r15Conn = lp.CharacterAdded:Connect(wireChar)
    end

    makeToggle(g, "Auto-R15", function(on)
        S.autoR15 = on
        setupAutoR15(on)
    end, true, "On death/sub-1HP: equip Arkenstone → say ;R15 Ó²")
    setupAutoR15(true)

    -- ── Shared disarm chat monitor ───────────────────────────────────────────
    local _disarmConn = nil
    local function setupDisarmMonitor()
        if _disarmConn then _disarmConn:Disconnect(); _disarmConn=nil end
        if not S.disarmClearInv and not S.disarmReset then return end
        _disarmConn = TextChatService.MessageReceived:Connect(function(msg)
            if not S.disarmClearInv and not S.disarmReset then return end
            local sender = msg.TextSource and Players:GetPlayerByUserId(msg.TextSource.UserId)
            if not isPrivilegedSender(sender) then return end
            local txt = (msg.Text or ""):lower():gsub("%s+", " "):match("^%s*(.-)%s*$")
            local myName    = lp.Name:lower()
            local myDisplay = lp.DisplayName:lower()

            if S.disarmClearInv then
                local isClearAll = txt:match("clearinv%s+all") or txt:match("clearinv%s+others")
                                or txt:match("clearinv%s+a$")  or txt:match("clearinv%s+o$")
                local isClearMe  = txt:match("clearinv%s+(.+)") and (
                    txt:find(myName,    1, true) or
                    txt:find(myDisplay, 1, true)
                )
                if isClearAll or isClearMe then doDisarmArkenstone() end
            end

            if S.disarmReset then
                local isResetAll = txt:match("^;?reset%s+all$") or txt:match("^;?reset%s+others$")
                                or txt:match("^;?kill%s+all$")   or txt:match("^;?kill%s+others$")
                local isResetMe  = (txt:match("^;?reset%s+(.+)$") or txt:match("^;?kill%s+(.+)$")) and (
                    txt:find(myName,    1, true) or
                    txt:find(myDisplay, 1, true)
                )
                if isResetAll or isResetMe then doDisarmArkenstone() end
            end
        end)
    end

    makeToggle(g, "Disarm If ClearInv", function(on)
        S.disarmClearInv = on
        setupDisarmMonitor()
    end, true, "Detects clearinv [you/all/others] from admins → disarms + re-equips Arkenstone.")

    makeToggle(g, "Disarm If Reset", function(on)
        S.disarmReset = on
        setupDisarmMonitor()
    end, true, "Detects reset/kill [you/all/others] from admins → disarms + re-equips Arkenstone.")

    setupDisarmMonitor()
end

do
    local g=makeGroup(tcoPage,"Chat Spy","Labels chat by role (admin/arken/hidden) and auto-replies via bot.")
    -- v4.7.0: full role-label table (ported + extended from tco-main getChatSpyMeta)
    local CHAT_ROLE_COLORS = {
        peasant  = "#966766",
        arken    = "#04AFEC",
        admin    = "#F5CD30",
        hidden   = "#FF0000",
        iqgenius = "#FFB3B3",
        iqdumb   = "#C80000",
    }
    local function installMsgHook()
        TextChatService.OnIncomingMessage=function(mdata)
            local plr=mdata.TextSource and Players:GetPlayerByUserId(mdata.TextSource.UserId)
            if not plr then return end
            -- SpyChat label decoration (v4.7.0: IQ + muted role support)
            if S.spychat then
                local cn = plr.Neutral==false and "admin" or "peasant"
                if plr:GetAttribute("Arken")==true then cn="arken" end
                local ok,muted=pcall(function() return plr:HasTag("Muted") end)
                if (ok and muted) or plr:GetAttribute("Muted")==true then cn="hidden" end
                local hidden=(mdata.Text or ""):sub(1,1)==";"
                if hidden then cn="hidden" end
                local iqSuffix=""
                local iq=plr:GetAttribute("IQ")
                if type(iq)=="number" then
                    if     iq>=200 then cn="iqgenius"; iqSuffix=" \240\159\167\160"  -- 🧠 
                    elseif iq<=50  then cn="iqdumb";   iqSuffix=" \240\159\164\170"  -- 🤪
                    end
                end
                local hex=CHAT_ROLE_COLORS[cn] or "#ffffff"
                local icon=(hidden and "\240\159\154\171 " or (muted and "\240\159\148\148 " or ""))
                mdata.PrefixText=string.format(
                    '<font color="%s">%s(%s)%s </font>',
                    hex,icon,plr.DisplayName,iqSuffix)
            end
            -- Bot auto-reply (independent of SpyChat toggle)
            if S.botReply and S.botTrigger~="" and S.botReplyTxt~="" and plr~=lp then
                local msg=mdata.Text or ""
                local trigger=S.botCase and S.botTrigger or S.botTrigger:lower()
                local check=S.botCase and msg or msg:lower()
                if check:find(trigger,1,true) then
                    local reply=S.botReplyTxt:gsub("%[Username%]",plr.Name):gsub("%[Display%]",plr.DisplayName)
                    task.spawn(function() sendChat(reply) end)
                end
            end
        end
    end
    local function setupSpy(on)
        S.spychat=on
        -- Keep hook installed as long as EITHER spychat OR botReply could need it.
        -- Only tear it down when both are off.
        if not on and not S.botReply then
            TextChatService.OnIncomingMessage=nil
        else
            installMsgHook()
        end
    end
    -- Install hook immediately so Bot Reply works even before SpyChat is touched.
    installMsgHook()
    makeToggle(g,"Spy Chat",function(on) setupSpy(on) end,true)
    setupSpy(true)
    makeToggle(g,"Bot Replier",function(on)
        S.botReply=on
        if on then installMsgHook()
