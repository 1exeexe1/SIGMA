    local function _punishSub(cmd, p)
        return cmd:gsub("%[Name%]",p.Name):gsub("%[Display%]",p.DisplayName)
    end
    local function _punishAllowed(p)
        if p==lp then return false end
        local nl=p.Name:lower()
        -- whitelist check (if non-empty, must match)
        local hasWl=false
        for k in pairs(S.punishWhitelist) do hasWl=true; break end
        if hasWl then
            local ok=false
            for k in pairs(S.punishWhitelist) do
                if nl:find(k:lower(),1,true) then ok=true; break end
            end
            if not ok then return false end
        end
        -- blacklist check
        for k in pairs(S.punishBlacklist) do
            if nl:find(k:lower(),1,true) then return false end
        end
        return true
    end
    local function _punishFire(cmd, p)
        if cmd=="" then return end
        if not _punishAllowed(p) then return end
        local finalCmd=_punishSub(cmd,p)
        task.spawn(function() pcall(function() sendChat(finalCmd) end) end)
        notify("Punish","→ "..finalCmd)
    end

    local function _rewireJoinLeave()
        if S._punishJoinConn then S._punishJoinConn:Disconnect(); S._punishJoinConn=nil end
        if S._punishLeaveConn then S._punishLeaveConn:Disconnect(); S._punishLeaveConn=nil end
        if S.punishOnJoinOn and S.punishOnJoinCmd~="" then
            S._punishJoinConn=Players.PlayerAdded:Connect(function(p)
                task.wait(1.5) -- wait for char
                _punishFire(S.punishOnJoinCmd,p)
            end)
        end
        if S.punishOnLeaveOn and S.punishOnLeaveCmd~="" then
            S._punishLeaveConn=Players.PlayerRemoving:Connect(function(p)
                _punishFire(S.punishOnLeaveCmd,p)
            end)
        end
    end

