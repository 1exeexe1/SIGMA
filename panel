        DC.phase = 5
        dcSetPhaseText("\226\151\136 Connect Corners", Color3.fromRGB(0,200,100))
        notify("De-Grid","Beam drawn! Press Connect to snap corners together.")
        return
    end

    -- Normal brick select (armed by toggle)
    if E.selectArmed then
        local t = E._mouse.Target
        if not t or not t:IsA("BasePart") or t == Workspace.Terrain then return end
        if t.Anchored then
            notify("De-Grid","That brick is anchored \226\128\148 select an unanchored brick!")
            return
        end
        E.brick = t
        E.selectArmed = false
        if E._selBrickSet then E._selBrickSet(false,"Select Brick") end
        E.selBox.Adornee = t
        installPhysics(t)
        if E.statusLbl then
            E.statusLbl.Text       = "Locked: "..t.Name.." (unanchored \226\156\147)"
            E.statusLbl.TextColor3 = Color3.fromRGB(0,200,100)
        end
        notify("De-Grid","Brick locked \226\128\148 Move/Rotate, then Apply Offset.")
        return
    end
end)

-- ── Heartbeat: ownership guard, drift detection, handle sync, collision ──
-- Drift thresholds: if the brick deviates more than these from desiredCF,
-- we immediately re-claim ownership and re-snap it. This catches both
-- accidental bumps from passing players AND gravity on unanchored bricks.
do
    local _DG_POS_TOL = 0.08   -- studs: position drift tolerance
    local _DG_ROT_TOL = 0.025  -- radians: rotation drift tolerance (≈1.4°)
    local _DG_OWNER_INTERVAL = 0.2  -- seconds: periodic ownership re-bump even without drift

    RunService.Heartbeat:Connect(function()
        if E.brick and E.brick.Parent then
            -- ── Drift detection + immediate re-ownership ──────────────────
            if E.desiredCF and _hasSetHidden then
                local cur = E.brick.CFrame
                local des = E.desiredCF
                -- Position drift check
                local posDrift = (cur.Position - des.Position).Magnitude
                -- Rotation drift: compare right-vectors (robust across gimbal lock)
                local rotDrift = (cur.RightVector - des.RightVector).Magnitude
                local drifted  = posDrift > _DG_POS_TOL or rotDrift > _DG_ROT_TOL
                local now      = tick()
                local periodic = (now - E._ownerLastT) >= _DG_OWNER_INTERVAL
                if drifted or periodic then
                    E._ownerLastT = now
                    -- Re-claim ownership
                    pcall(function() sethiddenproperty(lp, "SimulationRadius", 9e9) end)
                    if drifted then
                        -- Drift detected: snap back to desired CFrame immediately
                        pcall(function() E.brick.CFrame = des end)
                        if E.bodyPos  then E.bodyPos.Position  = des.Position end
                        if E.bodyGyro then E.bodyGyro.CFrame   = des - des.Position end
                    end
                end
            elseif _hasSetHidden then
                -- desiredCF not set yet — still keep ownership bumped periodically
                local now = tick()
                if (now - E._ownerLastT) >= _DG_OWNER_INTERVAL then
                    E._ownerLastT = now
                    pcall(function() sethiddenproperty(lp, "SimulationRadius", 9e9) end)
                end
            end
            -- ── Local-only CanCollide suppression ─────────────────────────
            -- The server never sees this write, so anchor/collide remotes are unaffected.
            if E.collideOff then
                pcall(function() E.brick.CanCollide = false end)
            end
            syncHandles()
        elseif E.brick then
            fullCleanup()
            notify("De-Grid", "Brick was removed externally!")
        end
    end)
end

