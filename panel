    if not sv.equipped then return end
    local target=_svMouse.Target; if not target then return end
    local hitPos=_svMouse.Hit.Position
    -- Check if clicking a resize handle
    for key,h in pairs(svHandles) do
        if target==h then
            sv.dragging=true; sv.dragKey=key
            sv.dragStartMouse=hitPos
            sv.dragStartOrigin=sv.origin
            sv.dragStartSX=sv.sX; sv.dragStartSY=sv.sY; sv.dragStartSZ=sv.sZ
            return
        end
    end
    if _scaRefreshOnClick or not sv.placed then
        local nv=CT_NORM_VEC[_svMouse.TargetSurface] or Vector3.new(0,1,0)
        sv.origin=snapToGrid(hitPos+nv*CT_GRID*0.5)
        sv.sX=1; sv.sY=1; sv.sZ=1; sv.placed=true
        svSyncZone(); svSizeLblUpdate()
    end
end

local function svHandleDrag()
    if not sv.dragging or not sv.dragKey then return end
    -- Reject frames where a second touch is active (mobile stutter guard)
    if _scaActiveTouchId and #UserInputService:GetTouchState() > 1 then return end
    local hitPos = getMouseWorldHit(_svMouse, sv.dragStartMouse)
    if hitPos.Magnitude > 20000 then return end
    local info=CT_FACES[sv.dragKey]; if not info then return end
    local ax,dir=info.ax,info.dir
    local axV=ax=="X" and Vector3.new(1,0,0) or (ax=="Y" and Vector3.new(0,1,0) or Vector3.new(0,0,1))
    local rawD=(hitPos-sv.dragStartMouse):Dot(axV)
    local blkD=math.clamp(math.floor(rawD/CT_GRID+0.5),-200,200)
    if dir>0 then
        local sS=ax=="X" and sv.dragStartSX or (ax=="Y" and sv.dragStartSY or sv.dragStartSZ)
        local nS=math.max(1,sS+blkD)
        if ax=="X" then sv.sX=nS elseif ax=="Y" then sv.sY=nS else sv.sZ=nS end
    else
        local sS=ax=="X" and sv.dragStartSX or (ax=="Y" and sv.dragStartSY or sv.dragStartSZ)
        local nS=math.max(1,sS-blkD); local sh=(sS-nS)*CT_GRID
        if ax=="X" then sv.sX=nS; sv.origin=Vector3.new(sv.dragStartOrigin.X+sh,sv.origin.Y,sv.origin.Z)
        elseif ax=="Y" then sv.sY=nS; sv.origin=Vector3.new(sv.origin.X,sv.dragStartOrigin.Y+sh,sv.origin.Z)
        else sv.sZ=nS; sv.origin=Vector3.new(sv.origin.X,sv.origin.Y,sv.dragStartOrigin.Z+sh) end
    end
    svSyncZone(); svSizeLblUpdate()
end

_ctoolVirtualEquip["Save"] = function()
    sv.equipped=true; svMenu.Visible=true
    if _svClickConn then _svClickConn:Disconnect() end
    if _svUpConn    then _svUpConn:Disconnect() end
    if _svDragConn  then _svDragConn:Disconnect() end
    _svClickConn=_svMouse.Button1Down:Connect(svHandleClick)
    _svUpConn=_svMouse.Button1Up:Connect(function() sv.dragging=false; sv.dragKey=nil end)
    _svDragConn=RunService.RenderStepped:Connect(svHandleDrag)
    if sv.placed then svSyncZone() end; svSizeLblUpdate()
end
_ctoolVirtualUnequip["Save"] = function()
    sv.equipped=false; svMenu.Visible=false
    if _svClickConn then _svClickConn:Disconnect(); _svClickConn=nil end
    if _svUpConn    then _svUpConn:Disconnect(); _svUpConn=nil end
    if _svDragConn  then _svDragConn:Disconnect(); _svDragConn=nil end
    sv.dragging=false; sv.dragKey=nil
    svSelBox.Adornee=nil; for _,h in pairs(svHandles) do h.Transparency=1 end
end

end -- ╚═ SAVE TOOL INTERNALS ══╝

