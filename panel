        end)
    end)

    makeButton(g, "\226\143\143 Stop Loud Boombox", function()
        _lbPlaying = false
        statusLbl.Text = "Status: idle"
        -- Return all boomboxes to backpack
        local char = lp.Character
        if char then
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") and tool.Name:lower():find("boombox") then
                    pcall(function() tool.Parent = lp.Backpack end)
                end
            end
        end
        notify("Boombox","Loud Boombox stopped.")
    end)

    makeSection(g, "Ring of Boomboxes \226\128\148 drops clones around you, locked in place")

    local _,ringCountBox = makeInput(g, "Ring count (1–8)", "4", function() end)
    local _,ringIdBox    = makeInput(g, "Audio ID", "142376088", function() end)
    ringCountBox.Text = "4"
    ringIdBox.Text    = "142376088"

    local ringStatusLbl = makeLabel(g, "Ring: inactive")
    ringStatusLbl.TextColor3 = Color3.fromRGB(140,140,140)

    makeButton(g, "\240\159\224\138 Start Ring", function()
        if _lbRingConn then notify("Boombox","Ring already active — Stop first."); return end
        local rawId   = ringIdBox.Text:match("%d+")
        local audioId = tonumber(rawId)
        if not audioId then notify("Boombox","Invalid Audio ID."); return end
        local count = math.clamp(tonumber(ringCountBox.Text) or 4, 1, 8)
        local boxes = _lbGetBoomboxes()
        if #boxes == 0 then notify("Boombox","No boomboxes in backpack!"); return end
        count = math.min(count, #boxes)

        local char = lp.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then notify("Boombox","No character!"); return end

        -- Spawn N anchor parts evenly spaced in a ring around the player
        _lbRingParts = {}
        local radius = 5
        for i = 1, count do
            local angle = (i-1) * (2*math.pi / count)
            local pos   = hrp.Position + Vector3.new(math.cos(angle)*radius, 0, math.sin(angle)*radius)
            local anchor = Instance.new("Part")
            anchor.Size         = Vector3.one
            anchor.Transparency = 1
            anchor.Anchored     = true
            anchor.CanCollide   = false
            anchor.CanQuery     = false
            anchor.CFrame       = CFrame.new(pos)
            anchor.Parent       = Workspace

            local tool = boxes[i]
            -- Un-parent to workspace (drop without removing from inventory logic)
            pcall(function()
                if tool.Parent == lp.Backpack then tool.Parent = char end
            end)
            -- Weld tool handle to anchor using absolute ownership via CFrame lock
            local handle = tool:FindFirstChild("Handle") or tool:FindFirstChildWhichIsA("BasePart")
            _lbRingParts[i] = {anchor=anchor, tool=tool, handle=handle, cf=anchor.CFrame, remote=_lbGetRemote(tool)}
        end

        -- Single shared settle then batch-fire PlaySong simultaneously
        task.wait(0.05)
        for _, entry in ipairs(_lbRingParts) do
            pcall(function()
                if entry.remote then entry.remote:FireServer("PlaySong", audioId) end
            end)
        end

        -- Heartbeat: lock each boombox handle to its anchor CFrame each frame
        _lbRingConn = RunService.Heartbeat:Connect(function()
            for _, entry in ipairs(_lbRingParts) do
                local h = entry.handle
                if h and h.Parent then
                    pcall(function() h.CFrame = entry.cf end)
                end
            end
        end)

        ringStatusLbl.Text = "Ring: active \226\151\134 " .. count .. " boomboxes"
        notify("Boombox","Ring of Boomboxes active \226\128\148 " .. count .. " units")
    end)

    makeButton(g, "\226\143\143 Stop Ring", function()
        if _lbRingConn then _lbRingConn:Disconnect(); _lbRingConn=nil end
        -- Return tools to backpack and clean anchors
        for _, entry in ipairs(_lbRingParts) do
            pcall(function()
                if entry.tool and entry.tool.Parent then
                    entry.tool.Parent = lp.Backpack
                end
                if entry.anchor and entry.anchor.Parent then
                    entry.anchor:Destroy()
                end
            end)
        end
        _lbRingParts = {}
        ringStatusLbl.Text = "Ring: inactive"
        notify("Boombox","Ring stopped.")
    end)
end

