makeSection(gR, "── Multi-Ring Management ───────────────────────")

local _mrSelected    = {}
local _mrListFrame   = nil

-- Forward-declare editor boxes (assigned below, used inside _mrRefreshList closures)
local speedBox, radiusBox, lengthBox, countBox

local function _mrRefreshList()
    if not _mrListFrame then return end
    for _, ch in ipairs(_mrListFrame:GetChildren()) do
        if not ch:IsA("UIListLayout") then ch:Destroy() end
    end

    local rings = getgenv()._sigmaRings
    local names = {}
    for k in pairs(rings) do names[#names+1] = k end
    table.sort(names)

    if #names == 0 then
        local lbl = Instance.new("TextLabel", _mrListFrame)
        lbl.Size = UDim2.new(1,0,0,20)
        lbl.BackgroundTransparency = 1
        lbl.Text = "(no saved rings)"
        lbl.TextColor3 = Color3.fromRGB(120,120,120)
        lbl.FontFace = FONT_MAIN; lbl.TextSize = 11; lbl.ZIndex = 9
        return
    end

    for _, name in ipairs(names) do
        local row = Instance.new("Frame", _mrListFrame)
        row.Size = UDim2.new(1,0,0,22)
        row.BackgroundTransparency = 1; row.ZIndex = 8

        local ll = Instance.new("UIListLayout", row)
        ll.FillDirection = Enum.FillDirection.Horizontal
        ll.Padding = UDim.new(0,3); ll.SortOrder = Enum.SortOrder.LayoutOrder

        -- Checkbox
        local selBtn = Instance.new("TextButton", row)
        selBtn.Size = UDim2.new(0,20,1,0); selBtn.ZIndex = 9
        selBtn.Text = _mrSelected[name] and "v" or "-"
        selBtn.FontFace = FONT_MAIN; selBtn.TextSize = 11
        selBtn.BackgroundColor3 = T.BTN; selBtn.TextColor3 = T.WHITE
        selBtn.BorderSizePixel = 0; selBtn.LayoutOrder = 1
        onTheme(function(th) selBtn.BackgroundColor3=th.BTN; selBtn.TextColor3=th.WHITE end)
        selBtn.MouseButton1Click:Connect(function()
            _mrSelected[name] = not _mrSelected[name]
            selBtn.Text = _mrSelected[name] and "v" or "-"
        end)

        -- Name + running indicator
        local isOn = _activeRings[name] ~= nil
        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Size = UDim2.new(0,110,1,0); nameLbl.BackgroundTransparency = 1
        nameLbl.Text = name .. (isOn and " O" or "")
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        nameLbl.TextColor3 = isOn and Color3.fromRGB(80,200,80) or T.WHITE
        nameLbl.FontFace = FONT_MAIN; nameLbl.TextSize = 11; nameLbl.ZIndex = 9
        nameLbl.LayoutOrder = 2
        onTheme(function(th) if not _activeRings[name] then nameLbl.TextColor3=th.WHITE end end)

        -- Load into editor
        local loadBtn = Instance.new("TextButton", row)
        loadBtn.Size = UDim2.new(0,34,1,0); loadBtn.ZIndex = 9
        loadBtn.Text = "Edit"; loadBtn.FontFace=FONT_MAIN; loadBtn.TextSize=10
        loadBtn.BackgroundColor3=T.BTN; loadBtn.TextColor3=T.WHITE
        loadBtn.BorderSizePixel=0; loadBtn.LayoutOrder=3
        onTheme(function(th) loadBtn.BackgroundColor3=th.BTN; loadBtn.TextColor3=th.WHITE end)

        -- Delete
        local delBtn = Instance.new("TextButton", row)
        delBtn.Size = UDim2.new(0,24,1,0); delBtn.ZIndex=9
        delBtn.Text = "X"; delBtn.FontFace=FONT_MAIN; delBtn.TextSize=10
        delBtn.BackgroundColor3=Color3.fromRGB(140,50,50); delBtn.TextColor3=T.WHITE
        delBtn.BorderSizePixel=0; delBtn.LayoutOrder=4
        onTheme(function(th) delBtn.TextColor3=th.WHITE end)

        -- Start / Stop
        local togBtn = Instance.new("TextButton", row)
        togBtn.Size = UDim2.new(0,34,1,0); togBtn.ZIndex=9
        togBtn.Text = isOn and "Stop" or "Start"; togBtn.FontFace=FONT_MAIN; togBtn.TextSize=10
        togBtn.BackgroundColor3 = isOn and Color3.fromRGB(50,130,50) or Color3.fromRGB(50,50,130)
        togBtn.TextColor3=T.WHITE; togBtn.BorderSizePixel=0; togBtn.LayoutOrder=5
        onTheme(function(th) togBtn.TextColor3=th.WHITE end)

        loadBtn.MouseButton1Click:Connect(function()
            local p = getgenv()._sigmaRings[name]
            if not p then return end
            _ringSpeed       = p.speed       or 2
            _ringRadius      = p.radius      or 8
            _ringLength      = p.length      or 10
            _ringCount       = p.count       or 6
            _ringPattern     = p.pattern     or "Circle"
            _ringAngleX      = p.angleX      or 0
            _ringAngleY      = p.angleY      or 0
            _ringAngleZ      = p.angleZ      or 0
            _ringAimOn       = p.aimOn       or false
            _ringAimFace     = p.aimFace     or "None"
            _ringFollowAngle = p.followAngle or false
            _ringHostName    = p.hostName    or "Myself"
            _ringBrickSource = p.brickSource or "My Folder"
            if speedBox  then speedBox.Text  = tostring(_ringSpeed)  end
            if radiusBox then radiusBox.Text = tostring(_ringRadius) end
            if lengthBox then lengthBox.Text = tostring(_ringLength) end
            if countBox  then countBox.Text  = tostring(_ringCount)  end
            notify("Rings", "Loaded \"" .. name .. "\" into editor.")
        end)

        delBtn.MouseButton1Click:Connect(function()
            _multiRingStop(name)
            _mrSelected[name] = nil
            getgenv()._sigmaRings[name] = nil
            _mrRefreshList()
            notify("Rings", "Deleted ring \"" .. name .. "\".")
        end)

        togBtn.MouseButton1Click:Connect(function()
            if _activeRings[name] then
                _multiRingStop(name)
                togBtn.Text = "Start"
                togBtn.BackgroundColor3 = Color3.fromRGB(50,50,130)
                nameLbl.Text = name
                nameLbl.TextColor3 = T.WHITE
            else
                _multiRingStart(name)
                togBtn.Text = "Stop"
                togBtn.BackgroundColor3 = Color3.fromRGB(50,130,50)
                nameLbl.Text = name .. " O"
                nameLbl.TextColor3 = Color3.fromRGB(80,200,80)
            end
        end)
    end
end

