-- ═══════════════════════════════════════════════════════════════

do
    -- ╔═ SEEDER SELECTION ══════════════════════════════════════════════════════╗
    -- ╔═ BUILD MODE ═══════════════════════════════════════════════════════════╗
    -- Cluster : legacy teleport-cluster approach (no seeder required).
    -- BFS     : infinite-range wave build from the seeder corner brick.
    --           Every brick is placed ON the face of an already-placed brick,
    --           so ZERO teleports are needed after the seeder is set.
    -- ─────────────────────────────────────────────────────────────────────────
    do
        local bmg = makeGroup(buildPage, "Build Mode")
        makeSection(bmg, "Cluster = legacy teleport  |  BFS = infinite-range wave (seeder required)")
        makeDropdown(bmg, "Mode", {"Cluster", "BFS"}, S.buildMode, function(v)
            S.buildMode = v
            notify("Sigma", "Build mode \226\134\146 " .. v
                .. (v == "BFS" and " (arm a seeder brick below)" or " (teleport cluster)"))
        end)
    end
    -- ╚═ BUILD MODE ═══╝

    -- Shared by Load Build, Build Cube, and Build Text.
    -- The seeder is an existing world brick clicked by the player.
    -- It acts as the BFS root: all builds chain outward from its faces,
    -- requiring ZERO teleportation after the seeder is set.
    -- ─────────────────────────────────────────────────────────────────────────
    do
        local sg = makeGroup(buildPage, "Seeder (Infinite-Range BFS)")
        makeSection(sg, "Click a world brick to use as the BFS root for Load / Cube / Text")

        local seederLbl = makeLabel(sg, "Seeder: (none)")

        local function updateSeederLabel()
            if S.seeder and S.seeder.Parent then
                local p = S.seeder.Position
                seederLbl.Text = string.format(
                    "Seeder: %s @ (%.0f, %.0f, %.0f)", S.seeder.Name, p.X, p.Y, p.Z)
            else
                seederLbl.Text = "Seeder: (none) \226\128\148 will use Terrain fallback for first brick"
            end
        end

        local armBtn
        local _armRow
        _armRow, armBtn = makeButton(sg, "\240\159\142\175 Arm Seeder Select", function()
            if S.seederArmed then
                -- Second press disarms
                S.seederArmed = false
                if S._seederConn then S._seederConn:Disconnect(); S._seederConn = nil end
                armBtn.Text = "\240\159\142\175 Arm Seeder Select"
                return
            end
            S.seederArmed = true
            armBtn.Text   = "\226\143\179 Click a brick in the world..."

            -- One-shot InputBegan: next LMB/touch click on any BasePart sets seeder
            S._seederConn = UserInputService.InputBegan:Connect(function(inp, gpe)
                if gpe then return end  -- game-processed (UI click) — ignore
                if inp.UserInputType ~= Enum.UserInputType.MouseButton1
                and inp.UserInputType ~= Enum.UserInputType.Touch then return end

                local target = lp:GetMouse().Target
                if target and target:IsA("BasePart") then
                    S.seeder     = target
                    S.seederArmed = false
                    S._seederConn:Disconnect(); S._seederConn = nil
                    armBtn.Text  = "\240\159\142\175 Arm Seeder Select"
                    updateSeederLabel()
                    notify("Sigma", "Seeder set \226\134\146 " .. target.Name
                        .. string.format(" @ (%.0f,%.0f,%.0f)",
                            target.Position.X, target.Position.Y, target.Position.Z))
                end
            end)
        end)

        makeButton(sg, "\226\156\149 Clear Seeder", function()
            S.seeder      = nil
            S.seederArmed = false
            if S._seederConn then S._seederConn:Disconnect(); S._seederConn = nil end
            armBtn.Text = "\240\159\142\175 Arm Seeder Select"
            updateSeederLabel()
            notify("Sigma", "Seeder cleared \226\128\148 Load/Cube/Text will use Terrain fallback.")
        end)
    end
    -- ╚═ SEEDER SELECTION ══╝

    local g=makeGroup(buildPage,"Save / Load")

    -- ── Save format (Potatoe-compatible) ─────────────────────────
    -- Fields: p={x,y,z}, c={r,g,b 0-255}, m=matStr, a=anchored,
    --         cc=canCollide, s={sx,sy,sz} (only if non-standard),
    --         sp={{face,hex,text},...} (face sprays)
    -- Positions are stored as the grid-snapped centre for standard
    -- blocks. Non-4×4×4 blocks: position shifted to corner (+0.5)
    -- to match Potatoe's format exactly.

    local MULT = GRID_MULT  -- 4

    local function saveBlock(bl)
        if not bl:IsA("BasePart") then return nil end
        -- Always store position as corner-offset (Potatoe format):
        --   corner = center - size/2 + 0.5
        --   center = corner + size/2 - 0.5  (exact recovery on load)
        -- Saving ALL blocks this way preserves the exact centre for any block,
        -- including 4x4x4 blocks shifted off-grid by asymmetric shape ops
        -- (e.g. decrease-left then increase-right). Old saves without .s are
        -- still handled on load (treated as standard 4x4x4 at grid position).
        local entry = {
            p  = {
                (bl.Position.X - bl.Size.X/2) + 0.5,
                (bl.Position.Y - bl.Size.Y/2) + 0.5,
                (bl.Position.Z - bl.Size.Z/2) + 0.5,
            },
            s  = {bl.Size.X, bl.Size.Y, bl.Size.Z},  -- always saved now
            c  = {math.round(bl.Color.R*255), math.round(bl.Color.G*255), math.round(bl.Color.B*255)},
            m  = MAT_TO_STR[bl.Material] or "plastic",
            a  = bl.Anchored,
            cc = bl.CanCollide,
        }
        -- Face sprays
        local sprays = {}
        for _,child in ipairs(bl:GetDescendants()) do
            if child:IsA("SurfaceGui") then
                local tl = child:FindFirstChildWhichIsA("TextLabel", true)
                if tl and tl.Text ~= "" then
                    local hex  = tl.Text:match('color="#(%x+)"')
                    local text = tl.Text:match(">(.+)</font>") or tl.Text
                    table.insert(sprays, {child.Face.Name, hex or "FFFFFF", text})
                end
            end
        end
        if #sprays > 0 then entry.sp = sprays end
        return entry
    end

    local function listSaves()
        local files = {}
        pcall(function()
            if typeof(isfolder)=="function" and not isfolder("SigmaPanel_Builds") then
                pcall(function() makefolder("SigmaPanel_Builds") end)
            end
            if typeof(listfiles)=="function" then
                for _,f in ipairs(listfiles("SigmaPanel_Builds")) do
                    local name = f:match("([^/]+)%.json$")
                    if name then table.insert(files, name) end
                end
            end
        end)
        if #files == 0 then files[1] = "(no saves)" end
        return files
    end

    local _,savesSetter = makeDropdown(g,"Select Save",listSaves(),nil,function(v)
        if v ~= "(no saves)" then S.saveName = v end
    end)
    makeInput(g,"New Name","Name...",function(t) S.saveName = t end)

    -- Save your own blocks
    makeButton(g,"Save Build",function(btn)
        if S.saveName == "" or S.saveName == "(no saves)" then btn.Text="Enter name!"; return end
        local data = {}
        local folder = getMyBrickFolder()
        if not folder then
            LOG("Save", "ERROR: brick folder not found for", lp.Name)
            btn.Text="No blocks found!"; return
        end
        LOG("Save", "--- Save Build: '"..S.saveName.."' ---")
        LOG("Save", "Scanning folder:", folder:GetFullName())
        local skipped = 0
        for _,v in ipairs(folder:GetChildren()) do
            local entry = saveBlock(v)
            if entry then
                table.insert(data, entry)
                local s = entry.s or {4,4,4}
                LOG("Save", string.format("  [%d] pos=(%.2f,%.2f,%.2f) sz=(%.0fx%.0fx%.0f) mat=%s sprays=%d",
                    #data,
                    entry.p[1], entry.p[2], entry.p[3],
                    s[1], s[2], s[3],
                    tostring(entry.m),
                    entry.sp and #entry.sp or 0))
            else
                skipped = skipped + 1
                LOG("Save", "  SKIP non-BasePart:", v.Name, v.ClassName)
            end
        end
        LOG("Save", string.format("Total: %d bricks saved, %d skipped. Writing to SigmaPanel_Builds/%s.json",
            #data, skipped, S.saveName))
        pcall(function()
            if typeof(isfolder)=="function" and not isfolder("SigmaPanel_Builds") then makefolder("SigmaPanel_Builds") end
            if typeof(writefile)=="function" then
                writefile("SigmaPanel_Builds/"..S.saveName..".json", HttpService:JSONEncode(data))
                LOG("Save", "Write OK.")
            else
                LOG("Save", "ERROR: writefile not available in this executor!")
            end
        end)
        btn.Text = "Saved! ("..#data.." blocks)"
        savesSetter(listSaves(), S.saveName)
    end)

    -- ╔══════════════════════════════════════════════════════════╗
    -- ║  LOAD BUILD  —  4-phase system                          ║
    -- ║  Phase 1: Blitz normal  blocks (4×4×4) → fast clusters  ║
    -- ║  Phase 2: Blitz detailed blocks (1×1×1) → fast clusters  ║
    -- ║  Phase 3: Build+Shape-resize for any other size          ║
    -- ║  Phase 4: Paint / spray pass (all blocks)                ║
    -- ╚══════════════════════════════════════════════════════════╝

    -- ── Live Preview / Move Preview toggles for Load Build ───────────────
    makeToggle(g, "Live Preview", function(on)
        S.livePreview = on
        S._previewGenTag = "load"
        if on then
            if _loadPreviewRefresh then _loadPreviewRefresh() end
        else
            _clearLivePreview()
        end
    end, false)
    makeToggle(g, "Move Preview", function(on)
        _setMovePreview(on)
    end, false)

    makeButton(g,"Load Build",function(btn)
        if S.saveName == "" or S.saveName == "(no saves)" then btn.Text="Select save!"; return end
        local path = "SigmaPanel_Builds/"..S.saveName..".json"
        if typeof(isfile) ~= "function" or not isfile(path) then btn.Text="Not found!"; return end
        if typeof(readfile) ~= "function" then btn.Text="Not supported!"; return end

        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if not ok or not data then btn.Text="Parse error!"; return end

        S.buildStopped = false
        S.skipBlock    = false
        btn.Text = "Parsing..."

        -- Capture and clear the move-preview offset before building
        local _loadOffset = _getPreviewOffset()
        _clearLivePreview()

        task.spawn(function()
            -- ── Save player position so we can restore after all TPs ─
            local _preBuildCF = nil
            do
                local _char = lp.Character
                local _hrp0 = _char and _char:FindFirstChild("HumanoidRootPart")
                if _hrp0 then _preBuildCF = _hrp0.CFrame end
            end

            -- ── Phase 0: Parse & categorise all blocks ─────────────
            -- normalMeta   → 4×4×4 blocks that sit exactly on the 4-stud grid
            -- detailedMeta → 1×1×1 blocks (detailed build mode)
            -- shapedMeta   → everything else: different size, OR same 4×4×4 size
            --                but centre is off the grid (asymmetric shape ops)
            -- allMeta      → every block, used by the final paint pass
            local normalMeta   = {}
            local detailedMeta = {}
            local shapedMeta   = {}
            local allMeta      = {}

            -- A position is "on the 4-stud grid" when each axis satisfies:
            -- axis == 2 + 4k  for some integer k  →  (axis - 2) % 4 == 0
            local function onGrid4(pos)
                local function chk(v)
                    local r = (v - 2) % 4
                    return r < 0.1 or r > 3.9
                end
                return chk(pos.X) and chk(pos.Y) and chk(pos.Z)
            end

            -- ── Legacy v2 shim (Save Tool wrote {v=2, bricks=[{px,py,pz,...}]} before v4.7.0.4)
            -- As of v4.7.0.4 the Construction Tool Save uses the same flat-array
            -- schema as Save/Load, so this path should never be hit for new saves.
            -- Kept for backwards compatibility with any v4.7.0.3 or older .json files.
            if type(data) == "table" and data.bricks then
                local raw = data.bricks
                local normalised = {}
                for _, b in ipairs(raw) do
                    table.insert(normalised, {
                        p   = {b.px, b.py, b.pz},
                        s   = b.sx and {b.sx, b.sy, b.sz} or nil,
                        c   = {math.floor((b.cr or 0.83)*255+0.5),
                               math.floor((b.cg or 0.83)*255+0.5),
                               math.floor((b.cb or 0.83)*255+0.5)},
                        m   = b.mat or "smooth",
                        a   = b.anch,
                        -- cc and sp not present in v2 format; defaults apply
                    })
                end
                data = normalised
            end

            for _, v in ipairs(data) do
                -- Accept both old (pos/mat/color) and compact (p/m/c) formats
                local px = v.p and v.p[1] or (v.pos and v.pos[1])
                local py = v.p and v.p[2] or (v.pos and v.pos[2])
                local pz = v.p and v.p[3] or (v.pos and v.pos[3])
                if px then

                local sz = v.s or v.size
                -- Recover exact centre from corner-offset format:
                --   saved corner = centre - size/2 + 0.5
                --   so centre    = corner  + size/2 - 0.5
                -- For old saves without .s, px/py/pz IS already the centre.
                local rawCenter
                if sz then
                    rawCenter = Vector3.new(
                        px + sz[1]/2 - 0.5,
                        py + sz[2]/2 - 0.5,
                        pz + sz[3]/2 - 0.5
                    )
                else
                    -- Legacy format (no size saved) → assumed 4×4×4 at grid
                    rawCenter = Vector3.new(px, py, pz)
                end
                -- NOTE: we do NOT snapToGrid rawCenter here.
                -- snapToGrid is only used for the Build remote fire later.
                -- Keeping rawCenter exact is what lets us correct asymmetric
                -- shape operations (e.g. block decreased from bottom AND top).

                local meta = {
                    rawCenter = rawCenter,          -- exact target centre
                    buildPos  = snapToGrid(rawCenter), -- where to fire Build remote
                    color = v.c and Color3.fromRGB(v.c[1],v.c[2],v.c[3])
                                 or Color3.new(0.83, 0.83, 0.83),
                    mat   = v.m or v.mat or "plastic",
                    sp    = v.sp or v.sprayed,
                    a     = v.a,
                    cc    = v.cc,
                    pos   = rawCenter,   -- alias used by paint pass
                }

                if sz then
                    local sx, sy, sz2 = sz[1], sz[2], sz[3]
                    meta.targetSize = Vector3.new(sx, sy, sz2)

                    -- isDetailed MUST be computed before buildPos override.
                    -- Detailed (1×1×1) blocks live on the 1-stud grid.
                    -- snapToGrid uses the 4-stud grid → collapses many distinct
                    -- 1×1×1 centres to the same snapped point → blitzBuild
                    -- deduplicates → most of the wall never fires.
                    local isDetailed   = sx == 1 and sy == 1 and sz2 == 1
                    local isNormalSize = sx == MULT and sy == MULT and sz2 == MULT
                    local isOnGrid     = onGrid4(rawCenter)

                    if isDetailed then
                        meta.buildPos  = rawCenter   -- 1-stud grid: no snap needed
                        meta.brickType = "detailed"
                        table.insert(detailedMeta, meta)
                    elseif isNormalSize and isOnGrid then
                        -- Standard 4×4×4 at an exact grid position → fast blitz
                        meta.brickType = "normal"
                        table.insert(normalMeta, meta)
                    else
                        -- Non-standard size  OR  same size but off-grid (shifted)
                        -- Needs Build + face-delta Shape resize
                        meta.brickType = "shaped"
                        table.insert(shapedMeta, meta)
                    end
                else
                    -- Old save format: no .s → 4×4×4 assumed, was on-grid
                    meta.targetSize = Vector3.new(MULT, MULT, MULT)
                    meta.brickType  = "normal"
                    table.insert(normalMeta, meta)
                end
                table.insert(allMeta, meta)
            end
            end

            -- ── Apply Move Preview offset to all meta build positions ─────────
            -- If the player dragged the load preview before firing, _loadOffset
            -- is non-zero and we shift every brick's buildPos/rawCenter/pos by it.
            if _loadOffset.Magnitude > 0.01 then
                for _, mt in ipairs(allMeta) do
                    mt.buildPos  = mt.buildPos  + _loadOffset
                    mt.rawCenter = mt.rawCenter + _loadOffset
                    mt.pos       = mt.pos       + _loadOffset
                end
            end

            local total = #normalMeta + #detailedMeta + #shapedMeta
            if total == 0 then
                LOG("Load", "ERROR: parsed 0 bricks from", S.saveName)
                notify("Sigma","Nothing to load!"); btn.Text="Load Build"; return
            end
            LOG("Load", string.format("--- Load Build: '%s' | %d total (%d normal, %d detailed, %d shaped) ---",
                S.saveName, total, #normalMeta, #detailedMeta, #shapedMeta))

            -- ── Seeder-as-Offset: translate entire build to seeder position ──────────
            -- If a seeder is armed, compute the save's bottom-left-front corner
            -- (min X, min Y, min Z across all rawCenters, accounting for brick half-size).
            -- offsetVec shifts every brick so that corner lands at the seeder position.
            -- This works in BOTH Cluster and BFS mode.
            local offsetVec = Vector3.new(0, 0, 0)
            if S.seeder and S.seeder.Parent then
                local minX, minY, minZ = math.huge, math.huge, math.huge
                for _, m in ipairs(allMeta) do
                    local hs = m.targetSize and m.targetSize * 0.5 or Vector3.new(2,2,2)
                    local c  = m.rawCenter
                    if c.X - hs.X < minX then minX = c.X - hs.X end
                    if c.Y - hs.Y < minY then minY = c.Y - hs.Y end
                    if c.Z - hs.Z < minZ then minZ = c.Z - hs.Z end
                end
                -- saveOrigin = bottom-left-front corner of the entire save
                local saveOrigin = Vector3.new(minX, minY, minZ)
                -- Seeder corner = bottom-left-front corner of the seeder brick.
                -- saveOrigin is a corner (rawCenter - halfSize), so we must compare
                -- corner-to-corner. Using sp.X/sp.Z (center) instead shifts the build
                -- by seeder.Size/2 on each lateral axis — the 2-stud sideways bug on a
                -- standard 4x4x4 seeder. Y uses the top surface (sp.Y + halfY) because
                -- the build sits ON TOP of the seeder, not centered at its Y.
                local sp  = S.seeder.Position
                local ssz = S.seeder.Size
                local seederCorner = Vector3.new(
                    sp.X - ssz.X / 2,
                    sp.Y + ssz.Y / 2,
                    sp.Z - ssz.Z / 2
                )
                -- Exact (unsnapped) offset — used for rawCenter, shaped, detailed bricks
                offsetVec = seederCorner - saveOrigin
                notify("Sigma", string.format(
                    "Build offset: (%.1f, %.1f, %.1f) from seeder",
                    offsetVec.X, offsetVec.Y, offsetVec.Z))
            end

            -- Apply offsetVec to every meta entry.
            -- rawCenter and pos get the EXACT offset (preserves shaped/detailed geometry).
            -- buildPos for NORMAL (4×4×4 grid-snapped) bricks gets a grid-snapped offset
            -- so they land on valid server-side build positions.
            -- buildPos for DETAILED (1×1×1, buildPos==rawCenter) also gets exact offset.
            -- buildPos for SHAPED bricks is rawCenter (set in parse loop), so same as above.
            if offsetVec.Magnitude > 0.01 then
                local snappedOff = Vector3.new(
                    math.floor(offsetVec.X / GRID_MULT + 0.5) * GRID_MULT,
                    math.floor(offsetVec.Y / GRID_MULT + 0.5) * GRID_MULT,
                    math.floor(offsetVec.Z / GRID_MULT + 0.5) * GRID_MULT
                )
                for _, m in ipairs(allMeta) do
                    m.rawCenter = m.rawCenter + offsetVec
                    m.pos       = m.rawCenter  -- pos is alias of rawCenter
                    -- Detailed bricks: buildPos == rawCenter (1-stud grid, no snap)
                    -- Normal bricks:   buildPos == snapToGrid(rawCenter) → use snappedOff
                    -- Shaped bricks:   buildPos == snapToGrid(rawCenter) but rawCenter
                    --                  is exact; re-derive from new rawCenter
                    local ts = m.targetSize
                    if ts then
                        local isDetailed = ts.X == 1 and ts.Y == 1 and ts.Z == 1
                        if isDetailed then
                            m.buildPos = m.rawCenter
                        else
                            -- normal & shaped: re-snap from the already-translated rawCenter
                            m.buildPos = snapToGrid(m.rawCenter)
                        end
                    else
                        -- legacy (no size) = normal
                        m.buildPos = m.buildPos + snappedOff
                    end
                end
            end

            notify("Sigma", string.format(
                "Loading %d blocks | %d normal \194\183 %d detail \194\183 %d shaped",
                total, #normalMeta, #detailedMeta, #shapedMeta))

            -- ── posKey: platform-safe integer position key ──────────
            -- string.format("%.0f") uses C banker's rounding (rounds 0.5
            -- to even). Same float can produce different strings in
            -- different calls. math.floor(x+0.5) is always round-half-up.
            local function posKey(p)
                return math.floor(p.X+0.5)..","..math.floor(p.Y+0.5)..","..math.floor(p.Z+0.5)
            end

            -- ── Preview: cyan neon wireframe bounding box ────────────
            -- Weak-value table: if the load coroutine dies mid-way, Lua GC
            -- can still collect the preview parts instead of leaking them.
            local _activeLoadPreviews = setmetatable({}, {__mode = "v"})
            local function cleanupLoadPreviews()
                for _, p in pairs(_activeLoadPreviews) do
                    pcall(function() if p and p.Parent then p:Destroy() end end)
                end
            end

            -- ── Per-brick typed preview ──────────────────────────────────
            -- Replaces the old single bounding-box wireframe.
            -- Each brick gets an invisible anchor Part + a SelectionBox outline
            -- colour-coded by brick type:
            --   Normal   (4×4×4 on-grid) → green   (0, 220, 80)
            --   Shaped   (resized/off-grid) → blue  (0, 140, 255)
            --   Detailed (1×1×1)          → yellow (255, 220, 0)
            --
            -- Parts are batched in groups of 50 with a task.wait(0) between
            -- batches so large saves don't freeze the client during preview init.
            -- All parts are tracked in _activeLoadPreviews (weak-value) so the
            -- GC can collect them if the coroutine dies unexpectedly.
            local PREVIEW_COLOR = {
                normal   = Color3.fromRGB(0,   220, 80),
                shaped   = Color3.fromRGB(0,   140, 255),
                detailed = Color3.fromRGB(255, 220, 0),
            }
            local function makeLoadPreview(metas)
                cleanupLoadPreviews()   -- destroy any leftover from a previous aborted load
                _activeLoadPreviews = setmetatable({}, {__mode = "v"})
                if #metas == 0 then return {} end

                local parts = {}
                local batch = 0
                for _, m in ipairs(metas) do
                    -- Anchor Part: invisible, exact brick size and position.
                    -- SelectionBox requires an Adornee that is a BasePart or Model.
                    local sz  = m.targetSize or Vector3.new(4, 4, 4)
                    local ap  = Instance.new("Part")
                    ap.Size        = sz
                    ap.CFrame      = CFrame.new(m.rawCenter)
                    ap.Transparency = 1
                    ap.Anchored    = true
                    ap.CanCollide  = false
                    ap.CastShadow  = false
                    ap.Parent      = Workspace

                    -- SelectionBox: coloured outline around the anchor part.
                    local col = PREVIEW_COLOR[m.brickType] or PREVIEW_COLOR.normal
                    local sb  = Instance.new("SelectionBox")
                    sb.Adornee        = ap
                    sb.Color3         = col
                    sb.LineThickness  = 0.04
                    sb.SurfaceTransparency = 1        -- no face fill, outline only
                    sb.SurfaceColor3  = col
                    sb.Parent         = Workspace

                    table.insert(parts, ap)
                    table.insert(parts, sb)
                    _activeLoadPreviews[#_activeLoadPreviews+1] = ap
                    _activeLoadPreviews[#_activeLoadPreviews+1] = sb

                    -- Yield every 50 bricks to keep the client responsive
                    batch = batch + 1
                    if batch >= 50 then
                        batch = 0
                        task.wait(0)
                    end
                end
                return parts
            end

            -- ── Cluster blitz — mirrors buildChunked EXACTLY ─────────
            local function clusterBlitz(metas, bsizeArg, label)
                if #metas == 0 then return end
                local ev = getToolRemote("Build")
                if not ev then notify("Sigma","Build tool not found!"); return end
                setupBuiltTracker()

                -- Match buildChunked radii:
                --   normal:   chunk=6 blocks × 4 studs=24 span, half-diag≈20.8 → use 22
                --   detailed: chunk=20 blocks × 1 stud=20 span, half-diag≈17.3 → use 18
                local REACH = (bsizeArg=="detailed")
                    and (BUILD_DETAIL_CHUNK * 0.9)          -- ~18 studs
                    or  (BUILD_NORMAL_CHUNK * GRID_MULT * 0.92) -- ~22 studs

                -- For detailed (1×1×1): use 0.8×0.8×0.8 probe in hasBlockAt.
                -- The default 3×3×3 probe detects adjacent 4×4×4 wall blocks
                -- (whose faces touch the probe box), causing false positives
                -- that make blitzBuild skip firing the remote for the detailed block.
                local probeBox = (bsizeArg=="detailed") and Vector3.new(0.8,0.8,0.8) or nil

                local remaining = {}
                for _, m in ipairs(metas) do remaining[#remaining+1] = m.buildPos end

                local clIdx = 0
                while #remaining > 0 do
                    if S.buildStopped then break end
                    clIdx = clIdx + 1

                    -- Seed is fixed anchor — only gather blocks within REACH of IT.
                    -- (Old bug: used drifting mean → cluster grew arbitrarily wide.)
                    local seed    = table.remove(remaining, 1)
                    local cluster = {seed}
                    local i = 1
                    while i <= #remaining do
                        if (remaining[i] - seed).Magnitude <= REACH then
                            cluster[#cluster+1] = table.remove(remaining, i)
                        else
                            i = i + 1
                        end
                    end

                    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                    if not hrp then break end

                    local tpTarget = seed + Vector3.new(0, 6, 0)
                    hrp.CFrame = CFrame.new(tpTarget)
                    task.wait(BUILD_SETTLE)      -- server sees new HRP position
                    -- Confirm server-side position has synced before anchoring.
                    -- Fast cluster-to-cluster teleports during a load build can
                    -- leave the server position stale, pushing cluster bricks
                    -- outside the 666-stud server build radius → silent drops.
                    waitForServerPosSync(hrp, tpTarget)
                    hrp.Anchored = true          -- lock AFTER server knows new pos

                    btn.Text = string.format("%s cl.%d (%d)", label, clIdx, #cluster)
                    if not ev or not ev.Parent then ev = getToolRemote("Build") end
                    if ev then blitzBuildChaos(ev, cluster, bsizeArg, probeBox) end

                    hrp.Anchored = false
                    task.wait(0.03)
                end

                local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.Anchored = false end
            end

            local previewParts = makeLoadPreview(allMeta)

            -- Scaffold bricks placed during this load (to be deleted in delete pass)
            local loadScaffold = {}

            -- ── Phase 1: Normal 4×4×4 blocks ────────────────────────────────────────
            -- Cluster mode: teleport-cluster (legacy, no seeder needed).
            -- BFS mode    : infinite-range wave from seeder corner, zero teleports.
            if #normalMeta > 0 then
                LOG("Load", string.format("Phase 1/3 | Building %d normal (4x4x4) bricks... [mode=%s]",
                    #normalMeta, S.buildMode == "BFS" and "BFS" or "Cluster"))
                if S.buildMode == "BFS" then
                    btn.Text = string.format("Phase 1/3 \226\128\148 %d normal (BFS)...", #normalMeta)
                    local normPositions = {}
                    for _, meta in ipairs(normalMeta) do normPositions[#normPositions+1] = meta.buildPos end
                    local seederPos = S.seeder and S.seeder.Parent and S.seeder.Position
                    if not seederPos then
                        notify("Sigma", "\226\154\160 BFS mode: no seeder set \226\128\148 Terrain fallback used for first brick.")
                    end
                    local normPlan = planInfBFS(normPositions, seederPos, GRID_MULT)
                    local scN = 0; for _ in pairs(normPlan.scaffoldKeys) do scN=scN+1 end
                    if scN > 0 then notify("Sigma", string.format("Load: %d scaffold bridge(s) added.", scN)) end
                    buildInfBFS(normPlan, "normal", btn, nil, loadScaffold)
                else
                    -- Cluster mode
                    btn.Text = string.format("Phase 1/3 \226\128\148 %d normal (Cluster)...", #normalMeta)
                    clusterBlitz(normalMeta, "normal", "Nrm")
                end
                if S.buildStopped then
                    for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
                    btn.Text="Stopped."; return
                end
            end

            if #normalMeta > 0 and not S.buildStopped then
                local myFF = getMyBrickFolder()
                if myFF then
                    -- Build position list for passFixBuild (needs Vector3 list, not metas)
                    local normPositions = {}
                    for _, meta in ipairs(normalMeta) do normPositions[#normPositions+1] = meta.buildPos end

                    -- First quick scan: how many are already built?
                    local builtKeys0 = {}
                    for _, p in ipairs(myFF:GetChildren()) do
                        if p:IsA("BasePart") then builtKeys0[posKey(p.Position)] = true end
                    end
                    local firstMiss = 0
                    for _, meta in ipairs(normalMeta) do
                        if not builtKeys0[posKey(meta.buildPos)] then firstMiss = firstMiss + 1 end
                    end

                    if firstMiss > 0 then
                        LOG("Load", string.format("Phase 1 fix: %d/%d normal bricks missed after initial pass — running passFixBuild (up to 5 passes)...", firstMiss, #normalMeta))
                        local fixEv = getToolRemote("Build")
                        passFixBuild(normPositions, "normal", fixEv, btn, 5)

                        -- Final scan after passFixBuild — log every still-missing brick
                        local builtKeys1 = {}
                        for _, p in ipairs(myFF:GetChildren()) do
                            if p:IsA("BasePart") then builtKeys1[posKey(p.Position)] = true end
                        end
                        local stillMissed = {}
                        for _, meta in ipairs(normalMeta) do
                            if not builtKeys1[posKey(meta.buildPos)] then
                                stillMissed[#stillMissed+1] = meta
                            end
                        end
                        if #stillMissed > 0 then
                            LOG("Load", string.format("Phase 1 PERSISTENT MISS: %d brick(s) still absent after all fix passes:", #stillMissed))
                            for _, meta in ipairs(stillMissed) do
                                LOG("Load", string.format(
                                    "  MISS buildPos=(%.2f,%.2f,%.2f) rawCenter=(%.2f,%.2f,%.2f) sz=(%.0fx%.0fx%.0f) mat=%s",
                                    meta.buildPos.X, meta.buildPos.Y, meta.buildPos.Z,
                                    meta.rawCenter.X, meta.rawCenter.Y, meta.rawCenter.Z,
                                    meta.targetSize.X, meta.targetSize.Y, meta.targetSize.Z,
                                    tostring(meta.mat)))
                            end

                            -- ── Phase 1 Last-Resort: terrain-direct build ──────────────
                            -- passFixBuild ran up to 5 cluster passes and these bricks
                            -- are still absent. Root cause is almost always isolation:
                            -- the brick (e.g. a roof overhang) has no cluster neighbour
                            -- close enough for the seed-based reach radius.
                            --
                            -- Strategy: for each missed brick, teleport HRP directly
                            -- above it, anchor HRP so the server sees a stable position,
                            -- fire Build on Terrain.Top, wait BUILD_SETTLE+0.30s for
                            -- replication, then release. A fresh folder-scan after the
                            -- loop logs each brick's final fate.
                            --
                            -- Why 0.30s extra settle (vs BUILD_SETTLE 0.10s):
                            -- Isolated terrain builds hit a slower server collision path;
                            -- the extra headroom prevents the ChildAdded event arriving
                            -- after we've already moved on to the next brick.
                            LOG("Load", string.format(
                                "Phase 1 last-resort: terrain-direct for %d brick(s)...", #stillMissed))
                            btn.Text = string.format("Nrm last-resort (%d)...", #stillMissed)

                            local lrHrp = lp.Character
                                      and lp.Character:FindFirstChild("HumanoidRootPart")
                            if fixEv and lrHrp then
                                for _, lrMeta in ipairs(stillMissed) do
                                    if S.buildStopped then break end

                                    -- 1. Teleport above target, wait for server replication
                                    lrHrp.CFrame = CFrame.new(
                                        lrMeta.buildPos + Vector3.new(0, 6, 0))
                                    task.wait(BUILD_SETTLE)

                                    -- 2. Anchor so server sees a stable HRP position
                                    lrHrp.Anchored = true

                                    -- 3. Fire build; server validates HRP is within range
                                    pcall(function()
                                        fixEv:FireServer(
                                            Workspace.Terrain, Enum.NormalId.Top,
                                            lrMeta.buildPos, "normal")
                                    end)

                                    -- 4. Long settle: isolated terrain path is slower
                                    task.wait(0.40)

                                    -- 5. Release anchor; always safe even if never set
                                    lrHrp.Anchored = false
                                    task.wait(0.05)
                                end

                                -- Safety: ensure HRP is never left anchored
                                lrHrp = lp.Character
                                    and lp.Character:FindFirstChild("HumanoidRootPart")
                                if lrHrp then lrHrp.Anchored = false end
                            end

                            -- Re-scan: log final fate of each brick
                            local lrFolder = getMyBrickFolder()
                            local lrBuilt  = {}
                            if lrFolder then
                                for _, p in ipairs(lrFolder:GetChildren()) do
                                    if p:IsA("BasePart") then
                                        lrBuilt[posKey(p.Position)] = true
                                    end
                                end
                            end
                            local lrRecovered, lrFailed = 0, 0
                            for _, lrMeta in ipairs(stillMissed) do
                                if lrBuilt[posKey(lrMeta.buildPos)] then
                                    lrRecovered = lrRecovered + 1
                                else
                                    lrFailed = lrFailed + 1
                                    LOG("Load", string.format(
                                        "  UNRECOVERABLE: buildPos=(%.2f,%.2f,%.2f) mat=%s",
                                        lrMeta.buildPos.X, lrMeta.buildPos.Y,
                                        lrMeta.buildPos.Z, tostring(lrMeta.mat)))
                                end
                            end
                            if lrFailed == 0 then
                                LOG("Load",
                                    "Phase 1/3: OK! All bricks placed after last-resort pass.")
                            else
                                LOG("Load", string.format(
                                    "Phase 1/3: last-resort recovered %d/%d — %d unrecoverable"
                                    .. " (server-side rejection).",
                                    lrRecovered, #stillMissed, lrFailed))
                            end
                        else
                            LOG("Load", "Phase 1/3: OK! All bricks placed after fix passes.")
                        end
                    else
                        LOG("Load", "Phase 1/3: OK! (no missed normal bricks)")
                    end
                end
            end
            if S.buildStopped then
                for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
                btn.Text="Stopped."; return
            end

            -- ── Phase 2: Shaped / off-grid blocks (BFS neighbour-aware) ─
            -- Core fix: adjacent shaped bricks are built ON each other's face
            -- instead of always on Terrain.Top, preventing air-pocket failures.
            -- Ordering via BFS so every non-seed brick has a valid anchor.
            if #shapedMeta > 0 then
                LOG("Load", string.format("Phase 2/3 | Building %d shaped bricks (BFS)...", #shapedMeta))
                btn.Text = string.format("Shape \226\128\148 %d (BFS)...", #shapedMeta)

                local SHAPE_WAIT = 0.12  -- matches build/paint rate; was 0.38 (too slow for large bricks)
                local AXES = {"X","Y","Z"}

                -- Face normal vectors (for teleport offset + face-centre calc)
                local FACE_NORM = {
                    [Enum.NormalId.Top]    = Vector3.new( 0, 1, 0),
                    [Enum.NormalId.Bottom] = Vector3.new( 0,-1, 0),
                    [Enum.NormalId.Right]  = Vector3.new( 1, 0, 0),
                    [Enum.NormalId.Left]   = Vector3.new(-1, 0, 0),
                    [Enum.NormalId.Back]   = Vector3.new( 0, 0, 1),
                    [Enum.NormalId.Front]  = Vector3.new( 0, 0,-1),
                }
                -- Size axis for each face (which axis the face is perpendicular to)
                local FACE_AX = {
                    [Enum.NormalId.Top]="Y",[Enum.NormalId.Bottom]="Y",
                    [Enum.NormalId.Right]="X",[Enum.NormalId.Left]="X",
                    [Enum.NormalId.Back]="Z",[Enum.NormalId.Front]="Z",
                }
                -- Maps dominant-axis + sign → the NormalId that faces that direction
                local AXIS_POS_FACE = {
                    X={[1]=Enum.NormalId.Right,[-1]=Enum.NormalId.Left},
                    Y={[1]=Enum.NormalId.Top,  [-1]=Enum.NormalId.Bottom},
                    Z={[1]=Enum.NormalId.Back, [-1]=Enum.NormalId.Front},
                }

                local buildEv = getToolRemote("Build")
                local shapeEv = getToolRemote("Shape")

                if not buildEv then
                    notify("Sigma","Build tool missing \226\128\148 shaped blocks skipped!")
                else
                    if not shapeEv then
                        notify("Sigma","Shape tool not found \226\128\148 shaped blocks will be 4\195\1514\195\1514")
                    end

                    -- Wait for myF (brick folder created by Phase 1)
                    local myF = nil
                    local fDL = tick() + 2
                    repeat
                        myF = getMyBrickFolder()
                        if not myF then task.wait(0.1) end
                    until myF or tick() > fDL

                    if not myF then
                        notify("Sigma","Brick folder missing \226\128\148 shaped blocks skipped!")
                    else
                        local N = #shapedMeta

                        -- ── A: Shared shape-op applier ───────────────────────────
                        -- Fires Shape remote for each face delta between the part's
                        -- current size/position and the meta target.
                        -- shrinkFirst=true → decreases before increases (fix-pass bias:
                        -- avoids growing into an already-placed neighbouring brick).
                        local function applyShapeOps(part, meta, shrinkFirst)
                            if not shapeEv or not part or not part.Parent then return end
                            local tSz = meta.targetSize
                            local tgt = meta.rawCenter
                            local facePairs = {
                                { Enum.NormalId.Right,  Enum.NormalId.Left,   "X" },
                                { Enum.NormalId.Top,    Enum.NormalId.Bottom, "Y" },
                                { Enum.NormalId.Back,   Enum.NormalId.Front,  "Z" },
                            }
                            local function fireFace(norm, n, mode)
                                for _ = 1, n do
                                    if not part or not part.Parent then return end
                                    if S.buildStopped or S.skipBlock then return end
                                    shapeEv:FireServer(part, norm, part.Position, mode)
                                    task.wait(SHAPE_WAIT)
                                end
                            end
                            for _, fp in ipairs(facePairs) do
                                if S.buildStopped or S.skipBlock then break end
                                if not part or not part.Parent then break end
                                local posNorm, negNorm, ax = fp[1], fp[2], fp[3]
                                -- Re-read size and position FRESH per axis.
                                -- After each FireServer the server resizes+moves the part,
                                -- so caching at the top of the function produces wrong deltas
                                -- for large bricks (e.g. 4×1×24 needs ~20 shape ops on Z).
                                local halfStart = part.Size[ax] / 2
                                local partPos   = part.Position[ax]
                                local halfTgt   = tSz[ax] / 2
                                local dPos = math.round((tgt[ax]+halfTgt)-(partPos+halfStart))
                                local dNeg = math.round((tgt[ax]-halfTgt)-(partPos-halfStart))
                                if shrinkFirst then
                                    if dPos < 0 then fireFace(posNorm, -dPos, "decrease") end
                                    if dNeg > 0 then fireFace(negNorm,  dNeg, "decrease") end
                                    if dPos > 0 then fireFace(posNorm,  dPos, "increase") end
                                    if dNeg < 0 then fireFace(negNorm, -dNeg, "increase") end
                                else
                                    if dPos > 0 then fireFace(posNorm,  dPos, "increase") end
                                    if dNeg < 0 then fireFace(negNorm, -dNeg, "increase") end
                                    if dPos < 0 then fireFace(posNorm, -dPos, "decrease") end
                                    if dNeg > 0 then fireFace(negNorm,  dNeg, "decrease") end
                                end
                            end
                        end

                        -- ── B: Neighbour detection via spatial hash (O(n)) ───────
                        -- areTouching(a, b): returns the face of A that B attaches to,
                        -- or nil if they are not touching. Uses rawCenter+targetSize
                        -- (intended geometry) so the graph is built before any bricks
                        -- are placed.
                        local function areTouching(a, b)
                            local cA, sA = a.rawCenter, a.targetSize
                            local cB, sB = b.rawCenter, b.targetSize
                            local D = cB - cA
                            -- BUG FIX: the old code only tested the single "dominant" axis
                            -- (largest |displacement|). For thin stacked bricks the face-normal
                            -- axis can have the SAME or SMALLER displacement than a lateral axis
                            -- (e.g. two 4×2×4 slabs where D=(2,2,0): X and Y tie, X won, Y
                            -- was never checked → pair missed → treated as disconnected seed →
                            -- terrain build failed). Fix: try all three axes in descending
                            -- displacement order; return the first one that satisfies both the
                            -- face-separation check and the cross-axis overlap check.
                            local axesByDist = {"X", "Y", "Z"}
                            table.sort(axesByDist, function(p, q)
                                return math.abs(D[p]) > math.abs(D[q])
                            end)
                            for _, ax in ipairs(axesByDist) do
                                -- Face-normal axis: centres must be separated by halfA+halfB
                                local expected = sA[ax]/2 + sB[ax]/2
                                if math.abs(math.abs(D[ax]) - expected) <= 0.2 then
                                    -- Cross axes: centres must overlap (shared face area exists)
                                    local valid = true
                                    for _, ax2 in ipairs(AXES) do
                                        if ax2 ~= ax then
                                            local sep    = math.abs(D[ax2])
                                            -- Correct threshold: bricks share face area when
                                            -- |D[ax2]| < (sA[ax2]+sB[ax2])/2.
                                            -- Old formula (min/2+0.5) was wrong in both directions:
                                            --   • too strict for large bricks → missed staggered pairs
                                            --   • too permissive for 1-stud bricks → D=(1,6,0) on a
                                            --     1×6×4 pair falsely passed, causing wrong BFS anchors,
                                            --     bricks placed at the wrong position, and spiral holes.
                                            -- -0.05 requires actual face-area overlap (not edge-only)
                                            -- while absorbing any floating-point residual from the server.
                                            local maxSep = (sA[ax2] + sB[ax2]) / 2 - 0.05
                                            if sep > maxSep then valid = false; break end
                                        end
                                    end
                                    if valid then
                                        local sign = D[ax] > 0 and 1 or -1
                                        return AXIS_POS_FACE[ax][sign]
                                    end
                                end
                            end
                            return nil
                        end

                        -- Spatial hash for neighbour lookups.
                        -- CELL is fixed at 8 studs. The search radius (in cells) is
                        -- computed from the largest half-dimension of any shaped brick,
                        -- so that a 4×1×24 whose neighbour center is 24 studs away is
                        -- never missed by the candidate search.
                        local CELL = 8
                        local maxHalfDim = 2  -- minimum sensible value (half of 4-stud brick)
                        for i = 1, N do
                            local s = shapedMeta[i].targetSize
                            local h = math.max(s.X, s.Y, s.Z) / 2
                            if h > maxHalfDim then maxHalfDim = h end
                        end
                        -- +1 cell of margin to handle bricks whose centres sit near a
                        -- cell boundary; without this a 24-stud brick at a boundary edge
                        -- could still slip through.
                        local searchR = math.max(1, math.ceil(maxHalfDim / CELL)) + 1
                        local spatialHash = {}
                        for i = 1, N do
                            local p  = shapedMeta[i].rawCenter
                            local k  = math.floor(p.X/CELL)..","..math.floor(p.Y/CELL)..","..math.floor(p.Z/CELL)
                            if not spatialHash[k] then spatialHash[k] = {} end
                            spatialHash[k][#spatialHash[k]+1] = i
                        end
                        local function getCandidates(p)
                            local cx=math.floor(p.X/CELL); local cy=math.floor(p.Y/CELL); local cz=math.floor(p.Z/CELL)
                            local r = {}
                            for dx=-searchR,searchR do for dy=-searchR,searchR do for dz=-searchR,searchR do
                                local k=(cx+dx)..",".. (cy+dy)..",".. (cz+dz)
                                if spatialHash[k] then
                                    for _,j in ipairs(spatialHash[k]) do r[#r+1]=j end
                                end
                            end end end
                            return r
                        end

                        -- adjacency[i] = list of {idx=j, face=faceOfI_toward_j}
                        local adjacency = {}
                        for i = 1, N do adjacency[i] = {} end
                        for i = 1, N do
                            for _, j in ipairs(getCandidates(shapedMeta[i].rawCenter)) do
                                if j > i then
                                    local fIJ = areTouching(shapedMeta[i], shapedMeta[j])
                                    if fIJ then
                                        local fJI = areTouching(shapedMeta[j], shapedMeta[i])
                                        adjacency[i][#adjacency[i]+1] = {idx=j, face=fIJ}
                                        if fJI then
                                            adjacency[j][#adjacency[j]+1] = {idx=i, face=fJI}
                                        end
                                    end
                                end
                            end
                        end

                        -- ── C: BFS ordering per connected component ──────────────
                        -- buildOrder[k] = {metaIdx, anchorMetaIdx_or_nil, faceOnAnchor_or_nil}
                        -- Seeds (first brick of each component) have nil anchor → Terrain build.
                        -- All subsequent bricks get an anchor = the BFS parent brick.
                        local visited    = {}
                        local buildOrder = {}
                        local builtPart  = {}  -- [metaIdx] = BasePart, filled as bricks are placed

                        local function bfsComponent(seed)
                            local queue = {seed}
                            visited[seed] = true
                            buildOrder[#buildOrder+1] = {seed, nil, nil}  -- seed: no anchor
                            local qi = 1
                            while qi <= #queue do
                                local cur = queue[qi]; qi = qi + 1
                                for _, nb in ipairs(adjacency[cur]) do
                                    if not visited[nb.idx] then
                                        visited[nb.idx] = true
                                        -- face of CUR that faces nb.idx
                                        local faceOnCur = areTouching(shapedMeta[cur], shapedMeta[nb.idx])
                                        buildOrder[#buildOrder+1] = {nb.idx, cur, faceOnCur or nb.face}
                                        queue[#queue+1] = nb.idx
                                    end
                                end
                            end
                        end

                        -- Seeds = lowest-Y unvisited brick in each component.
                        -- If S.seeder is set: pre-mark the seeder position as visited so
                        -- the first ring of shaped bricks is built ON the seeder (inf-range).
                        -- The seeder itself is injected into builtPart as index 0 (sentinel).
                        if S.seeder and S.seeder.Parent then
                            local sp = S.seeder.Position
                            -- FIX: rawCenters are already translated by offsetVec into world
                            -- space. S.seeder.Position is also a world position — so compare
                            -- directly in world space (rawCenter vs sp). The old code compared
                            -- offset rawCenters against the un-offset sp, finding the wrong
                            -- closest brick and corrupting the entire BFS placement order.
                            local bestDist, bestI = math.huge, nil
                            for i = 1, N do
                                local d = (shapedMeta[i].rawCenter - sp).Magnitude
                                if d < bestDist then bestDist=d; bestI=i end
                            end
                            if bestI then
                                builtPart[0]  = S.seeder  -- sentinel: seeder brick
                                visited[bestI] = true
                                local face0 = areTouching(
                                    {rawCenter=sp, targetSize=S.seeder.Size},
                                    shapedMeta[bestI]) or Enum.NormalId.Top
                                buildOrder[#buildOrder+1] = {bestI, 0, face0}
                                local q0 = {bestI}; local qi0 = 1
                                while qi0 <= #q0 do
                                    local cur = q0[qi0]; qi0=qi0+1
                                    for _, nb in ipairs(adjacency[cur]) do
                                        if not visited[nb.idx] then
                                            visited[nb.idx] = true
                                            local foc = areTouching(shapedMeta[cur], shapedMeta[nb.idx])
                                            buildOrder[#buildOrder+1] = {nb.idx, cur, foc or nb.face}
                                            q0[#q0+1] = nb.idx
                                        end
                                    end
                                end
                            end
                        end

                        -- Seeds = lowest-Y unvisited brick in each component
                        local sortedByY = {}
                        for i = 1, N do sortedByY[i] = i end
                        table.sort(sortedByY, function(a, b)
                            return shapedMeta[a].rawCenter.Y < shapedMeta[b].rawCenter.Y
                        end)
                        for _, i in ipairs(sortedByY) do
                            if not visited[i] then bfsComponent(i) end
                        end

                        -- ── D: Place bricks in BFS order (3-strategy placement) ─────────
                        -- Strategy A — face-attach off the BFS anchor (primary):
                        --   The Build remote copies the anchor's SIZE onto the new brick,
                        --   not a fixed 4×4×4. Building off a neighbour's face therefore
                        --   spawns the new brick at approximately the right size/position,
                        --   and applyShapeOps trims any remaining delta. No teleport needed
                        --   (infinite range). Eliminates air-pocket failures for stacked
                        --   shaped bricks because no terrain-side collision check fires.
                        -- Strategy B — teleport + terrain build (seed bricks / A unavailable):
                        --   Used for the first brick of each BFS component (no anchor yet)
                        --   or when the anchor itself failed to place earlier.
                        -- Strategy C — collide-toggle fallback (last resort):
                        --   If B still fails (another shaped brick is sitting at buildPos),
                        --   temporarily disable that brick's collision via the Paint remote,
                        --   retry the terrain build, then restore collision.
                        -- BFS ordering (bottom-up) minimises the chance of B/C being needed.
                        local lastBuilt = nil
                        local builtConn = myF.ChildAdded:Connect(function(child)
                            if child:IsA("BasePart") then lastBuilt = child end
                        end)

                        local missingShape = 0
                        for orderIdx, entry in ipairs(buildOrder) do
                            repeat
                            if S.buildStopped then break end
                            local metaIdx  = entry[1]
                            local meta     = shapedMeta[metaIdx]
                            local tSz      = meta.targetSize
                            S.skipBlock    = false

                            btn.Text = string.format(
                                "Shape %d/%d | %.0f\195\151%.0f\195\151%.0f",
                                orderIdx, #buildOrder, tSz.X, tSz.Y, tSz.Z)

                            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                            if not hrp then break end

                            if not buildEv or not buildEv.Parent then
                                buildEv = getToolRemote("Build")
                            end
                            if not buildEv then break end

                            lastBuilt = nil

                            local anchorMetaIdx = entry[2]
                            local anchorFace    = entry[3]

                            -- ── Strategy A: face-attach off the BFS anchor ────────────────
                            -- When the anchor brick was successfully placed, build directly
                            -- off its face. The Build remote copies the anchor's size onto
                            -- the new brick, so stacked shaped bricks no longer collide with
                            -- each other during placement.
                            -- CRITICAL: even though brick-to-brick builds bypass the server's
                            -- strict position check, the server still needs the player within
                            -- ~6 studs of the target face. Teleport to faceCenter+norm*6 and
                            -- anchor the HRP before firing — exactly as v4.6.1 did.
                            local usedStrategyA = false
                            if anchorMetaIdx ~= nil
                            and builtPart[anchorMetaIdx]
                            and builtPart[anchorMetaIdx].Parent then
                                usedStrategyA = true
                                local anchorPart = builtPart[anchorMetaIdx]
                                local norm       = FACE_NORM[anchorFace] or Vector3.new(0,1,0)
                                local ax         = FACE_AX[anchorFace]   or "Y"
                                -- Use the anchor's targetSize (not its live .Size) for the
                                -- face-center calculation. anchorPart.Size is the server-
                                -- replicated value, which may still lag by one frame if the
                                -- anchor was just shaped in the previous iteration. Using the
                                -- intended target size (always available, never stale) gives
                                -- the correct face-center even when replication is in flight.
                                local anchorMeta  = shapedMeta[anchorMetaIdx]
                                    or (anchorMetaIdx == 0 and {targetSize = anchorPart.Size} or nil)
                                local anchorHalf  = anchorMeta and anchorMeta.targetSize[ax] / 2
                                    or anchorPart.Size[ax] / 2  -- fallback: live size (sentinel seeder)
                                local faceCenter = anchorPart.Position + norm * anchorHalf

                                -- Face-attach is infinite range — no teleport needed.
                                -- The server's brick-to-brick build path bypasses the
                                -- proximity check that terrain builds require.
                                LOG("Load", string.format(
                                    "  [%d/%d] Strategy A: face-attach anchor=%d face=%s faceCenter=(%.1f,%.1f,%.1f)",
                                    orderIdx, #buildOrder, anchorMetaIdx, tostring(anchorFace),
                                    faceCenter.X, faceCenter.Y, faceCenter.Z))

                                buildEv:FireServer(anchorPart, anchorFace, faceCenter, "normal")

                                local dlA = tick() + 1.5
                                while not lastBuilt and tick() < dlA do task.wait(0.05) end

                                if lastBuilt then
                                    LOG("Load", string.format("  [%d/%d] Strategy A: OK (%.2fs wait)", orderIdx, #buildOrder, 1.5 - math.max(0, dlA - tick())))
                                else
                                    LOG("Load", string.format("  [%d/%d] Strategy A: FAILED → falling through to B", orderIdx, #buildOrder))
                                end
                            end

                            -- ── Strategy B: teleport + terrain build ──────────────────────
                            -- Used for BFS seed bricks (no anchor) or when Strategy A failed
                            -- (anchor brick itself failed to place in a prior iteration).
                            if not lastBuilt then
                                if usedStrategyA then
                                    LOG("Load", string.format("  [%d/%d] Strategy B: terrain build at (%.1f,%.1f,%.1f)",
                                        orderIdx, #buildOrder,
                                        meta.buildPos.X, meta.buildPos.Y, meta.buildPos.Z))
                                else
                                    LOG("Load", string.format("  [%d/%d] Strategy B (seed): terrain build at (%.1f,%.1f,%.1f)",
                                        orderIdx, #buildOrder,
                                        meta.buildPos.X, meta.buildPos.Y, meta.buildPos.Z))
                                end
                                hrp.CFrame   = CFrame.new(meta.buildPos + Vector3.new(0, 6, 0))
                                task.wait(BUILD_SETTLE)
                                hrp.Anchored = true
                                buildEv:FireServer(Workspace.Terrain, Enum.NormalId.Top,
                                                   meta.buildPos, "normal")
                                local dlB = tick() + 1.5
                                while not lastBuilt and tick() < dlB do task.wait(0.05) end
                                hrp.Anchored = false
                                if lastBuilt then
                                    LOG("Load", string.format("  [%d/%d] Strategy B: OK", orderIdx, #buildOrder))
                                else
                                    LOG("Load", string.format("  [%d/%d] Strategy B: FAILED → falling through to C", orderIdx, #buildOrder))
                                end
                            end

                            -- ── Strategy C: collide-toggle fallback ───────────────────────
                            -- Terrain build can still fail when an already-placed shaped brick
                            -- sits at buildPos (e.g., disconnected components whose seed lands
                            -- on top of a prior component). Temporarily disable collision on
                            -- the blocker, retry the terrain build, then restore collision.
                            if not lastBuilt then
                                local paintEvC = getToolRemote("Paint")
                                local blocker  = nil
                                local bestD    = 2.5
                                for _, ch in ipairs(myF:GetChildren()) do
                                    if ch:IsA("BasePart") then
                                        local d = (ch.Position - meta.buildPos).Magnitude
                                        if d < bestD then bestD = d; blocker = ch end
                                    end
                                end
                                if blocker and paintEvC then
                                    LOG("Load", string.format(
                                        "  [%d/%d] Strategy C: collide-toggle blocker at (%.1f,%.1f,%.1f) dist=%.2f",
                                        orderIdx, #buildOrder,
                                        blocker.Position.X, blocker.Position.Y, blocker.Position.Z, bestD))
                                    -- toggle collide OFF on the blocker
                                    paintEvC:FireServer(blocker, Enum.NormalId.Top, hrp.Position,
                                        "material", Color3.new(1,1,1), "collide", "")
                                    task.wait(0.08)
                                    -- retry terrain build
                                    hrp.CFrame   = CFrame.new(meta.buildPos + Vector3.new(0, 6, 0))
                                    task.wait(BUILD_SETTLE)
                                    hrp.Anchored = true
                                    buildEv:FireServer(Workspace.Terrain, Enum.NormalId.Top,
                                                       meta.buildPos, "normal")
                                    local dlC = tick() + 1.5
                                    while not lastBuilt and tick() < dlC do task.wait(0.05) end
                                    hrp.Anchored = false
                                    -- restore collide ON the blocker regardless of outcome
                                    paintEvC:FireServer(blocker, Enum.NormalId.Top, hrp.Position,
                                        "material", Color3.new(1,1,1), "collide", "")
                                    task.wait(0.05)
                                    if lastBuilt then
                                        LOG("Load", string.format("  [%d/%d] Strategy C: OK", orderIdx, #buildOrder))
                                    else
                                        LOG("Load", string.format("  [%d/%d] Strategy C: FAILED (all strategies exhausted)", orderIdx, #buildOrder))
                                    end
                                else
                                    LOG("Load", string.format(
                                        "  [%d/%d] Strategy C: skipped (no blocker within 2.5 studs or no Paint remote)",
                                        orderIdx, #buildOrder))
                                end
                            end

                            local part = lastBuilt
                            if not part or not part.Parent then
                                missingShape  = missingShape + 1
                                meta.failed   = true

                                -- ── DIAGNOSTIC DUMP ───────────────────────────────
                                local anchorM = anchorMetaIdx and shapedMeta[anchorMetaIdx]
                                LOG("Load", string.format(
                                    "SHAPE FAIL [%d/%d] idx=%d | target=(%.2f,%.2f,%.2f) sz=(%.0fx%.0fx%.0f)",
                                    orderIdx, #buildOrder, metaIdx,
                                    meta.rawCenter.X, meta.rawCenter.Y, meta.rawCenter.Z,
                                    tSz.X, tSz.Y, tSz.Z))
                                LOG("Load", string.format(
                                    "  buildPos=(%.2f,%.2f,%.2f) mat=%s col=(%d,%d,%d)",
                                    meta.buildPos.X, meta.buildPos.Y, meta.buildPos.Z,
                                    tostring(meta.mat),
                                    math.round((meta.color and meta.color.R or 0.83)*255),
                                    math.round((meta.color and meta.color.G or 0.83)*255),
                                    math.round((meta.color and meta.color.B or 0.83)*255)))
                                if anchorM then
                                    local aok = builtPart[anchorMetaIdx] and builtPart[anchorMetaIdx].Parent
                                    LOG("Load", string.format(
                                        "  anchor idx=%d placed=%s face=%s anchor_sz=(%.0fx%.0fx%.0f) anchor_pos=(%.2f,%.2f,%.2f)",
                                        anchorMetaIdx,
                                        aok and "YES" or "NO (anchor itself failed!)",
                                        tostring(anchorFace),
                                        anchorM.targetSize.X, anchorM.targetSize.Y, anchorM.targetSize.Z,
                                        anchorM.rawCenter.X, anchorM.rawCenter.Y, anchorM.rawCenter.Z))
                                else
                                    LOG("Load", "  anchor: NONE (this is a BFS seed/terrain build)")
                                end
                                LOG("Load", string.format("  Strategies tried: %s",
                                    anchorMetaIdx and builtPart[anchorMetaIdx] and builtPart[anchorMetaIdx].Parent
                                        and "A(face-attach)+B(terrain)+C(collide-toggle)"
                                        or "B(terrain)+C(collide-toggle)"))
                                -- Adjacent neighbours for context
                                local adj = adjacency[metaIdx]
                                if adj and #adj > 0 then
                                    LOG("Load", string.format("  Adjacent bricks (%d):", #adj))
                                    for _, nb in ipairs(adj) do
                                        local nm = shapedMeta[nb.idx]
                                        local nbPlaced = builtPart[nb.idx] and builtPart[nb.idx].Parent
                                        LOG("Load", string.format(
                                            "    [nb idx=%d] placed=%s face=%s sz=(%.0fx%.0fx%.0f) pos=(%.2f,%.2f,%.2f)",
                                            nb.idx,
                                            nbPlaced and "YES" or "NO",
                                            tostring(nb.face),
                                            nm.targetSize.X, nm.targetSize.Y, nm.targetSize.Z,
                                            nm.rawCenter.X, nm.rawCenter.Y, nm.rawCenter.Z))
                                    end
                                else
                                    LOG("Load", "  Adjacent bricks: none (isolated shaped brick)")
                                end
                                -- Check if any world brick is blocking the build position
                                local bf2 = getMyBrickFolder()
                                if bf2 then
                                    local closest, closestD = nil, 3.0
                                    for _, ch in ipairs(bf2:GetChildren()) do
                                        if ch:IsA("BasePart") then
                                            local d = (ch.Position - meta.buildPos).Magnitude
                                            if d < closestD then closestD = d; closest = ch end
                                        end
                                    end
                                    if closest then
                                        LOG("Load", string.format(
                                            "  Nearest existing brick: pos=(%.2f,%.2f,%.2f) sz=(%.0fx%.0fx%.0f) dist=%.2f",
                                            closest.Position.X, closest.Position.Y, closest.Position.Z,
                                            closest.Size.X, closest.Size.Y, closest.Size.Z,
                                            closestD))
                                    else
                                        LOG("Load", "  No existing brick within 3 studs of buildPos.")
                                    end
                                end
                                -- ── END DIAGNOSTIC DUMP ───────────────────────────

                                break
                            end

                            builtPart[metaIdx] = part
                            meta.builtPart     = part

                            -- ── Size-replication settle ───────────────────────────
                            -- The Build remote creates the brick server-side and the
                            -- client's ChildAdded fires almost immediately — before the
                            -- server's replicated Size has arrived. Reading part.Size
                            -- here can still return the stale 4×4×4 default, causing
                            -- applyShapeOps to compute a bogus full-reshape delta even
                            -- when the brick was already spawned at the correct size
                            -- (inherited from the anchor via face-attach). Wait one
                            -- extra tick for the size property to replicate, then check
                            -- whether shaping is actually needed before firing.
                            task.wait(SHAPE_WAIT)

                            -- ── Skip shaping if inherited size already matches ────
                            -- When Strategy A built off a correctly-sized anchor the
                            -- server copies that anchor's size onto the new brick.
                            -- If the inherited size already matches the target within
                            -- 0.49 studs on every axis, applyShapeOps would fire zero
                            -- net operations anyway — but reading a stale size before
                            -- replication settles caused it to re-shape the brick from
                            -- scratch (e.g. 4,1,4 → 4,4,2 repeated for every wall
                            -- brick instead of only the first one). This guard makes
                            -- the skip explicit and race-condition-proof.
                            local EPS_SPAWN = 0.49
                            local pSz = part.Size
                            local alreadySized = math.abs(pSz.X - tSz.X) <= EPS_SPAWN
                                             and math.abs(pSz.Y - tSz.Y) <= EPS_SPAWN
                                             and math.abs(pSz.Z - tSz.Z) <= EPS_SPAWN
                            if not alreadySized then
                                -- Shape ops: increase-first on initial pass
                                applyShapeOps(part, meta, false)
                            else
                                LOG("Load", string.format(
                                    "  [%d/%d] Size already correct (%.0fx%.0fx%.0f) — shaping skipped.",
                                    orderIdx, #buildOrder, pSz.X, pSz.Y, pSz.Z))
                            end
                            S.skipBlock = false
                            task.wait(0.05)

                            -- ── ROLLING-CHECK: every 10 bricks, re-verify the last 10 ──────
                            -- Catches size drift and placement dropouts while the build is
                            -- still in progress, before downstream bricks chain off a wrong
                            -- anchor. Runs shrink-first to avoid growing into neighbours.
                            -- Missing bricks are recovered via face-attach off the nearest
                            -- live placed brick (same logic as Tier 2 pass E below).
                            if shapeEv and orderIdx % 10 == 0 then
                                local startIdx = math.max(1, orderIdx - 9)
                                for chkOff = startIdx, orderIdx do
                                    if S.buildStopped then break end
                                    local chkEntry  = buildOrder[chkOff]
                                    if not chkEntry then break end
                                    local chkMIdx   = chkEntry[1]
                                    local chkMeta   = shapedMeta[chkMIdx]
                                    local chkTSz    = chkMeta.targetSize
                                    local chkPart   = builtPart[chkMIdx]

                                    -- Missing brick → face-attach recovery (inline, before
                                    -- rebuildMissingBrick is declared; duplicate logic here
                                    -- so the D loop stays self-contained).
                                    if not chkPart or not chkPart.Parent then
                                        LOG("Load", string.format(
                                            "  ROLL@%d: brick idx=%d MISSING — attempting face-attach.",
                                            orderIdx, chkMIdx))
                                        btn.Text = string.format(
                                            "Roll@%d miss idx=%d", orderIdx, chkMIdx)
                                        -- Find closest live placed brick
                                        local tgtPos2  = chkMeta.rawCenter
                                        local cAnchor, cBestD = nil, math.huge
                                        for mI2, bp2 in pairs(builtPart) do
                                            if bp2 and bp2.Parent then
                                                local d2 = (bp2.Position - tgtPos2).Magnitude
                                                if d2 < cBestD then cBestD=d2; cAnchor=bp2 end
                                            end
                                        end
                                        if cAnchor then
                                            local diff2     = tgtPos2 - cAnchor.Position
                                            local cBestFace = Enum.NormalId.Top
                                            local cBestDot  = -math.huge
                                            for faceR, normR in pairs(FACE_NORM) do
                                                local dot2 = diff2:Dot(normR)
                                                if dot2 > cBestDot then
                                                    cBestDot = dot2; cBestFace = faceR
                                                end
                                            end
                                            local normC  = FACE_NORM[cBestFace] or Vector3.new(0,1,0)
                                            local axC    = FACE_AX[cBestFace]   or "Y"
                                            local fcC    = cAnchor.Position + normC * (cAnchor.Size[axC]/2)
                                            -- Face-attach is infinite range — no teleport needed.
                                            lastBuilt = nil
                                            if not buildEv or not buildEv.Parent then
                                                buildEv = getToolRemote("Build")
                                            end
                                            if buildEv then
                                                buildEv:FireServer(cAnchor, cBestFace, fcC, "normal")
                                                local dlRoll = tick() + 1.5
                                                while not lastBuilt and tick() < dlRoll do
                                                    task.wait(0.05)
                                                end
                                                if lastBuilt then
                                                    builtPart[chkMIdx] = lastBuilt
                                                    chkMeta.builtPart  = lastBuilt
                                                    task.wait(SHAPE_WAIT)
                                                    -- Shaping IS range-checked: teleport to the
                                                    -- new brick before firing Shape remotes.
                                                    local hrpC = lp.Character
                                                        and lp.Character:FindFirstChild("HumanoidRootPart")
                                                    if hrpC then
                                                        hrpC.CFrame = CFrame.new(
                                                            lastBuilt.Position + Vector3.new(0, 6, 0))
                                                        task.wait(BUILD_SETTLE)
                                                    end
                                                    applyShapeOps(lastBuilt, chkMeta, true)
                                                    LOG("Load", string.format(
                                                        "  ROLL@%d: idx=%d recovered OK.",
                                                        orderIdx, chkMIdx))
                                                else
                                                    LOG("Load", string.format(
                                                        "  ROLL@%d: idx=%d recovery FAILED.",
                                                        orderIdx, chkMIdx))
                                                end
                                            end
                                        end

                                    -- Size mismatch → re-shape in place
                                    else
                                        local cSz = chkPart.Size
                                        if math.abs(cSz.X - chkTSz.X) > EPS_SPAWN
                                        or math.abs(cSz.Y - chkTSz.Y) > EPS_SPAWN
                                        or math.abs(cSz.Z - chkTSz.Z) > EPS_SPAWN then
                                            LOG("Load", string.format(
                                                "  ROLL@%d: idx=%d size mismatch (%.0fx%.0fx%.0f) → target (%.0fx%.0fx%.0f) — reshaping.",
                                                orderIdx, chkMIdx,
                                                cSz.X, cSz.Y, cSz.Z,
                                                chkTSz.X, chkTSz.Y, chkTSz.Z))
                                            btn.Text = string.format(
                                                "Roll@%d fix idx=%d", orderIdx, chkMIdx)
                                            local hrpR2 = lp.Character
                                                and lp.Character:FindFirstChild("HumanoidRootPart")
                                            if hrpR2 then
                                                hrpR2.CFrame = CFrame.new(
                                                    chkPart.Position + Vector3.new(0, 6, 0))
                                                task.wait(BUILD_SETTLE)
                                            end
                                            applyShapeOps(chkPart, chkMeta, true)
                                            task.wait(0.05)
                                        end
                                    end
                                end -- rolling window loop
                            end -- if shapeEv and orderIdx % 10 == 0
                            until true
                        end

                        builtConn:Disconnect()
                        do
                            local hrp2 = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                            if hrp2 then hrp2.Anchored = false end
                        end

                        -- ── E: Shape Fix Pass (rolling inline + full convergence sweeps) ──
                        --
                        -- TWO-TIER approach:
                        --
                        -- Tier 1 — Rolling inline check (already woven into the D loop above):
                        --   Every 10 bricks placed, the last 10 builtPart entries are
                        --   re-checked immediately while they are still hot in memory.
                        --   Mismatched bricks are re-shaped in place (teleport + applyShapeOps,
                        --   shrink-first to avoid growing into neighbours).
                        --   Missing bricks (nil / no Parent) are recovered via face-attach off
                        --   the closest live placed brick, then shaped to target.
                        --   This catches single-brick dropouts before they propagate to children
                        --   that depend on them as BFS anchors.
                        --
                        -- Tier 2 — Full convergence sweeps (this block, up to 5 rounds):
                        --   After the entire D loop finishes, sweep ALL N shaped bricks.
                        --   Mismatched → shrink-first applyShapeOps.
                        --   Missing → face-attach off closest live brick + shape.
                        --   Stops early once a full sweep produces zero corrections.
                        --   shrinkFirst=true throughout prevents growing into neighbours.
                        --
                        -- Shared helpers (used by both tiers):
                        local EPS_FIX = 0.49

                        -- findClosestLiveBrick(targetPos):
                        --   Returns the closest BasePart in builtPart[] that is still alive.
                        --   Used to find a face-attach anchor when a brick is missing.
                        local function findClosestLiveBrick(targetPos)
                            local bestDist, bestPart, bestMIdx = math.huge, nil, nil
                            for mIdx, bp in pairs(builtPart) do
                                if bp and bp.Parent then
                                    local d = (bp.Position - targetPos).Magnitude
                                    if d < bestDist then
                                        bestDist = d; bestPart = bp; bestMIdx = mIdx
                                    end
                                end
                            end
                            return bestPart, bestMIdx, bestDist
                        end

                        -- rebuildMissingBrick(metaIdx2, meta2, label):
                        --   Attempts to recover a missing shaped brick by face-attaching
                        --   off the closest live placed brick, waiting for the new part to
                        --   arrive, then shaping it to target size.
                        --   Returns the new BasePart on success, nil on failure.
                        local rebuildLastBuilt = nil
                        local rebuildConn      = myF.ChildAdded:Connect(function(child)
                            if child:IsA("BasePart") then rebuildLastBuilt = child end
                        end)

                        local function rebuildMissingBrick(metaIdx2, meta2, label)
                            if S.buildStopped then return nil end
                            local tSz2    = meta2.targetSize
                            local tgtPos  = meta2.rawCenter
                            local anchor, _, _ = findClosestLiveBrick(tgtPos)
                            if not anchor then
                                LOG("Load", string.format(
                                    "  %s [idx=%d] SKIP: no live brick to face-attach from.",
                                    label, metaIdx2))
                                return nil
                            end
                            -- Pick the face of anchor closest to tgtPos
                            local diff      = tgtPos - anchor.Position
                            local bestFace  = Enum.NormalId.Top
                            local bestDot   = -math.huge
                            for face, norm in pairs(FACE_NORM) do
                                local dot = diff:Dot(norm)
                                if dot > bestDot then bestDot = dot; bestFace = face end
                            end
                            local norm2      = FACE_NORM[bestFace] or Vector3.new(0,1,0)
                            local ax2        = FACE_AX[bestFace]   or "Y"
                            local faceCenter = anchor.Position + norm2 * (anchor.Size[ax2] / 2)

                            LOG("Load", string.format(
                                "  %s [idx=%d] face-attach off anchor pos=(%.1f,%.1f,%.1f) face=%s → target sz=(%.0fx%.0fx%.0f)",
                                label, metaIdx2,
                                anchor.Position.X, anchor.Position.Y, anchor.Position.Z,
                                tostring(bestFace), tSz2.X, tSz2.Y, tSz2.Z))

                            rebuildLastBuilt = nil
                            if not buildEv or not buildEv.Parent then
                                buildEv = getToolRemote("Build")
                            end
                            if not buildEv then return nil end

                            -- Face-attach is infinite range — fire directly, no teleport.
                            buildEv:FireServer(anchor, bestFace, faceCenter, "normal")
                            local dlR = tick() + 1.5
                            while not rebuildLastBuilt and tick() < dlR do task.wait(0.05) end

                            local newPart = rebuildLastBuilt
                            if not newPart or not newPart.Parent then
                                LOG("Load", string.format(
                                    "  %s [idx=%d] face-attach FAILED (no ChildAdded within 1.5s).", label, metaIdx2))
                                return nil
                            end

                            builtPart[metaIdx2]   = newPart
                            meta2.builtPart        = newPart
                            task.wait(SHAPE_WAIT)   -- let inherited size replicate
                            -- Shaping IS range-checked: teleport to the new brick first.
                            local hrpR = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                            if hrpR then
                                hrpR.CFrame = CFrame.new(newPart.Position + Vector3.new(0, 6, 0))
                                task.wait(BUILD_SETTLE)
                            end
                            applyShapeOps(newPart, meta2, true)
                            LOG("Load", string.format(
                                "  %s [idx=%d] rebuilt OK, shaped to (%.0fx%.0fx%.0f).",
                                label, metaIdx2, tSz2.X, tSz2.Y, tSz2.Z))
                            return newPart
                        end

                        -- ── Tier 1: Rolling inline check (woven into D loop) ─────────────
                        -- NOTE: The actual per-10-brick trigger is embedded INSIDE the D loop
                        -- above (search "ROLLING-CHECK"). This block documents the design and
                        -- holds the shared helpers; no additional code is needed here.

                        -- ── Tier 2: Full convergence sweeps (up to 5 rounds) ─────────────
                        if shapeEv then
                            for passNum = 1, 5 do
                                if S.buildStopped then break end
                                local anyFixed  = false
                                local fixCount  = 0
                                local missCount = 0
                                for metaIdx2 = 1, N do
                                    repeat
                                    if S.buildStopped then break end
                                    local meta2 = shapedMeta[metaIdx2]
                                    local tSz2  = meta2.targetSize
                                    local part2 = builtPart[metaIdx2]

                                    -- ── Missing brick recovery ────────────────────────
                                    if not part2 or not part2.Parent then
                                        missCount = missCount + 1
                                        LOG("Load", string.format(
                                            "  ShpFix pass %d: brick %d/%d MISSING — attempting face-attach recovery.",
                                            passNum, metaIdx2, N))
                                        btn.Text = string.format(
                                            "ShpFix%d \226\128\148 miss %d/%d", passNum, metaIdx2, N)
                                        local recovered = rebuildMissingBrick(
                                            metaIdx2, meta2,
                                            string.format("ShpFix%d", passNum))
                                        if recovered then
                                            anyFixed = true
                                            fixCount = fixCount + 1
                                        end
                                        break
                                    end

                                    -- ── Size mismatch correction ──────────────────────
                                    local sz2 = part2.Size
                                    if math.abs(sz2.X - tSz2.X) > EPS_FIX
                                    or math.abs(sz2.Y - tSz2.Y) > EPS_FIX
                                    or math.abs(sz2.Z - tSz2.Z) > EPS_FIX then
                                        anyFixed = true
                                        fixCount = fixCount + 1
                                        LOG("Load", string.format(
                                            "  ShpFix pass %d brick %d/%d: sz=(%.2f,%.2f,%.2f) target=(%.0f,%.0f,%.0f) delta=(%.2f,%.2f,%.2f)",
                                            passNum, metaIdx2, N,
                                            sz2.X, sz2.Y, sz2.Z,
                                            tSz2.X, tSz2.Y, tSz2.Z,
                                            tSz2.X - sz2.X,
                                            tSz2.Y - sz2.Y,
                                            tSz2.Z - sz2.Z))
                                        btn.Text = string.format(
                                            "ShpFix%d \226\128\148 %d/%d", passNum, metaIdx2, N)
                                        -- Teleport to the brick before re-shaping so the
                                        -- Shape remote's range check passes for large builds.
                                        local hrpF = lp.Character
                                            and lp.Character:FindFirstChild("HumanoidRootPart")
                                        if hrpF then
                                            hrpF.CFrame   = CFrame.new(part2.Position
                                                + Vector3.new(0, 6, 0))
                                            task.wait(BUILD_SETTLE)
                                        end
                                        applyShapeOps(part2, meta2, true)
                                        task.wait(0.05)
                                    end
                                    until true
                                end
                                if fixCount > 0 or missCount > 0 then
                                    LOG("Load", string.format(
                                        "  ShpFix pass %d: fixed %d brick(s), recovered %d missing.",
                                        passNum, fixCount, missCount))
                                end
                                if not anyFixed then
                                    LOG("Load", string.format(
                                        "  ShpFix converged after %d pass(es).", passNum))
                                    break
                                end
                                task.wait(0.12)
                            end
                        end

                        rebuildConn:Disconnect()

                        if missingShape > 0 then
                            LOG("Load", string.format("Phase 2/3: DONE with %d FAILED brick(s). See dumps above.", missingShape))
                            notify("Sigma", string.format(
                                "Shape phase: %d brick(s) failed to place.", missingShape))
                        else
                            LOG("Load", string.format("Phase 2/3: OK! All %d shaped bricks placed.", N))
                        end
                    end -- if myF
                end -- if buildEv
                if S.buildStopped then
                    for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
                    btn.Text="Stopped."; return
                end
            end

            -- ── Phase 3: Detailed 1×1×1 blocks ──────────────────────────────────────
            -- Comes AFTER shaped so the hasBlockAt probe isn't confused by
            -- the 4×4×4 placeholders that get placed (and then resized) in Phase 2.
            -- Uses buildPos = rawCenter (no 4-stud snap) and a 0.8×0.8×0.8 probe.
            if #detailedMeta > 0 then
                LOG("Load", string.format("Phase 3/3 | Building %d detailed (1x1x1) bricks... [mode=%s]",
                    #detailedMeta, S.buildMode == "BFS" and "BFS" or "Cluster"))
                if S.buildMode == "BFS" then
                    btn.Text = string.format("Phase 3/3 \226\128\148 %d detailed (BFS)...", #detailedMeta)
                    local detPositions = {}
                    for _, meta in ipairs(detailedMeta) do detPositions[#detPositions+1] = meta.buildPos end
                    local seederPosDet = S.seeder and S.seeder.Parent and S.seeder.Position
                    local detPlan = planInfBFS(detPositions, seederPosDet, 1)
                    local scD = 0; for _ in pairs(detPlan.scaffoldKeys) do scD=scD+1 end
                    if scD > 0 then notify("Sigma", string.format("Load: %d scaffold bridge(s) for detailed phase.", scD)) end
                    buildInfBFS(detPlan, "detailed", btn, nil, loadScaffold)
                else
                    -- Cluster mode
                    btn.Text = string.format("Phase 3/3 \226\128\148 %d detailed (Cluster)...", #detailedMeta)
                    clusterBlitz(detailedMeta, "detailed", "Det")
                end
                if S.buildStopped then
                    for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
                    btn.Text="Stopped."; return
                end
            end

            if #detailedMeta > 0 and not S.buildStopped then
                local myFD = getMyBrickFolder()
                if myFD then
                    local detPositions = {}
                    for _, meta in ipairs(detailedMeta) do detPositions[#detPositions+1] = meta.buildPos end

                    local builtKeys0d = {}
                    for _, p in ipairs(myFD:GetChildren()) do
                        if p:IsA("BasePart") then builtKeys0d[posKey(p.Position)] = true end
                    end
                    local firstMissDet = 0
                    for _, meta in ipairs(detailedMeta) do
                        if not builtKeys0d[posKey(meta.buildPos)] then firstMissDet = firstMissDet + 1 end
                    end

                    if firstMissDet > 0 then
                        LOG("Load", string.format("Phase 3 fix: %d/%d detailed bricks missed — running passFixBuild...", firstMissDet, #detailedMeta))
                        local fixEvD = getToolRemote("Build")
                        passFixBuild(detPositions, "detailed", fixEvD, btn, 5)

                        local builtKeys1d = {}
                        for _, p in ipairs(myFD:GetChildren()) do
                            if p:IsA("BasePart") then builtKeys1d[posKey(p.Position)] = true end
                        end
                        local stillMissedDet = {}
                        for _, meta in ipairs(detailedMeta) do
                            if not builtKeys1d[posKey(meta.buildPos)] then
                                stillMissedDet[#stillMissedDet+1] = meta
                            end
                        end
                        if #stillMissedDet > 0 then
                            LOG("Load", string.format("Phase 3 PERSISTENT MISS: %d detailed brick(s) still absent:", #stillMissedDet))
                            for _, meta in ipairs(stillMissedDet) do
                                LOG("Load", string.format(
                                    "  MISS buildPos=(%.2f,%.2f,%.2f) mat=%s",
                                    meta.buildPos.X, meta.buildPos.Y, meta.buildPos.Z,
                                    tostring(meta.mat)))
                            end
                        else
                            LOG("Load", "Phase 3/3: OK! All detailed bricks placed after fix passes.")
                        end
                    else
                        LOG("Load", "Phase 3/3: OK! (no missed detailed bricks)")
                    end
                end
            end
            if S.buildStopped then
                for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
                btn.Text="Stopped."; return
            end

            -- ── Phase 4: Paint + spray pass (all blocks) ─────────────
            btn.Text = "Painting..."
            local paintEv = getToolRemoteCached("Paint")
            local hrp     = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

            -- Re-resolve myF; if no blocks existed at load start, it was nil.
            local myF = nil
            local fDL = tick() + 2
            repeat
                myF = getMyBrickFolder()
                if not myF then task.wait(0.1) end
            until myF or tick() > fDL

            -- ── buildPartLookup was removed: all paint passes now iterate
            -- myF:GetChildren() directly (part-first) and resolve meta via
            -- metaByPos. The old meta-first + LUT approach missed shaped
            -- bricks because part.Position == rawCenter after shaping, not
            -- buildPos. Part-first + dual-keyed metaByPos covers all three
            -- brick categories (normal, shaped, detailed) correctly.
            --
            -- SCOPE NOTE: metaByPos is declared HERE, outside the paintEv guard,
            -- so that Paint Fix, Spray Fix, and Phase 5 (Property Phase) can all
            -- reference it regardless of which branch the paintEv guard took.
            -- Build a dual-key meta lookup: keyed by BOTH buildPos AND rawCenter.
            -- Normal/detailed bricks: part.Position == buildPos after placement.
            -- Shaped bricks: part.Position == rawCenter after applyShapeOps moves them.
            local metaByPos = {}
            for _, meta in ipairs(allMeta) do
                metaByPos[posKey(meta.buildPos)]  = meta
                metaByPos[posKey(meta.rawCenter)] = meta
            end

            if not paintEv then
                notify("Sigma","Paint tool not found \226\128\148 skipping paint.")
            elseif not hrp then
                notify("Sigma","No character \226\128\148 skipping paint.")
            elseif not myF then
                notify("Sigma","Brick folder not found \226\128\148 skipping paint.")
            else
                -- Settle: wait for the server to finish replicating the last
                -- shaped/detailed bricks before taking the first snapshot.
                -- BUILD_VERIFY_WAIT * 2 (0.36s) was too short for large builds
                -- where the shaped pass teleports many times and the final bricks
                -- replicate late. We now wait until myF's child count stabilises
                -- for two consecutive 0.3s windows, capped at 4 seconds total.
                do
                    local prevCount = -1
                    local stableFor = 0
                    local deadline  = tick() + 4
                    repeat
                        task.wait(0.3)
                        local f2 = getMyBrickFolder()
                        local cnt = f2 and #f2:GetChildren() or 0
                        if cnt == prevCount then
                            stableFor = stableFor + 1
                        else
                            stableFor = 0
                        end
                        prevCount = cnt
                    until stableFor >= 2 or tick() > deadline
                end

                -- Main paint pass: iterate parts in myF, resolve meta by
                -- part.Position. This is the correct direction:
                --   ??? Normal bricks: part.Position == buildPos (snapped) ???
                --   ??? Shaped bricks: part.Position == rawCenter (after applyShapeOps) ???
                --   ??? Detailed bricks: part.Position == rawCenter (1-stud, no snap) ???
                -- metaByPos is dual-keyed (buildPos AND rawCenter) so all three
                -- categories resolve correctly.
                local function paintAllParts(targetMyF)
                    local parts = targetMyF and targetMyF:GetChildren() or {}
                    for _, part in ipairs(parts) do
                        repeat
                        if S.buildStopped then break end
                        if not part:IsA("BasePart") then break end
                        local meta = metaByPos[posKey(part.Position)]
                        if not meta then break end

                        hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                        if not hrp then break end

                        for _, side in ipairs(ALL_SIDES_E) do
                            paintEv:FireServer(part, side, hrp.Position,
                                HANDSHAKE, meta.color, meta.mat, "")
                            task.wait(0.02)
                        end

                        if meta.sp then
                            for _, spray in ipairs(meta.sp) do
                                local faceEnum = Enum.NormalId[spray[1]]
                                local hexStr   = spray[2] or "FFFFFF"
                                local text     = spray[3] or ""
                                if faceEnum and text ~= "" then
                                    local styled = string.format(
                                        '<font color="#%s">%s</font>', hexStr, text)
                                    paintEv:FireServer(part, faceEnum, hrp.Position,
                                        HANDSHAKE, Color3.new(1,1,1), "spray", styled)
                                    task.wait(0.03)
                                end
                            end
                        end
                        until true
                    end
                end

                paintAllParts(getMyBrickFolder())
            end

            -- \u2500\u2500 Phase 4 Fix Pass: stubborn repaint until zero colour mismatches \u2500\u2500
            -- Uses the same while-true convergence pattern as blitzBuildChaos:
            -- keeps re-scanning and re-firing until every part's colour matches
            -- meta, or buildStopped. Each wave narrows to only the parts that
            -- still have drift, so the loop terminates the moment everything
            -- is correct. Single-wave best case: all bricks painted first try.
            if paintEv and not S.buildStopped then
                btn.Text = "Paint Fix..."
                local function getPaintMismatches(partList)
                    local mismatches = {}
                    for _, part in ipairs(partList) do
                        repeat
                        if S.buildStopped then break end
                        if not part:IsA("BasePart") then break end
                        local meta = metaByPos[posKey(part.Position)]
                        if not meta then break end
                        local pc = part.Color; local mc = meta.color
                        local drift = math.abs(pc.R-mc.R)+math.abs(pc.G-mc.G)+math.abs(pc.B-mc.B)
                        if drift > 0.015 then
                            mismatches[#mismatches+1] = {part=part, meta=meta}
                        end
                        until true
                    end
                    return mismatches
                end

                local allParts = (getMyBrickFolder() and getMyBrickFolder():GetChildren()) or {}
                local pending  = getPaintMismatches(allParts)
                local totalFixed = 0

                while #pending > 0 and not S.buildStopped do
                    btn.Text = string.format("Paint Fix... %d left", #pending)
                    for _, entry in ipairs(pending) do
                        if S.buildStopped then break end
                        hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                        if not hrp then break end
                        for _, side in ipairs(ALL_SIDES_E) do
                            paintEv:FireServer(entry.part, side, hrp.Position,
                                HANDSHAKE, entry.meta.color, entry.meta.mat, "")
                            task.wait(0.02)
                        end
                        totalFixed = totalFixed + 1
                    end
                    -- Give server time to apply before re-scanning for remaining drift
                    task.wait(BUILD_VERIFY_WAIT)
                    if S.buildStopped then break end
                    -- Re-scan ONLY the parts that were in last wave's mismatch list
                    local nextPending = {}
                    for _, entry in ipairs(pending) do
                        if entry.part and entry.part.Parent then
                            local pc = entry.part.Color; local mc = entry.meta.color
                            local drift = math.abs(pc.R-mc.R)+math.abs(pc.G-mc.G)+math.abs(pc.B-mc.B)
                            if drift > 0.015 then nextPending[#nextPending+1] = entry end
                        end
                    end
                    pending = nextPending
                end

                if totalFixed > 0 then
                    btn.Text = string.format("Paint Fix \226\128\148 %d fixed", totalFixed)
                    task.wait(0.4)
                end
            end

            -- \u2500\u2500 Spray Fix Pass: re-apply any missing/mismatched spray/decals \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
            -- Iterates parts in myF (part-first direction, same as main paint pass).
            -- Only fires for parts whose meta has sp data. No read-back API exists
            -- for decal text, so we re-apply spray for any part with sp meta.
            if paintEv and not S.buildStopped then
                local anySpray = false
                for _, meta in ipairs(allMeta) do
                    if meta.sp and #meta.sp > 0 then anySpray = true; break end
                end

                if anySpray then
                    local sprayCount = 0
                    btn.Text = "Spray Fix..."
                    local sprayMyF   = getMyBrickFolder()
                    local sprayParts = sprayMyF and sprayMyF:GetChildren() or {}
                    for _, part in ipairs(sprayParts) do
                        repeat
                        if S.buildStopped then break end
                        if not part:IsA("BasePart") then break end
                        local meta = metaByPos[posKey(part.Position)]
                        if not meta or not meta.sp or #meta.sp == 0 then break end

                        hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                        if not hrp then break end

                        for _, spray in ipairs(meta.sp) do
                            local faceEnum = Enum.NormalId[spray[1]]
                            local hexStr   = spray[2] or "FFFFFF"
                            local text     = spray[3] or ""
                            if faceEnum and text ~= "" then
                                local styled = string.format(
                                    '<font color="#%s">%s</font>', hexStr, text)
                                paintEv:FireServer(part, faceEnum, hrp.Position,
                                    HANDSHAKE, Color3.new(1,1,1), "spray", styled)
                                task.wait(0.03)
                                sprayCount = sprayCount + 1
                            end
                        end
                        until true
                    end
                    if sprayCount > 0 then
                        btn.Text = string.format("Spray Fix \226\128\148 %d decal(s)", sprayCount)
                        task.wait(0.4)
                    end
                end
            end

            -- \u2550\u2550 Phase 5: Property Phase (CanCollide + Anchored) \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550
            -- Fires after the full paint pipeline is done.
            -- The server defaults every freshly built brick to:
            --   Anchored   = true
            --   CanCollide = true
            -- We only act when the SAVED value is false (i.e. the player had toggled
            -- that property off before saving). The "anchor" and "collide" Paint-remote
            -- modes are TOGGLES \u2014 firing when the brick is already correct flips it back.
            -- So we always read the brick's CURRENT local property before firing.
            --
            -- Stubborn convergence: same while-true pattern as blitzBuildChaos.
            -- Each wave narrows to only parts still in the wrong state; the loop
            -- exits as soon as everything is confirmed correct, or buildStopped.
            if paintEv and not S.buildStopped then

                -- Quick skip: if no brick in the save has cc=false or a=false,
                -- there is nothing to do \u2014 skip the phase entirely.
                local hasPropWork = false
                for _, meta in ipairs(allMeta) do
                    if meta.cc == false or meta.a == false then
                        hasPropWork = true; break
                    end
                end

                if hasPropWork then
                    btn.Text = "Properties..."
                    LOG("Load", "Phase 5: Property Phase \u{2014} applying CanCollide / Anchored toggles.")

                    local function getPropMismatches(partList)
                        local mismatches = {}
                        for _, part in ipairs(partList) do
                            repeat
                            if S.buildStopped then break end
                            if not part:IsA("BasePart") then break end
                            local meta = metaByPos[posKey(part.Position)]
                            if not meta then break end
                            local needCC = (meta.cc == false and part.CanCollide == true)
                            local needA  = (meta.a  == false and part.Anchored   == true)
                            if needCC or needA then
                                mismatches[#mismatches+1] = {part=part, meta=meta}
                            end
                            until true
                        end
                        return mismatches
                    end

                    local propParts  = (getMyBrickFolder() and getMyBrickFolder():GetChildren()) or {}
                    local pending    = getPropMismatches(propParts)
                    local totalProps = 0

                    while #pending > 0 and not S.buildStopped do
                        btn.Text = string.format("Properties... %d left", #pending)
                        for _, entry in ipairs(pending) do
                            if S.buildStopped then break end
                            hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                            if not hrp then break end

                            -- CanCollide toggle: only fire when still wrong
                            if entry.meta.cc == false and entry.part.CanCollide == true then
                                pcall(function()
                                    paintEv:FireServer(
                                        entry.part, Enum.NormalId.Top, hrp.Position,
                                        HANDSHAKE, Color3.new(1,1,1), "collide", "")
                                end)
                                task.wait(0.06)
                                totalProps = totalProps + 1
                            end

                            -- Anchored toggle: only fire when still wrong
                            if entry.meta.a == false and entry.part.Anchored == true then
                                pcall(function()
                                    paintEv:FireServer(
                                        entry.part, Enum.NormalId.Top, hrp.Position,
                                        HANDSHAKE, Color3.new(1,1,1), "anchor", "")
                                end)
                                task.wait(0.06)
                                totalProps = totalProps + 1
                            end
                        end

                        -- Give server time to apply toggles before re-scanning
                        task.wait(BUILD_VERIFY_WAIT)
                        if S.buildStopped then break end

                        -- Re-scan only last wave's pending parts
                        local nextPending = {}
                        for _, entry in ipairs(pending) do
                            if entry.part and entry.part.Parent then
                                local needCC = (entry.meta.cc == false and entry.part.CanCollide == true)
                                local needA  = (entry.meta.a  == false and entry.part.Anchored   == true)
                                if needCC or needA then nextPending[#nextPending+1] = entry end
                            end
                        end
                        pending = nextPending
                    end

                    LOG("Load", string.format(
                        "Phase 5 done: %d property toggle(s) applied (CanCollide/Anchored).", totalProps))
                    if totalProps > 0 then
                        btn.Text = string.format("Properties \226\128\148 %d applied", totalProps)
                        task.wait(0.3)
                    end
                end
            end

            -- ── Final summary ─────────────────────────────────────────
            -- Count any still-missing normal bricks (survived both passes)
            local finalMissNorm = 0
            do
                local myFF = getMyBrickFolder()
                if myFF then
                    local builtKeys = {}
                    for _, p in ipairs(myFF:GetChildren()) do
                        if p:IsA("BasePart") then builtKeys[posKey(p.Position)] = true end
                    end
                    for _, meta in ipairs(normalMeta) do
                        if not builtKeys[posKey(meta.buildPos)] then
                            finalMissNorm = finalMissNorm + 1
                        end
                    end
                end
            end
            local finalMissShp = 0
            for _, meta in ipairs(shapedMeta) do
                if meta.failed then finalMissShp = finalMissShp + 1 end
            end

            -- ── Delete Pass: remove scaffold bricks added by BFS bridging ─────────
            -- Scaffold bricks are normal 4x4x4 bricks placed between disconnected
            -- components (e.g. gaps between shaped clusters, letter spacing in text).
            -- They were built via inf-range and are deleted the same way — no teleport.
            if #loadScaffold > 0 and not S.buildStopped then
                btn.Text = string.format("Del scaffold (%d)...", #loadScaffold)
                deleteScaffold(loadScaffold)
            end

            for _,p in ipairs(previewParts) do pcall(function() p:Destroy() end) end
            local placed = total - finalMissNorm - finalMissShp
            local summaryMsg
            if finalMissNorm == 0 and finalMissShp == 0 then
                summaryMsg = string.format("Load complete! %d/%d blocks \226\156\147", placed, total)
                LOG("Load", string.format("=== DONE: %d/%d placed. All OK! ===", placed, total))
            else
                summaryMsg = string.format(
                    "Load done \226\128\148 %d/%d | Norm miss: %d | Shape miss: %d",
                    placed, total, finalMissNorm, finalMissShp)
                LOG("Load", string.format("=== DONE: %d/%d placed | norm_miss=%d | shape_miss=%d ===",
                    placed, total, finalMissNorm, finalMissShp))
            end
            notify("Sigma", summaryMsg)

            -- ── Restore player position after all build TPs ───────────
            -- Only fires if the character is still alive and HRP exists.
            -- Skipped silently if the player respawned during the build
            -- (different HRP instance — restoring a stale CFrame could
            -- place them underground or inside geometry).
            if _preBuildCF then
                local _rChar = lp.Character
                local _rHrp  = _rChar and _rChar:FindFirstChild("HumanoidRootPart")
                if _rHrp then
                    _rHrp.CFrame = _preBuildCF
                    task.wait(BUILD_SETTLE)
                end
            end

            btn.Text = "Load Build"
        end)
    end)

    -- Register the Load Build Live Preview refresh callback.
    -- v4.7.4 fix: now shows per-brick SelectionBox outlines (makeLoadPreview) instead
    -- of a single bounding-box ghost (makePreviewBox). Falls back to bounding box only
    -- when the save contains more than 500 bricks to keep the client responsive.
    _loadPreviewRefresh = function()
        if not S.livePreview then return end
        if S.saveName == "" or S.saveName == "(no saves)" then return end
        local path = "SigmaPanel_Builds/"..S.saveName..".json"
        if typeof(isfile) ~= "function" or not isfile(path) then return end
        if typeof(readfile) ~= "function" then return end
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
        if not ok or not data or type(data) ~= "table" or #data == 0 then return end

        -- Determine preview origin (seeder or player HRP)
        local char = lp.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local seederPos  = S.seeder and S.seeder.Parent and S.seeder.Position
        local baseOrigin = seederPos and snapToGrid(seederPos + Vector3.new(0, GRID_MULT, 0))
                                     or snapToGrid(hrp.Position)
        baseOrigin = baseOrigin + S._previewOffset

        -- Parse all brick metas and track the save's bottom-left-front corner (minP)
        local minP    = Vector3.new(math.huge, math.huge, math.huge)
        local allMeta = {}
        for _, v in ipairs(data) do
            local px = v.p and v.p[1]; local py = v.p and v.p[2]; local pz = v.p and v.p[3]
            if px then
                local sz = v.s or {4,4,4}
                local cx = px + sz[1]/2 - 0.5
                local cy = py + sz[2]/2 - 0.5
                local cz = pz + sz[3]/2 - 0.5
                minP = Vector3.new(math.min(minP.X,cx), math.min(minP.Y,cy), math.min(minP.Z,cz))
                allMeta[#allMeta+1] = {
                    rawCenter  = Vector3.new(cx, cy, cz),
                    targetSize = Vector3.new(sz[1], sz[2], sz[3]),
                    brickType  = (sz[1] == 1) and "detailed" or "normal",
                }
            end
        end
        if #allMeta == 0 then return end

        -- Shift every meta so the save's minP aligns to baseOrigin
        local offset = baseOrigin - minP
        local sumX, sumY, sumZ = 0, 0, 0
        for _, m in ipairs(allMeta) do
            m.rawCenter = m.rawCenter + offset
            sumX = sumX + m.rawCenter.X
            sumY = sumY + m.rawCenter.Y
            sumZ = sumZ + m.rawCenter.Z
        end
        local n      = #allMeta
        local centre = Vector3.new(sumX/n, sumY/n, sumZ/n)

        -- Per-brick preview for ≤500 bricks; bounding-box fallback for larger saves
        local parts
        if n <= 500 then
            parts = makeLoadPreview(allMeta)
        else
            local maxP = Vector3.new(-math.huge,-math.huge,-math.huge)
            for _, m in ipairs(allMeta) do
                maxP = Vector3.new(math.max(maxP.X,m.rawCenter.X),math.max(maxP.Y,m.rawCenter.Y),math.max(maxP.Z,m.rawCenter.Z))
            end
            local spanX = maxP.X - minP.X + GRID_MULT
            local spanY = maxP.Y - minP.Y + GRID_MULT
            local spanZ = maxP.Z - minP.Z + GRID_MULT
            parts = makePreviewBox(baseOrigin, math.ceil(spanX/GRID_MULT), math.ceil(spanY/GRID_MULT), math.ceil(spanZ/GRID_MULT), GRID_MULT)
        end
        _spawnLivePreview(parts, centre)
    end

    makeButton(g,"Delete Save",function(btn)
        if S.saveName == "" or S.saveName == "(no saves)" then return end
        local path = "SigmaPanel_Builds/"..S.saveName..".json"
        pcall(function()
            if typeof(isfile)=="function" and isfile(path) and typeof(delfile)=="function" then
                delfile(path)
            end
        end)
        S.saveName = ""; local svList = listSaves(); savesSetter(svList, svList[1]); btn.Text = "Deleted!"
    end)
end


