lp.CharacterAdded:Connect(function(char)
    -- N8-PICKUP: re-collect tools dropped via "Drop Tools on Death"
    if S.autoDrop and S._dropDeathPos then
        local dropPos = S._dropDeathPos
        S._dropDeathPos = nil
        task.spawn(function()
            local hrpR2 = char:WaitForChild("HumanoidRootPart", 3)
            if not hrpR2 then return end
            -- Wait a moment for tools to settle in Workspace
            task.wait(0.6)
            local picked = 0
            for _, obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Tool") and obj:HasTag("SigmaDropped") then
                    local dist = (obj.Handle and obj.Handle.Position or obj:GetPivot().Position
                                 or dropPos) -- fallback if no Handle
                    pcall(function() dist = obj:GetPivot().Position end)
                    if (dist - dropPos).Magnitude < 60 then
                        pcall(function()
                            obj:RemoveTag("SigmaDropped")
                            obj.Parent = lp.Backpack
                            picked = picked + 1
                        end)
                    end
                end
            end
            if picked > 0 then
                notify("Drop Tools","Reclaimed "..picked.." tool(s) after death!")
            end
        end)
    end

    -- N7 FAST: TP to death position immediately on spawn
    if S.tpDeathPos and S._deathPos then
        local dest=S._deathPos
        S._deathPos=nil       -- clear immediately to prevent re-entrant double-TP
        task.spawn(function()
            local hrpImm=char:WaitForChild("HumanoidRootPart",3)
            if not hrpImm or not hrpImm.Parent then return end
            -- Anti-NaN: check if the spawn itself is void/NaN before TPing to death pos
            -- (death pos would also be in the void during a NaN maptide loop)
            if S.antiNan then
                task.wait(0.4)
                local sp=hrpImm.Position
                local isNaN=(sp.X~=sp.X)or(sp.Y~=sp.Y)or(sp.Z~=sp.Z)
                if isNaN or sp.Y<-800 then
                    hrpImm.CFrame=CFrame.new(0,50,0)
                    notify("Anti-NaN","Maptide NaN \226\128\148 TP\226\128\153d to map center!")
                    return  -- skip TP-to-death (death pos is also void)
                end
            end
            hrpImm.CFrame=CFrame.new(dest+Vector3.new(0,2,0))
            notify("TP Death","Spawned at your death position!")
        end)
    elseif S.antiNan then
        -- Anti-NaN standalone: TP-to-Death is off, but still protect against void spawns
        task.spawn(function()
            local hrpN=char:WaitForChild("HumanoidRootPart",3)
            if not hrpN then return end
            task.wait(0.4)
            local sp=hrpN.Position
            local isNaN=(sp.X~=sp.X)or(sp.Y~=sp.Y)or(sp.Z~=sp.Z)
            if isNaN or sp.Y<-800 then
                hrpN.CFrame=CFrame.new(0,50,0)
                notify("Anti-NaN","Maptide NaN \226\128\148 TP\226\128\153d to map center!")
            end
        end)
    end
    if S.autoFixCam then task.wait(0.5); fixPlayerState() end
    _atmosphere=Lighting:FindFirstChildOfClass("Atmosphere")

    if S.antiToxic then
        for _,p in pairs(Players:GetPlayers()) do
            if p~=lp and p.Character then
                for _,part in pairs(p.Character:GetDescendants()) do
                    if part:IsA("BasePart") then pcall(function() part.CanTouch=false; part.CanQuery=false end) end
                end
            end
        end
    end

    char.ChildAdded:Connect(function(inst)
        if inst.Name=="Hielo" and S.antiFreeze then
            inst:Destroy()
            local hum=char:FindFirstChildOfClass("Humanoid"); if hum then hum.Health=0 end
        elseif inst.Name=="Jail" and S.antiJail then
            task.wait(0.1); removeCollision(inst)
        end
    end)
    
    task.spawn(function()
        while char and char.Parent do
            repeat
            task.wait(0.5)
            if not S.antiFreeze then break end
            local hrp=char:FindFirstChild("HumanoidRootPart")
            local torso=char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
            local hum=char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health>0 then
                if (hrp and hrp.Anchored) or (torso and torso.Transparency>=0.9) then
                    -- Try health=0 first
                    hum.Health = 0
                    task.wait(0.1)
                    -- If still alive (some games prevent death), force respawn via LoadCharacter
                    if hum and hum.Parent and hum.Health > 0 then
                        pcall(function() lp:LoadCharacter() end)
                    end
                    if S.antiNotify then notify("Anti-Freeze","Freeze detected \226\128\148 forcing respawn.") end
                end
            end
            until true
        end
    end)

    task.wait(0.2)
    local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return end

    -- N8: Reclaim tools from deposit platform on respawn (Safe B-Kit Preserve)
    if S.safeBkitOn and S.depositBuilt and S.depositPos then
        task.spawn(function()
            task.wait(0.5)  -- wait for char to stabilise
            local hrpR = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not hrpR then return end
            -- TP to deposit to stand next to the dropped tools
            hrpR.CFrame = CFrame.new(S.depositPos + Vector3.new(0, 10, 0))
            task.wait(0.4)
            -- Pull all SafeDropped tools near the deposit into Backpack directly.
            -- Never use EquipTool here — it unequips the previous tool each call.
            local picked = 0
            for _, obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Tool") and obj:HasTag("SafeDropped") then
                    local d = (obj.Position - S.depositPos).Magnitude
                    if d < 60 then
                        pcall(function()
                            obj:RemoveTag("SafeDropped")
                            obj.Parent = lp.Backpack
                            picked = picked + 1
                        end)
                    end
                end
            end
            -- TP back to where the player died
            hrpR = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrpR and S._depositBackPos then
                hrpR.CFrame = CFrame.new(S._depositBackPos)
                S._depositBackPos = nil
            end
            if picked > 0 then notify("After-Life","Reclaimed "..picked.." tool(s) from deposit!") end
        end)
    end

    -- N7: Fast TP to death position is now done at top of CharacterAdded (instant)

    -- Wire death position save + tool drop for THIS character
    hum.Died:Connect(function()
        local hrpD = char:FindFirstChild("HumanoidRootPart")
        local deathPosNow = hrpD and hrpD.Position

        -- N7: save death position
        if S.tpDeathPos and deathPosNow then
            S._deathPos = deathPosNow
        end

        -- N8: Drop Tools on Death — drops entire inventory to Workspace.
        -- Temporarily skipped if Auto-R15 fires first (S._autoR15Active guard).
        if S.autoDrop and not S.safeBkitOn and not S._autoR15Active then
            local deathDropPos = deathPosNow
            task.wait(0.05)
            -- Move all backpack tools to character first (equip), then to world
            for _, t in ipairs(lp.Backpack:GetChildren()) do
                if t:IsA("Tool") then
                    pcall(function()
                        t:AddTag("SigmaDropped")
                        t.Parent = char
                    end)
                end
            end
            task.wait(0.05)
            for _, t in ipairs(char:GetChildren()) do
                if t:IsA("Tool") then
                    pcall(function()
                        t:AddTag("SigmaDropped")
                        t.Parent = Workspace
                    end)
                end
            end
            -- Store drop position so respawn handler can pick them up
            S._dropDeathPos = deathDropPos
        end

        -- N9: Safe B-Kit Preserve removed in v4.6.8 (replaced by Drop Tools on Death).
        -- safeBkitOn is kept as false; this block is a no-op stub for safety.
        -- (Enlighten Deposit still uses depositPos/depositBuilt independently.)
    end)
    if S.wsEnabled then hum.WalkSpeed=S.wsInfinite and math.huge or S.wsValue end
    if S.jpEnabled then hum.UseJumpPower=true; hum.JumpPower=S.jpInfinite and math.huge or S.jpValue end
    if S.godMode then
        for _,c in pairs(S.godConns) do if c then c:Disconnect() end end; S.godConns={}
        hum.MaxHealth=math.huge; hum.Health=math.huge
        S.godConns[#S.godConns+1]=RunService.Heartbeat:Connect(function()
            if not S.godMode or shared.GodModePaused then return end
            if hum and hum.Parent then hum.MaxHealth=math.huge; hum.Health=math.huge end
        end)
    end
    for _,p in pairs(Players:GetPlayers()) do
        repeat
        if p~=lp and (S.espNames or S.espDist) then
            local c2=p.Character; if not c2 then break end
            local head=c2:FindFirstChild("Head"); if not head then break end
