-- ── CLONE TOOL MODE (v4.7.0) ─────────────────────────────────────────────
-- Box-select from cfolder, drag-handle offset, fires Build remote per block.
-- Registered as a new mode in the Construction Tool virtual dispatch system.
-- v4.7.0.5: Added full SCA (zone part + handles + click-to-place + drag resize)
--           matching Construct / Brush / Demolish / Save exactly.
do
    -- ── SCA zone state (mirrors ct/br/dm/sv pattern) ─────────────────────
    local cloneZone = {
        placed=false, origin=Vector3.new(0,0,0), sX=1, sY=1, sZ=1,
        dragging=false, dragKey=nil,
        dragStartMouse=Vector3.zero, dragStartOrigin=Vector3.zero,
        dragStartSX=1, dragStartSY=1, dragStartSZ=1,
    }

    -- Zone visual (yellow to match Clone accent)
    local cloneZonePart=Instance.new("Part")
    cloneZonePart.Name="SigmaCloneZone"; cloneZonePart.Anchored=true; cloneZonePart.CanCollide=false
    cloneZonePart.Transparency=1; cloneZonePart.CastShadow=false
    cloneZonePart.Size=Vector3.new(CT_GRID,CT_GRID,CT_GRID); cloneZonePart.Parent=Workspace

    local cloneSelBox=Instance.new("SelectionBox")
    cloneSelBox.Color3=Color3.fromRGB(255,200,0); cloneSelBox.SurfaceColor3=Color3.fromRGB(255,200,0)
    cloneSelBox.SurfaceTransparency=0.88; cloneSelBox.LineThickness=0.09
    cloneSelBox.Adornee=nil; cloneSelBox.Parent=ScreenGui

    local cloneZoneHandles={}
    for key in pairs(CT_FACES) do
        local h=Instance.new("Part"); h.Name="CLH_"..key
        h.Size=Vector3.new(1.5,1.5,1.5); h.Material=Enum.Material.Neon
        h.Color=Color3.fromRGB(255,200,0); h.Anchored=true; h.CanCollide=false
        h.CastShadow=false; h.Transparency=1; h.Parent=Workspace
        local hl=Instance.new("Highlight")
        hl.Name="CLH_HL"; hl.FillColor=Color3.fromRGB(255,200,0); hl.FillTransparency=0.3
        hl.OutlineColor=Color3.fromRGB(255,255,255); hl.OutlineTransparency=0
        hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Enabled=false; hl.Parent=h
        cloneZoneHandles[key]=h
    end

    local function cloneSyncZone()
        if not cloneZone.placed then
            cloneSelBox.Adornee=nil
            for _,h in pairs(cloneZoneHandles) do h.Transparency=1; local hl=h:FindFirstChild("CLH_HL"); if hl then hl.Enabled=false end end
            return
        end
        local sX,sY,sZ=cloneZone.sX*CT_GRID,cloneZone.sY*CT_GRID,cloneZone.sZ*CT_GRID
