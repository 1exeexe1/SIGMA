local function dmHandleDrag()
    if not dm.dragging or not dm.dragKey then return end
    if _scaActiveTouchId and #UserInputService:GetTouchState() > 1 then return end
    local hp = getMouseWorldHit(_dmMouse, dm.dragStartMouse)
    if hp.Magnitude > 20000 then return end
    local info=CT_FACES[dm.dragKey]; local ax,dir=info.ax,info.dir
    local axV=ax=="X" and Vector3.new(1,0,0) or (ax=="Y" and Vector3.new(0,1,0) or Vector3.new(0,0,1))
    local rawD=(hp-dm.dragStartMouse):Dot(axV)
    local blkD=math.clamp(math.floor(rawD/CT_GRID+0.5),-200,200)
    if dir>0 then
        local sS=ax=="X" and dm.dragStartSX or (ax=="Y" and dm.dragStartSY or dm.dragStartSZ)
        local nS=math.max(1,sS+blkD)
        if ax=="X" then dm.sX=nS elseif ax=="Y" then dm.sY=nS else dm.sZ=nS end
    else
        local sS=ax=="X" and dm.dragStartSX or (ax=="Y" and dm.dragStartSY or dm.dragStartSZ)
        local nS=math.max(1,sS-blkD); local sh=(sS-nS)*CT_GRID
        if ax=="X" then dm.sX=nS; dm.origin=Vector3.new(dm.dragStartOrigin.X+sh,dm.origin.Y,dm.origin.Z)
        elseif ax=="Y" then dm.sY=nS; dm.origin=Vector3.new(dm.origin.X,dm.dragStartOrigin.Y+sh,dm.origin.Z)
        else dm.sZ=nS; dm.origin=Vector3.new(dm.origin.X,dm.origin.Y,dm.dragStartOrigin.Z+sh) end
    end
    dmSyncZone(); dmSizeLblUpdate()
end

_ctoolVirtualEquip["Demolish"] = function()
    dm.equipped=true; dmMenu.Visible=true
    if _dmClickConn then _dmClickConn:Disconnect() end
    if _dmUpConn then _dmUpConn:Disconnect() end
    if _dmDragConn then _dmDragConn:Disconnect() end
    _dmClickConn=_dmMouse.Button1Down:Connect(dmHandleClick)
    _dmUpConn=_dmMouse.Button1Up:Connect(function() dm.dragging=false; dm.dragKey=nil end)
    _dmDragConn=RunService.RenderStepped:Connect(dmHandleDrag)
    if dm.placed then dmSyncZone() end; dmSizeLblUpdate()
end
_ctoolVirtualUnequip["Demolish"] = function()
