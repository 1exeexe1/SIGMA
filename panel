end

makeButton(g1, "Select Brick (click brick in-world)", function(btn)
    disarmSelect()
    if _radSelectSB then _radSelectSB:Destroy(); _radSelectSB = nil end
    btn.Text = "Waiting for click..."
    local mouse = lp:GetMouse()
    _radSelectConn = mouse.Button1Down:Connect(function()
        local t = mouse.Target
        if t and t:IsA("BasePart") and t ~= Workspace.Terrain then
            RAD.selectedBrick = t
            disarmSelect()

            if _radSelectSB then _radSelectSB:Destroy() end
            _radSelectSB = Instance.new("SelectionBox")
            _radSelectSB.Adornee              = t
            _radSelectSB.Color3               = Color3.fromRGB(255, 80, 0)
            _radSelectSB.LineThickness         = 0.06
            _radSelectSB.SurfaceColor3         = Color3.fromRGB(255, 80, 0)
            _radSelectSB.SurfaceTransparency   = 0.7
            _radSelectSB.Parent                = Workspace

            radStatus("Selected: " .. t.Name
                .. " @ " .. math.round(t.Position.X)
                .. ", "  .. math.round(t.Position.Y)
                .. ", "  .. math.round(t.Position.Z))
        end
    end)
end)

makeButton(g1, "Prepare Brick (Glass / Black / Unanchor)", function(btn)
    if RAD.busy then radStatus("Busy!"); return end
    RAD.busy = true
    task.spawn(function()
        local char  = lp.Character
        local hrp   = char and char:FindFirstChild("HumanoidRootPart")
        local paintEv = getToolRemoteCached("Paint")
        if not paintEv or not hrp then
            radStatus("Paint tool / character missing!"); RAD.busy = false; return
        end

        local brick = RAD.selectedBrick

        -- No brick selected: build one at the player's feet and auto-select it
        if not brick or not brick.Parent then
            radStatus("No brick selected — building at player position...")
            local buildEv = getToolRemote("Build")
            local myF     = getMyBrickFolder()
            if not buildEv or not myF then
                radStatus("Build tool / brick folder missing!"); RAD.busy = false; return
            end

            -- Capture the next brick that lands in our folder
            local built = nil
            local conn = myF.ChildAdded:Connect(function(child)
                if child:IsA("BasePart") and not built then built = child end
            end)
            hrp.Anchored = true
            buildEv:FireServer(Workspace.Terrain, Enum.NormalId.Top,
                hrp.Position - Vector3.new(0, 3, 0), "normal")
            local dl = tick() + 2
            while not built and tick() < dl do task.wait(0.02) end
            hrp.Anchored = false
            conn:Disconnect()

            if not built then
                radStatus("Auto-build failed — place a brick manually then select it.")
                RAD.busy = false; return
            end

            -- Auto-select the newly built brick
            RAD.selectedBrick = built
            if _radSelectSB then _radSelectSB:Destroy() end
            _radSelectSB = Instance.new("SelectionBox")
            _radSelectSB.Adornee             = built
            _radSelectSB.Color3              = Color3.fromRGB(255, 80, 0)
            _radSelectSB.LineThickness       = 0.06
            _radSelectSB.SurfaceColor3       = Color3.fromRGB(255, 80, 0)
            _radSelectSB.SurfaceTransparency = 0.7
            _radSelectSB.Parent              = Workspace
            brick = built
            radStatus("Auto-built and selected: " .. brick.Name)
            task.wait(0.2)
        end

        -- Step 1: unanchor via Paint remote (anchor toggle) FIRST.
        -- Must come before color/material so the server processes the state
        -- change on the original brick before any paint remotes are queued.
        -- brick starts Anchored=true (server default); one toggle → Anchored=false.
        setAnchor(brick)
        task.wait(0.3)
        -- Step 2: set material to Glass
        pcall(function()
            paintEv:FireServer(brick, Enum.NormalId.Top, hrp.Position,
                "material", Color3.fromRGB(0, 0, 0), "glass", "")
        end)
        task.wait(0.2)
        -- Step 3: set color to Black
        pcall(function()
            paintEv:FireServer(brick, Enum.NormalId.Top, hrp.Position,
                "color", Color3.fromRGB(0, 0, 0), "glass", "")
        end)
        task.wait(0.2)
        -- Step 4: pin brick locally (brick.Anchored=true on client only) and
        -- install BodyPosition+BodyGyro so it holds position without drifting.
        -- pinBrick() bumps SimulationRadius internally; no separate bump needed.
        pinBrick(brick)

        radStatus("Prepared: Unanchored (server), Glass, Black, Pinned locally.")
        RAD.busy = false
    end)
end)

