local function findTool(name)
    return (lp.Character and lp.Character:FindFirstChild(name))
        or lp.Backpack:FindFirstChild(name)
end

local function forceEquip(name)
    local char = lp.Character
    if not char then return nil end
    local got = char:FindFirstChild(name)
    if got then return got end
    local tool = lp.Backpack:FindFirstChild(name)
    if not tool then return nil end
    -- True multi-equip: parent directly to Character without EquipTool.
    -- EquipTool would unequip whatever is currently held.
    -- Direct parenting lets multiple tools be held simultaneously.
    tool.Parent = char
    local deadline = tick() + 0.15
    while tick() < deadline do
        local t = char:FindFirstChild(name)
        if t then return t end
        task.wait()
    end
    return char:FindFirstChild(name)
end

local function equipAndGetEvent(name)
    local tool = forceEquip(name)
    return tool and tool:FindFirstChild("Event", true)
end

local function getToolEvent(name)
    local tool = findTool(name)
    return tool and tool:FindFirstChild("Event", true)
end

local function getToolRemote(name)
    local tool = forceEquip(name)
    if not tool then return nil end
    local deadline = tick() + 0.2
    repeat
        local ev = tool:FindFirstChild("Event", true)
                or tool:FindFirstChildWhichIsA("RemoteEvent", true)
        if ev then return ev end
        task.wait()
    until tick() > deadline
    return tool:FindFirstChild("Event", true)
end

-- ── TOOL REMOTE CACHE ────────────────────────────────────────
-- Avoids repeated forceEquip calls every frame inside auras/loops.
-- Each entry: {remote, lastCheck}. Validity = 0.5s.
-- Invalidated automatically on CharacterAdded.
local _TC_VALID = 0.5
local ToolCache = {}
for _, n in ipairs({"Build","Delete","Paint","Shape","Shovel","Sign"}) do
    ToolCache[n] = {remote=nil, lastCheck=0}
end
local function getToolRemoteCached(name)
    local c = ToolCache[name]
    if not c then return getToolRemote(name) end
    local now = tick()
    if c.remote and c.remote.Parent and (now - c.lastCheck) < _TC_VALID then
        return c.remote
    end
    c.remote    = getToolRemote(name)
    c.lastCheck = now
    return c.remote
end
-- Invalidate all caches on respawn
lp.CharacterAdded:Connect(function()
    for _, c in pairs(ToolCache) do c.lastCheck = 0 end
end)

